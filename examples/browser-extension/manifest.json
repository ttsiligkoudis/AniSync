{
  "manifest_version": 3,
  "name": "AniSync Auto-Tracker",
  "version": "0.3.0",
  "description": "Watches anime episodes on any streaming site and auto-updates your AniSync list (AniList / Kitsu / MAL).",
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "options_page": "options.html",
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
