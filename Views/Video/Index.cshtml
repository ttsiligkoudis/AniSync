@model AnimeList.Controllers.VideoBrowseViewModel
@{
    ViewData["BodyClass"] = "library-page";
    var isMovies = Model.Type == "movie";
    ViewData["ActiveNav"] = isMovies ? "movies" : "series";

    var label = isMovies ? "Movies" : "Series";
    var hasSearch = !string.IsNullOrEmpty(Model.Search);
    var hasGenre = !string.IsNullOrEmpty(Model.Genre);

    ViewData["Title"] = hasSearch ? $"Search: {Model.Search} · {label}"
        : hasGenre ? $"{Model.Genre} · {label}"
        : $"{label} · AniSync";

    // Browse + search both post back to the active type's route so the form's
    // hidden state isn't needed — the action URL carries the type.
    var browseAction = isMovies ? "/movies" : "/series";
    var here = browseAction;
    var traktFeedback = Context.Request.Query["trakt"].ToString();
}

@* Trakt connection strip. Only shown once Trakt is configured server-side.
   Connecting writes onto the user's account, so it's gated on a signed-in
   session. *@
@if (Model.TraktConfigured)
{
    <style>
        .trakt-strip {
            display: flex; align-items: center; gap: .75rem; flex-wrap: wrap;
            padding: .6rem .9rem; margin: 0 0 1rem; border-radius: 10px;
            background: rgba(237,9,79,.08); font-size: .9rem;
        }
        .trakt-strip-dot { width: .55rem; height: .55rem; border-radius: 50%; background: #888; flex: 0 0 auto; }
        .trakt-strip-dot.is-on { background: #2ecc71; }
        .trakt-strip-spacer { flex: 1 1 auto; }
        .trakt-strip a.trakt-btn, .trakt-strip button.trakt-btn {
            border: 0; cursor: pointer; text-decoration: none; font: inherit;
            padding: .35rem .9rem; border-radius: 999px; background: #ed094f; color: #fff; font-weight: 600;
        }
        .trakt-strip button.trakt-btn-ghost { background: transparent; color: inherit; opacity: .7; }
    </style>
    <div class="trakt-strip">
        <span class="trakt-strip-dot @(Model.TraktConnected ? "is-on" : "")" aria-hidden="true"></span>
        @if (Model.TraktConnected)
        {
            <span>Trakt connected@(string.IsNullOrEmpty(Model.TraktUsername) ? "" : $" as {Model.TraktUsername}")</span>
            <span class="trakt-strip-spacer"></span>
            <form method="post" action="/trakt/disconnect" style="margin:0">
                @Html.AntiForgeryToken()
                <input type="hidden" name="returnUrl" value="@here" />
                <button type="submit" class="trakt-btn trakt-btn-ghost">Disconnect</button>
            </form>
        }
        else if (Model.SignedIn)
        {
            <span>Connect Trakt to track what you watch.</span>
            <span class="trakt-strip-spacer"></span>
            <a class="trakt-btn" href="/trakt/connect?returnUrl=@Uri.EscapeDataString(here)">Connect Trakt</a>
        }
        else
        {
            <span>Sign in to connect Trakt and track what you watch.</span>
            <span class="trakt-strip-spacer"></span>
            <a class="trakt-btn" href="/account">Sign in</a>
        }
    </div>
    @if (traktFeedback == "connected")
    {
        <p class="library-empty" style="color:#2ecc71">✓ Trakt connected.</p>
    }
    else if (traktFeedback == "state")
    {
        <p class="library-empty" style="color:#ed094f">Trakt connect session expired — please try again.</p>
    }
    else if (traktFeedback == "exchange")
    {
        <p class="library-empty" style="color:#ed094f">Trakt rejected the token exchange — check the server logs.</p>
    }
    else if (traktFeedback == "denied")
    {
        <p class="library-empty" style="color:#ed094f">Trakt authorization was declined.</p>
    }
    else if (traktFeedback == "error")
    {
        <p class="library-empty" style="color:#ed094f">Couldn't connect Trakt — please try again.</p>
    }
}

@* Trakt shelves — Continue Watching + Watchlist. Only when connected and not
   searching. Each is hidden until its client-side fetch returns cards, so an
   empty list (or a Trakt hiccup) leaves no dangling header. The poster rows
   come back as the shared horizontal _PosterGrid (Variant=scroll). *@
@if (Model.TraktConnected && string.IsNullOrEmpty(Model.Search))
{
    <style>
        .trakt-shelf { margin: 0 0 1.5rem; }
        .trakt-shelf-title { font-size: 1.05rem; font-weight: 700; margin: 0 0 .6rem; }
    </style>
    <section class="trakt-shelf" data-kind="continue" hidden>
        <h2 class="trakt-shelf-title">Continue Watching</h2>
        <div class="trakt-shelf-body"></div>
    </section>
    <section class="trakt-shelf" data-kind="watchlist" hidden>
        <h2 class="trakt-shelf-title">Your Watchlist</h2>
        <div class="trakt-shelf-body"></div>
    </section>
    <script>
        (function () {
            document.querySelectorAll('.trakt-shelf').forEach(function (sec) {
                var kind = sec.getAttribute('data-kind');
                fetch('/video/trakt-shelf?kind=' + encodeURIComponent(kind), {
                    credentials: 'same-origin',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                })
                    .then(function (r) { return r.status === 204 ? '' : r.text(); })
                    .then(function (html) {
                        if (!html || !html.trim()) return;
                        sec.querySelector('.trakt-shelf-body').innerHTML = html;
                        sec.hidden = false;
                    })
                    .catch(function () { });
            });
        })();
    </script>
}

@* Combined filter form — search input + genre dropdown + Search button. Same
   visual language as the /discover filter bar; nothing auto-submits. *@
<form method="get" action="@browseAction" class="filter-bar" role="search">
    <input type="search"
           name="search"
           value="@Model.Search"
           placeholder="Search @label.ToLower()…"
           class="filter-bar-search"
           autocomplete="off" />

    <select name="genre" class="filter-bar-select" aria-label="Genre">
        <option value="">All genres</option>
        @foreach (var g in Model.AvailableGenres)
        {
            <option value="@g" selected="@(Model.Genre == g)">@g</option>
        }
    </select>

    <button type="submit" class="filter-bar-submit">Search</button>

    @if (hasSearch || hasGenre)
    {
        <a class="filter-bar-clear" href="@browseAction">Clear</a>
    }
</form>

@{
    var posterGridModel = new AnimeList.Models.PosterGridViewModel
    {
        Items = Model.Items,
        ConfigUid = Model.ConfigUid,
        VideoLinks = true,
        EmptyMessage = hasSearch
            ? $"No matches for \"{Model.Search}\"."
            : hasGenre
                ? $"No {Model.Genre.ToLower()} {label.ToLower()} right now."
                : $"Couldn't load {label.ToLower()} — try again later.",
    };
}

<div id="video-results-pane">
    @if (hasSearch)
    {
        @* Search results aren't paginated here (single Cinemeta relevance
           list), so render the bare grid server-side. *@
        @await Html.PartialAsync("_PosterGrid", posterGridModel)
    }
    else
    {
        @* data-endpoint / data-type route the shared discover-pagination.js at
           /video/page. data-list="top" satisfies the script's list guard (the
           server ignores it for video and pages on type). data-page=0 +
           data-needs-initial-load hand the first fetch to the script, which
           swaps the skeletons below for real cards. *@
        <div class="discover-paginator"
             data-endpoint="/video/page"
             data-type="@Model.Type"
             data-list="top"
             data-genre="@Model.Genre"
             data-page="@(Model.NeedsClientLoad ? 0 : 1)"
             data-needs-initial-load="@(Model.NeedsClientLoad ? "true" : null)">
            @if (Model.NeedsClientLoad)
            {
                <div class="library-grid">
                    @for (var i = 0; i < 12; i++)
                    {
                        <div class="library-card library-card-skeleton">
                            <div class="library-card-poster-wrap">
                                <div class="library-card-poster skeleton-shimmer"></div>
                            </div>
                            <span class="library-card-skeleton-line"></span>
                            <span class="library-card-skeleton-line library-card-skeleton-line-short"></span>
                        </div>
                    }
                </div>
            }
            else
            {
                @await Html.PartialAsync("_PosterGrid", posterGridModel)
            }
            <div class="paginator-loader" hidden aria-hidden="true">
                <div class="paginator-loader-spinner"></div>
            </div>
            <div class="discover-sentinel" aria-hidden="true"></div>
        </div>
    }
</div>

@section Scripts {
    @if (!hasSearch)
    {
        <script src="~/js/discover-pagination.js" asp-append-version="true" defer></script>
    }
}
