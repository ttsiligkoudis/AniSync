@model AnimeList.Controllers.VideoDetailViewModel
@{
    var m = Model.Meta;
    var isMovie = Model.Type == "movie";
    ViewData["ActiveNav"] = isMovie ? "movies" : "series";
    ViewData["Title"] = $"{m.name} · AniSync";
    ViewData["BodyClass"] = "video-detail-page";

    // Episodes grouped by season for the series listing. Season <= 0 (specials
    // / ungrouped) folds into season 1 so it still renders a tab.
    var seasons = (m.videos ?? new List<Video>())
        .OrderBy(v => v.season > 0 ? v.season : 1)
        .ThenBy(v => v.episode)
        .GroupBy(v => v.season > 0 ? v.season : 1)
        .ToList();

    // Info-row bits: year · runtime · score, then a genre line below.
    var infoBits = new List<string>();
    if (m.year is int yr && yr > 0) infoBits.Add(yr.ToString());
    if (m.avgDuration is int mins && mins > 0) infoBits.Add(isMovie ? $"{mins} min" : $"~{mins} min/ep");
    var infoLine = string.Join(" · ", infoBits);
    var hasScore = m.score.HasValue && m.score.Value > 0;
}

@* Scoped styling for the video detail page. Kept in-view (rather than
   site.css) so the new feature's styles stay isolated during Phase 1; uses
   theme-neutral rgba surfaces + currentColor so it reads correctly on both
   light and dark themes. *@
<style>
    .video-hero { position: relative; margin: -1rem -1rem 1.5rem; padding: 1.5rem 1rem; overflow: hidden; }
    .video-hero-backdrop {
        position: absolute; inset: 0; background-size: cover; background-position: center;
        opacity: .18; filter: blur(2px); z-index: 0;
    }
    .video-hero-inner { position: relative; z-index: 1; display: flex; gap: 1.25rem; flex-wrap: wrap; max-width: 1100px; margin: 0 auto; }
    .video-hero-poster { width: 200px; max-width: 38vw; border-radius: 12px; box-shadow: 0 8px 28px rgba(0,0,0,.45); flex: 0 0 auto; }
    .video-hero-body { flex: 1 1 320px; min-width: 0; }
    .video-hero-kicker { text-transform: uppercase; letter-spacing: .08em; font-size: .72rem; opacity: .6; margin: 0 0 .25rem; }
    .video-hero-title { font-size: clamp(1.5rem, 4vw, 2.4rem); margin: 0 0 .5rem; line-height: 1.15; }
    .video-hero-meta { display: flex; gap: .6rem; align-items: center; flex-wrap: wrap; margin: 0 0 .35rem; opacity: .85; }
    .video-hero-score { font-weight: 600; color: #f5c518; }
    .video-hero-genres { font-size: .85rem; opacity: .65; margin: 0 0 1rem; }
    .video-hero-desc { max-width: 70ch; line-height: 1.55; opacity: .9; margin: .5rem 0 0; }
    .video-play-btn {
        display: inline-flex; align-items: center; gap: .4rem; padding: .6rem 1.4rem;
        background: currentColor; border-radius: 999px; font-weight: 600; text-decoration: none;
        margin-bottom: .5rem;
    }
    .video-play-btn { color: #fff; background: #e5094f; }
    .video-play-btn:hover { filter: brightness(1.08); }

    .video-episodes { max-width: 1100px; margin: 0 auto; padding: 0 .25rem 2rem; }
    .video-season-title { font-size: 1.1rem; margin: 1.5rem 0 .75rem; }
    .video-episode-list { list-style: none; margin: 0; padding: 0; display: grid; gap: .5rem; }
    .video-episode {
        display: flex; gap: .85rem; align-items: flex-start; padding: .6rem; border-radius: 10px;
        text-decoration: none; color: inherit; background: rgba(127,127,127,.08); transition: background .15s;
    }
    .video-episode:hover { background: rgba(127,127,127,.18); }
    .video-episode-thumb { width: 132px; max-width: 32vw; aspect-ratio: 16/9; object-fit: cover; border-radius: 6px; flex: 0 0 auto; }
    .video-episode-thumb-placeholder { background: rgba(127,127,127,.2); }
    .video-episode-body { min-width: 0; display: flex; flex-direction: column; gap: .2rem; }
    .video-episode-num { font-size: .72rem; opacity: .55; text-transform: uppercase; letter-spacing: .05em; }
    .video-episode-name { font-weight: 600; }
    .video-episode-overview {
        font-size: .85rem; opacity: .7; line-height: 1.4;
        display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
    }
</style>

<section class="video-hero">
    @if (!string.IsNullOrEmpty(m.background))
    {
        <div class="video-hero-backdrop" style="background-image:url('@m.background')" aria-hidden="true"></div>
    }
    <div class="video-hero-inner">
        @if (!string.IsNullOrEmpty(m.poster))
        {
            <img class="video-hero-poster" src="@m.poster" alt="@m.name" decoding="async" />
        }
        <div class="video-hero-body">
            <p class="video-hero-kicker">@(isMovie ? "Movie" : "Series")</p>
            <h1 class="video-hero-title">@m.name</h1>
            <p class="video-hero-meta">
                @if (hasScore)
                {
                    <span class="video-hero-score">★ @m.score.Value.ToString("0.0")</span>
                }
                @if (!string.IsNullOrEmpty(infoLine))
                {
                    <span>@infoLine</span>
                }
            </p>
            @if (m.genres?.Count > 0)
            {
                <p class="video-hero-genres">@string.Join(" · ", m.genres.Take(5))</p>
            }

            @if (isMovie)
            {
                <a class="video-play-btn" href="/movie/@m.id/watch" data-watch-link>▶ Play</a>
            }
            else if (seasons.Count > 0)
            {
                var first = seasons[0].First();
                var firstSeason = first.season > 0 ? first.season : 1;
                <a class="video-play-btn" href="/series/@m.id/watch/@firstSeason/@first.episode" data-watch-link>
                    ▶ Play S@(firstSeason) · E@(first.episode)
                </a>
            }

            @if (!string.IsNullOrEmpty(m.description))
            {
                <p class="video-hero-desc">@m.description</p>
            }
        </div>
    </div>
</section>

@if (!isMovie)
{
    <section class="video-episodes">
        @if (seasons.Count == 0)
        {
            <p class="library-empty">No episode information available.</p>
        }
        else
        {
            foreach (var season in seasons)
            {
                <h2 class="video-season-title">Season @season.Key</h2>
                <ul class="video-episode-list">
                    @foreach (var v in season)
                    {
                        var epTitle = !string.IsNullOrEmpty(v.title) ? v.title
                            : !string.IsNullOrEmpty(v.name) ? v.name
                            : $"Episode {v.episode}";
                        <li>
                            <a class="video-episode" href="/series/@m.id/watch/@season.Key/@v.episode" data-watch-link>
                                @if (!string.IsNullOrEmpty(v.thumbnail))
                                {
                                    <img class="video-episode-thumb" src="@v.thumbnail" alt="" loading="lazy" decoding="async"
                                         onerror="this.style.visibility='hidden'" />
                                }
                                else
                                {
                                    <span class="video-episode-thumb video-episode-thumb-placeholder" aria-hidden="true"></span>
                                }
                                <span class="video-episode-body">
                                    <span class="video-episode-num">E@(v.episode)</span>
                                    <span class="video-episode-name">@epTitle</span>
                                    @if (!string.IsNullOrEmpty(v.overview))
                                    {
                                        <span class="video-episode-overview">@v.overview</span>
                                    }
                                </span>
                            </a>
                        </li>
                    }
                </ul>
            }
        }
    </section>
}

@section Scripts {
    @* Mark the navigation as coming from the detail page so the shared Watch
       view's back-link steps back here cleanly (see ENTRY_KEY in Watch.cshtml). *@
    <script>
        (function () {
            var links = document.querySelectorAll('[data-watch-link]');
            for (var i = 0; i < links.length; i++) {
                links[i].addEventListener('click', function () {
                    try { sessionStorage.setItem('aniSyncWatchEntry', 'fromAnime'); } catch (e) {}
                });
            }
        })();
    </script>
}
