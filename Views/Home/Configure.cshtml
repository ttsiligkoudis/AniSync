@model ConfigureViewModel
@{
    ViewData["ActiveNav"] = "configure";
    var stremioStr = "https://web.stremio.com/#/addons?addon=";
    // Two thin shortcuts. cfg keeps the toggle markup terse; linkedByService is recomputed
    // on every Model.LinkedByService access, so cache it once here for the picker + the
    // Linked Accounts loop to share.
    var cfg = Model.Configuration;
    var linkedByService = Model.LinkedByService;
}

@* Page-level header. The site-header (logo + hamburger) above is layout chrome
   that's identical across pages; this header gives the page its own identity
   so users land somewhere obviously named after they click "Configure addon"
   on the dashboard. The legacy success-badge below this block stays for the
   anonymous "Connected without Account" copy, which the layout's drawer pill
   doesn't surface (drawer shows a Sign in CTA for anonymous instead). *@
<header class="page-header">
    <h1 class="page-title">Configure</h1>
    <p class="page-subtitle">Stremio install URL · linked accounts · backups · scrobble webhook</p>
</header>

@if (!Model.AnonymousUser || Model.IsLoggedIn)
{
    @* Account card — wraps the provider picker and the connected/disconnect
       badge into the same .section-card surface every other group on the page
       uses, so the page reads as a stack of cards rather than a stripe of
       loose chrome above one. The picker doubles as a primary swap when the
       user has linked accounts. *@
    <section class="section-card">
        <span class="section-title">Account</span>

        @if (!Model.AnonymousUser)
        {
            @* Pre-login the picker shows all three providers — the user picks one to authenticate.
               Post-login it shrinks to "primary + healthy linked accounts" so unlinked providers
               don't tease as tappable. The HTML stays identical between states; the only thing
               that changes is which pills render. *@
            var kitsuLinked   = Model.IsLoggedIn && linkedByService.TryGetValue(AnimeService.Kitsu,        out var kl) && !kl.NeedsReauth;
            var anilistLinked = Model.IsLoggedIn && linkedByService.TryGetValue(AnimeService.Anilist,      out var al) && !al.NeedsReauth;
            var malLinked     = Model.IsLoggedIn && linkedByService.TryGetValue(AnimeService.MyAnimeList, out var ml) && !ml.NeedsReauth;

            var showKitsu   = !Model.IsLoggedIn || Model.IsKitsu   || kitsuLinked;
            var showAnilist = !Model.IsLoggedIn || Model.IsAnilist || anilistLinked;
            var showMal     = !Model.IsLoggedIn || Model.IsMal     || malLinked;

            if (Model.HasSwappableLinks)
            {
                <p class="service-toggle-hint">Tap another account below to make it your primary.</p>
            }

            <div class="service-toggle" id="serviceToggle">
                @if (showKitsu)
                {
                    <span class="label @(Model.IsKitsu ? "active" : "")" id="labelKitsu" data-service="0" data-service-name="Kitsu">Kitsu</span>
                }
                @if (showAnilist)
                {
                    <span class="label @(Model.IsAnilist ? "active" : "")" id="labelAnilist" data-service="1" data-service-name="Anilist">AniList</span>
                }
                @if (showMal)
                {
                    <span class="label @(Model.IsMal ? "active" : "")" id="labelMal" data-service="2" data-service-name="MyAnimeList">MyAnimeList</span>
                }
            </div>
        }

        @if (Model.IsLoggedIn)
        {
            <div class="account-status">
                <span class="success-badge">
                    @(!Model.AnonymousUser ? $"✓ Connected to {Model.AnimeService}" : "Connected without Account")
                </span>
                <button id="disconnectBtn" type="button" class="account-disconnect-btn">Disconnect</button>
            </div>
        }
    </section>
}

@if (Model.IsLoggedIn)
{
    @if (!Model.AnonymousUser)
    {
        // linkedTokens / linkedByService come from the page-top @{} block. Promotion to
        // primary lives in the service picker pills above; this section just lists
        // which providers are linked and offers Unlink / Re-link.
        var allServices = new[] { AnimeService.Kitsu, AnimeService.Anilist, AnimeService.MyAnimeList };

        <!-- ─── LINKED ACCOUNTS ─────────────────────────────────────────── -->
        <section class="section-card">
            <span class="section-title">Linked Accounts</span>
            <p class="section-description">
                Optional sync targets. When you save or auto-track an entry, AniSync writes
                to your primary account first and then mirrors the change to every linked
                provider it can map the anime onto.
            </p>

            <div class="linked-accounts">
                @foreach (var svc in allServices)
                {
                    var label = svc == AnimeService.MyAnimeList ? "MyAnimeList" : svc.ToString();
                    var isPrimary = svc == Model.AnimeService;
                    var linked = linkedByService.GetValueOrDefault(svc);
                    <div class="linked-account-row" data-service="@((int)svc)" data-service-name="@svc">
                        <div class="linked-account-name">@label</div>
                        <div class="linked-account-actions">
                            @if (isPrimary)
                            {
                                <span class="linked-account-badge linked-account-primary">Primary</span>
                            }
                            else if (linked != null)
                            {
                                var needsReauth = linked.NeedsReauth;
                                <span class="linked-account-badge @(needsReauth ? "linked-account-warn" : "linked-account-connected")">
                                    @(needsReauth ? "Needs re-auth" : "Linked")
                                </span>
                                @* Promotion to primary is now driven by the service-picker pills at *@
                                @* the top of the page; this row only handles re-link / unlink. *@
                                @if (needsReauth)
                                {
                                    if (svc == AnimeService.Kitsu)
                                    {
                                        <button type="button" class="btn-ghost btn-ghost-sm linked-account-toggle">Re-link</button>
                                    }
                                    else
                                    {
                                        <a class="btn-ghost btn-ghost-sm" href="/Auth/LinkProvider?service=@svc">Re-link ↗</a>
                                    }
                                }
                                <form method="post" action="/Auth/UnlinkProvider" class="linked-account-form">
                                    <input type="hidden" name="service" value="@svc" />
                                    <button type="submit" class="btn-ghost btn-ghost-sm">Unlink</button>
                                </form>
                            }
                            else if (svc == AnimeService.Kitsu)
                            {
                                <button type="button" class="btn-ghost btn-ghost-sm linked-account-toggle">Link</button>
                            }
                            else
                            {
                                <a class="btn-ghost btn-ghost-sm" href="/Auth/LinkProvider?service=@svc">Link ↗</a>
                            }
                        </div>
                        @* The Kitsu inline credentials form covers both first-time link and *@
                        @* re-link after a needs-reauth transition (password rotated, etc.). *@
                        @if (svc == AnimeService.Kitsu && !isPrimary && (linked == null || linked.NeedsReauth))
                        {
                            <form method="post" action="/Auth/LinkKitsu" class="linked-account-creds linked-kitsu-form">
                                <input type="text" name="username" placeholder="Kitsu username" required />
                                <input type="password" name="password" placeholder="Kitsu password" required />
                                <button type="submit" class="btn-primary-action btn-login">Link Kitsu</button>
                                <p class="option-name-sub" style="margin: 0;">
                                    Used only to obtain an OAuth token from Kitsu — your password
                                    is not stored in the configuration.
                                </p>
                            </form>
                        }
                    </div>
                }
            </div>

            @* Manual full-sync block — opens the modal that drives the client-side
               batch loop. Only visible when at least one healthy linked account exists,
               since there's nothing to sync to otherwise. *@
            @if (Model.HasSwappableLinks)
            {
                <div class="full-sync-row">
                    <div class="full-sync-text">
                        <strong>Backfill linked accounts</strong>
                        <span>Push every entry from your @Model.ServiceDisplay library to your linked accounts in one go. Useful right after first linking.</span>
                    </div>
                    <button type="button" id="syncNowBtn" class="btn-ghost btn-ghost-sm">Sync from primary</button>
                </div>
            }
        </section>
    }

    <!-- ─── CATALOGS ────────────────────────────────────────────────── -->
    <section class="section-card">
        <span class="section-title">Catalogs</span>
        <p class="section-description">Choose which catalogs and stream sources AniSync exposes to Stremio.</p>

        <div class="catalogs-grid">
            <span class="catalog-col-spacer"></span>
            <span class="catalog-col-label">Enable</span>
            <span class="catalog-col-label">Discover Only</span>
            <hr class="option-sep" />

            @* Select-all row — flips every row in the column it sits under. The aggregate *@
            @* state of the master toggles is kept in sync via JS as users toggle individual *@
            @* rows. *@
            <span class="option-name option-name-all">Select all</span>
            <label class="switch">
                <input type="checkbox" id="enableAll" />
                <span class="slider"></span>
            </label>
            <label class="switch">
                <input type="checkbox" id="discoverOnlyAll" />
                <span class="slider"></span>
            </label>
            <hr class="option-sep" />

            @if (!Model.AnonymousUser)
            {
                <span class="option-name">Currently watching</span>
                <label class="switch">
                    <input type="checkbox" id="showCurrent" class="catalogCheck" @(cfg.showCurrent ? "checked" : "") />
                    <span class="slider"></span>
                </label>
                <label class="switch @(!cfg.showCurrent ? "switch-disabled" : "")">
                    <input type="checkbox" id="discoverOnlyCurrent" class="discoverCheck" @(cfg.discoverOnlyCurrent ? "checked" : "") @(!cfg.showCurrent ? "disabled" : "") />
                    <span class="slider"></span>
                </label>
                <hr class="option-sep" />

                <span class="option-name">Completed</span>
                <label class="switch">
                    <input type="checkbox" id="showCompleted" class="catalogCheck" @(cfg.showCompleted ? "checked" : "") />
                    <span class="slider"></span>
                </label>
                <label class="switch @(!cfg.showCompleted ? "switch-disabled" : "")">
                    <input type="checkbox" id="discoverOnlyCompleted" class="discoverCheck" @(cfg.discoverOnlyCompleted ? "checked" : "") @(!cfg.showCompleted ? "disabled" : "") />
                    <span class="slider"></span>
                </label>
                <hr class="option-sep" />

                <span class="option-name">Plan to Watch</span>
                <label class="switch">
                    <input type="checkbox" id="showPlanning" class="catalogCheck" @(cfg.showPlanning ? "checked" : "") />
                    <span class="slider"></span>
                </label>
                <label class="switch @(!cfg.showPlanning ? "switch-disabled" : "")">
                    <input type="checkbox" id="discoverOnlyPlanning" class="discoverCheck" @(cfg.discoverOnlyPlanning ? "checked" : "") @(!cfg.showPlanning ? "disabled" : "") />
                    <span class="slider"></span>
                </label>
                <hr class="option-sep" />

                <span class="option-name">On Hold</span>
                <label class="switch">
                    <input type="checkbox" id="showPaused" class="catalogCheck" @(cfg.showPaused ? "checked" : "") />
                    <span class="slider"></span>
                </label>
                <label class="switch @(!cfg.showPaused ? "switch-disabled" : "")">
                    <input type="checkbox" id="discoverOnlyPaused" class="discoverCheck" @(cfg.discoverOnlyPaused ? "checked" : "") @(!cfg.showPaused ? "disabled" : "") />
                    <span class="slider"></span>
                </label>
                <hr class="option-sep" />

                <span class="option-name">Dropped</span>
                <label class="switch">
                    <input type="checkbox" id="showDropped" class="catalogCheck" @(cfg.showDropped ? "checked" : "") />
                    <span class="slider"></span>
                </label>
                <label class="switch @(!cfg.showDropped ? "switch-disabled" : "")">
                    <input type="checkbox" id="discoverOnlyDropped" class="discoverCheck" @(cfg.discoverOnlyDropped ? "checked" : "") @(!cfg.showDropped ? "disabled" : "") />
                    <span class="slider"></span>
                </label>
                <hr class="option-sep" />

                @* AniList exposes REPEATING as a real status; MAL has an is_rewatching flag the *@
                @* MalService surfaces as a synthetic Rewatching list. Kitsu has no equivalent. *@
                @if (Model.IsAnilist || Model.IsMal)
                {
                    <span class="option-name">Rewatching</span>
                    <label class="switch">
                        <input type="checkbox" id="showRepeating" class="catalogCheck" @(cfg.showRepeating ? "checked" : "") />
                        <span class="slider"></span>
                    </label>
                    <label class="switch @(!cfg.showRepeating ? "switch-disabled" : "")">
                        <input type="checkbox" id="discoverOnlyRepeating" class="discoverCheck" @(cfg.discoverOnlyRepeating ? "checked" : "") @(!cfg.showRepeating ? "disabled" : "") />
                        <span class="slider"></span>
                    </label>
                    <hr class="option-sep" />
                }
            }

            <span class="option-name">Trending now</span>
            <label class="switch">
                <input type="checkbox" id="showTrending" class="catalogCheck" @(cfg.showTrending ? "checked" : "") />
                <span class="slider"></span>
            </label>
            <label class="switch @(!cfg.showTrending ? "switch-disabled" : "")">
                <input type="checkbox" id="discoverOnlyTrending" class="discoverCheck" @(cfg.discoverOnlyTrending ? "checked" : "") @(!cfg.showTrending ? "disabled" : "") />
                <span class="slider"></span>
            </label>
            <hr class="option-sep" />

            <span class="option-name">Seasonal Anime</span>
            <label class="switch">
                <input type="checkbox" id="showSeasonal" class="catalogCheck" @(cfg.showSeasonal ? "checked" : "") />
                <span class="slider"></span>
            </label>
            <label class="switch @(!cfg.showSeasonal ? "switch-disabled" : "")">
                <input type="checkbox" id="discoverOnlySeasonal" class="discoverCheck" @(cfg.discoverOnlySeasonal ? "checked" : "") @(!cfg.showSeasonal ? "disabled" : "") />
                <span class="slider"></span>
            </label>
            <hr class="option-sep" />

            <span class="option-name">Airing This Week</span>
            <label class="switch">
                <input type="checkbox" id="showAiring" class="catalogCheck" @(cfg.showAiring ? "checked" : "") />
                <span class="slider"></span>
            </label>
            <label class="switch @(!cfg.showAiring ? "switch-disabled" : "")">
                <input type="checkbox" id="discoverOnlyAiring" class="discoverCheck" @(cfg.discoverOnlyAiring ? "checked" : "") @(!cfg.showAiring ? "disabled" : "") />
                <span class="slider"></span>
            </label>
        </div>

        @* Group multi-cour franchises into a single card via the IMDb / TMDB cross-service
           mapping. Disable this to surface every cour as its own card with the service-native
           id (kitsu:N / anilist:N / mal:N). *@
        <div class="streams-grid">
            <div class="stream-option">
                <div class="option-name-wrap">
                    <span class="option-name">Group anime seasons</span>
                    <span class="option-name-sub">Collapse multi-cour franchises into a single catalog card. Off shows every cour separately.</span>
                </div>
                <label class="switch">
                    <input type="checkbox" id="groupSeasons" @(Model.GroupSeasons ? "checked" : "") />
                    <span class="slider"></span>
                </label>
            </div>
        </div>
    </section>

    <!-- ─── STREAMS ─────────────────────────────────────────────────── -->
    <section class="section-card">
        <span class="section-title">Streams</span>
        <p class="section-description">Choose what AniSync attaches to each episode in Stremio.</p>

        <div class="streams-grid">
            @* Manage Entry and Auto-track touch the user's list, so they only make sense *@
            @* when there's an account behind the install. *@
            @if (!Model.AnonymousUser)
            {
                <div class="stream-option">
                    <div class="option-name-wrap">
                        <span class="option-name">Manage Entry</span>
                        <span class="option-name-sub">Quick-edit progress, score and notes from Stremio.</span>
                    </div>
                    <label class="switch">
                        <input type="checkbox" id="showManageEntry" @(Model.ShowManageEntry ? "checked" : "") />
                        <span class="slider"></span>
                    </label>
                </div>

                <div class="stream-option">
                    <div class="option-name-wrap">
                        <span class="option-name">Auto-track progress</span>
                        <span class="option-name-sub">Update your list when you start an episode in Stremio.</span>
                    </div>
                    <label class="switch">
                        <input type="checkbox" id="autoTrackProgress" @(Model.AutoTrackProgress ? "checked" : "") />
                        <span class="slider"></span>
                    </label>
                </div>
            }

            <div class="stream-option">
                <div class="option-name-wrap">
                    <span class="option-name">External services</span>
                    <span class="option-name-sub">Crunchyroll, Netflix, HiDive, …</span>
                </div>
                <label class="switch">
                    <input type="checkbox" id="showExternalStreams" @(cfg.showExternalStreams ? "checked" : "") />
                    <span class="slider"></span>
                </label>
            </div>
        </div>
    </section>

    <!-- ─── INSTALLATION OPTIONS ────────────────────────────────────── -->
    <section class="section-card">
        <span class="section-title">Installation Options</span>
        <p class="section-description">
            Install AniSync using your preferred method. The install URL updates automatically
            when you change the toggles above — Stremio caches manifests, so a fresh install
            is needed to pick up changes.
        </p>

        <div class="install-inner-card">
            <div class="install-header">
                <img src="/logo.png" alt="AniSync" class="install-icon-img" />
                <div class="install-header-text">
                    <h3>Stremio</h3>
                    <p>Install to Stremio or other Stremio-compatible clients using the Manifest URL.</p>
                </div>
            </div>

            <hr class="install-divider" />

            <a id="stremioUrl" class="btn-primary-action btn-install" href="stremio://@Context.Request.Host">
                Install to Stremio
            </a>
            <a id="stremioWebUrl" class="btn-secondary-action" target="_blank" rel="noopener" href="@($"{stremioStr}{Context.Request.Scheme}://{Context.Request.Host}")">
                Install to Stremio Web
            </a>

            <p class="manifest-url-label">Direct Manifest URL</p>
            <div class="manifest-url-row">
                <input id="manifestUrlInput" class="manifest-url-input" readonly type="text" value="" />
                <button id="copyManifestBtn" class="btn-icon-copy" type="button" title="Copy URL" aria-label="Copy URL">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                        <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
                    </svg>
                </button>
            </div>
        </div>
    </section>

    @if (!Model.AnonymousUser)
    {
        <!-- ─── HOME SERVER SYNC ────────────────────────────────────────── -->
        @* Webhook ingestion from Plex / Jellyfin / Emby. The URL below points to a single
           endpoint that auto-detects which server is calling — users only ever copy one URL. *@
        <section class="section-card">
            <span class="section-title">Home Server Sync</span>
            <p class="section-description">
                Mirror your watch progress from Plex, Jellyfin, or Emby into your linked anime
                trackers automatically. Paste the URL below into your media server's webhook
                settings — same URL for any of the three.
            </p>

            <p class="manifest-url-label">Webhook URL</p>
            <div class="manifest-url-row">
                <input id="scrobbleUrlInput" class="manifest-url-input" readonly type="text" value="" />
                <button id="copyScrobbleBtn" class="btn-icon-copy" type="button" title="Copy URL" aria-label="Copy URL">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                        <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
                    </svg>
                </button>
            </div>
            <div class="btn-action-row" style="margin-top: 0.75rem;">
                <button id="rotateScrobbleBtn" class="btn-ghost btn-ghost-sm" type="button">Rotate token</button>
                <span class="option-name-sub" style="margin-left: 0.5rem;">
                    Anyone with this URL can scrobble onto your account. Rotating invalidates the old URL.
                </span>
            </div>

            <p class="manifest-url-label" style="margin-top: 1.5rem;">Plex Home username (optional)</p>
            <div class="manifest-url-row">
                <input id="plexUsernameInput" class="manifest-url-input" type="text"
                       placeholder="(accept any Plex username)"
                       value="@(Model.PlexUsername ?? "")" />
                <button id="savePlexUsernameBtn" class="btn-ghost btn-ghost-sm" type="button" style="white-space: nowrap;">Save</button>
            </div>
            <p class="option-name-sub" style="margin-top: 0.5rem;">
                Set this only if you share your Plex server with others. Plex events from any
                other username will be ignored. Jellyfin / Emby don't need this — their webhook
                payloads only fire for the user who started playback.
            </p>
        </section>
    }

    <!-- ─── BACKUPS ─────────────────────────────────────────────────── -->
    @* Export is gated on a config row existing — HomeController.ExportConfig
       returns 400 for anonymous sessions. Import is left visible because it's
       the canonical "restore on a fresh browser" path: an anonymous (no-session)
       user imports a backup to recover their tokens + flags, which then bumps
       them into the non-anonymous flow on next render. *@
    <section class="section-card">
        <span class="section-title">Backups</span>
        <p class="section-description">
            @(Model.AnonymousUser
                ? "Restore your configuration from a previously exported file."
                : "Export your configuration to a file or restore from one.")
        </p>

        <div class="btn-action-row">
            @if (!Model.AnonymousUser)
            {
                <a id="exportConfigBtn" class="btn-ghost" href="/Home/ExportConfig" download>
                    <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                        <polyline points="17 8 12 3 7 8"></polyline>
                        <line x1="12" y1="3" x2="12" y2="15"></line>
                    </svg>
                    Export
                </a>
            }
            <button id="importConfigBtn" class="btn-ghost" type="button">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                    <polyline points="7 10 12 15 17 10"></polyline>
                    <line x1="12" y1="15" x2="12" y2="3"></line>
                </svg>
                Import
            </button>
            <input id="importConfigFile" type="file" accept="application/json,.json" hidden />
        </div>
    </section>

    @* Anonymous users have no DB row (HomeController only Upserts when !anonymousUser),
       so Reset is a no-op (the JS guards on configUid) and Delete has nothing to delete.
       Hide the whole card for them rather than render dead buttons. *@
    @if (!Model.AnonymousUser)
    {
        <!-- ─── DANGER ZONE ─────────────────────────────────────────────── -->
        <section class="section-card danger-zone-card">
            <span class="section-title">Danger Zone</span>
            <p class="section-description">Perform potentially destructive actions that cannot be undone.</p>

            <div class="btn-action-row">
                <button id="resetConfigBtn" class="btn-danger-pill" type="button">Reset Configuration</button>
                <button id="deleteConfigBtn" class="btn-danger-pill" type="button">Delete Configuration</button>
            </div>
        </section>
    }

    @* Full-sync modal. Driven entirely by the client — the server is stateless. The
       backdrop click and Escape are intentionally not wired to dismiss; the only way
       out while a sync is in flight is the Cancel button (which aborts in-flight
       fetches via AbortController and stops the loop). After completion or abort,
       the same button switches to "Close" and just hides the modal. *@
    <div id="syncModal" class="sync-modal" hidden aria-hidden="true" role="dialog" aria-labelledby="syncModalTitle">
        <div class="sync-modal-card">
            <h3 id="syncModalTitle" class="sync-modal-title">Backfill linked accounts</h3>
            <p id="syncModalMessage" class="sync-modal-message">Fetching primary library…</p>
            <div class="sync-modal-bar"><div id="syncModalBarFill" class="sync-modal-bar-fill"></div></div>
            <div class="sync-modal-actions">
                <button type="button" id="syncModalCancel" class="btn-primary-action btn-login">Cancel</button>
            </div>
        </div>
    </div>
}
else
{
    <!-- Login -->
    <div class="card-section" id="loginCard">
        <div id="kitsuCreds" style="display:@(Model.IsKitsu ? "block" : "none")">
            <div class="cred-group">
                <label for="username" class="required">Username</label>
                <input type="text" id="username" />
            </div>
            <div class="cred-group">
                <label for="password" class="required">Password</label>
                <input type="password" id="password" />
            </div>
            <p class="option-name-sub" style="margin-top: 0.5rem;">
                AniSync uses your password only for the initial sign-in to Kitsu — it is not stored
                in the configuration. After login we keep just the OAuth tokens Kitsu issues, and
                refresh them automatically when they expire.
            </p>
        </div>
        <a id="loginUrl" class="btn-primary-action btn-login" href='@Url.Action("Login", "Auth", new { animeService = Model.AnimeService })'>
            Login with <span id="loginServiceName">@Model.ServiceDisplay</span>
        </a>
    </div>

    <p class="hint-text">Login to your anime list provider to get started.</p>

    <a id="loginAnonymousUrl" class="btn-primary-action btn-login" href='@Url.Action("Login", "Auth")'>
       Or Continue without Account
    </a>
}

<script>
    // Numeric service selector: 0 = Kitsu, 1 = AniList, 2 = MyAnimeList. Mirrors the
    // AnimeService enum on the server.
    var selectedService = @Model.ServiceIndex;
    // Post-login the picker only shows the primary + healthy linked accounts, so any
    // non-active pill click is unambiguously a swap-primary intent.
    var isLoggedInState = @(Model.IsLoggedIn ? "true" : "false");
    var loginBaseUrl = '@Url.Action("Login", "Auth")';
    // Origin (scheme://host) of the addon — used to build the manifest URL and the
    // stremio:// deep-link. These never include flags; flags live in the URL path bytes.
    var addonOrigin = '@(Context.Request.Scheme)://@(Context.Request.Host)';
    var stremioWebPrefix = '@stremioStr';

    // Authenticated users have a 16-byte UID (base64url) pointing at a row in the
    // server-side config store; anonymous users still embed their (tiny) token data inline.
    // Exactly one of the two strings is non-empty per request.
    var configUid = '@(Model.ConfigUid ?? "")';
    var tokenDataStr = '@(Model.TokenData ?? "")';
    // Revision counter, appended to the install URL as 4 trailing bytes so the URL changes
    // after every Save. Stremio caches manifests aggressively (even past force-restart) and
    // a stable URL means it never refetches; bumping the URL forces a fresh install.
    var configRevision = @Model.ConfigRevision;
    // Per-user scrobble bearer token. Empty for anonymous installs (no Home Server Sync UI).
    var scrobbleToken = '@(Model.ScrobbleToken ?? "")';

    function base64UrlToBytes(str) {
        if (!str) return new Uint8Array(0);
        var base64 = str.replace(/-/g, '+').replace(/_/g, '/');
        while (base64.length % 4) base64 += '=';
        var binary = atob(base64);
        var bytes = new Uint8Array(binary.length);
        for (var i = 0; i < binary.length; i++) bytes[i] = binary.charCodeAt(i);
        return bytes;
    }

    function bytesToBase64Url(bytes) {
        var binary = '';
        for (var i = 0; i < bytes.length; i++) binary += String.fromCharCode(bytes[i]);
        return btoa(binary).replace(/\+/g, '-').replace(/\//g, '_').replace(/=+$/g, '');
    }

    var uidBytes = base64UrlToBytes(configUid);
    var tokenBytes = base64UrlToBytes(tokenDataStr);

    function readFlags() {
        var flags1 = 0;
        if ($('#showCurrent').is(':checked'))           flags1 |= 0x01;
        if ($('#showCompleted').is(':checked'))         flags1 |= 0x02;
        if ($('#showTrending').is(':checked'))          flags1 |= 0x04;
        if ($('#showSeasonal').is(':checked'))          flags1 |= 0x08;
        if ($('#discoverOnlyCurrent').is(':checked'))   flags1 |= 0x10;
        if ($('#discoverOnlyCompleted').is(':checked')) flags1 |= 0x20;
        if ($('#discoverOnlyTrending').is(':checked'))  flags1 |= 0x40;
        if ($('#discoverOnlySeasonal').is(':checked'))  flags1 |= 0x80;

        var flags2 = 0;
        if ($('#showPlanning').is(':checked'))           flags2 |= 0x01;
        if ($('#showPaused').is(':checked'))             flags2 |= 0x02;
        if ($('#showDropped').is(':checked'))            flags2 |= 0x04;
        if ($('#showRepeating').is(':checked'))          flags2 |= 0x08;
        if ($('#discoverOnlyPlanning').is(':checked'))   flags2 |= 0x10;
        if ($('#discoverOnlyPaused').is(':checked'))     flags2 |= 0x20;
        if ($('#discoverOnlyDropped').is(':checked'))    flags2 |= 0x40;
        if ($('#discoverOnlyRepeating').is(':checked'))  flags2 |= 0x80;

        var flags3 = 0;
        if ($('#showAiring').is(':checked'))             flags3 |= 0x01;
        if ($('#showExternalStreams').is(':checked'))    flags3 |= 0x02;
        // Inverse bits: stored 1 = "off". Toggling the UI off sets the bit; default-checked
        // toggles leave the bit at 0, matching pre-feature behavior for existing rows.
        // The toggles are hidden for anonymous users (no account → nothing to manage), so
        // .length-guard before reading state to avoid setting the bit just because the input
        // doesn't exist on the page.
        var $manage = $('#showManageEntry');
        if ($manage.length && !$manage.is(':checked'))   flags3 |= 0x04;
        var $autoTrack = $('#autoTrackProgress');
        if ($autoTrack.length && !$autoTrack.is(':checked')) flags3 |= 0x08;
        if ($('#discoverOnlyAiring').is(':checked'))     flags3 |= 0x10;
        // Inverse bit again: default-checked "Group anime seasons" leaves the bit at 0,
        // so legacy installs (zero flags) keep the existing IMDb-grouped behavior.
        var $group = $('#groupSeasons');
        if ($group.length && !$group.is(':checked'))     flags3 |= 0x20;

        return { flags1: flags1, flags2: flags2, flags3: flags3 };
    }

    function buildManifestPath() {
        var f = readFlags();
        var payload;
        if (uidBytes.length > 0) {
            // Binary v5: [0x05][16-byte UID][4-byte revision big-endian]. Revision bytes
            // make the URL different after every save so Stremio re-fetches the manifest.
            payload = new Uint8Array(1 + uidBytes.length + 4);
            payload[0] = 0x05;
            payload.set(uidBytes, 1);
            var rev = (configRevision >>> 0);
            var revOffset = 1 + uidBytes.length;
            payload[revOffset]     = (rev >>> 24) & 0xff;
            payload[revOffset + 1] = (rev >>> 16) & 0xff;
            payload[revOffset + 2] = (rev >>> 8)  & 0xff;
            payload[revOffset + 3] = rev          & 0xff;
        } else {
            // Binary v3 anonymous fallback: [0x03][flags1][flags2][flags3][gzip token bytes]
            payload = new Uint8Array(4 + tokenBytes.length);
            payload[0] = 0x03;
            payload[1] = f.flags1;
            payload[2] = f.flags2;
            payload[3] = f.flags3;
            payload.set(tokenBytes, 4);
        }
        return '/' + bytesToBase64Url(payload) + '/manifest.json';
    }

    function refreshUrls() {
        var path = buildManifestPath();
        var manifestHttps = addonOrigin + path;
        // stremio:// deep link uses the host (not scheme) so apps know to open natively.
        var stremioDeep = 'stremio://' + addonOrigin.replace(/^https?:\/\//, '') + path;
        var stremioWeb = stremioWebPrefix + manifestHttps;

        $('#stremioUrl').attr('href', stremioDeep);
        $('#stremioWebUrl').attr('href', stremioWeb);
        $('#manifestUrlInput').val(manifestHttps);
    }

    refreshUrls();

    // Catalog + stream toggles — recompute the manifest URL whenever flags change. (For
    // v5 the path bytes don't actually change since flags live in DB, but we still call
    // refreshUrls() to keep the path in sync after a SaveConfig response bumps revision.)
    $('.catalogCheck, .discoverCheck, #showExternalStreams, #showManageEntry, #autoTrackProgress, #groupSeasons')
        .on('change', refreshUrls);

    // When an enable checkbox is toggled, enable/disable its discover-only sibling
    $('.catalogCheck').on('change', function () {
        var $discoverLabel = $(this).parent().next();
        var $discoverSwitch = $discoverLabel.find('.discoverCheck');
        var isEnabled = $(this).is(':checked');
        $discoverSwitch.prop('disabled', !isEnabled);
        $discoverLabel.toggleClass('switch-disabled', !isEnabled);
        if (!isEnabled) $discoverSwitch.prop('checked', false);
    });

    // ── Select-all switches ───────────────────────────────────────────
    // Master "Enable" toggle: flips every catalog row to its state. trigger('change')
    // so the per-row sibling-disable handler runs, refreshUrls fires, etc.
    $('#enableAll').on('change', function () {
        var checked = $(this).is(':checked');
        $('.catalogCheck').prop('checked', checked).trigger('change');
    });

    // Master "Discover Only" toggle: only flips rows whose Enable is on (the rest are
    // visually disabled and stay unchecked).
    $('#discoverOnlyAll').on('change', function () {
        var checked = $(this).is(':checked');
        $('.catalogCheck').each(function () {
            if (!$(this).is(':checked')) return;
            var $disc = $(this).parent().next().find('.discoverCheck');
            $disc.prop('checked', checked).trigger('change');
        });
    });

    // Mirror aggregate state on the master toggles: master ON only when *every* row in
    // its column is on. Use prop (no trigger) so we don't recurse.
    function refreshAllToggles() {
        var enables = $('.catalogCheck');
        $('#enableAll').prop('checked', enables.length > 0 && enables.length === enables.filter(':checked').length);

        var discovers = $('.discoverCheck:not(:disabled)');
        $('#discoverOnlyAll').prop('checked', discovers.length > 0 && discovers.length === discovers.filter(':checked').length);
    }
    $('.catalogCheck, .discoverCheck').on('change', refreshAllToggles);
    refreshAllToggles();

    // ── Service picker ────────────────────────────────────────────────
    function serviceLabel(svc) {
        if (svc === 1) return 'AniList';
        if (svc === 2) return 'MyAnimeList';
        return 'Kitsu';
    }

    // Posts the SetPrimary swap and handles the collision-error case by offering a
    // second confirmation that retries with force=true. fetch lets us read the server's
    // 400 response body — a plain form-submit would just navigate to the error page.
    async function promotePrimary(svcEnum, label, force) {
        var params = new URLSearchParams();
        params.set('service', svcEnum);
        if (force) params.set('force', 'true');

        var resp = await fetch('/Auth/SetPrimary', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: params.toString(),
            redirect: 'follow',
        });

        if (resp.ok || resp.redirected) {
            window.location.href = resp.redirected ? resp.url : '/';
            return;
        }

        var errorText = (await resp.text()) || 'Unknown error.';
        // Collision surfaces as the "already the primary on another install" message —
        // offer the force path with a clear heads-up about what it sacrifices.
        if (!force && /already the primary on another/i.test(errorText)) {
            var msg = errorText
                + '\n\nThis usually means an old AniSync session for this account is still in our database. '
                + 'You can force the swap, which will remove that other install (its install URL will stop working in Stremio). '
                + 'Continue?';
            if (confirm(msg)) {
                await promotePrimary(svcEnum, label, true);
            }
            return;
        }

        alert(errorText);
    }

    $('#serviceToggle .label').on('click', function () {
        var $pill = $(this);

        if (isLoggedInState) {
            // Active pill = current primary, no-op. Any other rendered pill is a healthy
            // linked account — tap → confirm → POST /Auth/SetPrimary. The server rotates
            // the primary slot in place (UID preserved) and the page reloads.
            if ($pill.hasClass('active')) return;
            var svcEnum = $pill.attr('data-service-name');
            var label = serviceLabel(parseInt($pill.attr('data-service'), 10));
            if (!confirm('Switch your primary account to ' + label + '? Future writes will originate from this account first.')) return;

            promotePrimary(svcEnum, label, false);
            return;
        }

        var svc = parseInt($pill.attr('data-service'), 10);
        if (isNaN(svc)) return;
        selectedService = svc;
        $('#serviceToggle .label').removeClass('active');
        $pill.addClass('active');
        $('#loginServiceName').text(serviceLabel(svc));
        // Only the Kitsu password-grant flow needs the username/password fields visible.
        $('#kitsuCreds').toggle(svc === 0);
        updateLoginUrl();
    });

    $('#disconnectBtn').on('click', function () {
        window.location.href = '@Url.Action("Logout", "Auth")';
    });

    // ── Linked Accounts ───────────────────────────────────────────────
    // The Kitsu link row shows a button by default; clicking expands the inline
    // username/password form (Kitsu uses password-grant, no OAuth redirect).
    $('.linked-account-toggle').on('click', function () {
        var $row = $(this).closest('.linked-account-row');
        $row.find('.linked-kitsu-form').toggleClass('expanded');
    });

    // ── Full-sync (client-driven) ────────────────────────────────────
    // Server is stateless: we GET the entry list once, then loop POSTing
    // batches in a small worker pool and tracking progress here.
    // AbortController is the cancel mechanism — Cancel button or browser
    // close both stop the loop. Closing the page = the sync stops, no
    // zombie work continues server-side.
    var syncAbort = null;
    // Each batch processes sequentially server-side, so batch size sets
    // both the per-batch latency (-> Cancel responsiveness floor) and the
    // HTTP overhead amortisation. 5 is the sweet spot.
    var SYNC_BATCH_SIZE = 5;
    // Run two batches in flight at the same time. Inside each
    // FanOutSaveAsync the linked targets are already hit in parallel, so
    // 2 client-side workers + 2-3 linked providers means up to ~6
    // simultaneous upstream calls — borderline-safe given Kitsu ~5/s,
    // MAL ~2-3/s, and AniList's burst tolerance. Bumping to 3 starts
    // tripping MAL 429s in practice.
    var SYNC_PARALLEL = 2;

    function showSyncModal() {
        $('#syncModal').removeAttr('hidden').attr('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
    }

    function hideSyncModal() {
        $('#syncModal').attr('hidden', 'hidden').attr('aria-hidden', 'true');
        document.body.style.overflow = '';
    }

    function setSyncProgress(message, current, total) {
        var pct = total > 0 ? Math.min(100, Math.round((current / total) * 100)) : 0;
        $('#syncModalBarFill').css('width', pct + '%');
        $('#syncModalMessage').text(message);
    }

    // Format a progress message as a percentage rather than an entry count.
    // current/total still drive the bar fill via setSyncProgress; the text
    // just shows "Syncing 42%" instead of "Syncing 12 / 28" so the user
    // doesn't have to mentally divide.
    function syncPercent(current, total) {
        return total > 0 ? Math.min(100, Math.round((current / total) * 100)) : 0;
    }

    function setSyncCancelLabel(label) {
        $('#syncModalCancel').text(label);
    }

    async function startFullSync() {
        syncAbort = new AbortController();
        showSyncModal();
        setSyncProgress('Fetching primary library…', 0, 0);
        setSyncCancelLabel('Cancel');

        var completed = 0, failed = 0, processed = 0, total = 0;
        try {
            var resp = await fetch('/Auth/SyncEntries', { signal: syncAbort.signal });
            if (!resp.ok) throw new Error((await resp.text()) || 'Failed to fetch entries.');
            var body = await resp.json();
            var entries = body.entries || [];
            total = body.total || entries.length;
            // primaryTotal is the size of the primary's full library; total is just the
            // entries that actually need writing (the diff against linked secondaries).
            // The two diverge when most of the library is already in sync.
            var primaryTotal = body.primaryTotal != null ? body.primaryTotal : total;

            if (total === 0) {
                var doneMsg = primaryTotal === 0
                    ? 'Primary library is empty — nothing to sync.'
                    : 'All linked accounts already in sync — nothing to do.';
                setSyncProgress(doneMsg, 0, 0);
                setSyncCancelLabel('Close');
                return;
            }

            setSyncProgress('Syncing 0%', 0, total);

            // Pre-slice so workers just pull the next ready batch from a shared queue
            // — keeps the dispatch loop branch-free and the worker code small.
            var batches = [];
            for (var i = 0; i < entries.length; i += SYNC_BATCH_SIZE) {
                batches.push(entries.slice(i, i + SYNC_BATCH_SIZE));
            }

            // JS is single-threaded so cursor / counter increments don't race even
            // though SYNC_PARALLEL workers all touch them. The cooperative await
            // points are the only places another worker can run, and by that point
            // we've already committed our increment.
            var nextBatch = 0;

            async function syncWorker() {
                while (!syncAbort.signal.aborted) {
                    var idx = nextBatch++;
                    if (idx >= batches.length) return;
                    var slice = batches[idx];

                    try {
                        var r = await fetch('/Auth/SyncBatch', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ entries: slice }),
                            signal: syncAbort.signal,
                        });
                        if (!r.ok) {
                            // Server rejected the whole batch (e.g. session expired). Count
                            // every entry as failed but keep going — later batches might
                            // succeed if the cause was transient.
                            failed += slice.length;
                        } else {
                            var result = await r.json();
                            completed += result.completed || 0;
                            failed += result.failed || 0;
                        }
                    } catch (e) {
                        if (e.name === 'AbortError') return;
                        failed += slice.length;
                    }

                    processed = completed + failed;
                    setSyncProgress('Syncing ' + syncPercent(processed, total) + '%', processed, total);
                }
            }

            // Spin up the worker pool and wait for the queue to drain.
            var workers = [];
            for (var w = 0; w < SYNC_PARALLEL; w++) workers.push(syncWorker());
            await Promise.all(workers);

            if (syncAbort.signal.aborted) {
                setSyncProgress('Cancelled at ' + syncPercent(processed, total) + '%', processed, total);
            } else {
                var finalMsg = failed === 0
                    ? 'Done — 100% synced.'
                    : 'Done — ' + syncPercent(completed, total) + '% synced, ' + syncPercent(failed, total) + '% failed (see Fly logs).';
                setSyncProgress(finalMsg, processed, total);
            }
        } catch (e) {
            if (e.name !== 'AbortError') {
                setSyncProgress('Failed: ' + e.message, processed, total);
            } else {
                setSyncProgress('Cancelled at ' + syncPercent(processed, total) + '%', processed, total);
            }
        } finally {
            // Once the loop exits — done, cancelled, or errored — flip the action
            // button to Close so the user can dismiss the modal.
            setSyncCancelLabel('Close');
            syncAbort = null;
        }
    }

    $('#syncNowBtn').on('click', function () {
        if (!confirm('Backfill every entry from your primary library to all linked accounts? This can take a few minutes for large libraries — keep this tab open until it finishes.')) return;
        startFullSync();
    });

    $('#syncModalCancel').on('click', function () {
        // Mid-sync: abort fetches, mark cancellation. The loop notices on its next
        // iteration and falls through to the "Cancelled" message + Close label.
        if (syncAbort && !syncAbort.signal.aborted) {
            syncAbort.abort();
            return;
        }
        hideSyncModal();
    });

    // Backdrop click and Esc are intentionally NOT wired to dismiss — the user
    // explicitly asked for Cancel/Close to be the only way out, so a stray tap
    // outside the card can't accidentally tear down a sync mid-flight.

    // ── Copy manifest URL ─────────────────────────────────────────────
    $('#copyManifestBtn').on('click', async function () {
        var url = $('#manifestUrlInput').val();
        var $btn = $(this);
        var success = false;
        try {
            await navigator.clipboard.writeText(url);
            success = true;
        } catch {
            // Fallback for older browsers
            $('#manifestUrlInput').select();
            success = document.execCommand('copy');
        }
        $btn.toggleClass('copied', success);
        setTimeout(function () { $btn.removeClass('copied'); }, 1500);
    });

    // ── Save flags before launching Stremio ───────────────────────────
    // Persists current toggle state and bumps the revision so Stremio sees a different
    // URL — required because Stremio caches manifests for already-installed URLs and
    // wouldn't otherwise pick up flag changes.
    async function saveFlags() {
        if (!configUid) return;
        var f = readFlags();
        var resp = await fetch('/Home/SaveConfig', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ uid: configUid, flags1: f.flags1, flags2: f.flags2, flags3: f.flags3 }),
        });
        if (!resp.ok) throw new Error('Save failed: ' + resp.status);
        var data = await resp.json();
        if (typeof data.revision === 'number') {
            configRevision = data.revision;
            refreshUrls();
        }
    }

    // Both install buttons trigger a save first so the new URL reflects the latest flags.
    async function handleInstallClick(e) {
        if (!configUid) return; // anonymous (v3): URL already encodes flags
        e.preventDefault();
        try { await saveFlags(); } catch { /* let them try anyway */ }
        // Re-read the (possibly new) href after saveFlags bumped configRevision.
        var href = $(this).attr('href');
        if ($(this).attr('target') === '_blank') {
            window.open(href, '_blank', 'noopener');
        } else {
            window.location.href = href;
        }
    }
    $('#stremioUrl, #stremioWebUrl').on('click', handleInstallClick);

    // ── Home Server Sync ──────────────────────────────────────────────
    // Builds and renders the scrobble URL into the read-only input. Called on page load and
    // again after Rotate so the displayed URL always matches the live token.
    function refreshScrobbleUrl() {
        var $input = $('#scrobbleUrlInput');
        if (!$input.length) return;
        $input.val(scrobbleToken ? addonOrigin + '/api/v1/scrobble/' + scrobbleToken : '');
    }
    refreshScrobbleUrl();

    $('#copyScrobbleBtn').on('click', async function () {
        var url = $('#scrobbleUrlInput').val();
        var $btn = $(this);
        var success = false;
        try {
            await navigator.clipboard.writeText(url);
            success = true;
        } catch {
            $('#scrobbleUrlInput').select();
            success = document.execCommand('copy');
        }
        $btn.toggleClass('copied', success);
        setTimeout(function () { $btn.removeClass('copied'); }, 1500);
    });

    $('#rotateScrobbleBtn').on('click', async function () {
        if (!configUid) return;
        if (!confirm('Generate a new webhook URL? The current URL will stop working immediately and you will need to update Plex / Jellyfin / Emby with the new one.')) return;
        try {
            var resp = await fetch('/Home/RotateScrobbleToken', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ uid: configUid }),
            });
            if (!resp.ok) throw new Error('rotate failed: ' + resp.status);
            var data = await resp.json();
            if (!data.success || !data.token) throw new Error(data.error || 'rotate failed');
            scrobbleToken = data.token;
            refreshScrobbleUrl();
        } catch (e) {
            alert('Could not rotate the webhook token: ' + e.message);
        }
    });

    $('#savePlexUsernameBtn').on('click', async function () {
        if (!configUid) return;
        var username = $('#plexUsernameInput').val();
        var $btn = $(this);
        try {
            var resp = await fetch('/Home/SetPlexUsername', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ uid: configUid, username: username }),
            });
            if (!resp.ok) throw new Error('save failed: ' + resp.status);
            // Visual ack — flip the label briefly so the user knows it took.
            var original = $btn.text();
            $btn.text('Saved').prop('disabled', true);
            setTimeout(function () { $btn.text(original).prop('disabled', false); }, 1200);
        } catch (e) {
            alert('Could not save Plex username: ' + e.message);
        }
    });

    // ── Backups ───────────────────────────────────────────────────────
    $('#importConfigBtn').on('click', function () {
        $('#importConfigFile').trigger('click');
    });

    $('#importConfigFile').on('change', async function (e) {
        var file = e.target.files[0];
        if (!file) return;
        try {
            var text = await file.text();
            var json = JSON.parse(text);
            var resp = await fetch('/Home/ImportConfig', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(json),
            });
            if (!resp.ok) throw new Error('Import failed: ' + resp.status);
            window.location.href = '/';
        } catch (err) {
            alert('Could not import configuration: ' + err.message);
        } finally {
            $('#importConfigFile').val(''); // allow re-selecting same file later
        }
    });

    // ── Danger Zone ───────────────────────────────────────────────────
    $('#resetConfigBtn').on('click', async function () {
        if (!configUid) return;
        if (!confirm('Reset all toggles to defaults? Your login is kept.')) return;
        var resp = await fetch('/Home/ResetConfig', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ uid: configUid }),
        });
        if (resp.ok) window.location.reload();
        else alert('Reset failed.');
    });

    $('#deleteConfigBtn').on('click', async function () {
        if (!confirm('Delete your AniSync configuration permanently? Existing install URLs in Stremio will stop working and you will be signed out.')) return;
        var resp = await fetch('/Home/DeleteConfig', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ uid: configUid }),
        });
        if (resp.ok) window.location.href = '/';
        else alert('Delete failed.');
    });

    // ── Login form (anonymous / Kitsu credentials) ────────────────────
    $('#username, #password').on('input', updateLoginUrl);

    function updateLoginUrl() {
        var href = loginBaseUrl + '?animeService=' + selectedService;
        // Kitsu uses the password grant — credentials are typed into the form and
        // posted to /Auth/Login. The other providers are OAuth-redirected.
        if (selectedService === 0) {
            var username = $('#username').val();
            var password = encodeURIComponent($('#password').val());
            href += '&username=' + username + '&password=' + password;
        }
        $('#loginUrl').attr('href', href);
    }

    updateLoginUrl();

    $('#loginUrl').on('click', function (e) {
        e.preventDefault();
        if (selectedService === 0 && ($('#username').val() == '' || $('#password').val() == '')) return;
        window.location.href = $('#loginUrl').attr('href');
    });

    $('#loginAnonymousUrl').on('click', function (e) {
        e.preventDefault();
        var href = $('#loginAnonymousUrl').attr('href');
        href += '?animeService=' + selectedService + '&anonymous=true';
        window.location.href = href;
    });
</script>
