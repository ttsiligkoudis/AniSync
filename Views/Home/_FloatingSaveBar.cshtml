@model AnimeList.Models.ConfigureViewModel

@*
    Floating save bar shared by /configure, /stremio, /advanced. Hidden
    until a flag-bearing toggle changes (the change handler in
    _ConfigurePageScript flips it on via setDirty(true)). One commit
    point across all three views replaces the per-section "Save
    Preferences" button — toggles can live wherever they make sense
    semantically without each section needing its own save affordance.

    Gated on a uid-backed install since SaveConfig writes by uid;
    anonymous (v3) URLs already carry their flag state inline so
    there's nothing to persist on the server.
*@
@if (!Model.AnonymousUser && !string.IsNullOrEmpty(Model.ConfigUid))
{
    <div id="floatingSaveBar" class="floating-save-bar" hidden aria-live="polite" role="status">
        <span id="floatingSaveStatus" class="floating-save-status">Unsaved changes</span>
        <button id="floatingSaveBtn" class="floating-save-btn" type="button">Save</button>
    </div>
}
