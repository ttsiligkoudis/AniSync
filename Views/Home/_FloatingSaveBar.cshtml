@model AnimeList.Models.ConfigureViewModel

@*
    Floating save bar shared by /configure, /stremio, /advanced. Always
    visible — discoverability beats minimalism here, the user should
    never have to hunt for "where do I commit my changes?". The label
    swaps between "All changes saved" (clean) and "Unsaved changes"
    (any flag-bearing toggle has moved since last save). The button
    stays clickable in both states; clicking with nothing dirty just
    re-POSTs the current flag bytes (cheap idempotent server-side).

    Gated on a uid-backed install since SaveConfig writes by uid;
    anonymous (v3) URLs already carry their flag state inline so
    there's nothing to persist on the server.
*@
@if (!Model.AnonymousUser && !string.IsNullOrEmpty(Model.ConfigUid))
{
    <div id="floatingSaveBar" class="floating-save-bar" aria-live="polite" role="status">
        <span id="floatingSaveStatus" class="floating-save-status">All changes saved</span>
        <button id="floatingSaveBtn" class="floating-save-btn" type="button">Save</button>
    </div>
}
