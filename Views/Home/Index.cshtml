@{
    var tokenDataStr = (string)ViewBag.TokenData;
    var configUid = (string)ViewBag.ConfigUid;
    var configRevision = (long?)ViewBag.ConfigRevision ?? 0L;
    var animeService = (AnimeService?)ViewBag.AnimeService;
    // ConfigUid is set for authenticated v5 users, TokenData for anonymous v3 users —
    // either one means "logged in and we can render the install link".
    var isLoggedIn = !string.IsNullOrEmpty(tokenDataStr) || !string.IsNullOrEmpty(configUid);
    var isAnilist = animeService == AnimeService.Anilist;
    var isMal = animeService == AnimeService.MyAnimeList;
    var isKitsu = !isAnilist && !isMal;
    // Numeric service id used by the JS picker (matches the AnimeService enum order).
    var serviceIndex = isAnilist ? 1 : isMal ? 2 : 0;
    var serviceDisplay = isAnilist ? "AniList" : isMal ? "MyAnimeList" : "Kitsu";
    var stremioStr = "https://web.stremio.com/#/addons?addon=";
    bool anonymousUser = ViewBag.AnonymousUser == true;

    bool showCurrent = ViewBag.ShowCurrent ?? !anonymousUser;
    bool showCompleted = ViewBag.ShowCompleted ?? false;
    bool showTrending = ViewBag.ShowTrending ?? anonymousUser;
    bool showSeasonal = ViewBag.ShowSeasonal ?? true;
    bool showPlanning = ViewBag.ShowPlanning ?? false;
    bool showPaused = ViewBag.ShowPaused ?? false;
    bool showDropped = ViewBag.ShowDropped ?? false;
    bool showRepeating = ViewBag.ShowRepeating ?? false;
    bool showAiring = ViewBag.ShowAiring ?? false;
    bool discoverOnlyCurrent = ViewBag.DiscoverOnlyCurrent ?? false;
    bool discoverOnlyCompleted = ViewBag.DiscoverOnlyCompleted ?? false;
    bool discoverOnlyTrending = ViewBag.DiscoverOnlyTrending ?? false;
    bool discoverOnlySeasonal = ViewBag.DiscoverOnlySeasonal ?? true;
    bool discoverOnlyPlanning = ViewBag.DiscoverOnlyPlanning ?? false;
    bool discoverOnlyPaused = ViewBag.DiscoverOnlyPaused ?? false;
    bool discoverOnlyDropped = ViewBag.DiscoverOnlyDropped ?? false;
    bool discoverOnlyRepeating = ViewBag.DiscoverOnlyRepeating ?? false;
    bool discoverOnlyAiring = ViewBag.DiscoverOnlyAiring ?? false;
    bool showExternalStreams = ViewBag.ShowExternalStreams ?? false;
    bool showManageEntry = ViewBag.ShowManageEntry ?? true;
    bool autoTrackProgress = ViewBag.AutoTrackProgress ?? true;
}

<h1 class="app-logo">Ani<span class="accent">Sync</span></h1>
<p class="app-subtitle">Track your anime progress on Stremio</p>

@if (!anonymousUser)
{
    <!-- Service picker (always visible). Locks to the chosen service once the user is
         logged in — disconnect to switch to a different provider. -->
    <div class="service-toggle @(isLoggedIn ? "disabled" : "")" id="serviceToggle">
        <span class="label @(isKitsu ? "active" : "")" id="labelKitsu" data-service="0">Kitsu</span>
        <span class="label @(isAnilist ? "active" : "")" id="labelAnilist" data-service="1">AniList</span>
        <span class="label @(isMal ? "active" : "")" id="labelMal" data-service="2">MyAnimeList</span>
    </div>
}

@if (isLoggedIn)
{
    <span class="success-badge">
        @(!anonymousUser ? $"✓ Connected to {animeService}" : "Connected without Account")
        <button id="disconnectBtn" class="success-badge-action" title="Disconnect">✗</button>
    </span>

    @if (!anonymousUser)
    {
        var linkedTokens = (List<AnimeList.Models.LinkedToken>)ViewBag.LinkedTokens ?? new();
        var linkedByService = linkedTokens.ToDictionary(t => t.Service, t => t);
        var allServices = new[] { AnimeService.Kitsu, AnimeService.Anilist, AnimeService.MyAnimeList };

        <!-- ─── LINKED ACCOUNTS ─────────────────────────────────────────── -->
        <section class="section-card">
            <span class="section-title">Linked Accounts</span>
            <p class="section-description">
                Optional sync targets. When you save or auto-track an entry, AniSync writes
                to your primary account first and then mirrors the change to every linked
                provider it can map the anime onto.
            </p>

            <div class="linked-accounts">
                @foreach (var svc in allServices)
                {
                    var label = svc == AnimeService.MyAnimeList ? "MyAnimeList" : svc.ToString();
                    var isPrimary = svc == animeService;
                    var linked = linkedByService.GetValueOrDefault(svc);
                    <div class="linked-account-row" data-service="@((int)svc)" data-service-name="@svc">
                        <div class="linked-account-name">@label</div>
                        <div class="linked-account-actions">
                            @if (isPrimary)
                            {
                                <span class="linked-account-badge linked-account-primary">Primary</span>
                            }
                            else if (linked != null)
                            {
                                var needsReauth = linked.NeedsReauth;
                                <span class="linked-account-badge @(needsReauth ? "linked-account-warn" : "linked-account-connected")">
                                    @(needsReauth ? "Needs re-auth" : "Linked")
                                </span>
                                @if (needsReauth)
                                {
                                    if (svc == AnimeService.Kitsu)
                                    {
                                        <button type="button" class="btn-ghost btn-ghost-sm linked-account-toggle">Re-link</button>
                                    }
                                    else
                                    {
                                        <a class="btn-ghost btn-ghost-sm" href="/Auth/LinkProvider?service=@svc">Re-link ↗</a>
                                    }
                                }
                                else
                                {
                                    @* Promote the link to primary. UID is preserved server-side so *@
                                    @* the user's install URL keeps working — only the primary slot rotates. *@
                                    <form method="post" action="/Auth/SetPrimary" class="linked-account-form">
                                        <input type="hidden" name="service" value="@svc" />
                                        <button type="submit" class="btn-ghost btn-ghost-sm">Make primary</button>
                                    </form>
                                }
                                <form method="post" action="/Auth/UnlinkProvider" class="linked-account-form">
                                    <input type="hidden" name="service" value="@svc" />
                                    <button type="submit" class="btn-ghost btn-ghost-sm">Unlink</button>
                                </form>
                            }
                            else if (svc == AnimeService.Kitsu)
                            {
                                <button type="button" class="btn-ghost btn-ghost-sm linked-account-toggle">Link</button>
                            }
                            else
                            {
                                <a class="btn-ghost btn-ghost-sm" href="/Auth/LinkProvider?service=@svc">Link ↗</a>
                            }
                        </div>
                        @* The Kitsu inline credentials form covers both first-time link and *@
                        @* re-link after a needs-reauth transition (password rotated, etc.). *@
                        @if (svc == AnimeService.Kitsu && !isPrimary && (linked == null || linked.NeedsReauth))
                        {
                            <form method="post" action="/Auth/LinkKitsu" class="linked-account-creds linked-kitsu-form">
                                <input type="text" name="username" placeholder="Kitsu username" required />
                                <input type="password" name="password" placeholder="Kitsu password" required />
                                <button type="submit" class="btn-primary-action btn-login">Link Kitsu</button>
                            </form>
                        }
                    </div>
                }
            </div>
        </section>
    }

    <!-- ─── CATALOGS ────────────────────────────────────────────────── -->
    <section class="section-card">
        <span class="section-title">Catalogs</span>
        <p class="section-description">Choose which catalogs and stream sources AniSync exposes to Stremio.</p>

        <div class="catalogs-grid">
            <span class="catalog-col-spacer"></span>
            <span class="catalog-col-label">Enable</span>
            <span class="catalog-col-label">Discover Only</span>
            <hr class="option-sep" />

            @* Select-all row — flips every row in the column it sits under. The aggregate *@
            @* state of the master toggles is kept in sync via JS as users toggle individual *@
            @* rows. *@
            <span class="option-name option-name-all">Select all</span>
            <label class="switch">
                <input type="checkbox" id="enableAll" />
                <span class="slider"></span>
            </label>
            <label class="switch">
                <input type="checkbox" id="discoverOnlyAll" />
                <span class="slider"></span>
            </label>
            <hr class="option-sep" />

            @if (!anonymousUser)
            {
                <span class="option-name">Currently watching</span>
                <label class="switch">
                    <input type="checkbox" id="showCurrent" class="catalogCheck" @(showCurrent ? "checked" : "") />
                    <span class="slider"></span>
                </label>
                <label class="switch @(!showCurrent ? "switch-disabled" : "")">
                    <input type="checkbox" id="discoverOnlyCurrent" class="discoverCheck" @(discoverOnlyCurrent ? "checked" : "") @(!showCurrent ? "disabled" : "") />
                    <span class="slider"></span>
                </label>
                <hr class="option-sep" />

                <span class="option-name">Completed</span>
                <label class="switch">
                    <input type="checkbox" id="showCompleted" class="catalogCheck" @(showCompleted ? "checked" : "") />
                    <span class="slider"></span>
                </label>
                <label class="switch @(!showCompleted ? "switch-disabled" : "")">
                    <input type="checkbox" id="discoverOnlyCompleted" class="discoverCheck" @(discoverOnlyCompleted ? "checked" : "") @(!showCompleted ? "disabled" : "") />
                    <span class="slider"></span>
                </label>
                <hr class="option-sep" />

                <span class="option-name">Plan to Watch</span>
                <label class="switch">
                    <input type="checkbox" id="showPlanning" class="catalogCheck" @(showPlanning ? "checked" : "") />
                    <span class="slider"></span>
                </label>
                <label class="switch @(!showPlanning ? "switch-disabled" : "")">
                    <input type="checkbox" id="discoverOnlyPlanning" class="discoverCheck" @(discoverOnlyPlanning ? "checked" : "") @(!showPlanning ? "disabled" : "") />
                    <span class="slider"></span>
                </label>
                <hr class="option-sep" />

                <span class="option-name">On Hold</span>
                <label class="switch">
                    <input type="checkbox" id="showPaused" class="catalogCheck" @(showPaused ? "checked" : "") />
                    <span class="slider"></span>
                </label>
                <label class="switch @(!showPaused ? "switch-disabled" : "")">
                    <input type="checkbox" id="discoverOnlyPaused" class="discoverCheck" @(discoverOnlyPaused ? "checked" : "") @(!showPaused ? "disabled" : "") />
                    <span class="slider"></span>
                </label>
                <hr class="option-sep" />

                <span class="option-name">Dropped</span>
                <label class="switch">
                    <input type="checkbox" id="showDropped" class="catalogCheck" @(showDropped ? "checked" : "") />
                    <span class="slider"></span>
                </label>
                <label class="switch @(!showDropped ? "switch-disabled" : "")">
                    <input type="checkbox" id="discoverOnlyDropped" class="discoverCheck" @(discoverOnlyDropped ? "checked" : "") @(!showDropped ? "disabled" : "") />
                    <span class="slider"></span>
                </label>
                <hr class="option-sep" />

                @* AniList exposes REPEATING as a real status; MAL has an is_rewatching flag the *@
                @* MalService surfaces as a synthetic Rewatching list. Kitsu has no equivalent. *@
                @if (isAnilist || isMal)
                {
                    <span class="option-name">Rewatching</span>
                    <label class="switch">
                        <input type="checkbox" id="showRepeating" class="catalogCheck" @(showRepeating ? "checked" : "") />
                        <span class="slider"></span>
                    </label>
                    <label class="switch @(!showRepeating ? "switch-disabled" : "")">
                        <input type="checkbox" id="discoverOnlyRepeating" class="discoverCheck" @(discoverOnlyRepeating ? "checked" : "") @(!showRepeating ? "disabled" : "") />
                        <span class="slider"></span>
                    </label>
                    <hr class="option-sep" />
                }
            }

            <span class="option-name">Trending now</span>
            <label class="switch">
                <input type="checkbox" id="showTrending" class="catalogCheck" @(showTrending ? "checked" : "") />
                <span class="slider"></span>
            </label>
            <label class="switch @(!showTrending ? "switch-disabled" : "")">
                <input type="checkbox" id="discoverOnlyTrending" class="discoverCheck" @(discoverOnlyTrending ? "checked" : "") @(!showTrending ? "disabled" : "") />
                <span class="slider"></span>
            </label>
            <hr class="option-sep" />

            <span class="option-name">Seasonal Anime</span>
            <label class="switch">
                <input type="checkbox" id="showSeasonal" class="catalogCheck" @(showSeasonal ? "checked" : "") />
                <span class="slider"></span>
            </label>
            <label class="switch @(!showSeasonal ? "switch-disabled" : "")">
                <input type="checkbox" id="discoverOnlySeasonal" class="discoverCheck" @(discoverOnlySeasonal ? "checked" : "") @(!showSeasonal ? "disabled" : "") />
                <span class="slider"></span>
            </label>
            <hr class="option-sep" />

            <span class="option-name">Airing This Week</span>
            <label class="switch">
                <input type="checkbox" id="showAiring" class="catalogCheck" @(showAiring ? "checked" : "") />
                <span class="slider"></span>
            </label>
            <label class="switch @(!showAiring ? "switch-disabled" : "")">
                <input type="checkbox" id="discoverOnlyAiring" class="discoverCheck" @(discoverOnlyAiring ? "checked" : "") @(!showAiring ? "disabled" : "") />
                <span class="slider"></span>
            </label>
        </div>
    </section>

    <!-- ─── STREAMS ─────────────────────────────────────────────────── -->
    <section class="section-card">
        <span class="section-title">Streams</span>
        <p class="section-description">Choose what AniSync attaches to each episode in Stremio.</p>

        <div class="streams-grid">
            @* Manage Entry and Auto-track touch the user's list, so they only make sense *@
            @* when there's an account behind the install. *@
            @if (!anonymousUser)
            {
                <div class="stream-option">
                    <div class="option-name-wrap">
                        <span class="option-name">Manage Entry</span>
                        <span class="option-name-sub">Quick-edit progress, score and notes from Stremio.</span>
                    </div>
                    <label class="switch">
                        <input type="checkbox" id="showManageEntry" @(showManageEntry ? "checked" : "") />
                        <span class="slider"></span>
                    </label>
                </div>

                <div class="stream-option">
                    <div class="option-name-wrap">
                        <span class="option-name">Auto-track progress</span>
                        <span class="option-name-sub">Update your list when you start an episode in Stremio.</span>
                    </div>
                    <label class="switch">
                        <input type="checkbox" id="autoTrackProgress" @(autoTrackProgress ? "checked" : "") />
                        <span class="slider"></span>
                    </label>
                </div>
            }

            <div class="stream-option">
                <div class="option-name-wrap">
                    <span class="option-name">External services</span>
                    <span class="option-name-sub">Crunchyroll, Netflix, HiDive, …</span>
                </div>
                <label class="switch">
                    <input type="checkbox" id="showExternalStreams" @(showExternalStreams ? "checked" : "") />
                    <span class="slider"></span>
                </label>
            </div>
        </div>
    </section>

    <!-- ─── INSTALLATION OPTIONS ────────────────────────────────────── -->
    <section class="section-card">
        <span class="section-title">Installation Options</span>
        <p class="section-description">
            Install AniSync using your preferred method. The install URL updates automatically
            when you change the toggles above — Stremio caches manifests, so a fresh install
            is needed to pick up changes.
        </p>

        <div class="install-inner-card">
            <div class="install-header">
                <img src="/logo.png" alt="AniSync" class="install-icon-img" />
                <div class="install-header-text">
                    <h3>Stremio</h3>
                    <p>Install to Stremio or other Stremio-compatible clients using the Manifest URL.</p>
                </div>
            </div>

            <hr class="install-divider" />

            <a id="stremioUrl" class="btn-primary-action btn-install" href="stremio://@Context.Request.Host">
                Install to Stremio
            </a>
            <a id="stremioWebUrl" class="btn-secondary-action" target="_blank" rel="noopener" href="@($"{stremioStr}{Context.Request.Scheme}://{Context.Request.Host}")">
                Install to Stremio Web
            </a>

            <p class="manifest-url-label">Direct Manifest URL</p>
            <div class="manifest-url-row">
                <input id="manifestUrlInput" class="manifest-url-input" readonly type="text" value="" />
                <button id="copyManifestBtn" class="btn-icon-copy" type="button" title="Copy URL" aria-label="Copy URL">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                        <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
                    </svg>
                </button>
            </div>
        </div>
    </section>

    <!-- ─── BACKUPS ─────────────────────────────────────────────────── -->
    <section class="section-card">
        <span class="section-title">Backups</span>
        <p class="section-description">Export your configuration to a file or restore from one.</p>

        <div class="btn-action-row">
            <a id="exportConfigBtn" class="btn-ghost" href="/Home/ExportConfig" download>
                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                    <polyline points="17 8 12 3 7 8"></polyline>
                    <line x1="12" y1="3" x2="12" y2="15"></line>
                </svg>
                Export
            </a>
            <button id="importConfigBtn" class="btn-ghost" type="button">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                    <polyline points="7 10 12 15 17 10"></polyline>
                    <line x1="12" y1="15" x2="12" y2="3"></line>
                </svg>
                Import
            </button>
            <input id="importConfigFile" type="file" accept="application/json,.json" hidden />
        </div>
    </section>

    <!-- ─── DANGER ZONE ─────────────────────────────────────────────── -->
    <section class="section-card danger-zone-card">
        <span class="section-title">Danger Zone</span>
        <p class="section-description">Perform potentially destructive actions that cannot be undone.</p>

        <div class="btn-action-row">
            <button id="resetConfigBtn" class="btn-danger-pill" type="button">Reset Configuration</button>
            <button id="deleteConfigBtn" class="btn-danger-pill" type="button">Delete Configuration</button>
        </div>
    </section>
}
else
{
    <!-- Login -->
    <div class="card-section" id="loginCard">
        <div id="kitsuCreds" style="display:@(isKitsu ? "block" : "none")">
            <div class="cred-group">
                <label for="username" class="required">Username</label>
                <input type="text" id="username" />
            </div>
            <div class="cred-group">
                <label for="password" class="required">Password</label>
                <input type="password" id="password" />
            </div>
        </div>
        <a id="loginUrl" class="btn-primary-action btn-login" href='@Url.Action("Login", "Auth", new { animeService })'>
            Login with <span id="loginServiceName">@serviceDisplay</span>
        </a>
    </div>

    <p class="hint-text">Login to your anime list provider to get started.</p>

    <a id="loginAnonymousUrl" class="btn-primary-action btn-login" href='@Url.Action("Login", "Auth")'>
       Or Continue without Account
    </a>
}

<script>
    // Numeric service selector: 0 = Kitsu, 1 = AniList, 2 = MyAnimeList. Mirrors the
    // AnimeService enum on the server.
    var selectedService = @serviceIndex;
    var loginBaseUrl = '@Url.Action("Login", "Auth")';
    // Origin (scheme://host) of the addon — used to build the manifest URL and the
    // stremio:// deep-link. These never include flags; flags live in the URL path bytes.
    var addonOrigin = '@(Context.Request.Scheme)://@(Context.Request.Host)';
    var stremioWebPrefix = '@stremioStr';

    // Authenticated users have a 16-byte UID (base64url) pointing at a row in the
    // server-side config store; anonymous users still embed their (tiny) token data inline.
    // Exactly one of the two strings is non-empty per request.
    var configUid = '@(configUid ?? "")';
    var tokenDataStr = '@(tokenDataStr ?? "")';
    // Revision counter, appended to the install URL as 4 trailing bytes so the URL changes
    // after every Save. Stremio caches manifests aggressively (even past force-restart) and
    // a stable URL means it never refetches; bumping the URL forces a fresh install.
    var configRevision = @configRevision;

    function base64UrlToBytes(str) {
        if (!str) return new Uint8Array(0);
        var base64 = str.replace(/-/g, '+').replace(/_/g, '/');
        while (base64.length % 4) base64 += '=';
        var binary = atob(base64);
        var bytes = new Uint8Array(binary.length);
        for (var i = 0; i < binary.length; i++) bytes[i] = binary.charCodeAt(i);
        return bytes;
    }

    function bytesToBase64Url(bytes) {
        var binary = '';
        for (var i = 0; i < bytes.length; i++) binary += String.fromCharCode(bytes[i]);
        return btoa(binary).replace(/\+/g, '-').replace(/\//g, '_').replace(/=+$/g, '');
    }

    var uidBytes = base64UrlToBytes(configUid);
    var tokenBytes = base64UrlToBytes(tokenDataStr);

    function readFlags() {
        var flags1 = 0;
        if ($('#showCurrent').is(':checked'))           flags1 |= 0x01;
        if ($('#showCompleted').is(':checked'))         flags1 |= 0x02;
        if ($('#showTrending').is(':checked'))          flags1 |= 0x04;
        if ($('#showSeasonal').is(':checked'))          flags1 |= 0x08;
        if ($('#discoverOnlyCurrent').is(':checked'))   flags1 |= 0x10;
        if ($('#discoverOnlyCompleted').is(':checked')) flags1 |= 0x20;
        if ($('#discoverOnlyTrending').is(':checked'))  flags1 |= 0x40;
        if ($('#discoverOnlySeasonal').is(':checked'))  flags1 |= 0x80;

        var flags2 = 0;
        if ($('#showPlanning').is(':checked'))           flags2 |= 0x01;
        if ($('#showPaused').is(':checked'))             flags2 |= 0x02;
        if ($('#showDropped').is(':checked'))            flags2 |= 0x04;
        if ($('#showRepeating').is(':checked'))          flags2 |= 0x08;
        if ($('#discoverOnlyPlanning').is(':checked'))   flags2 |= 0x10;
        if ($('#discoverOnlyPaused').is(':checked'))     flags2 |= 0x20;
        if ($('#discoverOnlyDropped').is(':checked'))    flags2 |= 0x40;
        if ($('#discoverOnlyRepeating').is(':checked'))  flags2 |= 0x80;

        var flags3 = 0;
        if ($('#showAiring').is(':checked'))             flags3 |= 0x01;
        if ($('#showExternalStreams').is(':checked'))    flags3 |= 0x02;
        // Inverse bits: stored 1 = "off". Toggling the UI off sets the bit; default-checked
        // toggles leave the bit at 0, matching pre-feature behavior for existing rows.
        // The toggles are hidden for anonymous users (no account → nothing to manage), so
        // .length-guard before reading state to avoid setting the bit just because the input
        // doesn't exist on the page.
        var $manage = $('#showManageEntry');
        if ($manage.length && !$manage.is(':checked'))   flags3 |= 0x04;
        var $autoTrack = $('#autoTrackProgress');
        if ($autoTrack.length && !$autoTrack.is(':checked')) flags3 |= 0x08;
        if ($('#discoverOnlyAiring').is(':checked'))     flags3 |= 0x10;

        return { flags1: flags1, flags2: flags2, flags3: flags3 };
    }

    function buildManifestPath() {
        var f = readFlags();
        var payload;
        if (uidBytes.length > 0) {
            // Binary v5: [0x05][16-byte UID][4-byte revision big-endian]. Revision bytes
            // make the URL different after every save so Stremio re-fetches the manifest.
            payload = new Uint8Array(1 + uidBytes.length + 4);
            payload[0] = 0x05;
            payload.set(uidBytes, 1);
            var rev = (configRevision >>> 0);
            var revOffset = 1 + uidBytes.length;
            payload[revOffset]     = (rev >>> 24) & 0xff;
            payload[revOffset + 1] = (rev >>> 16) & 0xff;
            payload[revOffset + 2] = (rev >>> 8)  & 0xff;
            payload[revOffset + 3] = rev          & 0xff;
        } else {
            // Binary v3 anonymous fallback: [0x03][flags1][flags2][flags3][gzip token bytes]
            payload = new Uint8Array(4 + tokenBytes.length);
            payload[0] = 0x03;
            payload[1] = f.flags1;
            payload[2] = f.flags2;
            payload[3] = f.flags3;
            payload.set(tokenBytes, 4);
        }
        return '/' + bytesToBase64Url(payload) + '/manifest.json';
    }

    function refreshUrls() {
        var path = buildManifestPath();
        var manifestHttps = addonOrigin + path;
        // stremio:// deep link uses the host (not scheme) so apps know to open natively.
        var stremioDeep = 'stremio://' + addonOrigin.replace(/^https?:\/\//, '') + path;
        var stremioWeb = stremioWebPrefix + manifestHttps;

        $('#stremioUrl').attr('href', stremioDeep);
        $('#stremioWebUrl').attr('href', stremioWeb);
        $('#manifestUrlInput').val(manifestHttps);
    }

    refreshUrls();

    // Catalog + stream toggles — recompute the manifest URL whenever flags change. (For
    // v5 the path bytes don't actually change since flags live in DB, but we still call
    // refreshUrls() to keep the path in sync after a SaveConfig response bumps revision.)
    $('.catalogCheck, .discoverCheck, #showExternalStreams, #showManageEntry, #autoTrackProgress')
        .on('change', refreshUrls);

    // When an enable checkbox is toggled, enable/disable its discover-only sibling
    $('.catalogCheck').on('change', function () {
        var $discoverLabel = $(this).parent().next();
        var $discoverSwitch = $discoverLabel.find('.discoverCheck');
        var isEnabled = $(this).is(':checked');
        $discoverSwitch.prop('disabled', !isEnabled);
        $discoverLabel.toggleClass('switch-disabled', !isEnabled);
        if (!isEnabled) $discoverSwitch.prop('checked', false);
    });

    // ── Select-all switches ───────────────────────────────────────────
    // Master "Enable" toggle: flips every catalog row to its state. trigger('change')
    // so the per-row sibling-disable handler runs, refreshUrls fires, etc.
    $('#enableAll').on('change', function () {
        var checked = $(this).is(':checked');
        $('.catalogCheck').prop('checked', checked).trigger('change');
    });

    // Master "Discover Only" toggle: only flips rows whose Enable is on (the rest are
    // visually disabled and stay unchecked).
    $('#discoverOnlyAll').on('change', function () {
        var checked = $(this).is(':checked');
        $('.catalogCheck').each(function () {
            if (!$(this).is(':checked')) return;
            var $disc = $(this).parent().next().find('.discoverCheck');
            $disc.prop('checked', checked).trigger('change');
        });
    });

    // Mirror aggregate state on the master toggles: master ON only when *every* row in
    // its column is on. Use prop (no trigger) so we don't recurse.
    function refreshAllToggles() {
        var enables = $('.catalogCheck');
        $('#enableAll').prop('checked', enables.length > 0 && enables.length === enables.filter(':checked').length);

        var discovers = $('.discoverCheck:not(:disabled)');
        $('#discoverOnlyAll').prop('checked', discovers.length > 0 && discovers.length === discovers.filter(':checked').length);
    }
    $('.catalogCheck, .discoverCheck').on('change', refreshAllToggles);
    refreshAllToggles();

    // ── Service picker ────────────────────────────────────────────────
    function serviceLabel(svc) {
        if (svc === 1) return 'AniList';
        if (svc === 2) return 'MyAnimeList';
        return 'Kitsu';
    }

    $('#serviceToggle .label').on('click', function () {
        // Once authenticated the picker is locked — the user has to disconnect
        // (which deletes the stored token) before switching providers.
        if ($('#serviceToggle').hasClass('disabled')) return;
        var svc = parseInt($(this).attr('data-service'), 10);
        if (isNaN(svc)) return;
        selectedService = svc;
        $('#serviceToggle .label').removeClass('active');
        $(this).addClass('active');
        $('#loginServiceName').text(serviceLabel(svc));
        // Only the Kitsu password-grant flow needs the username/password fields visible.
        $('#kitsuCreds').toggle(svc === 0);
        updateLoginUrl();
    });

    $('#disconnectBtn').on('click', function () {
        window.location.href = '@Url.Action("Logout", "Auth")';
    });

    // ── Linked Accounts ───────────────────────────────────────────────
    // The Kitsu link row shows a button by default; clicking expands the inline
    // username/password form (Kitsu uses password-grant, no OAuth redirect).
    $('.linked-account-toggle').on('click', function () {
        var $row = $(this).closest('.linked-account-row');
        $row.find('.linked-kitsu-form').toggleClass('expanded');
    });

    // ── Copy manifest URL ─────────────────────────────────────────────
    $('#copyManifestBtn').on('click', async function () {
        var url = $('#manifestUrlInput').val();
        var $btn = $(this);
        var success = false;
        try {
            await navigator.clipboard.writeText(url);
            success = true;
        } catch {
            // Fallback for older browsers
            $('#manifestUrlInput').select();
            success = document.execCommand('copy');
        }
        $btn.toggleClass('copied', success);
        setTimeout(function () { $btn.removeClass('copied'); }, 1500);
    });

    // ── Save flags before launching Stremio ───────────────────────────
    // Persists current toggle state and bumps the revision so Stremio sees a different
    // URL — required because Stremio caches manifests for already-installed URLs and
    // wouldn't otherwise pick up flag changes.
    async function saveFlags() {
        if (!configUid) return;
        var f = readFlags();
        var resp = await fetch('/Home/SaveConfig', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ uid: configUid, flags1: f.flags1, flags2: f.flags2, flags3: f.flags3 }),
        });
        if (!resp.ok) throw new Error('Save failed: ' + resp.status);
        var data = await resp.json();
        if (typeof data.revision === 'number') {
            configRevision = data.revision;
            refreshUrls();
        }
    }

    // Both install buttons trigger a save first so the new URL reflects the latest flags.
    async function handleInstallClick(e) {
        if (!configUid) return; // anonymous (v3): URL already encodes flags
        e.preventDefault();
        try { await saveFlags(); } catch { /* let them try anyway */ }
        // Re-read the (possibly new) href after saveFlags bumped configRevision.
        var href = $(this).attr('href');
        if ($(this).attr('target') === '_blank') {
            window.open(href, '_blank', 'noopener');
        } else {
            window.location.href = href;
        }
    }
    $('#stremioUrl, #stremioWebUrl').on('click', handleInstallClick);

    // ── Backups ───────────────────────────────────────────────────────
    $('#importConfigBtn').on('click', function () {
        $('#importConfigFile').trigger('click');
    });

    $('#importConfigFile').on('change', async function (e) {
        var file = e.target.files[0];
        if (!file) return;
        try {
            var text = await file.text();
            var json = JSON.parse(text);
            var resp = await fetch('/Home/ImportConfig', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(json),
            });
            if (!resp.ok) throw new Error('Import failed: ' + resp.status);
            window.location.href = '/';
        } catch (err) {
            alert('Could not import configuration: ' + err.message);
        } finally {
            $('#importConfigFile').val(''); // allow re-selecting same file later
        }
    });

    // ── Danger Zone ───────────────────────────────────────────────────
    $('#resetConfigBtn').on('click', async function () {
        if (!configUid) return;
        if (!confirm('Reset all toggles to defaults? Your login is kept.')) return;
        var resp = await fetch('/Home/ResetConfig', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ uid: configUid }),
        });
        if (resp.ok) window.location.reload();
        else alert('Reset failed.');
    });

    $('#deleteConfigBtn').on('click', async function () {
        if (!confirm('Delete your AniSync configuration permanently? Existing install URLs in Stremio will stop working and you will be signed out.')) return;
        var resp = await fetch('/Home/DeleteConfig', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ uid: configUid }),
        });
        if (resp.ok) window.location.href = '/';
        else alert('Delete failed.');
    });

    // ── Login form (anonymous / Kitsu credentials) ────────────────────
    $('#username, #password').on('input', updateLoginUrl);

    function updateLoginUrl() {
        var href = loginBaseUrl + '?animeService=' + selectedService;
        // Kitsu uses the password grant — credentials are typed into the form and
        // posted to /Auth/Login. The other providers are OAuth-redirected.
        if (selectedService === 0) {
            var username = $('#username').val();
            var password = encodeURIComponent($('#password').val());
            href += '&username=' + username + '&password=' + password;
        }
        $('#loginUrl').attr('href', href);
    }

    updateLoginUrl();

    $('#loginUrl').on('click', function (e) {
        e.preventDefault();
        if (selectedService === 0 && ($('#username').val() == '' || $('#password').val() == '')) return;
        window.location.href = $('#loginUrl').attr('href');
    });

    $('#loginAnonymousUrl').on('click', function (e) {
        e.preventDefault();
        var href = $('#loginAnonymousUrl').attr('href');
        href += '?animeService=' + selectedService + '&anonymous=true';
        window.location.href = href;
    });
</script>
