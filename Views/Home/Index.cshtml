@{
    var tokenDataStr = (string)ViewBag.TokenData;
    var animeService = (AnimeService?)ViewBag.AnimeService;
    var isLoggedIn = !string.IsNullOrEmpty(tokenDataStr);
    var isAnilist = animeService == AnimeService.Anilist;
    var stremioStr = "https://web.stremio.com/#/addons?addon=";
    bool anonymousUser = ViewBag.AnonymousUser == true;
    bool showCurrent = ViewBag.ShowCurrent ?? !anonymousUser;
    bool showCompleted = ViewBag.ShowCompleted ?? false;
    bool showTrending = ViewBag.ShowTrending ?? anonymousUser;
    bool showSeasonal = ViewBag.ShowSeasonal ?? true;
    bool discoverOnlyCurrent = ViewBag.DiscoverOnlyCurrent ?? false;
    bool discoverOnlyCompleted = ViewBag.DiscoverOnlyCompleted ?? false;
    bool discoverOnlyTrending = ViewBag.DiscoverOnlyTrending ?? false;
    bool discoverOnlySeasonal = ViewBag.DiscoverOnlySeasonal ?? true;
}

<h1 class="app-logo">Ani<span class="accent">Sync</span></h1>
<p class="app-subtitle">Track your anime progress on Stremio</p>

@if (!anonymousUser)
{
    <!-- Service toggle (always visible) -->
    <div class="service-toggle">
        <span class="label @(!isAnilist ? "active" : "")" id="labelKitsu">Kitsu</span>
        <div class="toggle-track @(isAnilist ? "anilist" : "kitsu") @(isLoggedIn ? "disabled" : "")" id="serviceToggle">
            <div class="toggle-thumb"></div>
        </div>
        <span class="label @(isAnilist ? "active" : "")" id="labelAnilist">AniList</span>
    </div>
}

@if (isLoggedIn)
{
    <span class="success-badge">
        @(!anonymousUser ? $"✓ Connected to {animeService}" : "Connected without User")
        <button id="disconnectBtn" class="btn btn-sm btn-outline-danger" title="Disconnect">✗</button>
    </span>

    <!-- Catalog options -->
    <div class="card-section">
        <div class="catalog-header">
            <h5>Catalogs</h5>
            <span class="catalog-col-label">Enable</span>
            <span class="catalog-col-label">Discover Only</span>
        </div>

        @if (!anonymousUser)
        {
            <div class="option-row">
                <span>Currently watching</span>
                <label class="switch">
                    <input type="checkbox" id="showCurrent" class="catalogCheck" @(showCurrent ? "checked" : "") />
                    <span class="slider"></span>
                </label>
                <label class="switch @(!showCurrent ? "switch-disabled" : "")">
                    <input type="checkbox" id="discoverOnlyCurrent" class="discoverCheck" @(discoverOnlyCurrent ? "checked" : "") @(!showCurrent ? "disabled" : "") />
                    <span class="slider"></span>
                </label>
            </div>

            <div class="option-row">
                <span>Completed</span>
                <label class="switch">
                    <input type="checkbox" id="showCompleted" class="catalogCheck" @(showCompleted ? "checked" : "") />
                    <span class="slider"></span>
                </label>
                <label class="switch @(!showCompleted ? "switch-disabled" : "")">
                    <input type="checkbox" id="discoverOnlyCompleted" class="discoverCheck" @(discoverOnlyCompleted ? "checked" : "") @(!showCompleted ? "disabled" : "") />
                    <span class="slider"></span>
                </label>
            </div>
        }

        <div class="option-row">
            <span>Trending now</span>
            <label class="switch">
                <input type="checkbox" id="showTrending" class="catalogCheck" @(showTrending ? "checked" : "") />
                <span class="slider"></span>
            </label>
            <label class="switch @(!showTrending ? "switch-disabled" : "")">
                <input type="checkbox" id="discoverOnlyTrending" class="discoverCheck" @(discoverOnlyTrending ? "checked" : "") @(!showTrending ? "disabled" : "") />
                <span class="slider"></span>
            </label>
        </div>

        <div class="option-row">
            <span>Seasonal Anime</span>
            <label class="switch">
                <input type="checkbox" id="showSeasonal" class="catalogCheck" @(showSeasonal ? "checked" : "") />
                <span class="slider"></span>
            </label>
            <label class="switch switch-disabled">
                <input type="checkbox" id="discoverOnlySeasonal" class="discoverCheck" @(discoverOnlySeasonal ? "checked" : "") @(!showSeasonal ? "disabled" : "") checked disabled />
                <span class="slider"></span>
            </label>
        </div>
    </div>

    <!-- Install -->
    <a id="stremioUrl" class="btn-primary-action btn-install" href="stremio://@Context.Request.Host">
        Install on Stremio
    </a>
    <div class="hint-text hint-actions">
        <span>Open or copy</span>
        <a id="url" href="@($"{stremioStr}{Context.Request.Scheme}://{Context.Request.Host}")">this link</a>
        <span>for Stremio.</span>
        <button type="button" id="copyUrlBtn" class="hint-copy-btn">Copy</button>
    </div>
}
else
{
    <!-- Login -->
    <div class="card-section" id="loginCard">
        <div id="kitsuCreds" style="display:@(!isAnilist ? "block" : "none")">
            <div class="cred-group">
                <label for="username" class="required">Username</label>
                <input type="text" id="username" />
            </div>
            <div class="cred-group">
                <label for="password" class="required">Password</label>
                <input type="password" id="password" />
            </div>
        </div>
        <a id="loginUrl" class="btn-primary-action btn-login" href='@Url.Action("Login", "Auth", new { animeService })'>
            Login with <span id="loginServiceName">@animeService</span>
        </a>
    </div>

    <p class="hint-text">Login to your anime list provider to get started.</p>

    <a id="loginAnonymousUrl" class="btn-primary-action btn-login" href='@Url.Action("Login", "Auth")'>
       Or Continue without Account
    </a>
}

<script>
    var isAnilist = @Html.Raw(isAnilist.ToString().ToLower());
    var loginBaseUrl = '@Url.Action("Login", "Auth")';
    var url = $('#url').attr('href');
    var stremioUrl = $('#stremioUrl').attr('href');

    var config = {
        tokenData: @Html.Raw(SerializeObject(tokenDataStr, new JsonSerializerSettings { DefaultValueHandling = DefaultValueHandling.Ignore, NullValueHandling = NullValueHandling.Ignore })),
    };

    changeUrl();

    // Service toggle
    $('#serviceToggle, #labelKitsu, #labelAnilist').on('click', function () {
        isAnilist = !isAnilist;
        var track = $('#serviceToggle');
        track.toggleClass('anilist', isAnilist).toggleClass('kitsu', !isAnilist);
        $('#labelAnilist').toggleClass('active', isAnilist);
        $('#labelKitsu').toggleClass('active', !isAnilist);
        $('#loginServiceName').text(isAnilist ? 'AniList' : 'Kitsu');
        $('#kitsuCreds').toggle(!isAnilist);
        updateLoginUrl();
    });

    $('#disconnectBtn').on('click', function () {
        window.location.href = '@Url.Action("Logout", "Auth")';
    });

    $('#copyUrlBtn').on('click', async function () {
        var copyUrl = $('#url').attr('href').replace('@stremioStr', '');

        try {
            await navigator.clipboard.writeText(copyUrl);
            $(this).text('Copied');
            setTimeout(() => $(this).text('Copy'), 1500);
        } catch {
            var tempInput = $('<input>');
            $('body').append(tempInput);
            tempInput.val(copyUrl).trigger('select');
            document.execCommand('copy');
            tempInput.remove();
            $(this).text('Copied');
            setTimeout(() => $(this).text('Copy'), 1500);
        }
    });

    // Catalog checkboxes
    $('.catalogCheck, .discoverCheck').on('change', function () {
        changeUrl();
    });

    // When an enable checkbox is toggled, enable/disable its discover-only sibling
    $('.catalogCheck').on('change', function () {
        var $row = $(this).closest('.option-row');
        var $discoverSwitch = $row.find('.discoverCheck');
        var $discoverLabel = $discoverSwitch.closest('.switch');
        var isEnabled = $(this).is(':checked');

        $discoverSwitch.prop('disabled', !isEnabled);
        $discoverLabel.toggleClass('switch-disabled', !isEnabled);
        if (!isEnabled) {
            $discoverSwitch.prop('checked', false);
        }
    });

    function changeUrl() {
        delete config.showCurrent;
        delete config.showCompleted;
        delete config.showTrending;
        delete config.showSeasonal;
        delete config.discoverOnlyCurrent;
        delete config.discoverOnlyCompleted;
        delete config.discoverOnlyTrending;
        delete config.discoverOnlySeasonal;

        if ($('#showCurrent').is(':checked')) config.showCurrent = true;
        if ($('#showCompleted').is(':checked')) config.showCompleted = true;
        if ($('#showTrending').is(':checked')) config.showTrending = true;
        if ($('#showSeasonal').is(':checked')) config.showSeasonal = true;
        if ($('#discoverOnlyCurrent').is(':checked')) config.discoverOnlyCurrent = true;
        if ($('#discoverOnlyCompleted').is(':checked')) config.discoverOnlyCompleted = true;
        if ($('#discoverOnlyTrending').is(':checked')) config.discoverOnlyTrending = true;
        if ($('#discoverOnlySeasonal').is(':checked')) config.discoverOnlySeasonal = true;

        var tempUrl = '/' + encodeURIComponent(JSON.stringify(config)) + '/manifest.json';
        $('#url').attr('href', url + tempUrl);
        $('#stremioUrl').attr('href', stremioUrl + tempUrl);
    }

    // Kitsu credentials
    $('#username, #password').on('input', function () {
        updateLoginUrl();
    });

    function updateLoginUrl() {
        var svc = isAnilist ? 1 : 0;
        var href = loginBaseUrl + '?animeService=' + svc;

        if (!isAnilist) {
            var username = $('#username').val();
            var password = encodeURIComponent($('#password').val());
            href += '&username=' + username + '&password=' + password;
        }

        $('#loginUrl').attr('href', href);
    }

    updateLoginUrl();

    $('#loginUrl').on('click', function (e) {
        e.preventDefault();
        if (!isAnilist && ($('#username').val() == '' || $('#password').val() == '')) {
            return;
        }

        window.location.href = $('#loginUrl').attr('href');
    });
</script>