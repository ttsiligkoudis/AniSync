@model AnimeList.Models.DashboardViewModel
@{
    var tokenData = Model.TokenData;
    var isLoggedIn = tokenData != null;
    var anonymousUser = tokenData?.anonymousUser ?? false;
    var serviceLabel = tokenData?.anime_service.ToString();
    var hasContinueWatching = Model.ContinueWatching?.Count > 0;
}

@* Compact site header — small wordmark on the left, login state on the right.
   Phase 4 of the refactor will fold a hamburger drawer + mobile bottom nav in
   here; for now the header is just identity + connection state. *@
<header class="site-header">
    <h1 class="site-logo">Ani<span class="accent">Sync</span></h1>
    @if (isLoggedIn && !anonymousUser)
    {
        <span class="site-header-badge">
            ✓ @serviceLabel
            <a class="site-header-badge-action" href="@Url.Action("Logout", "Auth")" title="Disconnect">✗</a>
        </span>
    }
</header>

@* Hero card — StreamD-style pill badge + two-tone heading + dual CTAs. Copy
   branches on login state: anonymous visitors get the pitch + "Get started"
   hand-off to /configure (where the Stremio install URL and provider picker
   live), logged-in users get a welcome-back nudge + entry points into the
   library and discover surfaces. *@
<section class="hero-card">
    @if (isLoggedIn && !anonymousUser)
    {
        <span class="hero-badge">✓ Synced with @serviceLabel</span>
        <h2 class="hero-title">
            Continue your <span class="hero-title-accent">anime journey</span>
        </h2>
        <p class="hero-tagline">Pick up where you left off, or surface what to watch next.</p>
        <div class="hero-ctas">
            <a class="hero-cta hero-cta-primary" href="/library">Open library →</a>
            <a class="hero-cta hero-cta-secondary" href="/discover">Discover trending</a>
        </div>
    }
    else
    {
        <span class="hero-badge">Track on Stremio</span>
        <h2 class="hero-title">
            Your anime, <span class="hero-title-accent">synced everywhere</span>
        </h2>
        <p class="hero-tagline">Track progress across AniList, MyAnimeList, and Kitsu — and watch on Stremio.</p>
        <div class="hero-ctas">
            <a class="hero-cta hero-cta-primary" href="@Url.Action("Configure", "Home")">Get started →</a>
            <a class="hero-cta hero-cta-secondary" href="/discover">Browse trending</a>
        </div>
    }
</section>

@* Stats strip: two big counts (Watching / Completed) plus a top-genres chip
   row. Only renders for logged-in non-anonymous users with at least one
   completed entry — without that, the genre breakdown would be empty and
   the strip would feel like a placeholder. v1 will add Hours Watched + Mean
   Score once the per-service queries surface episode counts and per-entry
   scores; v0 sticks to what's already in the existing list-catalog response. *@
@if (isLoggedIn && !anonymousUser && Model.CompletedTotal > 0)
{
    <section class="dashboard-section stats-section">
        <div class="dashboard-section-header">
            <h2 class="dashboard-section-title">Your stats</h2>
            <span class="dashboard-section-link-muted">via @serviceLabel</span>
        </div>
        <div class="stats-strip">
            <div class="stats-cell">
                <div class="stats-number">@Model.WatchingTotal</div>
                <div class="stats-label">Watching</div>
            </div>
            <div class="stats-cell">
                <div class="stats-number">@Model.CompletedTotal</div>
                <div class="stats-label">Completed</div>
            </div>
        </div>
        @if (Model.TopGenres.Count > 0)
        {
            <div class="genre-chips">
                <span class="genre-chips-label">Top genres:</span>
                @foreach (var (genre, _) in Model.TopGenres)
                {
                    <span class="genre-chip">@genre</span>
                }
            </div>
        }
    </section>
}

@* Continue Watching: a small slice of the user's Currently Watching list
   surfaced on the dashboard so the front door does something useful for
   returning users instead of just showing three nav tiles. Only renders for
   logged-in non-anonymous users with at least one item; falls back to the
   plain dashboard otherwise. The grid uses the existing _PosterGrid partial
   for visual consistency with /library and /discover. *@
@if (hasContinueWatching)
{
    <section class="dashboard-section">
        <div class="dashboard-section-header">
            <h2 class="dashboard-section-title">Continue watching</h2>
            <a class="dashboard-section-link" href="/library">View all →</a>
        </div>
        @await Html.PartialAsync("_PosterGrid", new AnimeList.Models.PosterGridViewModel
        {
            Items = Model.ContinueWatching,
            ConfigUid = Model.ConfigUid,
        })
    </section>
}

@* Three-tile navigation. Library is gated behind a logged-in primary so anonymous
   users get a "log in to enable" hint rather than a confusing dead click. Discover
   works for everyone (Trending / Seasonal / Airing don't require auth). Configure
   addon is always reachable — anonymous users still need it for the install URL.
   Stacked rather than side-by-side because main's max-width is 520px and three
   horizontal cards would be too narrow to read comfortably. *@
<div class="dashboard-tiles">
    @if (isLoggedIn && !anonymousUser)
    {
        <a class="dashboard-tile" href="/library">
            <h3 class="dashboard-tile-title">My Library</h3>
            <p class="dashboard-tile-text">Currently watching, completed, planning — across every linked provider.</p>
        </a>
    }
    else
    {
        <div class="dashboard-tile dashboard-tile-disabled">
            <h3 class="dashboard-tile-title">My Library</h3>
            <p class="dashboard-tile-text">Log in to see your AniList / MAL / Kitsu lists in one place.</p>
        </div>
    }

    <a class="dashboard-tile" href="/discover">
        <h3 class="dashboard-tile-title">Discover</h3>
        <p class="dashboard-tile-text">Trending, seasonal, and currently airing anime.</p>
    </a>

    <a class="dashboard-tile" href="@Url.Action("Configure", "Home")">
        <h3 class="dashboard-tile-title">Configure addon</h3>
        <p class="dashboard-tile-text">
            @(isLoggedIn ? "Manage linked accounts, install URL, and integrations." : "Get the Stremio install URL and pick your tracker.")
        </p>
    </a>
</div>
