            if (el) el.textContent = Number(val).toLocaleString();
        }
        fetch('/Home/SeasonStatsData', { credentials: 'same-origin', skipLoader: true })
            .then(function (r) { return r.ok ? r.json() : null; })
            .then(function (data) {
                // total === 0 means AniList hasn't populated the season yet
                // or the call blipped — hide rather than show a row of zeros.
                if (!data || !data.success || !data.total) { section.hidden = true; return; }
