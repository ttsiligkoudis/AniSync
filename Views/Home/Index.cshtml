<script>
    (function () {
        var shelves = document.querySelectorAll('[data-shelf]');
        if (!shelves.length) return;

        // Server-rendered _PosterGrid partials carry an inline <script> (the
        // airing-time localisation + clock-order reorder used by New Episodes
        // Today). innerHTML-inserted scripts don't execute, so re-create each
        // one after the swap to make it run.
        function runScripts(container) {
            container.querySelectorAll('script').forEach(function (old) {
                var s = document.createElement('script');
                if (old.src) { s.src = old.src; }
                else { s.textContent = old.textContent; }
                old.parentNode.replaceChild(s, old);
            });
        }

        shelves.forEach(function (section) {
            var src = section.getAttribute('data-shelf-src');
            var container = section.querySelector('[data-shelf-container]');
            if (!src || !container) return;

            // No await between iterations → every shelf fetch fires together
            // and resolves independently.
            fetch(src, { credentials: 'same-origin', skipLoader: true })
                .then(function (resp) { return resp.ok ? resp.text() : null; })
                .then(function (html) {
                    if (html == null || !html.trim()) {
                        // Upstream error or empty result — drop the skeleton
                        // shelf rather than leaving it loading forever.
                        section.hidden = true;
                        return;
                    }
                    container.innerHTML = html;
                    runScripts(container);
                    section.hidden = false;
                })
                .catch(function () { section.hidden = true; });
        });
    })();
</script>

