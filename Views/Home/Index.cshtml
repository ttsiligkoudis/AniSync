@model AnimeList.Models.DashboardViewModel
@{
    ViewData["ActiveNav"] = "home";
    ViewData["Title"] = "Dashboard";
    var tokenData = Model.TokenData;
    var isLoggedIn = tokenData != null;
    var anonymousUser = tokenData?.anonymousUser ?? false;
    var serviceLabel = tokenData?.anime_service.ToString();
    // Primary + every currently-working linked secondary, dot-separated,
    // so the hero badge reads "✓ Synced with AniList · MAL · Kitsu"
    // when the user has linked all three rather than hiding the fact
    // that saves fan out to more than one tracker.
    var allConnectedLabel = isLoggedIn && !anonymousUser
        ? string.Join(" · ", new[] { serviceLabel }.Concat(Model.LinkedServices ?? []))
        : serviceLabel;
}

@* Hero card — StreamD-style pill badge + two-tone heading + dual CTAs. Copy
   branches on login state: anonymous visitors get the pitch + "Get started"
   hand-off to /configure (where the Stremio install URL and provider picker
   live), logged-in users get a welcome-back nudge + entry points into the
   library and discover surfaces. *@
<section class="hero-card">
    @if (isLoggedIn && !anonymousUser)
    {
        <span class="hero-badge">✓ Synced with @allConnectedLabel</span>
        <h2 class="hero-title">
            Continue your <span class="hero-title-accent">anime journey</span>
        </h2>
        <p class="hero-tagline">Pick up where you left off, or surface what to watch next.</p>
        <div class="hero-ctas">
            <a class="hero-cta hero-cta-primary" href="/library">Open library →</a>
            <a class="hero-cta hero-cta-secondary" href="/discover">Discover trending</a>
        </div>
    }
    else
    {
        <span class="hero-badge">Track on Stremio</span>
        <h2 class="hero-title">
            Your anime, <span class="hero-title-accent">synced everywhere</span>
        </h2>
        <p class="hero-tagline">Track progress across AniList, MyAnimeList, and Kitsu — and watch on Stremio.</p>
        <div class="hero-ctas">
            <a class="hero-cta hero-cta-primary" href="@Url.Action("Configure", "Home")">Get started →</a>
            <a class="hero-cta hero-cta-secondary" href="/discover">Browse trending</a>
        </div>
    }
</section>

@* "This Season" stat strip — applies to every visitor since the counts
   describe the whole AniList catalog, not the viewer's list. Skipped
   silently when AniList returned zeros (transient failure / sandbox
   blocks the upstream / etc.) so the dashboard doesn't show a placeholder
   row of zeros. Each cell links to the relevant /discover filter so
   tapping the count is a useful navigation, not just a number. *@
@if (Model.SeasonTotal > 0)
{
    <section class="dashboard-section">
        <div class="dashboard-section-header">
            <h2 class="dashboard-section-title">This Season</h2>
            <a class="dashboard-section-link" href="/discover?list=seasonal&amp;season=@Uri.EscapeDataString(CurrentSeasonLabel())">
                <span>View all</span>
                <svg class="dashboard-section-link-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <line x1="5" y1="12" x2="19" y2="12"></line>
                    <polyline points="12 5 19 12 12 19"></polyline>
                </svg>
            </a>
        </div>
        <div class="stats-strip">
            @* These tiles are informational only — no link target. The
               equivalent navigation already lives in the Discover tab on
               the bottom-nav / drawer, so making the tiles tap targets
               just added an inconsistent path. *@
            <div class="stats-cell" aria-label="Currently airing anime">
                <span class="stats-icon stats-icon-blue">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="2" y="7" width="20" height="15" rx="2" ry="2"></rect>
                        <polyline points="17 2 12 7 7 2"></polyline>
                    </svg>
                </span>
                <div class="stats-number">@Model.SeasonCurrentlyAiring</div>
                <div class="stats-label">Currently Airing</div>
            </div>
            <div class="stats-cell" aria-label="New this season">
                <span class="stats-icon stats-icon-green">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 3 L13.5 9 L19 10.5 L13.5 12 L12 18 L10.5 12 L5 10.5 L10.5 9 Z"></path>
                        <path d="M19 4 L19.6 5.5 L21 6 L19.6 6.5 L19 8 L18.4 6.5 L17 6 L18.4 5.5 Z"></path>
                    </svg>
                </span>
                <div class="stats-number">@Model.SeasonNewThis</div>
                <div class="stats-label">New This Season</div>
            </div>
            <div class="stats-cell" aria-label="Total this season">
                <span class="stats-icon stats-icon-amber">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polygon points="5 3 19 12 5 21 5 3"></polygon>
                    </svg>
                </span>
                <div class="stats-number">@Model.SeasonTotal</div>
                <div class="stats-label">Total This Season</div>
            </div>
        </div>
    </section>
}

@* New episodes airing today. Day-bounded slice of the AniList airing
   schedule, deduped to one card per show. Cached server-side until the
   next UTC midnight so the shelf rotates with the calendar day rather
   than 24h-rolling. Hidden when the upstream returned empty (transient
   AniList failure, or genuinely no episodes airing today in the AniList
   schedule). *@
@if (Model.NewEpisodesToday.Count > 0)
{
    <section class="dashboard-section">
        <div class="dashboard-section-header">
            <h2 class="dashboard-section-title">New Episodes Today</h2>
            <span class="dashboard-section-link-muted">Refreshes daily</span>
        </div>
        @await Html.PartialAsync("_PosterGrid", new AnimeList.Models.PosterGridViewModel
        {
            Items = Model.NewEpisodesToday,
            ConfigUid = Model.ConfigUid,
            Variant = "scroll",
        })
    </section>
}

@* Popular-this-season + most-anticipated shelves. Same horizontal-scroll
   _PosterGrid the anime detail page's Recommended carousel uses, so the
   card chrome (poster + score + format / episodes / year info row) is
   identical across surfaces. Rendered for every visitor — the underlying
   AniList data is public; logged-in users get per-card Manage Entry
   hand-off via ConfigUid the same way Continue Watching does. *@
@if (Model.PopularThisSeason.Count > 0)
{
    var currentSeasonHref = $"/discover?list=seasonal&season={Uri.EscapeDataString(CurrentSeasonLabel())}";
    <section class="dashboard-section">
        <div class="dashboard-section-header">
            <h2 class="dashboard-section-title">Most Popular this Season</h2>
            <a class="dashboard-section-link" href="@currentSeasonHref">
                <span>View all</span>
                <svg class="dashboard-section-link-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <line x1="5" y1="12" x2="19" y2="12"></line>
                    <polyline points="12 5 19 12 12 19"></polyline>
                </svg>
            </a>
        </div>
        @await Html.PartialAsync("_PosterGrid", new AnimeList.Models.PosterGridViewModel
        {
            Items = Model.PopularThisSeason,
            ConfigUid = Model.ConfigUid,
            Variant = "scroll",
        })
    </section>
}

@if (Model.MostAnticipated.Count > 0)
{
    var nextSeasonHref = $"/discover?list=seasonal&season={Uri.EscapeDataString(NextSeasonLabel())}";
    <section class="dashboard-section">
        <div class="dashboard-section-header">
            <h2 class="dashboard-section-title">Most Anticipated</h2>
            <a class="dashboard-section-link" href="@nextSeasonHref">
                <span>View all</span>
                <svg class="dashboard-section-link-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <line x1="5" y1="12" x2="19" y2="12"></line>
                    <polyline points="12 5 19 12 12 19"></polyline>
                </svg>
            </a>
        </div>
        @await Html.PartialAsync("_PosterGrid", new AnimeList.Models.PosterGridViewModel
        {
            Items = Model.MostAnticipated,
            ConfigUid = Model.ConfigUid,
            Variant = "scroll",
        })
    </section>
}

@* Stats strip: two big counts (Watching / Completed) plus a top-genres chip
   row. Only renders for logged-in non-anonymous users with at least one
   completed entry — without that, the genre breakdown would be empty and
   the strip would feel like a placeholder. v1 will add Hours Watched + Mean
   Score once the per-service queries surface episode counts and per-entry
   scores; v0 sticks to what's already in the existing list-catalog response. *@
@if (isLoggedIn && !anonymousUser && Model.HasStats)
{
    <section class="dashboard-section stats-section" data-stats-section>
        @{
            // Stats come from AniList's User.statistics GraphQL regardless of
            // which provider the user picked as their primary — that's where
            // the dashboard sources count + mean + minutesWatched from.
            // ContributingServices[0] is the actual source service (always
            // "Anilist" today; the list shape leaves room for a future
            // multi-source aggregation), so use it instead of the primary's
            // service label to keep the attribution honest.
            var statsSourceLabel = Model.ContributingServices.Count > 0
                ? Model.ContributingServices[0]
                : "Anilist";
            // "Anilist" → "AniList" for display, matching the service's own
            // branding. Other service names already display naturally.
            if (string.Equals(statsSourceLabel, "Anilist", StringComparison.OrdinalIgnoreCase))
                statsSourceLabel = "AniList";
            var statsAttribution = $"via {statsSourceLabel}";
        }
        <div class="dashboard-section-header">
            <h2 class="dashboard-section-title">Your stats</h2>
            <span class="dashboard-section-actions">
                <span class="dashboard-section-link-muted">@statsAttribution</span>
                @* Info popover. AniList re-aggregates User.statistics on
                   its own schedule (typically 24-48 h) and exposes no
                   public mutation to force a recompute, so the popover
                   tells users to click "Update Stats" on the AniList
                   settings page and then come back and hit our "refresh
                   your stats" link, which drops the localStorage cache
                   and re-fetches /Home/AnilistStats. Click-only — no
                   :hover trigger so touch and desktop both open the same
                   way (mobile tap-then-tap-link became unreliable when
                   :hover stuck the popover open on the first tap). *@
                <span class="dashboard-stats-info">
                    <button class="dashboard-stats-info-btn"
                            type="button"
                            aria-label="About these stats"
                            aria-expanded="false"
                            aria-controls="dashboardStatsInfoTooltip"
                            data-stats-info-toggle>
                        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <circle cx="12" cy="12" r="10"></circle>
                            <line x1="12" y1="16" x2="12" y2="12"></line>
                            <line x1="12" y1="8" x2="12.01" y2="8"></line>
                        </svg>
                    </button>
                    <span id="dashboardStatsInfoTooltip" class="dashboard-stats-info-tooltip">
                        AniList recomputes your stats on its own schedule
                        (typically every 24-48 hours). To force an
                        immediate refresh, click "Update Stats" on
                        <a href="https://anilist.co/settings/lists" target="_blank" rel="noopener noreferrer">AniList's list settings</a>
                        and then
                        <a href="#" data-stats-refresh-link>refresh your stats</a>.
                    </span>
                </span>
            </span>
        </div>
        @* 4-cell stats strip — values fill in from JS (localStorage cache
           or /Home/AnilistStats fetch). Placeholders render as "—" so a
           cold browser sees the layout immediately; manage-entry-modal.js
           also writes through data-stat="watching" / -"completed" / -"hours"
           after a save so the panel stays in sync without a reload. The
           Hours / Mean cells start hidden — the fetch shows them when the
           value comes back > 0 / non-null. *@
        <div class="stats-strip">
            <div class="stats-cell" data-stat="watching">
                <span class="stats-icon stats-icon-blue">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="2" y="7" width="20" height="15" rx="2" ry="2"></rect>
                        <polyline points="17 2 12 7 7 2"></polyline>
                    </svg>
                </span>
                <div class="stats-number">—</div>
                <div class="stats-label">Watching</div>
            </div>
            <div class="stats-cell" data-stat="completed">
                <span class="stats-icon stats-icon-green">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                        <polyline points="22 4 12 14.01 9 11.01"></polyline>
                    </svg>
                </span>
                <div class="stats-number">—</div>
                <div class="stats-label">Completed</div>
            </div>
            <div class="stats-cell" data-stat="hours" hidden>
                <span class="stats-icon stats-icon-amber">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"></circle>
                        <polyline points="12 6 12 12 16 14"></polyline>
                    </svg>
                </span>
                <div class="stats-number">—</div>
                <div class="stats-label">Hours</div>
            </div>
            <div class="stats-cell" data-stat="mean" hidden>
                <span class="stats-icon stats-icon-purple">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
                    </svg>
                </span>
                <div class="stats-number">—</div>
                <div class="stats-label">Mean</div>
            </div>
        </div>
    </section>
    @* Click-to-toggle behaviour for the stats info popover plus the
       localStorage-cached stats fetch. Both kept tiny + inline since the
       widget only mounts under the HasStats branch. *@
    <script>
        (function () {
            var section = document.querySelector('[data-stats-section]');
            if (!section) return;

            // ── Popover open/close (click-only, both desktop + touch) ──
            var wrap = section.querySelector('.dashboard-stats-info');
            var btn = wrap && wrap.querySelector('[data-stats-info-toggle]');
            function closePopover() {
                if (!wrap) return;
                wrap.classList.remove('is-open');
                if (btn) btn.setAttribute('aria-expanded', 'false');
            }
            if (btn) {
                btn.addEventListener('click', function (e) {
                    e.stopPropagation();
                    var isOpen = wrap.classList.toggle('is-open');
                    btn.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
                });
            }
            if (wrap) {
                // Close on inner-link click so the popover doesn't
                // linger across new-tab navigation / bfcache restores.
                // The "refresh your stats" link is handled separately
                // below (it preventDefault's, so this still fires).
                wrap.addEventListener('click', function (e) {
                    if (e.target.closest('a')) closePopover();
                });
            }
            document.addEventListener('click', function (e) {
                if (wrap && !wrap.contains(e.target)) closePopover();
            });
            document.addEventListener('keydown', function (e) {
                if (e.key === 'Escape' && wrap && wrap.classList.contains('is-open')) {
                    closePopover();
                    if (btn) btn.focus();
                }
            });

            // ── localStorage-cached stats fetch ──
            // 24 h TTL mirrors the typical AniList recompute cadence;
            // shorter than the previous 48 h server cache so a user who
            // updates stats on AniList and forgets about us picks up the
            // new numbers within a day. Cache lives in the browser, not
            // our server — one fetch per user per day per device rather
            // than per dashboard render.
            var CACHE_KEY = 'anisync.anilistStats.v1';
            var TTL_MS = 24 * 60 * 60 * 1000;
            function readCache() {
                try {
                    var raw = localStorage.getItem(CACHE_KEY);
                    if (!raw) return null;
                    var obj = JSON.parse(raw);
                    if (!obj || typeof obj.ts !== 'number' || (Date.now() - obj.ts) > TTL_MS) return null;
                    return obj.data || null;
                } catch (_) { return null; }
            }
            function writeCache(data) {
                try { localStorage.setItem(CACHE_KEY, JSON.stringify({ ts: Date.now(), data: data })); }
                catch (_) { /* quota / private mode — ignore */ }
            }
            function clearCache() {
                try { localStorage.removeItem(CACHE_KEY); } catch (_) {}
            }

            function setCell(stat, value, formatter) {
                var cell = section.querySelector('[data-stat="' + stat + '"]');
                if (!cell) return;
                var numEl = cell.querySelector('.stats-number');
                var hasValue = value != null && value !== 0;
                // Hours / Mean cells are hidden by default and only
                // show when the value is actually positive — matches
                // the old server-rendered conditional gates.
                if (stat === 'hours' || stat === 'mean') {
                    cell.hidden = !hasValue;
                }
                if (numEl) numEl.textContent = hasValue ? formatter(value) : '—';
            }
            function render(stats) {
                if (!stats) {
                    // Null payload (e.g. AniList token revoked) — keep
                    // placeholders, don't write a junk cache entry.
                    return;
                }
                // Property names are camelCase: System.Text.Json's default
                // PropertyNamingPolicy is CamelCase under ASP.NET Core's
                // AddControllersWithViews configuration.
                setCell('watching', stats.watching, function (v) { return v.toLocaleString(); });
                setCell('completed', stats.completed, function (v) { return v.toLocaleString(); });
                setCell('hours', stats.totalHoursWatched, function (v) { return v.toLocaleString(); });
                setCell('mean', stats.meanScore, function (v) { return Number(v).toFixed(1); });
            }
            async function fetchAndRender() {
                try {
                    var resp = await fetch('/Home/AnilistStats', {
                        credentials: 'same-origin',
                        skipLoader: true,
                    });
                    if (!resp.ok) return;
                    var data = await resp.json();
                    if (!data || !data.success) return;
                    writeCache(data.stats);
                    render(data.stats);
                } catch (_) { /* network blip — placeholders stay */ }
            }

            var cached = readCache();
            if (cached) {
                render(cached);
            } else {
                fetchAndRender();
            }

            // "refresh your stats" link inside the popover — drop the
            // localStorage entry and pull fresh numbers. Used after the
            // user has clicked "Update Stats" on AniList itself.
            var refreshLink = section.querySelector('[data-stats-refresh-link]');
            if (refreshLink) {
                refreshLink.addEventListener('click', function (e) {
                    e.preventDefault();
                    clearCache();
                    fetchAndRender();
                });
            }
        })();
    </script>
}

@* Continue Watching: a small slice of the user's Currently Watching list,
   fetched client-side from /Home/ContinueWatchingData (a rendered
   _PosterGrid partial) and cached in localStorage for 10 minutes. The
   section's outer skeleton always renders for logged-in non-anonymous
   users and starts [hidden]; the JS un-hides it once the HTML loads. *@
@if (isLoggedIn && !anonymousUser)
{
    <section class="dashboard-section" data-continue-watching-section hidden>
        <div class="dashboard-section-header">
            <h2 class="dashboard-section-title">Continue watching</h2>
            <a class="dashboard-section-link" href="/library?list=current">
                <span>View all</span>
                <svg class="dashboard-section-link-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <line x1="5" y1="12" x2="19" y2="12"></line>
                    <polyline points="12 5 19 12 12 19"></polyline>
                </svg>
            </a>
        </div>
        <div data-continue-watching-container></div>
    </section>
    <script>
        (function () {
            var section = document.querySelector('[data-continue-watching-section]');
            if (!section) return;
            var container = section.querySelector('[data-continue-watching-container]');
            if (!container) return;

            // 10-minute TTL mirrors the prior server-side UserListCache:
            // long enough for a Home → Library → Home cycle to be free,
            // short enough that cross-channel writes (scrobble webhook
            // from another device, an edit on AniList's site directly)
            // can't sit stale forever. In-app writes drop the key
            // explicitly via invalidateContinueWatchingCache() in
            // wwwroot/js/manage-entry-modal.js.
            var KEY = 'anisync.continueWatching.v1';
            var TTL_MS = 10 * 60 * 1000;

            function readCache() {
                try {
                    var raw = localStorage.getItem(KEY);
                    if (!raw) return null;
                    var obj = JSON.parse(raw);
                    if (!obj || typeof obj.ts !== 'number' || (Date.now() - obj.ts) > TTL_MS) return null;
                    return obj.html;
                } catch (_) { return null; }
            }
            function writeCache(html) {
                try { localStorage.setItem(KEY, JSON.stringify({ ts: Date.now(), html: html })); }
                catch (_) { /* quota / private mode — best-effort */ }
            }

            function paint(html) {
                if (!html || !html.trim()) {
                    container.replaceChildren();
                    section.hidden = true;
                    return;
                }
                // Server-rendered partial; Razor escapes all user-controlled
                // text. innerHTML is safe here and lets the same markup the
                // other shelves use (Views/Shared/_PosterGrid.cshtml) drop
                // straight in without a parallel JS card builder to keep
                // in sync.
                container.innerHTML = html;
                section.hidden = false;
            }

            async function fetchAndPaint() {
                try {
                    var resp = await fetch('/Home/ContinueWatchingData', {
                        credentials: 'same-origin',
                        skipLoader: true,
                    });
                    if (!resp.ok) return;
                    var html = await resp.text();
                    writeCache(html);
                    paint(html);
                } catch (_) { /* network blip — leave the section hidden */ }
            }

            var cached = readCache();
            if (cached != null) {
                paint(cached);
            } else {
                fetchAndPaint();
            }
        })();
    </script>
}

@* Browse By: secondary discovery surfaces. Replaces the previous three nav
   tiles now that the layout's bottom-nav + hamburger drawer cover primary
   navigation (Home / Library / Discover / Configure) — keeping nav tiles
   here too would just duplicate. Four browse paths: Seasons, Genres,
   Studios, Tags — all functional, all under /discover. *@
<section class="dashboard-section">
    <div class="dashboard-section-header">
        <h2 class="dashboard-section-title">Browse By</h2>
        <span class="dashboard-section-link-muted">Find your next favourite</span>
    </div>
    <div class="browse-grid">
        <a class="browse-tile" href="/discover?list=seasonal">
            <span class="browse-tile-icon browse-tile-icon-blue">
                <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                    <line x1="16" y1="2" x2="16" y2="6"></line>
                    <line x1="8" y1="2" x2="8" y2="6"></line>
                    <line x1="3" y1="10" x2="21" y2="10"></line>
                </svg>
            </span>
            <div class="browse-tile-body">
                <h3 class="browse-tile-title">Seasons</h3>
                <p class="browse-tile-text">Browse by release season</p>
            </div>
        </a>

        <a class="browse-tile" href="/discover">
            <span class="browse-tile-icon browse-tile-icon-green">
                <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"></circle>
                    <polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"></polygon>
                </svg>
            </span>
            <div class="browse-tile-body">
                <h3 class="browse-tile-title">Genres</h3>
                <p class="browse-tile-text">Find anime by genre</p>
            </div>
        </a>

