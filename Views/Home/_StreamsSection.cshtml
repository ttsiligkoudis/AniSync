@model AnimeList.Models.ConfigureViewModel
@using AnimeList.Services
@{
    // isStremio = true when this partial renders on /stremio (toggles
    // affect the Stremio addon stream surface). false on /advanced
    // (where the same external-services toggle still applies but the
    // Manage Entry stream — a Stremio-only affordance — is hidden so
    // /advanced doesn't show a setting it can't change anywhere else
    // for the user reading that page).
    var isStremio = ViewData["isStremio"] as bool? ?? false;
    var cfg = Model.Configuration ?? new AnimeList.Models.Configuration();
}

@*
    Shared Streams settings card. Mounted by Stremio.cshtml and
    Advanced.cshtml so both surfaces present the same affordances for
    everything that influences the source picker on each /watch page
    plus the Manage Entry quick-edit Stream the Stremio addon emits.
*@
<section class="section-card">
    <span class="section-title">Streams</span>
    <p class="section-description">
        @if (isStremio)
        {
            <text>Choose what AniSync attaches to each episode in Stremio.</text>
        }
        else
        {
            <text>Stream sources surfaced on the in-app episode picker.</text>
        }
    </p>

    <div class="streams-grid">
        @if (!Model.AnonymousUser)
        {
            @if (isStremio)
            {
                <div class="stream-option">
                    <div class="option-name-wrap">
                        <span class="option-name">Manage Entry</span>
                        <span class="option-name-sub">Quick-edit progress, score and notes from Stremio.</span>
                    </div>
                    <label class="switch">
                        <input type="checkbox" id="showManageEntry" @(Model.ShowManageEntry ? "checked" : "") />
                        <span class="slider"></span>
                    </label>
                </div>
            }

            <div class="stream-option">
                <div class="option-name-wrap">
                    <span class="option-name">Auto-track progress</span>
                    <span class="option-name-sub">Update your list when you start an episode.</span>
                </div>
                <label class="switch">
                    <input type="checkbox" id="autoTrackProgress" @(Model.AutoTrackProgress ? "checked" : "") />
                    <span class="slider"></span>
                </label>
            </div>
        }

        <div class="stream-option">
            <div class="option-name-wrap">
                <span class="option-name">External services</span>
                <span class="option-name-sub">Crunchyroll, Netflix, HiDive, …</span>
            </div>
            <label class="switch">
                <input type="checkbox" id="showExternalStreams" @(cfg.showExternalStreams ? "checked" : "") />
                <span class="slider"></span>
            </label>
        </div>
    </div>

    @* Stream addons card. Each entry is a Stremio-compatible stream
       addon (Torrentio, MediaFusion, Comet, Jackettio, AIOStreams, …).
       The user pastes the addon's personal manifest URL — addon-specific
       config (Real-Debrid keys, indexer toggles, language filters) all
       live inside that URL, so AniSync stays out of the per-provider
       business. Hidden for anonymous installs entirely (no uid to
       persist against), and hidden on /stremio (isStremio=true) so the
       Stremio settings page stays focused on what the addon manifest
       exposes — stream-addon plumbing is a server-side concern that
       lives on /advanced. *@
    @if (!isStremio && !Model.AnonymousUser && !string.IsNullOrEmpty(Model.ConfigUid))
    {
        <p class="manifest-url-label" style="margin-top: 1.5rem;">Stream addons</p>

        @* Quick setup — the easy path. Pick a debrid service, paste the
           one API key it gives you, and AniSync builds + validates the
           scraper-addon manifest URLs for you (Torrentio, Comet) instead
           of making you walk each addon's own /configure page and paste
           the result back by hand. The "Get your API key" link jumps to
           the selected provider's token page. Anything the catalog can't
           build deterministically (e.g. MediaFusion, whose config is
           encrypted with the addon's own secret) still goes through the
           manual paste box below. *@
        <div class="debrid-setup" id="debridSetup">
            <div class="debrid-setup-row">
                <select id="debridProvider" class="debrid-select" aria-label="Debrid provider">
                    @foreach (var p in StreamAddonCatalog.Providers)
                    {
                        <option value="@p.Id" data-apikey-url="@p.ApiKeyUrl">@p.DisplayName</option>
                    }
                </select>
                <input id="debridApiKey" class="manifest-url-input" type="password"
                       placeholder="Paste your API key" autocomplete="off" spellcheck="false" />
            </div>
            <div class="debrid-setup-addons">
                <span class="debrid-setup-addons-label">Add:</span>
                @foreach (var a in StreamAddonCatalog.Addons)
                {
                    <label class="debrid-addon-check">
                        <input type="checkbox" class="debrid-addon-toggle" value="@a.Id" checked />
                        <span>@a.DisplayName</span>
                    </label>
                }
            </div>
            <div class="debrid-setup-actions">
                <a id="debridApiKeyLink" class="debrid-apikey-link" target="_blank" rel="noopener"
                   href="@StreamAddonCatalog.Providers[0].ApiKeyUrl">Get your API key ↗</a>
                <button id="debridAddBtn" class="btn-ghost btn-ghost-sm" type="button">Save</button>
            </div>
            <p id="debridSetupStatus" class="debrid-setup-status" role="status" aria-live="polite"></p>
        </div>

        <ul id="streamAddonList" class="stream-addon-list">
            @foreach (var addon in Model.StreamAddons)
            {
                // Standard Stremio convention is /manifest.json for the
                // addon descriptor and /configure for the HTML config
                // page that regenerates a new manifest URL. Swap the
                // suffix to give the user a one-click way back to the
                // addon's settings (Real-Debrid key rotation, indexer
                // toggles, language filters) without re-pasting the
                // URL by hand. Anything that doesn't end in
                // /manifest.json is left alone — link still works as a
                // fallback.
                var configureUrl = addon.Url?.Replace("/manifest.json", "/configure") ?? addon.Url;
                @* The drag handle on the left is the ONLY way to
                   initiate a reorder — pointer events bind to that
                   span (see _ConfigurePageScript). Row itself is not
                   draggable="true" because HTML5 drag doesn't fire on
                   touch and we want one code path that covers both
                   mouse + finger uniformly. *@
                <li class="stream-addon-row" data-url="@addon.Url">
                    <span class="stream-addon-drag-handle" aria-label="Drag to reorder" title="Drag to reorder">
                        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <line x1="3" y1="8" x2="21" y2="8"/>
                            <line x1="3" y1="16" x2="21" y2="16"/>
                        </svg>
                    </span>
                    <div class="stream-addon-meta">
                        <span class="stream-addon-name">@addon.Name</span>
                        <span class="stream-addon-url">@addon.Url</span>
                    </div>
                    <div class="stream-addon-actions">
                        <a class="stream-addon-icon-btn stream-addon-configure" href="@configureUrl" target="_blank" rel="noopener" aria-label="Configure" title="Configure">
                            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <circle cx="12" cy="12" r="3"/>
                                <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 1 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 1 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 1 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 1 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
                            </svg>
                        </a>
                        <button class="stream-addon-icon-btn stream-addon-copy" type="button" aria-label="Copy manifest URL" title="Copy manifest URL">
                            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                                <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
                            </svg>
                        </button>
                        <button class="stream-addon-icon-btn stream-addon-remove" type="button" aria-label="Remove" title="Remove">
                            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <polyline points="3 6 5 6 21 6"/>
                                <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
                                <line x1="10" y1="11" x2="10" y2="17"/>
                                <line x1="14" y1="11" x2="14" y2="17"/>
                            </svg>
                        </button>
                    </div>
                </li>
            }
        </ul>
        <p class="manifest-url-label">Or paste a manifest URL</p>
        <div class="manifest-url-row">
            <input id="streamAddonInput" class="manifest-url-input" type="text"
                   placeholder="https://….example.com/…/manifest.json" autocomplete="off" />
            <button id="streamAddonAddBtn" class="btn-ghost btn-ghost-sm" type="button" style="white-space: nowrap;">Add</button>
        </div>
        <p class="option-name-sub" style="margin-top: 0.5rem;">
            Already have a configured manifest URL? Paste any Stremio
            stream-addon manifest — Torrentio
            (<a href="https://torrentio.strem.fun" target="_blank" rel="noopener">torrentio.strem.fun</a>),
            MediaFusion (<a href="https://mediafusion.elfhosted.com" target="_blank" rel="noopener">mediafusion.elfhosted.com</a>),
            Comet (<a href="https://comet.feels.legal/configure" target="_blank" rel="noopener">comet.feels.legal</a>),
            Jackettio, or
            <a href="https://aiostreams.elfhosted.com" target="_blank" rel="noopener">AIOStreams</a>
            (one URL that bundles many addons). Episode lookups fan out across every entry in
            this list, with duplicates merged by torrent hash.
        </p>
    }
</section>
