@*
    Shared "Preferences" card. Both /configure and /stremio render this
    partial with the same ConfigureViewModel so the toggle set stays in
    sync — any pref added here surfaces on every page that hosts the
    section without per-page lists drifting out of step. Saving is owned
    by the floating save bar (_FloatingSaveBar.cshtml): the shared
    _ConfigurePageScript reads every toggle's checkbox via bitFor() so
    one Save click on either page persists the full pref set.

    Per-toggle visibility:
      - hideUnreleasedWatching is hidden for anonymous users (they have
        no library to filter against, so the toggle would be inert);
      - groupSeasons and showAdultContent are available to everyone so
        the addon catalogs anonymous users install respect them too.

    DOM ids must match the selectors readFlags() in _ConfigurePageScript
    already drives.
*@
@model ConfigureViewModel

@{
    var prefs = new List<(string Id, string Label, string Description, bool Checked)>();
    if (!Model.AnonymousUser)
    {
        prefs.Add((
            "hideUnreleasedWatching",
            "Hide unaired from Watching",
            "When on, entries that haven't aired yet are filtered out of your Currently Watching list (site + Stremio). Off shows everything in the list as-is.",
            Model.HideUnreleasedWatching));
    }
    prefs.Add((
        "groupSeasons",
        "Group anime seasons",
        "Collapse multi-cour franchises into a single card across the site and the Stremio addon. Off shows every cour separately.",
        Model.GroupSeasons));
    prefs.Add((
        "showAdultContent",
        "Show 18+ content",
        "Off (default) hides hentai / R18 entries from Discover, Library, and the Stremio addon catalogs. Direct anime URLs still work either way — this only affects what shows up in the grid.",
        Model.ShowAdultContent));
}

@if (prefs.Count > 0)
{
    <section class="section-card">
        <span class="section-title">Preferences</span>
        <p class="section-description">
            General display preferences that apply across the site and the Stremio addon.
        </p>

        <div class="streams-grid">
            @foreach (var pref in prefs)
            {
                <div class="stream-option">
                    <div class="option-name-wrap">
                        <span class="option-name">@pref.Label</span>
                        <span class="option-name-sub">@pref.Description</span>
                    </div>
                    <label class="switch">
                        <input type="checkbox" id="@pref.Id" @(pref.Checked ? "checked" : "") />
                        <span class="slider"></span>
                    </label>
                </div>
            }
        </div>
    </section>
}
