@*
    Shared "Preferences" card used by both /configure and /stremio. The caller
    passes a list of toggle descriptors; this partial renders the section-card
    chrome with one toggle row per descriptor. Saving is owned by the floating
    save bar (_FloatingSaveBar.cshtml) — any flag-bearing toggle in the page
    flips it on, and one Save click persists every toggle's state in one call.
    When the descriptor list is empty (anonymous user / nothing to surface
    on this view) the whole card is omitted so the page doesn't get an
    empty section header. DOM ids on each <input> must match the selectors
    readFlags() in _ConfigurePageScript already drives.
*@
@model IReadOnlyList<(string Id, string Label, string Description, bool Checked)>

@if (Model != null && Model.Count > 0)
{
    <section class="section-card">
        <span class="section-title">Preferences</span>
        <p class="section-description">
            General display preferences that apply across the site and the Stremio addon.
        </p>

        <div class="streams-grid">
            @foreach (var pref in Model)
            {
                <div class="stream-option">
                    <div class="option-name-wrap">
                        <span class="option-name">@pref.Label</span>
                        <span class="option-name-sub">@pref.Description</span>
                    </div>
                    <label class="switch">
                        <input type="checkbox" id="@pref.Id" @(pref.Checked ? "checked" : "") />
                        <span class="slider"></span>
                    </label>
                </div>
            }
        </div>
    </section>
}
