@*
    Shared "Preferences" card. Both /configure and /stremio render this
    partial with the same ConfigureViewModel so the toggle set stays in
    sync — any pref added here surfaces on every page that hosts the
    section without per-page lists drifting out of step. Saving is owned
    by the floating save bar (_FloatingSaveBar.cshtml): the shared
    _ConfigurePageScript reads every toggle's checkbox via bitFor() so
    one Save click on either page persists the full pref set.

    Visibility:
      - Every toggle here is anime-only, so the whole card only renders when
        anime is one of the user's selected media types (Model.EnabledMediaTypes);
        with anime off there are no settings to show and the card is hidden.
      - hideUnreleasedWatching is additionally hidden for anonymous users (they
        have no library to filter against, so the toggle would be inert).

    DOM ids must match the selectors readFlags() in _ConfigurePageScript
    already drives. When a toggle isn't rendered (anime off), bitFor() falls
    back to its stored value, so Save never clobbers a hidden setting.
*@
@model ConfigureViewModel

@{
    // Every preference here only affects anime (Currently-Watching filtering,
    // multi-cour grouping, R18 catalog hiding), so they only render when anime
    // is one of the user's selected media types. With anime off, `prefs` stays
    // empty and the whole card is hidden by the @if below. A future non-anime
    // pref would just be added outside this gate.
    var animeEnabled = Model.EnabledMediaTypes.Contains(MetaType.anime);
    var prefs = new List<(string Id, string Label, string Description, bool Checked)>();
    if (animeEnabled)
    {
        if (!Model.AnonymousUser)
        {
            prefs.Add((
                "hideUnreleasedWatching",
                "Hide unaired anime from Watching",
                "When on, entries that haven't aired yet are filtered out of your Currently Watching list (site + Stremio). Off shows everything in the list as-is.",
                Model.HideUnreleasedWatching));
        }
        prefs.Add((
            "groupSeasons",
            "Group anime seasons",
            "Collapse multi-cour franchises into a single card across the site and the Stremio addon. Off shows every cour separately.",
            Model.GroupSeasons));
        prefs.Add((
            "showAdultContent",
            "Show 18+ anime content",
            "Off (default) hides hentai / R18 entries from Discover, Library, and the Stremio addon catalogs. Direct anime URLs still work either way — this only affects what shows up in the grid.",
            Model.ShowAdultContent));
    }
    // Applies to anime AND movies/series Discover, so it isn't gated on the
    // anime-only block above — any logged-in user gets it. (Video completed
    // filtering reads the user's Trakt watched history.)
    if (!Model.AnonymousUser)
    {
        prefs.Add((
            "hideCompletedDiscover",
            "Hide completed from Discover",
            "When on, titles you've already Completed are filtered out of every Discover catalog — anime (Trending / Popular / Seasonal / Airing) and movies/series alike. Off shows them like everyone else. Doesn't affect the Stremio addon.",
            Model.HideCompletedFromDiscover));
    }
}

@if (prefs.Count > 0)
{
    <section class="section-card">
        <span class="section-title">Preferences</span>
        <p class="section-description">
            General display preferences that apply across the site and the Stremio addon.
        </p>

        <div class="streams-grid">
            @foreach (var pref in prefs)
            {
                <div class="stream-option">
                    <div class="option-name-wrap">
                        <span class="option-name">@pref.Label</span>
                        <span class="option-name-sub">@pref.Description</span>
                    </div>
                    <label class="switch">
                        <input type="checkbox" id="@pref.Id" @(pref.Checked ? "checked" : "") />
                        <span class="slider"></span>
                    </label>
                </div>
            }
        </div>
    </section>
}
