@model ConfigureViewModel
@*
    Shared script block for both /configure and /stremio. Razor interpolation
    bakes the per-request session data (configUid, revision, scrobble token,
    flag flags) into the JS at server-render time. The script targets DOM ids
    via jQuery; selectors that don't match on a given page (e.g. catalogCheck
    inputs aren't on /configure post-split) silently no-op, so the same
    script works for both pages without per-page subsetting.
*@
<script>
    // Numeric service selector: 0 = Kitsu, 1 = AniList, 2 = MyAnimeList. Mirrors the
    // AnimeService enum on the server.
    var selectedService = @Model.ServiceIndex;
    // Post-login the picker only shows the primary + healthy linked accounts, so any
    // non-active pill click is unambiguously a swap-primary intent.
    var isLoggedInState = @(Model.IsLoggedIn ? "true" : "false");
    var loginBaseUrl = '@Url.Action("Login", "Auth")';
    // Origin (scheme://host) of the addon — used to build the manifest URL and the
    // stremio:// deep-link. These never include flags; flags live in the URL path bytes.
    var addonOrigin = '@(Context.Request.Scheme)://@(Context.Request.Host)';
    var stremioWebPrefix = 'https://web.stremio.com/#/addons?addon=';

    // Authenticated users have a 16-byte UID (base64url) pointing at a row in the
    // server-side config store; anonymous users still embed their (tiny) token data inline.
    // Exactly one of the two strings is non-empty per request.
    var configUid = '@(Model.ConfigUid ?? "")';
    var tokenDataStr = '@(Model.TokenData ?? "")';
    // Revision counter, appended to the install URL as 4 trailing bytes so the URL changes
    // after every Save. Stremio caches manifests aggressively (even past force-restart) and
    // a stable URL means it never refetches; bumping the URL forces a fresh install.
    var configRevision = @Model.ConfigRevision;
    // Per-user scrobble bearer token. Empty for anonymous installs (no Home Server Sync UI).
    var scrobbleToken = '@(Model.ScrobbleToken ?? "")';

    // Server-rendered initial flag bytes. We use these as a baseline when
    // readFlags() runs on a page that doesn't expose every toggle (e.g.
    // /configure shows only Group-anime-seasons; saving without preserving
    // the catalog/stream bits would otherwise zero them out, losing what
    // the user picked on /stremio). For each bit, readFlags() reads the
    // DOM checkbox if its input exists, otherwise falls back to the
    // corresponding bit from these initial values.
    @{
        var (initF1, initF2, initF3) = PackBinaryFlags(Model.Configuration);
    }
    var initialFlags1 = @initF1;
    var initialFlags2 = @initF2;
    var initialFlags3 = @initF3;

    function base64UrlToBytes(str) {
        if (!str) return new Uint8Array(0);
        var base64 = str.replace(/-/g, '+').replace(/_/g, '/');
        while (base64.length % 4) base64 += '=';
        var binary = atob(base64);
        var bytes = new Uint8Array(binary.length);
        for (var i = 0; i < binary.length; i++) bytes[i] = binary.charCodeAt(i);
        return bytes;
    }

    function bytesToBase64Url(bytes) {
        var binary = '';
        for (var i = 0; i < bytes.length; i++) binary += String.fromCharCode(bytes[i]);
        return btoa(binary).replace(/\+/g, '-').replace(/\//g, '_').replace(/=+$/g, '');
    }

    var uidBytes = base64UrlToBytes(configUid);
    var tokenBytes = base64UrlToBytes(tokenDataStr);

    // Read a single bit. If the input exists in the DOM, use its checked state;
    // otherwise preserve the bit from the server-rendered initial value so we
    // never zero out a flag just because its checkbox isn't on the current page.
    function bitFor(selector, initial, mask) {
        var $el = $(selector);
        if ($el.length === 0) return initial & mask;
        return $el.is(':checked') ? mask : 0;
    }
    // Same shape for inverse bits — stored 1 = "off", so "checked → 0, unchecked → mask".
    function inverseBitFor(selector, initial, mask) {
        var $el = $(selector);
        if ($el.length === 0) return initial & mask;
        return $el.is(':checked') ? 0 : mask;
    }

    function readFlags() {
        var flags1 = 0;
        flags1 |= bitFor('#showCurrent',           initialFlags1, 0x01);
        flags1 |= bitFor('#showCompleted',         initialFlags1, 0x02);
        flags1 |= bitFor('#showTrending',          initialFlags1, 0x04);
        flags1 |= bitFor('#showSeasonal',          initialFlags1, 0x08);
        flags1 |= bitFor('#discoverOnlyCurrent',   initialFlags1, 0x10);
        flags1 |= bitFor('#discoverOnlyCompleted', initialFlags1, 0x20);
        flags1 |= bitFor('#discoverOnlyTrending',  initialFlags1, 0x40);
        flags1 |= bitFor('#discoverOnlySeasonal',  initialFlags1, 0x80);

        var flags2 = 0;
        flags2 |= bitFor('#showPlanning',           initialFlags2, 0x01);
        flags2 |= bitFor('#showPaused',             initialFlags2, 0x02);
        flags2 |= bitFor('#showDropped',            initialFlags2, 0x04);
        flags2 |= bitFor('#showRepeating',          initialFlags2, 0x08);
        flags2 |= bitFor('#discoverOnlyPlanning',   initialFlags2, 0x10);
        flags2 |= bitFor('#discoverOnlyPaused',     initialFlags2, 0x20);
        flags2 |= bitFor('#discoverOnlyDropped',    initialFlags2, 0x40);
        flags2 |= bitFor('#discoverOnlyRepeating',  initialFlags2, 0x80);

        var flags3 = 0;
        flags3 |= bitFor('#showAiring',             initialFlags3, 0x01);
        flags3 |= bitFor('#showExternalStreams',    initialFlags3, 0x02);
        flags3 |= inverseBitFor('#showManageEntry', initialFlags3, 0x04);
        flags3 |= inverseBitFor('#autoTrackProgress', initialFlags3, 0x08);
        flags3 |= bitFor('#discoverOnlyAiring',     initialFlags3, 0x10);
        // enableSeasonGrouping is positive-sense (1 = grouping ON, 0 = OFF default),
        // so the bit follows the checkbox state directly — no inversion.
        flags3 |= bitFor('#groupSeasons',           initialFlags3, 0x20);

        return { flags1: flags1, flags2: flags2, flags3: flags3 };
    }

    function buildManifestPath() {
        var f = readFlags();
        var payload;
        if (uidBytes.length > 0) {
            // Binary v5: [0x05][16-byte UID][4-byte revision big-endian]. Revision bytes
            // make the URL different after every save so Stremio re-fetches the manifest.
            payload = new Uint8Array(1 + uidBytes.length + 4);
            payload[0] = 0x05;
            payload.set(uidBytes, 1);
            var rev = (configRevision >>> 0);
            var revOffset = 1 + uidBytes.length;
            payload[revOffset]     = (rev >>> 24) & 0xff;
            payload[revOffset + 1] = (rev >>> 16) & 0xff;
            payload[revOffset + 2] = (rev >>> 8)  & 0xff;
            payload[revOffset + 3] = rev          & 0xff;
        } else {
            // Binary v3 anonymous fallback: [0x03][flags1][flags2][flags3][gzip token bytes]
            payload = new Uint8Array(4 + tokenBytes.length);
            payload[0] = 0x03;
            payload[1] = f.flags1;
            payload[2] = f.flags2;
            payload[3] = f.flags3;
            payload.set(tokenBytes, 4);
        }
        return '/' + bytesToBase64Url(payload) + '/manifest.json';
    }

    function refreshUrls() {
        var path = buildManifestPath();
        var manifestHttps = addonOrigin + path;
        // stremio:// deep link uses the host (not scheme) so apps know to open natively.
        var stremioDeep = 'stremio://' + addonOrigin.replace(/^https?:\/\//, '') + path;
        var stremioWeb = stremioWebPrefix + manifestHttps;

        $('#stremioUrl').attr('href', stremioDeep);
        $('#stremioWebUrl').attr('href', stremioWeb);
        $('#manifestUrlInput').val(manifestHttps);
    }

    refreshUrls();

    // Catalog + stream toggles — recompute the manifest URL whenever flags change. (For
    // v5 the path bytes don't actually change since flags live in DB, but we still call
    // refreshUrls() to keep the path in sync after a SaveConfig response bumps revision.)
    $('.catalogCheck, .discoverCheck, #showExternalStreams, #showManageEntry, #autoTrackProgress, #groupSeasons')
        .on('change', refreshUrls);

    // When an enable checkbox is toggled, enable/disable its discover-only sibling
    $('.catalogCheck').on('change', function () {
        var $discoverLabel = $(this).parent().next();
        var $discoverSwitch = $discoverLabel.find('.discoverCheck');
        var isEnabled = $(this).is(':checked');
        $discoverSwitch.prop('disabled', !isEnabled);
        $discoverLabel.toggleClass('switch-disabled', !isEnabled);
        if (!isEnabled) $discoverSwitch.prop('checked', false);
    });

    // ── Select-all switches ───────────────────────────────────────────
    // Master "Enable" toggle: flips every catalog row to its state. trigger('change')
    // so the per-row sibling-disable handler runs, refreshUrls fires, etc.
    $('#enableAll').on('change', function () {
        var checked = $(this).is(':checked');
        $('.catalogCheck').prop('checked', checked).trigger('change');
    });

    // Master "Discover Only" toggle: only flips rows whose Enable is on (the rest are
    // visually disabled and stay unchecked).
    $('#discoverOnlyAll').on('change', function () {
        var checked = $(this).is(':checked');
        $('.catalogCheck').each(function () {
            if (!$(this).is(':checked')) return;
            var $disc = $(this).parent().next().find('.discoverCheck');
            $disc.prop('checked', checked).trigger('change');
        });
    });

    // Mirror aggregate state on the master toggles: master ON only when *every* row in
    // its column is on. Use prop (no trigger) so we don't recurse.
    function refreshAllToggles() {
        var enables = $('.catalogCheck');
        $('#enableAll').prop('checked', enables.length > 0 && enables.length === enables.filter(':checked').length);

        var discovers = $('.discoverCheck:not(:disabled)');
        $('#discoverOnlyAll').prop('checked', discovers.length > 0 && discovers.length === discovers.filter(':checked').length);
    }
    $('.catalogCheck, .discoverCheck').on('change', refreshAllToggles);
    refreshAllToggles();

    // ── Service picker ────────────────────────────────────────────────
    function serviceLabel(svc) {
        if (svc === 1) return 'AniList';
        if (svc === 2) return 'MyAnimeList';
        return 'Kitsu';
    }

    // Posts the SetPrimary swap and handles the collision-error case by offering a
    // second confirmation that retries with force=true. fetch lets us read the server's
    // 400 response body — a plain form-submit would just navigate to the error page.
    async function promotePrimary(svcEnum, label, force) {
        var params = new URLSearchParams();
        params.set('service', svcEnum);
        if (force) params.set('force', 'true');

        var resp = await fetch('/Auth/SetPrimary', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: params.toString(),
            redirect: 'follow',
        });

        if (resp.ok || resp.redirected) {
            window.location.href = resp.redirected ? resp.url : '/';
            return;
        }

        var errorText = (await resp.text()) || 'Unknown error.';
        // Collision surfaces as the "already the primary on another install" message —
        // offer the force path with a clear heads-up about what it sacrifices.
        if (!force && /already the primary on another/i.test(errorText)) {
            var msg = errorText
                + '\n\nThis usually means an old AniSync session for this account is still in our database. '
                + 'You can force the swap, which will remove that other install (its install URL will stop working in Stremio). '
                + 'Continue?';
            if (confirm(msg)) {
                await promotePrimary(svcEnum, label, true);
            }
            return;
        }

        alert(errorText);
    }

    $('#serviceToggle .label').on('click', function () {
        var $pill = $(this);

        if (isLoggedInState) {
            // Active pill = current primary, no-op. Any other rendered pill is a healthy
            // linked account — tap → confirm → POST /Auth/SetPrimary. The server rotates
            // the primary slot in place (UID preserved) and the page reloads.
            if ($pill.hasClass('active')) return;
            var svcEnum = $pill.attr('data-service-name');
            var label = serviceLabel(parseInt($pill.attr('data-service'), 10));
            if (!confirm('Switch your primary account to ' + label + '? Future writes will originate from this account first.')) return;

            promotePrimary(svcEnum, label, false);
            return;
        }

        var svc = parseInt($pill.attr('data-service'), 10);
        if (isNaN(svc)) return;
        selectedService = svc;
        $('#serviceToggle .label').removeClass('active');
        $pill.addClass('active');
        $('#loginServiceName').text(serviceLabel(svc));
        // Only the Kitsu password-grant flow needs the username/password fields visible.
        $('#kitsuCreds').toggle(svc === 0);
        updateLoginUrl();
    });

    $('#disconnectBtn').on('click', function () {
        window.location.href = '@Url.Action("Logout", "Auth")';
    });

    // ── Linked Accounts ───────────────────────────────────────────────
    // The Kitsu link row shows a button by default; clicking expands the inline
    // username/password form (Kitsu uses password-grant, no OAuth redirect).
    $('.linked-account-toggle').on('click', function () {
        var $row = $(this).closest('.linked-account-row');
        $row.find('.linked-kitsu-form').toggleClass('expanded');
    });

    // ── Full-sync (client-driven) ────────────────────────────────────
    // Server is stateless: we GET the entry list once, then loop POSTing
    // batches in a small worker pool and tracking progress here.
    // AbortController is the cancel mechanism — Cancel button or browser
    // close both stop the loop. Closing the page = the sync stops, no
    // zombie work continues server-side.
    var syncAbort = null;
    // Each batch processes sequentially server-side, so batch size sets
    // both the per-batch latency (-> Cancel responsiveness floor) and the
    // HTTP overhead amortisation. 5 is the sweet spot.
    var SYNC_BATCH_SIZE = 5;
    // Run two batches in flight at the same time. Inside each
    // FanOutSaveAsync the linked targets are already hit in parallel, so
    // 2 client-side workers + 2-3 linked providers means up to ~6
    // simultaneous upstream calls — borderline-safe given Kitsu ~5/s,
    // MAL ~2-3/s, and AniList's burst tolerance. Bumping to 3 starts
    // tripping MAL 429s in practice.
    var SYNC_PARALLEL = 2;

    function showSyncModal() {
        $('#syncModal').removeAttr('hidden').attr('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
    }

    function hideSyncModal() {
        $('#syncModal').attr('hidden', 'hidden').attr('aria-hidden', 'true');
        document.body.style.overflow = '';
    }

    function setSyncProgress(message, current, total) {
        var pct = total > 0 ? Math.min(100, Math.round((current / total) * 100)) : 0;
        $('#syncModalBarFill').css('width', pct + '%');
        $('#syncModalMessage').text(message);
    }

    // Format a progress message as a percentage rather than an entry count.
    // current/total still drive the bar fill via setSyncProgress; the text
    // just shows "Syncing 42%" instead of "Syncing 12 / 28" so the user
    // doesn't have to mentally divide.
    function syncPercent(current, total) {
        return total > 0 ? Math.min(100, Math.round((current / total) * 100)) : 0;
    }

    function setSyncCancelLabel(label) {
        $('#syncModalCancel').text(label);
    }

    async function startFullSync() {
        syncAbort = new AbortController();
        showSyncModal();
        setSyncProgress('Fetching primary library…', 0, 0);
        setSyncCancelLabel('Cancel');

        var completed = 0, failed = 0, processed = 0, total = 0;
        try {
            var resp = await fetch('/Auth/SyncEntries', { signal: syncAbort.signal });
            if (!resp.ok) throw new Error((await resp.text()) || 'Failed to fetch entries.');
            var body = await resp.json();
            var entries = body.entries || [];
            total = body.total || entries.length;
            // primaryTotal is the size of the primary's full library; total is just the
            // entries that actually need writing (the diff against linked secondaries).
            // The two diverge when most of the library is already in sync.
            var primaryTotal = body.primaryTotal != null ? body.primaryTotal : total;

            if (total === 0) {
                var doneMsg = primaryTotal === 0
                    ? 'Primary library is empty — nothing to sync.'
                    : 'All linked accounts already in sync — nothing to do.';
                setSyncProgress(doneMsg, 0, 0);
                setSyncCancelLabel('Close');
                return;
            }

            setSyncProgress('Syncing 0%', 0, total);

            // Pre-slice so workers just pull the next ready batch from a shared queue
            // — keeps the dispatch loop branch-free and the worker code small.
            var batches = [];
            for (var i = 0; i < entries.length; i += SYNC_BATCH_SIZE) {
                batches.push(entries.slice(i, i + SYNC_BATCH_SIZE));
            }

            // JS is single-threaded so cursor / counter increments don't race even
            // though SYNC_PARALLEL workers all touch them. The cooperative await
            // points are the only places another worker can run, and by that point
            // we've already committed our increment.
            var nextBatch = 0;

            async function syncWorker() {
                while (!syncAbort.signal.aborted) {
                    var idx = nextBatch++;
                    if (idx >= batches.length) return;
                    var slice = batches[idx];

                    try {
                        var r = await fetch('/Auth/SyncBatch', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ entries: slice }),
                            signal: syncAbort.signal,
                        });
                        if (!r.ok) {
                            // Server rejected the whole batch (e.g. session expired). Count
                            // every entry as failed but keep going — later batches might
                            // succeed if the cause was transient.
                            failed += slice.length;
                        } else {
                            var result = await r.json();
                            completed += result.completed || 0;
                            failed += result.failed || 0;
                        }
                    } catch (e) {
                        if (e.name === 'AbortError') return;
                        failed += slice.length;
                    }

                    processed = completed + failed;
                    setSyncProgress('Syncing ' + syncPercent(processed, total) + '%', processed, total);
                }
            }

            // Spin up the worker pool and wait for the queue to drain.
            var workers = [];
            for (var w = 0; w < SYNC_PARALLEL; w++) workers.push(syncWorker());
            await Promise.all(workers);

            if (syncAbort.signal.aborted) {
                setSyncProgress('Cancelled at ' + syncPercent(processed, total) + '%', processed, total);
            } else {
                var finalMsg = failed === 0
                    ? 'Done — 100% synced.'
                    : 'Done — ' + syncPercent(completed, total) + '% synced, ' + syncPercent(failed, total) + '% failed (see Fly logs).';
                setSyncProgress(finalMsg, processed, total);
            }
        } catch (e) {
            if (e.name !== 'AbortError') {
                setSyncProgress('Failed: ' + e.message, processed, total);
            } else {
                setSyncProgress('Cancelled at ' + syncPercent(processed, total) + '%', processed, total);
            }
        } finally {
            // Once the loop exits — done, cancelled, or errored — flip the action
            // button to Close so the user can dismiss the modal.
            setSyncCancelLabel('Close');
            syncAbort = null;
        }
    }

    $('#syncNowBtn').on('click', function () {
        if (!confirm('Backfill every entry from your primary library to all linked accounts? This can take a few minutes for large libraries — keep this tab open until it finishes.')) return;
        startFullSync();
    });

    $('#syncModalCancel').on('click', function () {
        // Mid-sync: abort fetches, mark cancellation. The loop notices on its next
        // iteration and falls through to the "Cancelled" message + Close label.
        if (syncAbort && !syncAbort.signal.aborted) {
            syncAbort.abort();
            return;
        }
        hideSyncModal();
    });

    // Backdrop click and Esc are intentionally NOT wired to dismiss — the user
    // explicitly asked for Cancel/Close to be the only way out, so a stray tap
    // outside the card can't accidentally tear down a sync mid-flight.

    // ── Copy manifest URL ─────────────────────────────────────────────
    $('#copyManifestBtn').on('click', async function () {
        var url = $('#manifestUrlInput').val();
        var $btn = $(this);
        var success = false;
        try {
            await navigator.clipboard.writeText(url);
            success = true;
        } catch {
            // Fallback for older browsers
            $('#manifestUrlInput').select();
            success = document.execCommand('copy');
        }
        $btn.toggleClass('copied', success);
        setTimeout(function () { $btn.removeClass('copied'); }, 1500);
    });

    // ── Save flags before launching Stremio ───────────────────────────
    // Persists current toggle state and bumps the revision so Stremio sees a different
    // URL — required because Stremio caches manifests for already-installed URLs and
    // wouldn't otherwise pick up flag changes.
    async function saveFlags() {
        if (!configUid) return;
        var f = readFlags();
        var resp = await fetch('/Home/SaveConfig', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ uid: configUid, flags1: f.flags1, flags2: f.flags2, flags3: f.flags3 }),
        });
        if (!resp.ok) throw new Error('Save failed: ' + resp.status);
        var data = await resp.json();
        if (typeof data.revision === 'number') {
            configRevision = data.revision;
            refreshUrls();
        }
    }

    // Both install buttons trigger a save first so the new URL reflects the latest flags.
    async function handleInstallClick(e) {
        if (!configUid) return; // anonymous (v3): URL already encodes flags
        e.preventDefault();
        try { await saveFlags(); } catch { /* let them try anyway */ }
        // Re-read the (possibly new) href after saveFlags bumped configRevision.
        var href = $(this).attr('href');
        if ($(this).attr('target') === '_blank') {
            window.open(href, '_blank', 'noopener');
        } else {
            window.location.href = href;
        }
    }
    $('#stremioUrl, #stremioWebUrl').on('click', handleInstallClick);

    // ── Save button (Configure page) ─────────────────────────────────
    // Explicit Save CTA on /configure — wraps the same saveFlags()
    // helper used by the install buttons, with a small status pill
    // for "Saved" / "Failed" feedback so users have an obvious
    // commit point for site preferences (currently just the
    // Group-anime-seasons toggle).
    $('#savePreferencesBtn').on('click', async function () {
        var $btn = $(this);
        var $status = $('#savePreferencesStatus');
        $btn.prop('disabled', true).text('Saving…');
        $status.removeClass('save-success save-error').text('');
        try {
            await saveFlags();
            $status.addClass('save-success').text('✓ Saved');
        } catch {
            $status.addClass('save-error').text('✗ Save failed');
        } finally {
            $btn.prop('disabled', false).text('Save');
            setTimeout(function () { $status.text(''); }, 3000);
        }
    });

    // ── Home Server Sync ──────────────────────────────────────────────
    // Builds and renders the scrobble URL into the read-only input. Called on page load and
    // again after Rotate so the displayed URL always matches the live token.
    function refreshScrobbleUrl() {
        var $input = $('#scrobbleUrlInput');
        if (!$input.length) return;
        $input.val(scrobbleToken ? addonOrigin + '/api/v1/scrobble/' + scrobbleToken : '');
    }
    refreshScrobbleUrl();

    $('#copyScrobbleBtn').on('click', async function () {
        var url = $('#scrobbleUrlInput').val();
        var $btn = $(this);
        var success = false;
        try {
            await navigator.clipboard.writeText(url);
            success = true;
        } catch {
            $('#scrobbleUrlInput').select();
            success = document.execCommand('copy');
        }
        $btn.toggleClass('copied', success);
        setTimeout(function () { $btn.removeClass('copied'); }, 1500);
    });

    $('#rotateScrobbleBtn').on('click', async function () {
        if (!configUid) return;
        if (!confirm('Generate a new webhook URL? The current URL will stop working immediately and you will need to update Plex / Jellyfin / Emby with the new one.')) return;
        try {
            var resp = await fetch('/Home/RotateScrobbleToken', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ uid: configUid }),
            });
            if (!resp.ok) throw new Error('rotate failed: ' + resp.status);
            var data = await resp.json();
            if (!data.success || !data.token) throw new Error(data.error || 'rotate failed');
            scrobbleToken = data.token;
            refreshScrobbleUrl();
        } catch (e) {
            alert('Could not rotate the webhook token: ' + e.message);
        }
    });

    $('#savePlexUsernameBtn').on('click', async function () {
        if (!configUid) return;
        var username = $('#plexUsernameInput').val();
        var $btn = $(this);
        try {
            var resp = await fetch('/Home/SetPlexUsername', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ uid: configUid, username: username }),
            });
            if (!resp.ok) throw new Error('save failed: ' + resp.status);
            // Visual ack — flip the label briefly so the user knows it took.
            var original = $btn.text();
            $btn.text('Saved').prop('disabled', true);
            setTimeout(function () { $btn.text(original).prop('disabled', false); }, 1200);
        } catch (e) {
            alert('Could not save Plex username: ' + e.message);
        }
    });

    // ── Backups ───────────────────────────────────────────────────────
    $('#importConfigBtn').on('click', function () {
        $('#importConfigFile').trigger('click');
    });

    $('#importConfigFile').on('change', async function (e) {
        var file = e.target.files[0];
        if (!file) return;
        try {
            var text = await file.text();
            var json = JSON.parse(text);
            var resp = await fetch('/Home/ImportConfig', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(json),
            });
            if (!resp.ok) throw new Error('Import failed: ' + resp.status);
            window.location.href = '/';
        } catch (err) {
            alert('Could not import configuration: ' + err.message);
        } finally {
            $('#importConfigFile').val(''); // allow re-selecting same file later
        }
    });

    // ── Danger Zone ───────────────────────────────────────────────────
    $('#resetConfigBtn').on('click', async function () {
        if (!configUid) return;
        if (!confirm('Reset all toggles to defaults? Your login is kept.')) return;
        var resp = await fetch('/Home/ResetConfig', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ uid: configUid }),
        });
        if (resp.ok) window.location.reload();
        else alert('Reset failed.');
    });

    $('#deleteConfigBtn').on('click', async function () {
        if (!confirm('Delete your AniSync configuration permanently? Existing install URLs in Stremio will stop working and you will be signed out.')) return;
        var resp = await fetch('/Home/DeleteConfig', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ uid: configUid }),
        });
        if (resp.ok) window.location.href = '/';
        else alert('Delete failed.');
    });

    // ── Login form (anonymous / Kitsu credentials) ────────────────────
    $('#username, #password').on('input', updateLoginUrl);

    function updateLoginUrl() {
        var href = loginBaseUrl + '?animeService=' + selectedService;
        // Kitsu uses the password grant — credentials are typed into the form and
        // posted to /Auth/Login. The other providers are OAuth-redirected.
        if (selectedService === 0) {
            var username = $('#username').val();
            var password = encodeURIComponent($('#password').val());
            href += '&username=' + username + '&password=' + password;
        }
        $('#loginUrl').attr('href', href);
    }

    updateLoginUrl();

    $('#loginUrl').on('click', function (e) {
        e.preventDefault();
        if (selectedService === 0 && ($('#username').val() == '' || $('#password').val() == '')) return;
        window.location.href = $('#loginUrl').attr('href');
    });

    $('#loginAnonymousUrl').on('click', function (e) {
        e.preventDefault();
        var href = $('#loginAnonymousUrl').attr('href');
        href += '?animeService=' + selectedService + '&anonymous=true';
        window.location.href = href;
    });
</script>
