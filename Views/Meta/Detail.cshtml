@model AnimeList.Controllers.AnimeDetailViewModel
@functions {
    // Per-service status → user-facing label. Kept inline because the detail
    // page is the only consumer; if a second view ever needs it, extract to
    // Utils. The fall-through (`_ => status`) lets unrecognised values render
    // as-is rather than swallowing them silently.
    static string PrettyStatus(AnimeService svc, string status)
    {
        if (string.IsNullOrEmpty(status)) return null;
        return svc switch
        {
            AnimeService.Anilist => status switch
            {
                "CURRENT" => "Watching",
                "PLANNING" => "Planning",
                "COMPLETED" => "Completed",
                "PAUSED" => "Paused",
                "DROPPED" => "Dropped",
                "REPEATING" => "Rewatching",
                _ => status,
            },
            AnimeService.MyAnimeList => status switch
            {
                "watching" => "Watching",
                "plan_to_watch" => "Planning",
                "completed" => "Completed",
                "on_hold" => "On Hold",
                "dropped" => "Dropped",
                "rewatching" => "Rewatching",
                _ => status,
            },
            _ => status switch
            {
                "current" => "Watching",
                "planned" => "Planning",
                "completed" => "Completed",
                "on_hold" => "On Hold",
                "dropped" => "Dropped",
                _ => status,
            },
        };
    }
}
@{
    ViewData["BodyClass"] = "anime-detail-page";
    // a is guaranteed non-null — AnimeController.Detail short-circuits to
    // Views/Shared/NotFound.cshtml when the upstream / mapping comes back
    // empty, so this view never gets rendered against a null anime.
    var a = Model.Anime;

    // This view is shared with the video (movie / series) section — see
    // VideoController.Detail. isVideo flips the anime-tracker chrome off
    // (Manage Entry → Trakt watchlist, no AniList extras hydration) and routes
    // the watch links through basePath (/movie · /series instead of /anime).
    var isVideo = Model.MediaType != MetaType.anime;
    var basePath = string.IsNullOrEmpty(Model.BasePath) ? "/meta" : Model.BasePath;
    // The media type rides the ?type= query on every watch link (omitted for
    // anime, the route default). Append typeQuery to every {basePath}/{id}/watch
    // URL the page builds so navigation stays in the right Cinemeta-backed
    // branch for movie / series.
    var typeQuery = isVideo ? $"?type={Model.MediaType}" : "";
    // Highlight Discover in the nav for the video detail pages.
    if (isVideo) { ViewData["ActiveNav"] = "discover"; }

    // Surface the anime name as the page title so browser history / bookmarks /
    // tab labels show the show being viewed instead of a generic "AniSync".
    ViewData["Title"] = a.name;

    var canEdit = !Model.AnonymousUser && !string.IsNullOrEmpty(Model.ConfigUid);

    // Group external links by category so the page shows distinct sections
    // (Streaming, Character, etc.) rather than one flat list.
    // Filters:
    //   - "Manage" is the standalone-page hand-off the addon uses; we have a
    //     proper Edit button on this page, so it'd be duplication.
    //   - "Similar" links double the recommendations carousel below since the
    //     carousel uses the richer Meta.recommendations data populated from
    //     the same source. Keep the Stremio-facing Link entries on the meta
    //     (they still flow through to the addon JSON), just don't render
    //     them as a separate links section here.
    //   - Studios sit alongside Tag / Staff / director in the bottom link
    //     sections — they're rendered with the same anime-detail-link-list
    //     chip style as everything else (used to be a "By X" stripe in the
    //     hero, but it visually competed with the title block).
    var linksByCategory = (a.links ?? new())
        .Where(l => !string.IsNullOrEmpty(l.url) && !string.IsNullOrEmpty(l.name))
        .Where(l => !string.Equals(l.category, "Manage", StringComparison.OrdinalIgnoreCase))
        .Where(l => !string.Equals(l.category, "Similar", StringComparison.OrdinalIgnoreCase))
        .GroupBy(l => string.IsNullOrEmpty(l.category) ? "Links" : l.category)
        .ToList();

    var hasYouTube = a.trailerStreams?.Count > 0
        && !string.IsNullOrEmpty(a.trailerStreams[0]?.ytId);
}

@* Hero block — backdrop image (when available) + poster + title + meta info.
   Falls back to a flat dark hero when the backdrop is missing so the layout
   doesn't collapse on entries without banner art. *@
<section class="anime-detail-hero @(string.IsNullOrEmpty(a.background) ? "anime-detail-hero-flat" : "")">
    @if (!string.IsNullOrEmpty(a.background))
    {
        <div class="anime-detail-backdrop" style="background-image: url('@a.background');"></div>
        <div class="anime-detail-backdrop-shade"></div>
    }
    <div class="anime-detail-hero-body">
        @if (!string.IsNullOrEmpty(a.poster))
        {
            <img class="anime-detail-poster" src="@a.poster" alt="@a.name" decoding="async" />
        }
        else
        {
            <div class="anime-detail-poster anime-detail-poster-placeholder"></div>
        }
        <div class="anime-detail-meta">
            <h1 class="anime-detail-title">@a.name</h1>
            @{
                var infoBits = new List<string>();
                if (!string.IsNullOrEmpty(a.format)) infoBits.Add(a.format);
                if (a.episodes is int eps && eps > 0) infoBits.Add($"{eps} ep{(eps > 1 ? "s" : "")}");
                if (a.avgDuration is int dur && dur > 0) infoBits.Add($"~{dur} min");
                if (a.year is int yr && yr > 0) infoBits.Add(yr.ToString());
                if (isVideo && !string.IsNullOrEmpty(Model.VideoCertification)) infoBits.Add(Model.VideoCertification);
                if (!string.IsNullOrEmpty(a.source)) infoBits.Add(a.source);
            }
            @if (infoBits.Count > 0)
            {
                <div class="anime-detail-info">@string.Join(" · ", infoBits)</div>
            }
            @* Score (community) + airing status + user-state side by side.
               The status pill color-shifts on "Airing" / "On hiatus" /
               "Cancelled" so the state reads at a glance. The user-state
               pill (cobalt-tinted) folds into the same row so the viewer's
               personal status reads as one of the at-a-glance facts about
               the show, not as an orphan badge below the tag list. *@
            <div class="anime-detail-badges">
                @if (a.score is double sc && sc > 0)
                {
                    <span class="anime-detail-score">★ @sc.ToString("0.0")</span>
                }
                @if (!string.IsNullOrEmpty(a.airStatus))
                {
                    var statusKey = a.airStatus.ToLowerInvariant().Replace(" ", "-");
                    <span class="anime-detail-status anime-detail-status-@statusKey">
                        @if (a.airStatus == "Airing")
                        {
                            <span class="anime-detail-status-dot" aria-hidden="true"></span>
                        }
                        @a.airStatus
                    </span>
                }
                @* User-state pill — three render shapes:
                     1. Logged-in user with a list entry → cobalt pill
                        ("Watching · Ep 2/24") with a trailing pencil icon;
                        whole pill clicks through to the manage-entry modal.
                     2. Logged-in user with NO entry for this anime → "Add
                        to List" pill with a trailing plus icon, same
                        click target so the modal handles the create flow.
                     3. Anonymous viewer → pill omitted entirely (the modal
                        wouldn't open and there's no "you" to talk about).
                   data-open-modal is the global hook intercepted by
                   manage-entry-modal.js. *@
                @* Video (movie / series) tracking is Trakt — surface the SAME
                   Manage Entry modal the anime path uses (data-open-modal +
                   data-meta-media-type routes the GET / save through Trakt:
                   watchlist / history / rating). The pill shows the current
                   Trakt status from Model.Entry, or "Add to List" when none.
                   Only when Trakt is connected; the anime chain below is guarded
                   with !isVideo so exactly one pill renders. *@
                @if (isVideo && Model.TraktConnected)
                {
                    var vStatus = Model.Entry?.Status;
                    string vLabel;
                    if (string.IsNullOrEmpty(vStatus)) { vLabel = "Add to List"; }
                    else if (vStatus == "planning") { vLabel = "Planning"; }
                    else if (vStatus == "completed") { vLabel = "Completed"; }
                    else if (vStatus == "onhold") { vLabel = "On Hold"; }
                    else if (vStatus == "dropped") { vLabel = "Dropped"; }
                    else if (vStatus == "rewatching") { vLabel = "Rewatching"; }
                    else
                    {
                        // "watching" — show episode progress for series only;
                        // a movie is a single unit.
                        vLabel = Model.MediaType == MetaType.series && Model.Entry?.TotalEpisodes is int vt && vt > 0
                            ? $"Watching · Ep {Model.Entry.Progress}/{vt}"
                            : "Watching";
                    }
                    var vIsAdd = string.IsNullOrEmpty(vStatus);
                    <button type="button" class="anime-detail-user-state"
                            data-open-modal data-meta-id="@a.id" data-meta-name="@a.name"
                            data-meta-media-type="@(Model.MediaType == MetaType.movie ? "movie" : "series")">
                        <span>@vLabel</span>
                        <svg class="anime-detail-user-state-icon" viewBox="0 0 24 24" width="14" height="14" fill="none"
                             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            @if (vIsAdd)
                            {
                                <path d="M12 5v14"></path>
                                <path d="M5 12h14"></path>
                            }
                            else
                            {
                                <path d="M12 20h9"></path>
                                <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path>
                            }
                        </svg>
                    </button>
                }
                @{
                    // Override info — non-null when the requested anime has no mapping
                    // to the user's primary but lives on a linked secondary the user
                    // has connected. The data-meta-service-override attribute is read
                    // by manage-entry-modal.js and routes the GET / POST through that
                    // linked token instead of the primary. titleTooltip surfaces a
                    // discoverable hint so the user understands the save goes to
                    // their linked provider, not the active primary picker.
                    var overrideService = Model.EntryServiceOverride;
                    var overrideAttr = overrideService.HasValue ? ((int)overrideService.Value).ToString() : null;
                    var overrideLabel = overrideService.HasValue
                        ? (overrideService.Value == AnimeService.MyAnimeList ? "MyAnimeList" : overrideService.Value.ToString())
                        : null;
                    var manageTitle = overrideLabel != null
                        ? $"Saved to your linked {overrideLabel} account — this anime isn't in your {Model.AnimeService} catalog."
                        : null;
                    // The status label below should also reflect the override
                    // service's vocabulary when the entry came via a linked
                    // token; otherwise PrettyStatus uses the primary's labels.
                    var statusService = overrideService ?? Model.AnimeService;
                }
                @if (!isVideo && Model.EntryUnavailable && canEdit)
                {
                    @* No mapping to the user's primary AND the source provider
                       (anilist: / kitsu: / mal:) isn't linked as a secondary —
                       there's literally nowhere for AniSync to write a save,
                       so swap the button for an honest "Not available" badge.
                       The user can still browse the meta + episodes; linking
                       the source provider on /account would unlock Manage
                       Entry retroactively. *@
                    <span class="anime-detail-user-state anime-detail-user-state-unavailable"
                          title="Not available on your account — this anime isn't on your @Model.AnimeService catalog. Link the source provider on Account to track it.">
                        Not available
                    </span>
                }
                else if (!isVideo && Model.IsMultiSeasonGroup && canEdit)
                {
                    @* Multi-cour grouped (id is imdb:tt..., franchise spans
                       more than one season) → the user's per-cour entry can't
                       honestly speak for the franchise as a whole, so we
                       render a generic "Manage Entry" button instead of the
                       per-cour status text. data-meta-id stays as the imdb
                       id so the modal can route any save through the
                       franchise-umbrella resolver. *@
                    <button type="button" class="anime-detail-user-state"
                            data-open-modal data-meta-id="@a.id" data-meta-name="@a.name"
                            data-meta-service-override="@overrideAttr"
                            title="@manageTitle">
                        <span>Manage Entry</span>
                        <svg class="anime-detail-user-state-icon" viewBox="0 0 24 24" width="14" height="14" fill="none"
                             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="M12 20h9"></path>
                            <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path>
                        </svg>
                    </button>
                }
                else if (!isVideo && Model.Entry != null)
                {
                    var statusLabel = PrettyStatus(statusService, Model.Entry.Status);
                    var userBits = new List<string>();
                    if (!string.IsNullOrEmpty(statusLabel)) userBits.Add(statusLabel);
                    if (Model.Entry.Progress > 0)
                    {
                        userBits.Add(Model.Entry.TotalEpisodes is int t && t > 0
                            ? $"Ep {Model.Entry.Progress} / {t}"
                            : $"Ep {Model.Entry.Progress}");
                    }
                    if (userBits.Count > 0)
                    {
                        if (canEdit)
                        {
                            <button type="button" class="anime-detail-user-state"
                                    data-open-modal data-meta-id="@a.id" data-meta-name="@a.name"
                                    data-meta-service-override="@overrideAttr"
                                    title="@manageTitle">
                                <span>@string.Join(" · ", userBits)</span>
                                <svg class="anime-detail-user-state-icon" viewBox="0 0 24 24" width="14" height="14" fill="none"
                                     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                    <path d="M12 20h9"></path>
                                    <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path>
                                </svg>
                            </button>
                        }
                        else
                        {
                            <span class="anime-detail-user-state">@string.Join(" · ", userBits)</span>
                        }
                    }
                }
                else if (!isVideo && canEdit)
                {
                    <button type="button" class="anime-detail-user-state"
                            data-open-modal data-meta-id="@a.id" data-meta-name="@a.name"
                            data-meta-service-override="@overrideAttr"
                            title="@manageTitle">
                        <span>@(overrideLabel != null ? $"Add to {overrideLabel}" : "Add to List")</span>
                        <svg class="anime-detail-user-state-icon" viewBox="0 0 24 24" width="14" height="14" fill="none"
                             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="M12 5v14"></path>
                            <path d="M5 12h14"></path>
                        </svg>
                    </button>
                }
            </div>

            @* Continue-watching CTA. Lives on its own centered row beneath the
               badges so it reads as the page's primary action without
               competing with the cobalt-tinted user-state pill to its left.
               Hidden when there's nothing playable (no addons / no External
               services), the anime is a movie (those have their own
               .anime-detail-movie-cta below the description), the user has
               completed the show, progress is already past the last loaded
               video, OR the next unseen episode hasn't aired yet — same
               condition that makes the corresponding episode row inert in
               the list below, so the CTA disappears in lockstep with its
               click target. *@
            @{
                var watchProgress = Model.Entry?.Progress ?? 0;
                var totalEps = a.videos?.Count ?? 0;
                var entryTotal = Model.Entry?.TotalEpisodes;
                var statusNorm = NormalizeListStatus(Model.Entry?.Status);
                var isCompleted = statusNorm == "completed"
                    || (entryTotal is int et && et > 0 && watchProgress >= et);
                var nextEp = watchProgress + 1;

                // Look up the target video (NormaliseCourEpisodeNumbering
                // has already sorted + renumbered so episode == ordinal,
                // matching the URL semantics) and consult its release
                // date — if it's a future-aired episode, the click target
                // is inert and the CTA shouldn't promise something we
                // can't actually play. airingAt (AniList-overlaid in the
                // controller) wins over the Cinemeta `released` string when
                // present, so a notification ping unlocks the CTA without
                // waiting for Cinemeta to catch up to the real broadcast.
                var todayHero = DateTime.UtcNow.Date;
                var nowUnixHero = DateTimeOffset.UtcNow.ToUnixTimeSeconds();
                // For multi-season (imdb-grouped) renders, the target video
                // could legitimately live in any season — pick the one
                // matching the entry's tracked cour when possible so a
                // S4-airing franchise lands on S4 ep N instead of the
                // first cour's same-numbered episode.
                var entrySeason = a.videos?
                    .Where(v => v.episode == nextEp)
                    .Select(v => (int?)(v.season > 0 ? v.season : 1))
                    .LastOrDefault();
                var targetVideo = a.videos?
                    .FirstOrDefault(v => v.episode == nextEp
                        && (entrySeason == null || (v.season > 0 ? v.season : 1) == entrySeason.Value));
                var targetIsFuture = false;
                if (targetVideo != null)
                {
                    if (targetVideo.airingAt.HasValue)
                    {
                        targetIsFuture = targetVideo.airingAt.Value > nowUnixHero;
                    }
                    else if (!string.IsNullOrEmpty(targetVideo.released)
                        && targetVideo.released.Length >= 10
                        && DateTime.TryParse(targetVideo.released[..10], out var nextReleaseDate))
                    {
                        targetIsFuture = nextReleaseDate.Date > todayHero;
                    }
                }

                var showWatchCta = a.type != MetaType.movie.ToString()
                    && totalEps > 0
                    && nextEp <= totalEps
                    && !isCompleted
                    && !targetIsFuture
                    // Hide the CTA on multi-cour grouped renders — same
                    // rationale as the "Manage Entry" pill above: a single
                    // ep number can't honestly point at "the next episode"
                    // when the franchise spans multiple cours with their own
                    // numbering. Users navigate to a specific episode via
                    // the season-tabbed list below instead.
                    && !Model.IsMultiSeasonGroup;
                // When multi-season, embed the season segment in the URL
                // so the Watch route lands on the correct cour's episode
                // instead of the first-occurrence default.
                var watchHref = targetVideo != null
                        && (a.videos?.Select(v => v.season > 0 ? v.season : 1).Distinct().Count() ?? 0) > 1
                    ? $"{basePath}/{a.id}/watch/{(targetVideo.season > 0 ? targetVideo.season : 1)}/{nextEp}{typeQuery}"
                    : $"{basePath}/{a.id}/watch/{nextEp}{typeQuery}";
            }
            @if (showWatchCta)
            {
                var watchLabel = watchProgress > 0 ? $"Continue · Ep {nextEp}" : $"Watch Ep {nextEp}";
                <div class="anime-detail-watch-next-wrap">
                    <a class="anime-detail-watch-next" href="@watchHref"
                       aria-label="@watchLabel">
                        <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true">
                            <polygon points="6 4 20 12 6 20 6 4"></polygon>
                        </svg>
                        <span>@watchLabel</span>
                    </a>
                </div>
            }
            @* Studios are rendered as their own section in the bottom
               linksByCategory loop now — same chip style as Tag / Staff
               / director. The hero stays focused on title + score +
               status + genres without competing chrome below it. *@
            @if (a.genres?.Count > 0)
            {
                @* Genre chips link into /discover?genre=X so a tap surfaces
                   more anime sharing the genre rather than bouncing to AniList.
                   Shares the .anime-detail-link-list scaffolding with the
                   bottom sections but adds .anime-detail-genre-list as a
                   visual modifier — neutral-grey chrome (instead of the
                   cobalt accent the Tag / Staff / Studio chips use below)
                   so the genre row reads as part of the hero badge stack
                   alongside the score / status pills rather than as a
                   stray copy of the bottom section. Centred on all
                   viewports too — they sit between the title and the
                   score/status pair and look off-balance when flush left. *@
                <ul class="anime-detail-link-list anime-detail-genre-list">
                    @foreach (var g in a.genres.Take(8))
                    {
                        <li>
                            <a class="anime-detail-link" href="@($"/discover?genre={Uri.EscapeDataString(g)}")">@g</a>
                        </li>
                    }
                </ul>
            }
            @{
                var sl = Model.SourceLinks;
                var hasAnySource = sl != null &&
                    (sl.AnilistId.HasValue || sl.MalId.HasValue
                     || sl.KitsuId.HasValue || !string.IsNullOrEmpty(sl.ImdbId));
            }
            @if (hasAnySource)
            {
                @* External source chips — one per service the anime resolves to
                   in the cross-service mapping dataset. Each chip is brand-coloured
                   so the row reads as a recognisable row of provider marks rather
                   than a generic link list. Opens in a new tab; rel=noreferrer
                   stops the Config UID (when present in the current URL) leaking
                   to the third-party site via the Referer header. *@
                <div class="anime-detail-sources" aria-label="Open on external sites">
                    @if (sl.AnilistId.HasValue)
                    {
                        <a class="source-chip source-chip-anilist"
                           href="https://anilist.co/anime/@sl.AnilistId"
                           target="_blank" rel="noreferrer noopener"
                           aria-label="Open on AniList">
                            <span class="source-chip-mark" aria-hidden="true">A</span>
                            <span class="source-chip-label">AniList</span>
                        </a>
                    }
                    @if (sl.MalId.HasValue)
                    {
                        <a class="source-chip source-chip-mal"
                           href="https://myanimelist.net/anime/@sl.MalId"
                           target="_blank" rel="noreferrer noopener"
                           aria-label="Open on MyAnimeList">
                            <span class="source-chip-mark" aria-hidden="true">M</span>
                            <span class="source-chip-label">MyAnimeList</span>
                        </a>
                    }
                    @if (sl.KitsuId.HasValue)
                    {
                        <a class="source-chip source-chip-kitsu"
                           href="https://kitsu.io/anime/@sl.KitsuId"
                           target="_blank" rel="noreferrer noopener"
                           aria-label="Open on Kitsu">
                            <span class="source-chip-mark" aria-hidden="true">K</span>
                            <span class="source-chip-label">Kitsu</span>
                        </a>
                    }
                    @if (!string.IsNullOrEmpty(sl.ImdbId))
                    {
                        @* IMDb is the only chip that's "mark-only" — the mark
                           badge already spells out "IMDb", so a trailing
                           "IMDb" label would just duplicate it. Saves width
                           on mobile where every pixel helps the row stay on
                           one line. *@
                        <a class="source-chip source-chip-imdb"
                           href="https://www.imdb.com/title/@sl.ImdbId/"
                           target="_blank" rel="noreferrer noopener"
                           aria-label="Open on IMDb">
                            <span class="source-chip-mark" aria-hidden="true">IMDb</span>
                        </a>
                    }
                    @{
                        @* Stremio web detail deep-link. The id format Stremio
                           expects is the same prefixed catalog id we already
                           carry on anime.id — kitsu:N, mal:N, anilist:N, or
                           ttNNNNNNN — so a plain url-encode is all we need.
                           For the imdb-grouped franchise render anime.id is
                           the tt umbrella (BuildGroupedImdbAnimeAsync stamps
                           it that way) which routes Stremio to the Cinemeta
                           entry that aggregates every cour; otherwise it's
                           the user's primary's id, matching the catalog the
                           user actually subscribed to in their Stremio. The
                           tmdb / anidb / tvdb prefixes are skipped — there's
                           no public Stremio addon that catalogs anime under
                           those ids, so the link would land on a blank
                           detail page. *@
                        var stremioId = a.id;
                        var stremioIdSupported = !string.IsNullOrEmpty(stremioId)
                            && (stremioId.StartsWith(Utils.anilistPrefix)
                                || stremioId.StartsWith(Utils.malPrefix)
                                || stremioId.StartsWith(Utils.kitsuPrefix)
                                || stremioId.StartsWith(Utils.imdbPrefix));
                        var stremioType = a.type == MetaType.movie.ToString() ? "movie" : "series";
                        var stremioPath = $"detail/{stremioType}/{Uri.EscapeDataString(stremioId ?? string.Empty)}";
                    }
                    @if (stremioIdSupported)
                    {
                        @* href is the web fallback so right-click / middle-
                           click / copy-link / no-JS users all land on a
                           working URL. data-stremio-app-url is the native
                           protocol handler the click script tries first,
                           with a visibility-change heuristic that promotes
                           a pre-opened placeholder tab to the web URL when
                           the OS doesn't switch focus to a registered
                           Stremio handler within ~1.5s. *@
                        <a class="source-chip source-chip-stremio"
                           href="@($"https://web.stremio.com/#/{stremioPath}")"
                           data-stremio-app-url="@($"stremio:///{stremioPath}")"
                           target="_blank" rel="noreferrer noopener"
                           aria-label="Open on Stremio">
                            <span class="source-chip-mark" aria-hidden="true">S</span>
                            <span class="source-chip-label">Stremio</span>
                        </a>
                    }
                </div>
            }
        </div>
    </div>
</section>

@if (!string.IsNullOrEmpty(a.description))
{
    @* Long AniList synopses run 500+ words; clamp to ~3 lines on collapse
       so "Show more" is meaningful (a 5-line clamp left most synopses
       reading as fully visible — the expand button felt redundant). The
       data-collapsed attribute keys the CSS line-clamp and the JS toggle
       below; short synopses (under ~3 lines worth of text) skip the
       toggle entirely. *@
    var isLongSynopsis = a.description.Length > 180;
    <section class="anime-detail-section">
        <h2 class="anime-detail-section-title">Synopsis</h2>
        <div class="anime-detail-synopsis-wrap" @Html.Raw(isLongSynopsis ? "data-collapsed=\"true\"" : "")>
            <p class="anime-detail-synopsis">@a.description</p>
            @if (isLongSynopsis)
            {
                <button type="button" class="anime-detail-synopsis-toggle"
                        aria-expanded="false">Show more</button>
            }
        </div>
    </section>
}

@if (hasYouTube)
{
    var trailer = a.trailerStreams[0];
    var trailerUrl = $"https://www.youtube.com/watch?v={trailer.ytId}";
    @* Lazy-loaded YouTube embed. hqdefault is the safest thumbnail URL —
       always exists (vs maxresdefault which 404s for some videos). The
       initial render is just a thumbnail card with zero YouTube weight; on
       click the JS below swaps the inner content for a youtube-nocookie
       iframe. When a video's uploader has embedding disabled (or the
       network blocks the player), YouTube serves its own in-frame error
       page with a "Watch video on YouTube" click-through baked in — so we
       don't need to build a fallback affordance ourselves.

       data-yt-id feeds the script; the href stays on the anchor as a
       no-JS fallback (browsers with JS disabled still get to YouTube
       via a normal click). *@
    <section class="anime-detail-section">
        <h2 class="anime-detail-section-title">Trailer</h2>
        <a class="anime-detail-trailer-card"
           href="@trailerUrl"
           target="_blank"
           rel="noreferrer noopener"
           aria-label="Play trailer"
           data-yt-id="@trailer.ytId">
            <img src="https://img.youtube.com/vi/@trailer.ytId/hqdefault.jpg"
                 alt="" loading="lazy"
                 class="anime-detail-trailer-thumb" />
            <span class="anime-detail-trailer-shade" aria-hidden="true"></span>
            <span class="anime-detail-trailer-play" aria-hidden="true">
                <svg viewBox="0 0 24 24" width="36" height="36" fill="currentColor">
                    <path d="M8 5v14l11-7z"></path>
                </svg>
            </span>
        </a>
    </section>
}

@if (a.videos?.Count > 0)
{
    var canQuickMark = canEdit && Model.Entry != null && !string.IsNullOrEmpty(Model.Entry.Status);
    var currentProgress = Model.Entry?.Progress ?? 0;

    // Group episodes by their `season` field. Single-season anime end up
    // with one group and no tabs; multi-cour franchises (Stremio-style
    // mapping with the IMDb id grouped) get a row of pill tabs.
    var seasonGroups = a.videos
        .GroupBy(v => v.season > 0 ? v.season : 1)
        .OrderBy(g => g.Key)
        .ToList();
    var hasMultipleSeasons = seasonGroups.Count > 1;

    // Default visible season: the one containing the user's current
    // progress when known, otherwise the latest. Stremio's pattern is
    // "land where the user left off" so they can pick up directly.
    int defaultSeason;
    if (currentProgress > 0)
    {
        // Find the season group whose episodes include the current progress.
        // The franchise mapping stores cour-specific episode numbers, so
        // the absolute episode 7 might be Season 1 ep 7 OR Season 2 ep 1
        // depending on numbering. Pick the first match by episode-num,
        // falling back to the last season when no row matches.
        var match = seasonGroups
            .FirstOrDefault(g => g.Any(v => v.episode == currentProgress)) ?? seasonGroups.Last();
        defaultSeason = match.Key;
    }
    else
    {
        defaultSeason = seasonGroups.Last().Key;
    }

    // Treat each row's air date relative to today so we can amber-tint
    // future dates and skip the watched check on unaired episodes. nowUnix
    // backs the AniList-overlaid airingAt comparison (which wins over the
    // Cinemeta-sourced released string when present — see AnimeController's
    // OverlayAniListAiringScheduleAsync for why).
    var today = DateTime.UtcNow.Date;
    var nowUnix = DateTimeOffset.UtcNow.ToUnixTimeSeconds();
    @* Episodes section. Wrapped in .anime-detail-episodes-wrap so the
       collapse / expand JS can toggle a single class on it and the inner
       body's height + season tabs respond together.
         - data-collapsed: when present, the body is hidden via CSS (max-
           height: 0 + overflow: hidden + visibility: hidden). Default is
           expanded for parity with how the section currently behaves.
         - .anime-detail-episodes-body: caps the body's max-height so long-
           running shows (One Piece, Detective Conan, …) don't push the
           Recommended carousel and external-link sections far below the
           fold. Short shows (≤ ~8 eps) fit naturally without scrolling
           because max-height only kicks in when the content overflows. *@
    <section class="anime-detail-section anime-detail-episodes-wrap">
        <div class="anime-detail-episodes-header">
            <h2 class="anime-detail-section-title">Episodes <span class="anime-detail-section-count">(@a.videos.Count)</span></h2>
            @if (a.videos.Count > 1)
            {
                @* Client-side filter — matches against the row's
                   data-episode-num and the rendered title text. No
                   extra network call; the rows are already in the DOM. *@
                <input type="search"
                       class="anime-detail-episodes-filter"
                       placeholder="Filter episodes…"
                       aria-label="Filter episodes by number or title"
                       data-episodes-filter
                       autocomplete="off"
                       spellcheck="false" />
            }
            <button type="button" class="anime-detail-episodes-toggle"
                    aria-expanded="true"
                    aria-controls="anime-detail-episodes-body">
                <span class="anime-detail-episodes-toggle-label">Collapse</span>
                <svg class="anime-detail-episodes-toggle-icon" viewBox="0 0 24 24" width="14" height="14"
                     fill="none" stroke="currentColor" stroke-width="2.2"
                     stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
            </button>
        </div>

        @if (hasMultipleSeasons)
        {
            @* Horizontally-scrollable season tab strip. Each tab carries a
               data-season-num the JS uses to toggle which <li>s are visible
               in the single shared episode list below. Active tab gets the
               cobalt fill. Rendered OUTSIDE the .anime-detail-episodes-body
               (which is the max-height scroll container) so the tabs stay
               anchored above the scrolling list — a multi-cour franchise
               with 150+ episodes would otherwise scroll the season switcher
               off the top of the viewport before the user can pick another
               cour. *@
            <nav class="season-tabs" role="tablist" aria-label="Seasons">
                @foreach (var g in seasonGroups)
                {
                    var isActive = g.Key == defaultSeason;
                    <button type="button"
                            class="season-tab @(isActive ? "season-tab-active" : "")"
                            data-season-num="@g.Key"
                            role="tab"
                            aria-selected="@(isActive ? "true" : "false")">
                        Season @g.Key
                    </button>
                }
            </nav>
        }

        <div class="anime-detail-episodes-body" id="anime-detail-episodes-body">
        <ol class="anime-detail-episodes" reversed="false"
            data-active-season="@defaultSeason"
            @(canQuickMark ? $"data-can-edit=\"true\" data-meta-id=\"{a.id}\" data-current-progress=\"{currentProgress}\" data-current-status=\"{Model.Entry.Status}\"" : "")>
            @foreach (var v in a.videos)
            {
                var watched = currentProgress > 0 && v.episode <= currentProgress;
                bool isFuture = false;
                // AniList's overlaid airingAt is the source of truth when
                // present — Cinemeta's `released` string is the fallback for
                // entries the AniList overlay couldn't populate (mapping
                // miss, older finished shows without a schedule, etc).
                string displayDate = null;
                if (v.airingAt.HasValue)
                {
                    isFuture = v.airingAt.Value > nowUnix;
                    displayDate = DateTimeOffset.FromUnixTimeSeconds(v.airingAt.Value)
                        .UtcDateTime.ToString("yyyy-MM-dd");
                }
                else if (!string.IsNullOrEmpty(v.released) && v.released.Length >= 10
                    && DateTime.TryParse(v.released[..10], out var releaseDate))
                {
                    isFuture = releaseDate.Date > today;
                    displayDate = v.released[..Math.Min(10, v.released.Length)];
                }
                else if (!string.IsNullOrEmpty(v.released))
                {
                    displayDate = v.released[..Math.Min(10, v.released.Length)];
                }

                var classes = new List<string> { "anime-detail-episode" };
                if (watched) classes.Add("anime-detail-episode-watched");
                if (isFuture) classes.Add("anime-detail-episode-future");
                // When season tabs are present, hide rows that aren't in the
                // active season. Single-season views skip this filter so all
                // rows render directly.
                if (hasMultipleSeasons && (v.season > 0 ? v.season : 1) != defaultSeason)
                    classes.Add("anime-detail-episode-hidden");

                var description = !string.IsNullOrEmpty(v.overview) ? v.overview : v.description;

                // Episode rows are always interactive now — clicking lands
                // on /watch, which surfaces the stream picker (and a "set up
                // streaming" prompt when no addon/external source is wired
                // up yet). Future episodes stay inert via the
                // anime-detail-episode-future guard in the click handler.
                <li class="@string.Join(" ", classes)"
                    data-episode-num="@v.episode"
                    data-season-num="@(v.season > 0 ? v.season : 1)"
                    role="button" tabindex="0">
                    <div class="anime-detail-episode-thumb-wrap">
                        @if (!string.IsNullOrEmpty(v.thumbnail))
                        {
                            @* onerror: when the thumbnail URL 404s (common for
                               unaired future episodes — Cinemeta sets a stub
                               URL before art exists), drop the broken-image
                               glyph and let the wrap fall back to the placeholder
                               treatment (play-diamond on dark). *@
                            <img class="anime-detail-episode-thumb" src="@v.thumbnail" alt="" loading="lazy" decoding="async"
                                 onerror="this.parentNode.classList.add('anime-detail-episode-thumb-failed');this.remove();" />
                        }
                        else
                        {
                            <div class="anime-detail-episode-thumb anime-detail-episode-thumb-placeholder"></div>
                        }
                        @* Play-diamond glyph overlay — same on every row,
                           gives the row a Stremio-style visual anchor even
                           when the thumbnail is missing or generic. *@
                        <span class="anime-detail-episode-play" aria-hidden="true">
                            <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
                                <path d="M12 4l8 8-8 8-8-8z"></path>
                            </svg>
                        </span>
                        @if (watched)
                        {
                            @* Yellow "eye" badge in top-right of the thumbnail
                               for already-watched episodes. Stremio's
                               equivalent is the amber/yellow bookmark — same
                               function: at-a-glance "I've seen this". *@
                            <span class="anime-detail-episode-eye" aria-label="Watched">
                                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                                    <circle cx="12" cy="12" r="3"></circle>
                                </svg>
                            </span>
                        }
                    </div>
                    <div class="anime-detail-episode-body">
                        <div class="anime-detail-episode-row">
                            @{
                                // Cinemeta puts the episode title in `name`;
                                // some other code paths populate `title`
                                // instead (AniList streamingEpisodes,
                                // service-native fallbacks). Prefer name,
                                // fall through to title, finally "Episode N".
                                var episodeTitle = !string.IsNullOrEmpty(v.name) ? v.name
                                    : !string.IsNullOrEmpty(v.title) ? v.title
                                    : $"Episode {v.episode}";
                            }
                            <span class="anime-detail-episode-title">
                                @v.episode. @episodeTitle
                            </span>
                            @if (!string.IsNullOrEmpty(displayDate))
                            {
                                <span class="anime-detail-episode-date @(isFuture ? "anime-detail-episode-date-future" : "")">
                                    @displayDate
                                </span>
                            }
                        </div>
                        @if (!string.IsNullOrEmpty(description))
                        {
                            <p class="anime-detail-episode-desc">@description</p>
                        }
                    </div>
                </li>
            }
        </ol>
        </div>
    </section>
}
else if (a.type == MetaType.movie.ToString())
{
    @* Movie meta has no per-episode list (the underlying service collapses
       the whole feature into one streamable unit), so the user has no
       click target to reach the watch page. Surface a single CTA pointed
       at /anime/{id}/watch/1 — the watch route treats episode=1 as the
       movie body for movie-typed entries. Always shown now: even without a
       stream addon / External services wired up, the watch page surfaces
       the source picker and a "set up streaming" prompt. *@
    <section class="anime-detail-section anime-detail-movie-cta-wrap">
        @* Anime movies route to /meta/{id}/watch/1 (the watch route treats
           episode 1 as the movie body); video movies use /meta/{id}/watch
           (no episode segment) with ?type=. *@
        <a class="anime-detail-movie-cta" href="@(isVideo ? $"{basePath}/{a.id}/watch{typeQuery}" : $"/meta/{a.id}/watch/1")">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none"
                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polygon points="6 4 20 12 6 20 6 4"></polygon>
            </svg>
            <span>Watch movie</span>
        </a>
    </section>
}

@* Video (Trakt-enriched) extras — rendered server-side. Cast names come from
   Trakt (no headshots in its API); Recommended is Trakt /related hydrated to
   posters via metahub. The anime deferred carousels below are skipped for
   video (their /extras source is AniList-only). *@
@if (isVideo && Model.VideoCast?.Count > 0)
{
    <section class="anime-detail-section">
        <h2 class="anime-detail-section-title">Cast</h2>
        <div class="video-cast-scroll">
            @foreach (var c in Model.VideoCast)
            {
                <div class="video-cast-card">
                    @* The initial sits behind the headshot so it shows through
                       when Trakt has no image or the CDN url 404s (onerror
                       strips the img). *@
                    <span class="video-cast-avatar">
                        <span class="video-cast-avatar-initial" aria-hidden="true">@(string.IsNullOrEmpty(c.Name) ? "?" : c.Name[..1])</span>
                        @if (!string.IsNullOrEmpty(c.Image))
                        {
                            <img class="video-cast-avatar-img" src="@c.Image" alt="" loading="lazy"
                                 decoding="async" onerror="this.remove()" />
                        }
                    </span>
                    <span class="video-cast-name">@c.Name</span>
                    @if (!string.IsNullOrEmpty(c.Character))
                    {
                        <span class="video-cast-char">@c.Character</span>
                    }
                </div>
            }
        </div>
    </section>
}

@if (isVideo && a.recommendations?.Count > 0)
{
    <section class="anime-detail-section">
        <h2 class="anime-detail-section-title">Recommended</h2>
        @await Html.PartialAsync("_PosterGrid", new AnimeList.Models.PosterGridViewModel
        {
            Items = a.recommendations,
            Variant = "scroll",
            VideoLinks = true,
            ConfigUid = Model.ConfigUid,
        })
    </section>
}

@* Related (prequel/sequel) + Recommended carousels are populated client-side
   after page load via /anime/{id}/extras so the hero + episodes render off
   GetAnimeByIdAsync alone. Each placeholder stays hidden until the fetch
   completes; the script reveals + fills it with the same _PosterGrid card
   markup the server would have emitted inline. Anime only — video fills its
   own server-rendered carousels above. *@
@if (!isVideo)
{
<section class="anime-detail-section anime-detail-section-deferred" data-anime-related hidden>
    <h2 class="anime-detail-section-title">Related</h2>
    <div class="poster-scroll-row" data-anime-related-grid></div>
</section>

<section class="anime-detail-section anime-detail-section-deferred" data-anime-recommendations hidden>
    <h2 class="anime-detail-section-title">Recommended</h2>
    <div class="poster-scroll-row" data-anime-recommendations-grid></div>
</section>
}

@functions {
    // Builds an in-app href for a Link based on its category, or returns
    // null when the link doesn't map (e.g. a tag link without an id, or a
    // category we don't have a browse route for). Callers fall back to the
    // external url + target=_blank in that case.
    private static string InternalHrefFor(AnimeList.Models.Link link)
    {
        if (link == null) return null;
        var cat = link.category?.ToLowerInvariant();
        if (cat == "tag")
        {
            return string.IsNullOrEmpty(link.name)
                ? null
                : $"/discover/tag/{Uri.EscapeDataString(link.name)}";
        }
        if (cat == "studio")
        {
            return link.anilistId.HasValue ? $"/discover/studio/{link.anilistId.Value}" : null;
        }
        // Staff roles get categorised by StaffRoleToCategory ("Director",
        // "Composer", "Artist", "Producer", "Staff") — all route to the
        // same /discover/staff/{id} page.
        if (cat is "staff" or "director" or "composer" or "artist" or "producer" or "writer")
        {
            return link.anilistId.HasValue ? $"/discover/staff/{link.anilistId.Value}" : null;
        }
        return null;
    }
}

@* AniList-primary pages render their Tag/Studio/director/staff/etc. chips
   inline because GetAnimeByIdAsync returns them in anime.links already.
   Non-AniList pages defer the chip data to /anime/{id}/extras (the augment
   call is the same one the carousels share, so we ride along the deferred
   fetch instead of blocking the hero on it). *@
@if (!Model.DeferredSupplementaryLinks)
{
    @foreach (var group in linksByCategory)
    {
        <section class="anime-detail-section">
            <h2 class="anime-detail-section-title">@group.Key</h2>
            <ul class="anime-detail-link-list">
                @foreach (var link in group)
                {
                    var internalHref = InternalHrefFor(link);
                    if (!string.IsNullOrEmpty(internalHref))
                    {
                        <li>
                            <a class="anime-detail-link" href="@internalHref">@link.name</a>
                        </li>
                    }
                    else
                    {
                        <li>
                            <a class="anime-detail-link" href="@link.url" target="_blank" rel="noreferrer noopener">
                                @link.name
                            </a>
                        </li>
                    }
                }
            </ul>
        </section>
    }
}
else
{
    @* Placeholder host — the client script generates one .anime-detail-section
       per category and appends it here in the same shape the inline loop would
       have rendered. Hidden until populated so a non-AniList page with no
       upstream data doesn't show an empty header block. *@
    <div data-anime-supplementary hidden></div>
}

@* Synopsis collapse/expand toggle + trailer lazy-embed. Inlined here
   (rather than in manage-entry-modal.js) so they work for anonymous
   viewers too — that script bails early when the modal DOM isn't
   present, which used to silently disable these for logged-out users. *@
<script>
    // Mark sessionStorage right before navigating from /anime/{id} to
    // /watch/{ep} so Watch.cshtml knows the previous history entry is
    // this detail page and can reuse it with a simple history.back()
    // (avoiding a duplicate /anime/{id} entry on the stack).
    //
    // Needed because the site sets <meta name="referrer" content="no-referrer">,
    // which strips document.referrer on every same-origin navigation —
    // without this marker the watch page can't tell whether to step
    // back or do a fresh replace. Setting the marker only on the click
    // that actually triggers the navigation keeps it from going stale
    // (e.g., user visited /anime/X earlier in the session, then clicked
    // a notification straight to /watch).
    (function () {
        function markWatchEntry() {
            try { sessionStorage.setItem('aniSyncWatchEntry', 'fromAnime'); }
            catch (_) { /* sessionStorage unavailable — best effort */ }
        }
        // Catches the static "Watch next" / movie CTA anchors and any
        // future <a href="…/watch/…"> links the page might grow. Modifier
        // clicks (Ctrl/Cmd/Shift/middle) open in a new tab — don't mark.
        document.addEventListener('click', function (e) {
            if (e.button !== 0 || e.metaKey || e.ctrlKey || e.shiftKey || e.altKey) return;
            var a = e.target.closest && e.target.closest('a[href*="/watch/"]');
            if (!a) return;
            markWatchEntry();
        }, true);
        // Episode rows in the list navigate via window.location.assign
        // rather than <a> (see handleEpisodeActivate further down), so
        // we hook the same delegated click event and mark the entry if
        // the click landed on a non-future episode row. Cheap: the
        // marker write is idempotent.
        document.addEventListener('click', function (e) {
            if (e.button !== 0 || e.metaKey || e.ctrlKey || e.shiftKey || e.altKey) return;
            var li = e.target.closest && e.target.closest('li.anime-detail-episode');
            if (!li || li.classList.contains('anime-detail-episode-future')) return;
            if (e.target.closest('button, a, [data-no-stream]')) return;
            markWatchEntry();
        }, true);
    })();
</script>
<script>
    (function () {
        // ── Synopsis collapse/expand ──────────────────────────────────
        document.addEventListener('click', function (e) {
            var btn = e.target.closest && e.target.closest('button.anime-detail-synopsis-toggle');
            if (!btn) return;
            e.preventDefault();
            var wrap = btn.closest('.anime-detail-synopsis-wrap');
            if (!wrap) return;
            var collapsed = wrap.getAttribute('data-collapsed') === 'true';
            if (collapsed) {
                wrap.removeAttribute('data-collapsed');
                btn.textContent = 'Show less';
                btn.setAttribute('aria-expanded', 'true');
            } else {
                wrap.setAttribute('data-collapsed', 'true');
                btn.textContent = 'Show more';
                btn.setAttribute('aria-expanded', 'false');
            }
        });

        // ── Episodes collapse/expand ──────────────────────────────────
        // Single handler driving the whole .anime-detail-episodes-wrap
        // section: a click on the toggle flips data-collapsed on the wrap
        // (CSS handles the hide), rewrites the button label between
        // "Collapse" / "Expand", and flips aria-expanded for screen
        // readers. Section is default expanded — the toggle exists for
        // long-running shows (One Piece, etc.) where the user wants to
        // jump to recommendations / external links without scrolling
        // through 1,100 rows.
        document.addEventListener('click', function (e) {
            var btn = e.target.closest && e.target.closest('button.anime-detail-episodes-toggle');
            if (!btn) return;
            e.preventDefault();
            var wrap = btn.closest('.anime-detail-episodes-wrap');
            if (!wrap) return;
            var collapsed = wrap.getAttribute('data-collapsed') === 'true';
            var label = btn.querySelector('.anime-detail-episodes-toggle-label');
            if (collapsed) {
                wrap.removeAttribute('data-collapsed');
                if (label) label.textContent = 'Collapse';
                btn.setAttribute('aria-expanded', 'true');
            } else {
                wrap.setAttribute('data-collapsed', 'true');
                if (label) label.textContent = 'Expand';
                btn.setAttribute('aria-expanded', 'false');
            }
        });

        // ── Season tab switch ─────────────────────────────────────────
        // Pure DOM-toggle, no fetch — the full episode list ships in one
        // <ol> with each row carrying data-season-num, and the tabs just
        // flip which rows are visible. Lives here (not in
        // manage-entry-modal.js) so anonymous viewers can still navigate
        // multi-season franchises; that script early-returns when the
        // modal DOM isn't present.
        document.addEventListener('click', function (e) {
            var tab = e.target.closest && e.target.closest('button.season-tab[data-season-num]');
            if (!tab) return;
            e.preventDefault();

            var seasonNum = tab.getAttribute('data-season-num');
            if (!seasonNum) return;

            var nav = tab.closest('.season-tabs');
            var list = document.querySelector('ol.anime-detail-episodes');
            if (!nav || !list) return;

            // Active class + aria-selected on every tab in the strip.
            Array.prototype.forEach.call(
                nav.querySelectorAll('.season-tab'),
                function (t) {
                    var isActive = t === tab;
                    t.classList.toggle('season-tab-active', isActive);
                    t.setAttribute('aria-selected', isActive ? 'true' : 'false');
                });

            // Update data-active-season and toggle per-row visibility. The
            // CSS class .anime-detail-episode-hidden does the actual hide.
            list.setAttribute('data-active-season', seasonNum);
            Array.prototype.forEach.call(
                list.querySelectorAll('li.anime-detail-episode'),
                function (li) {
                    var rowSeason = li.getAttribute('data-season-num');
                    li.classList.toggle('anime-detail-episode-hidden', rowSeason !== seasonNum);
                });
        });

        // ── Trailer lazy-embed ────────────────────────────────────────
        //
        // Click → swap thumbnail for a youtube-nocookie iframe (privacy-
        // light embed domain; no cookies until playback). Loading the
        // YouTube embed itself takes ~500 KB-1 MB, so we never load it
        // until the user opts in.
        //
        // When a video's uploader has embedding disabled, or when a
        // network firewall blocks the player, YouTube renders its own
        // in-frame error page with a "Watch video on YouTube" link baked
        // in — so we don't try to detect failure ourselves and trust
        // YouTube's UI to provide the click-through.
        document.addEventListener('click', function (e) {
            var card = e.target.closest && e.target.closest('.anime-detail-trailer-card[data-yt-id]');
            if (!card) return;
            // The original <a target="_blank"> stays on the anchor as a
            // no-JS fallback; preventDefault hands the click entirely to
            // this handler when JS is available.
            e.preventDefault();

            var ytId = card.getAttribute('data-yt-id');
            if (!ytId) return;

            // Idempotent: a re-click on a card that's already swapped to an
            // iframe is a no-op (the iframe keeps playing).
            if (card.querySelector('iframe')) return;

            var iframe = document.createElement('iframe');
            iframe.className = 'anime-detail-trailer-iframe';
            iframe.allow = 'accelerometer; autoplay; encrypted-media; gyroscope; picture-in-picture; fullscreen';
            // The page-level <meta name="referrer" content="no-referrer"> in
            // _Layout.cshtml strips the Referer on every outbound request to
            // protect the Config UID from leaking via the URL. That same
            // policy makes YouTube's embed player serve "error 153 — video
            // player configuration error" because it can't identify the
            // embedding domain. Override on this iframe only: 'origin' sends
            // just "https://this-host/" (no path / query), which satisfies
            // YouTube's domain check without exposing anything from the URL
            // that could leak the UID. The wider page policy stays untouched.
            iframe.referrerPolicy = 'origin';
            iframe.setAttribute('allowfullscreen', '');
            iframe.title = 'Trailer';
            // autoplay=1: the user already pressed "play" on our thumbnail, so
            //   starting playback inline matches their intent (no extra click).
            // rel=0: limit "up next" recommendations to the same channel so
            //   the trailer doesn't end on unrelated suggestions.
            // modestbranding=1: drop the big YouTube watermark; the player
            //   still shows it briefly at the start but the persistent badge
            //   is gone.
            iframe.src = 'https://www.youtube-nocookie.com/embed/' + encodeURIComponent(ytId)
                + '?autoplay=1&rel=0&modestbranding=1';

            // Wipe the thumbnail / play overlay / shade and mount the iframe
            // in the same card so the existing 16:9 aspect-ratio + border-
            // radius styling carries through. The classList swap signals to
            // CSS that we're past hover-affordance territory.
            card.innerHTML = '';
            card.appendChild(iframe);
            card.classList.add('anime-detail-trailer-playing');
            // The card is no longer a "go to YouTube" link, so neutralise
            // the anchor semantics. Keeping the <a> element avoids re-laying
            // out the section, which would otherwise jolt the page.
            card.removeAttribute('href');
            card.removeAttribute('target');
            card.style.cursor = 'default';
        });
    })();
</script>

@* Deferred-extras hydration. The hero + episodes render off
   GetAnimeByIdAsync alone; this script fetches related + recommendations +
   (for non-AniList pages) supplementary chip rows from /anime/{id}/extras
   after the page paints, then reveals the placeholder sections. Skips the
   fetch entirely when there's nothing to populate (no placeholders on the
   page = no upstream call). Anime-only: /anime/extras is an AniList-backed
   endpoint, so the video (movie / series) path skips it — its deferred
   placeholders stay hidden. *@
@if (!isVideo)
{
<script>
    (function () {
        var relatedSection         = document.querySelector('[data-anime-related]');
        var relatedGrid            = document.querySelector('[data-anime-related-grid]');
        var recommendationsSection = document.querySelector('[data-anime-recommendations]');
        var recommendationsGrid    = document.querySelector('[data-anime-recommendations-grid]');
        var supplementaryHost      = document.querySelector('[data-anime-supplementary]');

        // No placeholders on the page = nothing to hydrate; bail before the
        // network call so anonymous fresh-visitors and entries with no AniList
        // mapping don't pay for a 200-empty round-trip.
        if (!relatedSection && !recommendationsSection && !supplementaryHost) return;

        // Route shape: /meta/extras/{*id}. Pull the id slug off the current
        // pathname (anything after /meta/) and prepend /meta/extras/. Trim
        // any trailing slash so /meta/anilist:123/ resolves the same as
        // /meta/anilist:123. Extras is anime-only (this script only runs for
        // the anime path), so no ?type= is needed.
        var idSlug = window.location.pathname.replace(/^\/meta\//, '').replace(/\/$/, '');
        var extrasPath = '/meta/extras/' + idSlug;

        // Render a single Meta card matching the markup _PosterGrid emits for
        // the scroll variant — same class names + nesting so the existing CSS
        // applies without duplication.
        function buildCard(meta) {
            if (!meta || !meta.id) return null;
            var card = document.createElement('a');
            card.className = 'library-card';
            card.href = '/meta/' + meta.id;
            card.title = meta.name || '';
            card.setAttribute('data-meta-id', meta.id);
            card.setAttribute('data-meta-name', meta.name || '');

            var wrap = document.createElement('div');
            wrap.className = 'library-card-poster-wrap';
            // Mirror _PosterGrid: the placeholder ALWAYS renders (its 2:3
            // aspect-ratio establishes the card's box height); the poster is
            // layered over it via position:absolute. Without the placeholder the
            // wrap collapses to zero height and the absolutely-positioned image
            // is invisible — which is why poster-bearing cards showed as
            // text-only. onerror strips a 404'd image so the placeholder shows
            // through instead of a broken-image glyph.
            var placeholder = document.createElement('div');
            placeholder.className = 'library-card-poster-placeholder';
            placeholder.setAttribute('aria-hidden', 'true');
            placeholder.innerHTML =
                '<svg class="library-card-poster-placeholder-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">'
                + '<rect x="3" y="5" width="18" height="14" rx="1.5" stroke="currentColor" stroke-width="1.5" />'
                + '<path d="m4 16 4.2-4.2a1 1 0 0 1 1.4 0L13 15.2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />'
                + '<path d="m11.5 14 2.8-2.8a1 1 0 0 1 1.4 0L20 15.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />'
                + '<circle cx="15.5" cy="9" r="1.25" fill="currentColor" />'
                + '</svg>';
            var phTitle = document.createElement('span');
            phTitle.className = 'library-card-poster-placeholder-title';
            phTitle.textContent = meta.name || '';
            placeholder.appendChild(phTitle);
            wrap.appendChild(placeholder);
            if (meta.poster) {
                var img = document.createElement('img');
                img.className = 'library-card-poster';
                img.src = meta.poster;
                img.alt = meta.name || '';
                img.loading = 'lazy';
                img.decoding = 'async';
                img.onerror = function () { this.remove(); };
                wrap.appendChild(img);
            }
            if (typeof meta.score === 'number' && meta.score > 0) {
                var score = document.createElement('span');
                score.className = 'library-card-score';
                score.textContent = '★ ' + meta.score.toFixed(1);
                wrap.appendChild(score);
            }
            card.appendChild(wrap);

            var title = document.createElement('span');
            title.className = 'library-card-title';
            title.textContent = meta.name || '';
            card.appendChild(title);

            var bits = [];
            if (meta.format) bits.push(meta.format);
            if (typeof meta.episodes === 'number' && meta.episodes > 0) {
                bits.push(meta.episodes + ' ep' + (meta.episodes > 1 ? 's' : ''));
            }
            if (typeof meta.year === 'number' && meta.year > 0) bits.push(String(meta.year));
            if (bits.length > 0) {
                var info = document.createElement('span');
                info.className = 'library-card-meta';
                info.textContent = bits.join(' · ');
                card.appendChild(info);
            }
            return card;
        }

        function fillGrid(section, grid, metas) {
            if (!section || !grid || !metas || metas.length === 0) return;
            metas.forEach(function (meta) {
                var card = buildCard(meta);
                if (card) grid.appendChild(card);
            });
            section.removeAttribute('hidden');
        }

        // Mirrors AnimeDetailViewModel.InternalHrefFor on the server side —
        // map tag / studio / staff role categories onto the in-app browse
        // routes so the chip clicks stay inside the site instead of bouncing
        // to AniList. Returns null when the category isn't routable, in which
        // case the caller falls back to the link's external url.
        function internalHrefFor(link) {
            if (!link) return null;
            var cat = (link.category || '').toLowerCase();
            if (cat === 'tag') {
                return link.name ? '/discover/tag/' + encodeURIComponent(link.name) : null;
            }
            if (cat === 'studio') {
                return link.anilistId ? '/discover/studio/' + link.anilistId : null;
            }
            if (cat === 'staff' || cat === 'director' || cat === 'composer'
                || cat === 'artist' || cat === 'producer' || cat === 'writer') {
                return link.anilistId ? '/discover/staff/' + link.anilistId : null;
            }
            return null;
        }

        function fillSupplementary(host, links) {
            if (!host || !links || links.length === 0) return;
            // Group by category (display label = category, "Links" fallback)
            // mirroring the server-side LINQ groupBy.
            var groups = {};
            var order = [];
            links.forEach(function (link) {
                if (!link || !link.url || !link.name) return;
                var key = link.category || 'Links';
                if (!groups[key]) {
                    groups[key] = [];
                    order.push(key);
                }
                groups[key].push(link);
            });

            order.forEach(function (key) {
                var section = document.createElement('section');
                section.className = 'anime-detail-section';

                var title = document.createElement('h2');
                title.className = 'anime-detail-section-title';
                title.textContent = key;
                section.appendChild(title);

                var ul = document.createElement('ul');
                ul.className = 'anime-detail-link-list';
                groups[key].forEach(function (link) {
                    var li = document.createElement('li');
                    var a = document.createElement('a');
                    a.className = 'anime-detail-link';
                    var internal = internalHrefFor(link);
                    if (internal) {
                        a.href = internal;
                    } else {
                        a.href = link.url;
                        a.target = '_blank';
                        a.rel = 'noreferrer noopener';
                    }
                    a.textContent = link.name;
                    li.appendChild(a);
                    ul.appendChild(li);
                });
                section.appendChild(ul);
                host.appendChild(section);
            });
            host.removeAttribute('hidden');
        }

        // skipLoader: keep the global fetch-wrap loader from showing — this
        // is background hydration, not user-initiated, so a full-screen
        // spinner would be misleading.
        fetch(extrasPath, { headers: { 'Accept': 'application/json' }, skipLoader: true })
            .then(function (r) { return r.ok ? r.json() : null; })
            .then(function (data) {
                if (!data) return;
                // System.Text.Json's web defaults camelCase property names,
                // so the response keys are related / recommendations /
                // supplementaryLinks regardless of the PascalCase used on
                // the AnimeExtrasResponse DTO.
                fillGrid(relatedSection, relatedGrid, data.related);
                fillGrid(recommendationsSection, recommendationsGrid, data.recommendations);
                fillSupplementary(supplementaryHost, data.supplementaryLinks);
            })
            .catch(function () { /* silent — sections just stay hidden */ });
    })();
</script>
}

@* Episode rows navigate to the dedicated /anime/{id}/watch/{ep} page
   (Plyr-based player + source picker + prev/next nav). Future-dated
   episodes don't trigger — nothing to stream yet. We pass season in
   the URL only when the show actually has more than one cour so
   single-season URLs stay clean. *@
<script>
    @* Episode filter — runs independent of the stream-source gate below
       since the filter is useful even when the user has no addons wired
       up (they can still browse + read titles). Pure DOM filter, no
       network. *@
    (function () {
        var filter = document.querySelector('[data-episodes-filter]');
        var list = document.querySelector('.anime-detail-episodes');
        if (!filter || !list) return;
        var rows = list.querySelectorAll('li.anime-detail-episode');
        if (rows.length === 0) return;

        function apply() {
            var q = filter.value.trim().toLowerCase();
            for (var i = 0; i < rows.length; i++) {
                var li = rows[i];
                if (!q) {
                    li.classList.remove('anime-detail-episode-filtered');
                    continue;
                }
                var num = (li.getAttribute('data-episode-num') || '').toLowerCase();
                var titleEl = li.querySelector('.anime-detail-episode-title');
                var title = (titleEl && titleEl.textContent ? titleEl.textContent : '').toLowerCase();
                var match = num === q || num.indexOf(q) !== -1 || title.indexOf(q) !== -1;
                li.classList.toggle('anime-detail-episode-filtered', !match);
            }
        }

        filter.addEventListener('input', apply);
        filter.addEventListener('keydown', function (e) {
            if (e.key === 'Escape' && filter.value !== '') {
                filter.value = '';
                apply();
            }
        });
    })();

    (function () {
        var animeId = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.Anime?.id));
        // Always "/meta"; the media type rides the ?type= query (empty for anime).
        var basePath = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(basePath));
        var typeQuery = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(typeQuery));
        if (!animeId) return;

        // Episode rows always navigate to /watch now — even without a
        // stream addon / External services wired up, the watch page renders
        // the source picker and a "set up streaming" prompt. Future episodes
        // are still skipped in handleEpisodeActivate().
        var episodesList = document.querySelector('.anime-detail-episodes');
        if (!episodesList) return;

        // Walk the rendered rows once to learn whether we have multiple
        // cours — same data the server used to pick season tabs, just
        // derived from the DOM so we don't have to plumb it through
        // ViewBag. Single-cour shows omit the season segment from the
        // URL to keep it short.
        var seasons = new Set();
        episodesList.querySelectorAll('li.anime-detail-episode').forEach(function (li) {
            seasons.add(li.getAttribute('data-season-num') || '1');
        });
        var hasMultipleSeasons = seasons.size > 1;

        function handleEpisodeActivate(li) {
            if (!li || li.classList.contains('anime-detail-episode-future')) return;
            var ep = parseInt(li.getAttribute('data-episode-num'), 10);
            var season = parseInt(li.getAttribute('data-season-num'), 10);
            if (!ep || ep <= 0) return;
            var idSeg = encodeURIComponent(animeId);
            var href = hasMultipleSeasons && !isNaN(season)
                ? basePath + '/' + idSeg + '/watch/' + season + '/' + ep + typeQuery
                : basePath + '/' + idSeg + '/watch/' + ep + typeQuery;
            window.location.assign(href);
        }

        episodesList.addEventListener('click', function (e) {
            // Ignore clicks from inside any interactive child the row may
            // grow later (quick-mark +1 button etc.) — they handle their
            // own behaviour.
            if (e.target.closest('button, a, [data-no-stream]')) return;
            var li = e.target.closest('li.anime-detail-episode');
            handleEpisodeActivate(li);
        });
        episodesList.addEventListener('keydown', function (e) {
            if (e.key !== 'Enter' && e.key !== ' ') return;
            var li = e.target.closest('li.anime-detail-episode');
            if (!li) return;
            e.preventDefault();
            handleEpisodeActivate(li);
        });
    })();
</script>
<script>
    // Stremio source chip — try the native app via the stremio:// custom
    // protocol first, fall back to the web app when no handler claims it.
    //
    // The pattern is the same one Slack / Discord / Spotify use for their
    // "open in app" deep links: fire the protocol URL on the current tab,
    // watch the page for visibilitychange / blur / pagehide. If the OS
    // hands off to a registered Stremio handler within ~1.5s the page
    // loses focus and we leave it alone — when the user comes back from
    // the app they're still on the same anime detail page they clicked
    // from. If nothing claims the protocol in time we navigate the
    // current tab to the web Stremio URL so the click isn't a no-op
    // (browser back restores the detail page on return).
    //
    // We deliberately don't pre-open a placeholder tab here: window.open
    // for a foreground _blank target fires blur / visibilitychange on
    // the source tab itself, which is indistinguishable from the OS
    // handing off to a native handler. The earlier placeholder version
    // tripped on that — every click looked like a successful app launch.
    //
    // The anchor's href stays pointed at the web fallback so right-click
    // "open in new tab", middle-click, copy-link, and no-JS scrapers all
    // resolve to a working URL without going through this handler.
    (function () {
        document.querySelectorAll('.source-chip-stremio[data-stremio-app-url]').forEach(function (chip) {
            chip.addEventListener('click', function (e) {
                var appUrl = this.dataset.stremioAppUrl;
                var webUrl = this.href;
                if (!appUrl) return;
                // Defer to default behaviour for modifier-click /
                // middle-click — those are explicit "open in new tab"
                // gestures and shouldn't be swallowed.
                if (e.metaKey || e.ctrlKey || e.shiftKey || e.altKey || e.button === 1) return;

                e.preventDefault();

                // Loading state on the chip so the ~1.5s app-probe
                // window doesn't read as a frozen click. Stores the
                // original markup so it can be restored after the
                // probe resolves (either branch). Doesn't disable the
                // chip — the click already preventDefault'd so a
                // re-click would just re-fire the same probe.
                if (!chip.dataset.originalContent) {
                    chip.dataset.originalContent = chip.innerHTML;
                }
                chip.classList.add('is-loading');
                chip.innerHTML = '<span class="source-chip-mark" aria-hidden="true">' +
                    '<span class="source-chip-spinner" role="status" aria-label="Opening…"></span>' +
                    '</span><span class="source-chip-label">Opening…</span>';

                // App-handoff signal. On mobile + on desktop the
                // browser tab going `hidden` is a reliable cue (OS
                // switches to the Stremio app on mobile; on desktop
                // it depends on window-manager focus rules). On
                // desktop Linux / Windows where Stremio opens in a
                // separate window without minimising the browser,
                // visibilitychange doesn't fire — but `blur` does
                // when focus moves to the new app window. We listen
                // for both, and discount signals that arrive within
                // 250ms of the click since those are almost always
                // synthetic (browser-internal focus shifts from
                // window.location.href / DOM mutation, not the OS
                // handing off to an app).
                var appClaimed = false;
                var clickTime = Date.now();
                var claim = function () {
                    if (Date.now() - clickTime < 250) return;
                    appClaimed = true;
                };
                document.addEventListener('visibilitychange', claim);
                window.addEventListener('blur', claim);
                window.addEventListener('pagehide', claim);

                // Trigger the stremio:// scheme on the current tab,
                // but defer it past the next paint so the spinner has
                // a chance to render + start animating before the
                // browser's "Allow this site to open stremio?" prompt
                // appears and pauses page animations. Without the
                // defer, the protocol call runs synchronously after
                // the DOM mutation and the user sees a frozen
                // C-shape because the spinner never reached its
                // first animated frame.
                //
                // On mobile with the app installed the OS switches
                // focus to Stremio (no current-tab navigation
                // happens). On desktop with a registered handler the
                // browser shows its built-in "Allow…" prompt without
                // leaving the page. On systems without a handler
                // modern browsers either silently no-op (mobile) or
                // briefly attempt navigation and stay on a protocol-
                // error page — the timeout fallback below papers
                // over that case by opening the web Stremio URL in a
                // new tab.
                setTimeout(function () {
                    try { window.location.href = appUrl; } catch (_) { }
                }, 250);

                // 3000ms is long enough for the user to see + dismiss
                // a "Allow this site to open stremio?" prompt before
                // the no-app fallback fires. Shorter timeouts (1500
                // was the previous value) raced the prompt — the
                // fallback tab opened while the user was still
                // deciding, ending up with both the app launching
                // AND a web tab in the background.
                setTimeout(function () {
                    document.removeEventListener('visibilitychange', claim);
                    window.removeEventListener('blur', claim);
                    window.removeEventListener('pagehide', claim);

                    // Restore the chip regardless of which branch we
                    // take below — the user will either be on the
                    // Stremio app, the new web tab, or here looking
                    // at the chip in its restored state.
                    chip.classList.remove('is-loading');
                    if (chip.dataset.originalContent) {
                        chip.innerHTML = chip.dataset.originalContent;
                        delete chip.dataset.originalContent;
                    }

                    if (appClaimed || document.hidden) return;

                    // No app handler claimed the deep link in time —
                    // open the web fallback in a new tab. `noopener`
                    // is intentionally omitted so window.open returns
                    // a real window reference we can inspect — with
                    // noopener set it always returns null, which made
                    // us unable to tell a successful popup from a
                    // popup-blocked one and fall back to navigating
                    // the original tab (which the user explicitly
                    // doesn't want — the click should never disturb
                    // the page they came from).
                    try { window.open(webUrl, '_blank'); }
                    catch (_) { /* popup-blocked — silent no-op,
                                   never navigate the original tab */ }
                }, 3000);
            });
        });
    })();
</script>
