@model CalendarViewModel
@{
    ViewData["Title"] = "Calendar";
}

<div class="container cal-page">
    <header class="cal-header">
        <div class="cal-title-group">
            <h1 class="cal-title">Calendar</h1>
            <p class="cal-sub">Recent &amp; upcoming episodes from your anime Watching list and your Trakt series.</p>
        </div>
        <div class="cal-nav">
            <a class="cal-nav-btn" href="/calendar?y=@Model.PrevYear&m=@Model.PrevMonth" aria-label="Previous month" rel="prev">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 18l-6-6 6-6" /></svg>
            </a>
            <span class="cal-month-label">@Model.MonthLabel</span>
            <a class="cal-nav-btn" href="/calendar?y=@Model.NextYear&m=@Model.NextMonth" aria-label="Next month" rel="next">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 18l6-6-6-6" /></svg>
            </a>
            @if (!Model.IsCurrentMonth)
            {
                <a class="cal-today-btn" href="/calendar">Today</a>
            }
        </div>
    </header>

    <div class="cal-legend" aria-hidden="true">
        <span class="cal-legend-item"><span class="cal-dot cal-dot-anime"></span> Anime</span>
        <span class="cal-legend-item"><span class="cal-dot cal-dot-series"></span> Series</span>
    </div>

    @if (Model.TotalEpisodes == 0)
    {
        <div class="cal-empty">
            No episodes scheduled this month for the shows you're tracking. Episodes show up here once
            they're on your anime <strong>Watching</strong> list or your Trakt <strong>Watching</strong> / <strong>Planning</strong> lists.
        </div>
    }

    <div class="cal-grid" role="grid" aria-label="@Model.MonthLabel">
        <div class="cal-weekdays" role="row">
            @foreach (var w in CalendarViewModel.WeekdayLabels)
            {
                <div class="cal-weekday" role="columnheader">@w</div>
            }
        </div>
        <div class="cal-days">
            @foreach (var day in Model.Days)
            {
                <div class="cal-day@(day.InMonth ? "" : " cal-day-out")@(day.IsToday ? " cal-day-today" : "")" role="gridcell">
                    <div class="cal-day-num">@day.Date.Day</div>
                    @if (day.Episodes.Count > 0)
                    {
                        <div class="cal-day-eps">
                            @foreach (var ep in day.Episodes)
                            {
                                var label = ep.Season.HasValue ? $"S{ep.Season}E{ep.Episode}" : $"Ep {ep.Episode}";
                                <a class="cal-ep cal-ep-@ep.Kind" href="@ep.LinkPath" title="@ep.Title · @label">
                                    @if (!string.IsNullOrEmpty(ep.CoverImage))
                                    {
                                        <img class="cal-ep-thumb" src="@ep.CoverImage" alt="" loading="lazy" decoding="async" />
                                    }
                                    else
                                    {
                                        <span class="cal-ep-thumb cal-ep-thumb-ph" aria-hidden="true"></span>
                                    }
                                    <span class="cal-ep-text">
                                        <span class="cal-ep-title">@ep.Title</span>
                                        <span class="cal-ep-meta">@label</span>
                                    </span>
                                </a>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>
