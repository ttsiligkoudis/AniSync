@model CalendarViewModel
@{
    ViewData["Title"] = "Calendar";
}

<div class="container cal-page">
    <header class="cal-header">
        <div class="cal-title-group">
            <h1 class="cal-title">Calendar</h1>
            <p class="cal-sub">Recent &amp; upcoming episodes from your anime Watching list and your Trakt series.</p>
        </div>
        <div class="cal-nav">
            <a class="cal-nav-btn" href="/calendar?d=@Model.PrevDate" aria-label="Previous week" rel="prev">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 18l-6-6 6-6" /></svg>
            </a>
            <span class="cal-month-label">@Model.RangeLabel</span>
            <a class="cal-nav-btn" href="/calendar?d=@Model.NextDate" aria-label="Next week" rel="next">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 18l6-6-6-6" /></svg>
            </a>
            @if (!Model.IsCurrentWeek)
            {
                <a class="cal-today-btn" href="/calendar">This week</a>
            }
        </div>
    </header>

    <div class="cal-legend" aria-hidden="true">
        <span class="cal-legend-item"><span class="cal-dot cal-dot-anime"></span> Anime</span>
        <span class="cal-legend-item"><span class="cal-dot cal-dot-series"></span> Series</span>
    </div>

    @if (Model.TotalEpisodes == 0)
    {
        <div class="cal-empty">
            No episodes scheduled this week for the shows you're tracking. Episodes show up here once
            they're on your anime <strong>Watching</strong> list or your Trakt <strong>Watching</strong> / <strong>Planning</strong> lists.
        </div>
    }

    <div class="cal-week">
        @foreach (var day in Model.Days)
        {
            <section class="cal-wday@(day.IsToday ? " cal-wday-today" : "")">
                <div class="cal-wday-head">
                    <span class="cal-wday-dow">@day.Date.ToString("dddd")</span>
                    <span class="cal-wday-date">@day.Date.ToString("MMM d")</span>
                    @if (day.IsToday)
                    {
                        <span class="cal-wday-badge">Today</span>
                    }
                </div>
                @if (day.Episodes.Count == 0)
                {
                    <div class="cal-wday-empty">No episodes</div>
                }
                else
                {
                    <div class="cal-wday-eps">
                        @foreach (var ep in day.Episodes)
                        {
                            var label = ep.Season.HasValue ? $"S{ep.Season}E{ep.Episode}" : $"Ep {ep.Episode}";
                            var utcTime = DateTimeOffset.FromUnixTimeSeconds(ep.AiringAt).UtcDateTime.ToString("HH:mm");
                            <a class="cal-row cal-row-@ep.Kind" href="@ep.LinkPath" title="@ep.Title">
                                @if (!string.IsNullOrEmpty(ep.CoverImage))
                                {
                                    <img class="cal-row-thumb" src="@ep.CoverImage" alt="" loading="lazy" decoding="async" />
                                }
                                else
                                {
                                    <span class="cal-row-thumb cal-row-thumb-ph" aria-hidden="true"></span>
                                }
                                <span class="cal-row-body">
                                    <span class="cal-row-title">@ep.Title</span>
                                    <span class="cal-row-meta">
                                        <span class="cal-row-time" data-ts="@ep.AiringAt">@utcTime</span>
                                        <span class="cal-row-sep">·</span>
                                        <span class="cal-row-ep">@label</span>
                                        <span class="cal-row-sep">·</span>
                                        <span class="cal-row-kind">@(ep.Kind == "anime" ? "Anime" : "Series")</span>
                                    </span>
                                </span>
                            </a>
                        }
                    </div>
                }
            </section>
        }
    </div>
</div>

@* Localise the air time from the Unix timestamp; falls back to the
   server-rendered UTC HH:mm when JS is off. (Day grouping stays UTC.) *@
<script>
    (function () {
        document.querySelectorAll('.cal-row-time[data-ts]').forEach(function (el) {
            var ts = parseInt(el.getAttribute('data-ts'), 10);
            if (!ts) return;
            try {
                el.textContent = new Date(ts * 1000)
                    .toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
            } catch (_) { /* keep the UTC fallback */ }
        });
    })();
</script>
