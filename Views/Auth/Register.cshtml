@{
    ViewData["Title"] = "Create Kitsu account";
    var error = ViewBag.Error as string;
    var name = ViewBag.Name as string;
    var email = ViewBag.Email as string;
}

<header class="page-header">
    <h1 class="page-title">Create Kitsu account</h1>
    <p class="page-subtitle">Sign up directly through Kitsu — AniSync will log you in once your account exists.</p>
</header>

<div class="card-section" style="max-width: 28rem; margin: 0 auto;">
    @if (!string.IsNullOrEmpty(error))
    {
        <div class="register-error" role="alert">@error</div>
    }

    <form method="post" action="@Url.Action("Register", "Auth")" autocomplete="on">
        <div class="cred-group">
            <label for="name" class="required">Username</label>
            <input type="text" id="name" name="name" value="@name" required autocomplete="username" />
        </div>
        <div class="cred-group">
            <label for="email" class="required">Email</label>
            <input type="email" id="email" name="email" value="@email" required autocomplete="email" />
        </div>
        <div class="cred-group">
            <label for="password" class="required">Password</label>
            <input type="password" id="password" name="password" required minlength="8" autocomplete="new-password" />
        </div>
        <div class="cred-group">
            <label for="confirmPassword" class="required">Confirm password</label>
            <input type="password" id="confirmPassword" name="confirmPassword" required minlength="8" autocomplete="new-password" />
        </div>
        <p class="option-name-sub" style="margin: 0.25rem 0 0.75rem;">
            Your account is created on Kitsu directly — AniSync only sees the password
            long enough to obtain an OAuth token, then drops it from memory.
            Kitsu will email you a confirmation link; clicking it is optional for
            AniSync (you'll already be logged in here) but recommended to fully
            activate your Kitsu account on their site.
        </p>
        <button type="submit" class="btn-primary-action btn-login">Create account</button>
    </form>

    <p class="hint-text" style="margin-top: 0.75rem;">
        Already have an account? <a href="@Url.Action("Configure", "Home")">Back to login</a>.
    </p>
    <p class="hint-text" style="margin-top: 0.25rem;">
        Want AniList or MyAnimeList instead? Sign up on
        <a href="https://anilist.co/signup" target="_blank" rel="noopener noreferrer">AniList</a>
        or
        <a href="https://myanimelist.net/register.php" target="_blank" rel="noopener noreferrer">MyAnimeList</a>,
        then come back and log in.
    </p>
</div>
