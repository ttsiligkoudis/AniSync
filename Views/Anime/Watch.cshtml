                        // track is available. Anime fansubs are
                        // overwhelmingly English-default and almost
                        // always beat OpenSubtitles on timing /
                        // accuracy, so when it's there we want it
                        // selected without an extra click. If the
                        // file has no English embedded track we
                        // explicitly leave the current selection
                        // alone — a surprise Spanish / Russian /
                        // Arabic auto-pick is worse than just
                        // surfacing the embedded entries in the menu
                        // for the user to pick from manually.
                        //
                        // Detection looks at BOTH the language tag
                        // and the TrackName, because fansub muxers
                        // routinely leave Language="und" while
                        // setting TrackName="English [SubsPlease]"
                        // or similar. Either signal alone is enough.
                        var englishTrack = null;
                        for (var i = 0; i < full.length; i++) {
                            var t = full[i];
                            var lang = (t.language || '').toLowerCase();
                            var name = (t.name || '').toLowerCase();
                            if (lang.indexOf('en') === 0 ||
                                /\benglish\b/.test(name) ||
                                /\beng\b/.test(name)) {
                                englishTrack = t;
                                break;
                            }
                        }
                        if (englishTrack && englishTrack.data) {
                            applySubtitle({
                                kind: 'ass',
                                html: (englishTrack.label || 'Embedded') + ' SSA',
                                trackData: englishTrack.data,
                            });
                            try {
                                console.info(
                                    '[AniSync] embedded auto-promoted — ' +
                                    (englishTrack.cues || []).length + ' cues, ' +
                                    'OS pool size=' + (subtitles || []).length);
                            } catch (_) {}
                            // Auto-handover from embedded SSA to a same-
                            // language OS track at the end of the embedded
                            // cue range. The streaming extractor's
                            // tail-gated early-exit means embedded cues
                            // typically stop at the start of the credit
                            // roll — any post-credit dialogue (stinger
                            // scene, preview narration) would otherwise
                            // play unsubtitled. Switching to a matching
                            // OS track at that boundary preserves
                            // coverage without giving up the embedded
                            // styling for the main episode body.
                            setupEmbeddedToOsHandover(englishTrack, subtitles, function () {
                                refreshSubtitleSelector(buildSubtitleSelector);
                            });
                        } else {
                            try {
                                console.info(
                                    '[AniSync] no English embedded track to auto-promote (full=' +
                                    full.length + ')');
                            } catch (_) {}
                        }
                        // Rebuild AFTER applySubtitle so the menu's
                        // "default" markers reflect the new active
                        // entry (or stay on the original pick when no
                        // English embedded track was found).
                        refreshSubtitleSelector(buildSubtitleSelector);
                    });
            }

            // ── AniSkip skip-intro / skip-outro overlay ───────────────
            // Shows a corner-anchored button when the playhead enters
            // the intro or outro range. Click → seek to range.end + 1s
            // (the +1s puts the user just past the marker so they don't
            // immediately re-enter the trigger zone). Auto-skip is
            // persisted in localStorage so the user can flip it on once
            // and forget about it across episodes.
            var skipButton = document.getElementById('watchSkipButton');
            var skipAutoBtn = document.getElementById('watchSkipAuto');
            var embedStatusEl = document.getElementById('watchEmbeddedStatus');
            var subsProviderEl = document.getElementById('watchSubsProvider');

