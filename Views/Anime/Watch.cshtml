            // into a raw classifier + an opt-in-aware wrapper so the
            // toolbar toggle can render based on the raw signal while
            // the extractor consults the user's persisted preference.
            function classifyNetwork() {
                try {
                    var ua = navigator.userAgent || '';
                    var isMobile = /Mobi|Mobile|Android|iPhone|iPad|iPod/i.test(ua);

                    var c = navigator.connection
                        || navigator.mozConnection
                        || navigator.webkitConnection;

                    if (c) {
                        if (c.saveData) return 'data-saver';
                        if (c.type === 'cellular') return 'cellular';
                        var et = c.effectiveType;
                        if (et === 'slow-2g' || et === '2g' || et === '3g') return 'slow-connection';
                        if (typeof c.downlink === 'number' && c.downlink > 0 && c.downlink < 1.5) {
                            return 'low-bandwidth';
                        }
                        // Mobile UA: require positive wifi/ethernet from
                        // connection.type. type is a mobile-only field
                        // (Chrome Android sets it correctly; desktop
                        // Chrome doesn't expose it at all) — its absence
                        // on a mobile UA means we're on a farbled browser.
                        if (isMobile && c.type !== 'wifi' && c.type !== 'ethernet') {
                            return 'mobile-unknown-network';
                        }
                    } else if (isMobile) {
                        // No Network Information API at all (Safari iOS).
                        return 'mobile-unknown-network';
                    }
                } catch (_) {}
                return null;
            }

            // Reasons that the toolbar toggle can override. saveData /
            // slow-connection / low-bandwidth stay hard-skips even when
            // the opt-in is on — Data Saver is an explicit user
            // preference we shouldn't second-guess, and the bandwidth
            // floors are about whether the extraction can actually
            // succeed, not whether the user is willing to pay for it.
            var OPTIN_OVERRIDES = { 'cellular': 1, 'mobile-unknown-network': 1 };

            function networkSkipReason() {
                var reason = classifyNetwork();
                if (reason && OPTIN_OVERRIDES[reason]) {
                    try {
                        if (localStorage.getItem(EMBED_MOBILE_OPTIN_KEY) === '1') {
                            return null;
                        }
                    } catch (_) {}
                }
                return reason;
            }

            function resolveStreamUrl(originalUrl, signal) {
                return new Promise(function (resolve, reject) {
                    var TIMEOUT_MS = 25000;     // total budget incl. retries
                    var MAX_ATTEMPTS = 5;
                    var done = false;
                    var observer = null;
                    var attempts = 0;
                    var retryTimer = null;

                    function finish(u, viaReject) {
                        if (done) return;
                        done = true;
                        if (observer) { try { observer.disconnect(); } catch (_) {} }
                        if (retryTimer) { clearTimeout(retryTimer); retryTimer = null; }
                        if (viaReject) reject(u); else resolve(u);
                    }

                    function tryServerResolve() {
                        attempts++;
                        fetch('/anime/resolve-stream?url=' + encodeURIComponent(originalUrl), {
                            credentials: 'same-origin',
                            headers: { 'Accept': 'application/json' },
                            signal: signal,
                            // The watch page already has visible
                            // loading chrome for the source pick; the
                            // global overlay on top would just double
                            // up.
                            skipLoader: true,
                        })
                            .then(function (r) { return r.ok ? r.json() : null; })
                            .then(function (data) {
                                if (done) return;
                                var u = data && data.resolvedUrl;
                                if (u) {
                                    try {
                                        if (CDN_HOST_RE.test(new URL(u).hostname)) {
                                            finish(u);
                                            return;
                                        }
                                    } catch (_) {}
                                }
                                // Server returned but didn't give us
                                // a CDN host — Torrentio likely hadn't
                                // resolved yet. Back off and try
                                // again; later attempts usually
                                // succeed once the player has touched
                                // the resolver itself.
                                scheduleRetry();
                            })
                            .catch(function () { scheduleRetry(); });
                    }

                    function scheduleRetry() {
                        if (done) return;
                        if (attempts >= MAX_ATTEMPTS) {
                            finish(new Error('resolve failed after ' + MAX_ATTEMPTS + ' attempts'), true);
                            return;
                        }
                        // 1s, 2s, 3s, 4s — gives the upstream chain
                        // time to warm.
                        retryTimer = setTimeout(tryServerResolve, 1000 * attempts);
                    }

                    // Resource Timing fast-path. Wins on browsers
                    // that DO record the post-redirect URL via
                    // <video>; harmless otherwise.
                    function findResolved() {
                        try {
                            var entries = performance.getEntriesByType('resource');
                            for (var i = entries.length - 1; i >= 0; i--) {
                                var name = entries[i].name;
                                try {
                                    if (CDN_HOST_RE.test(new URL(name).hostname)) return name;
                                } catch (_) { /* not a URL */ }
                            }
                        } catch (_) { /* timing API unavailable */ }
                        return null;
                    }

                    var hit = findResolved();
                    if (hit) { finish(hit); return; }

                    try {
                        observer = new PerformanceObserver(function () {
                            var h = findResolved();
                            if (h) finish(h);
                        });
                        observer.observe({ entryTypes: ['resource'] });
                    } catch (_) { /* fall back to server-side path */ }

                    tryServerResolve();

                    if (signal) {
                        signal.addEventListener('abort', function () {
                            finish(new Error('aborted'), true);
                        });
                    }
                    setTimeout(function () {
                        finish(new Error('resolve timeout'), true);
                    }, TIMEOUT_MS);
                });
            }

            // Stream the MKV via Range-aware fetch into
            // matroska-subtitles, accumulate per-track cues, and on
            // completion build a renderable ASS document for each
            // track. Progressive callback (onTracks) fires as soon
            // as the parser sees the Tracks element so the menu can
            // surface entries before full parse completes — final
            // (onComplete) fires once cue accumulation is done.
            function extractEmbeddedSubs(url, onTracks, onComplete) {
                var abortCtl = new AbortController();

                // Bandwidth-aware short-circuit. If the browser tells
                // us we're on cellular / Data Saver / slow connection,
                // don't pull the MKV through cf-cors-proxy — it can
                // be 700 MB-1.5 GB of the user's bandwidth and almost
                // certainly not what they want. OpenSubtitles still
                // populates the menu via its own JSON-sized fetch,
                // so users get something usable either way.
                var skipReason = networkSkipReason();
                if (skipReason) {
                    var label = {
                        'data-saver': 'Data Saver on',
                        'cellular': 'cellular connection',
                        'slow-connection': 'slow connection',
                        'low-bandwidth': 'low bandwidth',
                        'mobile-unknown-network': "couldn't confirm wifi on mobile",
                    }[skipReason] || skipReason;
                    try {
                        console.info('[AniSync] embedded extraction skipped:', skipReason);
                    } catch (_) {}
                    setEmbedStatus('Skipped — ' + label, 'none');
                    onComplete([]);
                    return abortCtl;
                }

                // Resolve the URL we'll actually fetch from. Three
                // outcomes for CORS-blocked hosts (debrid CDNs +
                // Torrentio resolver):
                //   * No CORS_PROXY_URL → skip silently. The pill
                //     stays hidden, OpenSubtitles fills the menu.
                //   * Proxy configured + Torrentio URL → wait for
                //     <video> to follow the redirect and capture the
                //     resolved debrid-CDN URL via Resource Timing,
                //     then route THAT through the proxy. (Going
                //     through the Worker directly to Torrentio trips
                //     Cloudflare's bot-block; going to RD doesn't.)
                //   * Proxy configured + URL already on a debrid CDN
                //     → route directly through the proxy.
                // Resolve to TWO URLs:
                //   direct  — the bare CDN URL the indexed extractor
                //             Worker needs (post-Torrentio-redirect).
                //   stream  — the cf-cors-proxy-wrapped URL the
                //             streaming matroska-subtitles fallback
                //             feeds into fetch(). Always falls back
                //             to the original URL when no proxy is set
                //             (will fail at fetch time, surfaces the
                //             "support unavailable" error rather than
                //             hanging).
                var urlPromise;
                if (isCorsBlockedHost(url)) {
                    // The in-process indexed extractor doesn't need a
                    // CORS proxy — it fetches RD bytes server-side.
                    // Only bail when both are unavailable, which now
                    // just means "no cors-proxy configured" since the
                    // in-process extractor is always present.
                    if (!CORS_PROXY_URL) {
                        setEmbedStatus(null);
                        onComplete([]);
                        return abortCtl;
                    }
                    setEmbedStatus('Waiting for stream URL…', 'loading');
                    var originalUrl = url;
                    urlPromise = resolveStreamUrl(originalUrl, abortCtl.signal).then(function (resolved) {
                        return {
                            direct: resolved,
                            stream: viaCorsProxy(resolved) || viaCorsProxy(originalUrl),
                        };
                    });
                } else {
                    urlPromise = Promise.resolve({ direct: url, stream: url });
                }

                urlPromise.then(function (urls) {
                    if (abortCtl.signal.aborted) return;

                    // Streaming extraction via matroska-subtitles +
                    // cf-cors-proxy. Pulls the MKV through the user's
                    // browser and parses subs as bytes arrive. Slower
                    // than indexed Range fetching could be in theory,
                    // but the only path that worked reliably across
                    // every variant of indexed extractor we tried
                    // (cf-mkv-extractor JS, the Rust port, and the
                    // in-process C# port were all defeated by RD's
                    // edges throttling deep-offset Range requests
                    // from non-residential IPs). See the lang=auto
                    // English filter + tail-gated early-exit inside
                    // runExtraction for the bandwidth-saving bits.
                    setEmbedStatus('Looking for embedded subtitles…', 'loading');
                    url = urls.stream;
                    var readyPromise = window.subtitleLibsReady
                        || Promise.resolve({ matroska: false, jassub: false });
                    readyPromise.then(function (status) {
                        if (abortCtl.signal.aborted) return;
                        if (!status.matroska || typeof MatroskaSubtitles === 'undefined' || !MatroskaSubtitles.SubtitleParser) {
                            setEmbedStatus('Embedded-subtitle support unavailable', 'error');
                            onComplete([]);
                            return;
                        }
                        runExtraction();
                    }).catch(function (e) {
                        console.warn('embedded sub readiness chain failed:', e);
                        onComplete([]);
                    });
                }, function (err) {
                    // Stream-URL resolve rejected — typically means
                    // Torrentio didn't surface a CDN URL within the
                    // retry budget. Going to Torrentio through the
                    // Worker would just hit Cloudflare's bot-block
                    // again, so skip extraction quietly: hide the
                    // pill, fire onComplete([]), let OpenSubtitles /
                    // OpenSubtitles carries the subtitle UX for this pick.
                    if (abortCtl.signal.aborted) return;
                    console.info('embedded sub extraction skipped — resolve never returned a CDN URL:', err && err.message);
                    setEmbedStatus(null);
                    onComplete([]);
                });
                return abortCtl;

                function runExtraction() {
                    if (abortCtl.signal.aborted) return;
                    var parser;
                    try { parser = new MatroskaSubtitles.SubtitleParser(); }
                    catch (e) {
                        // Surface the actual error so we can see whether
                        // it's a missing-API problem (Buffer / stream
                        // polyfills), a different export shape, or a
                        // genuine bug in the parser. Truncated to keep
                        // the pill readable.
                        var msg = (e && e.message) ? String(e.message) : 'unknown error';
                        console.warn('matroska parser init threw:', e);
                        setEmbedStatus('Parser init failed: ' + msg.slice(0, 80), 'error');
                        onComplete([]);
                        return;
                    }

                var trackMeta = [];   // [{ number, language, codecID, header }]
                var trackCues = {};   // number → array of { time, duration, text }

                // lang=auto behaviour: mirror the cf-mkv-extractor
                // Worker — collect cues only from the first English-
                // tagged track. Anything else falls through to the
                // OpenSubtitles path the same way an
                // English-less Worker response does. -1 means "we
                // haven't decided yet", > 0 is a real EBML track
                // number, 0 means "no English track found, drop
                // everything." Decided in the 'tracks' handler.
                var targetTrackNumber = -1;

                // Early-exit heuristic — bail once we're plausibly
                // past the dialogue region. Two-stage gate so we
                // don't false-trigger during the OP. Anime opening
                // credits run ~90 seconds with zero subtitle events
                // (no track has lyrics during the OP for most
                // releases), which at typical 1080p MKV bitrate is
                // ~85-130 MB of file bytes — almost identical to a
                // post-credits silent tail. We can't tell them
                // apart from cue-gap alone, so we use file position
                // as the discriminator:
                //
                //   * Mid-file gap (< 85% of Content-Length): keep
                //     reading. The OP lives here and it WILL go
                //     quiet for a minute or two.
                //   * Tail-of-file gap (>= 85%): bail after a small
                //     30 MB cue-less stretch. By this point dialogue
                //     is over and what remains is credits + preview.
                //
                // When Content-Length is missing (some CDNs use
                // chunked transfer) we fall back to a very loose
                // pure-gap threshold that won't trip on a typical
                // OP. In that branch we lose the byte savings but
                // keep correctness.
                var EARLY_EXIT_TAIL_FRACTION = 0.85;
                var EARLY_EXIT_GAP_IN_TAIL = 30 * 1024 * 1024;
                var EARLY_EXIT_GAP_NO_LENGTH = 400 * 1024 * 1024;
                var totalBytesRead = 0;
                var contentLength = 0;
                var lastCueByteOffset = 0;
                var seenAnyCue = false;
                var earlyExited = false;

                function isEnglishTrack(t) {
                    var l = (t.language || '').toLowerCase();
                    var n = (t.name || '').toLowerCase();
                    return l.indexOf('en') === 0 || /\benglish\b/.test(n) || /\beng\b/.test(n);
                }

                parser.once('tracks', function (tracks) {
                    trackMeta = tracks.map(function (t) {
                        // Track names are the most reliable English-
                        // detection signal on releases that left
                        // language tagged as "und" — fansubs usually
                        // set the TrackName to something like
                        // "English [SubsPlease]" even when they
                        // skip the Language element. Capture it
                        // explicitly so the auto-promote and menu
                        // label paths can read it.
                        var name = t.name || '';
                        return {
                            number: t.number,
                            language: t.language || 'und',
                            name: name,
                            codecID: t.type || '',
                            header: t.header || '',
                            // Friendly label: track name (when the
                            // mux set one) wins because it's almost
                            // always a real word — "English",
                            // "Signs & Songs", "[GroupName]". Falls
                            // back to ISO-639-2/B → friendly when
                            // there's no name to lean on. Anime
                            // sometimes ships with non-standard or
                            // empty language entries.
                            label: name || prettyLanguage(t.language),
                        };
                    });
                    try {
                        console.log('[AniSync] embedded tracks seen:', trackMeta.map(function (t) {
                            return {
                                number: t.number,
                                language: t.language,
                                codecID: t.codecID,
                                headerLength: (t.header || '').length,
                                hasStyles: (t.header || '').indexOf('[V4+ Styles]') >= 0,
                            };
                        }));
                    } catch (_) {}

                    // Pick the first English-tagged track. Mirrors
                    // the cf-mkv-extractor Worker so the streaming
                    // fallback doesn't blow up to 700 MB of MKV
                    // pulled through the browser just to discard
                    // non-English tracks on the way out — the
                    // auto-promote rule downstream would drop them
                    // anyway. 0 means "no English here"; in that
                    // case we abort the extract entirely and let
                    // OpenSubtitles carry the UX, matching
                    // what the Worker does when its lang=auto
                    // filter returns empty.
                    var english = null;
                    for (var i = 0; i < trackMeta.length; i++) {
                        if (isEnglishTrack(trackMeta[i])) { english = trackMeta[i]; break; }
                    }
                    if (english) {
                        targetTrackNumber = english.number;
                        trackMeta = [english];
                    } else {
                        targetTrackNumber = 0;
                        trackMeta = [];
                    }

                    if (trackMeta.length > 0) {
                        setEmbedStatus(
                            'Found embedded ' + (english.label || 'English') + ' track — parsing cues…',
                            'loading');
                    } else {
                        setEmbedStatus('No English embedded subtitle in this file', 'none');
                    }
                    // Notify caller that track metadata is available;
                    // the cues themselves still need time to stream
                    // in, but the menu can update with the language
                    // list immediately.
                    onTracks(trackMeta);

                    // No English track — there's nothing for the
                    // streaming pipeline to produce. Bail out now
                    // instead of streaming the whole MKV just to
                    // throw every cue away in the subtitle handler.
                    if (targetTrackNumber === 0) {
                        earlyExited = true;
                        try { parser.end(); } catch (_) {}
                    }
                });
                parser.on('subtitle', function (sub, trackNumber) {
                    // Update the early-exit timer on ANY cue so a
                    // legitimately quiet stretch in the English
                    // track (e.g., action scene with only Japanese
                    // signs / songs on a sibling track) doesn't
                    // false-trigger the bail-out.
                    seenAnyCue = true;
                    lastCueByteOffset = totalBytesRead;
                    if (targetTrackNumber > 0 && trackNumber !== targetTrackNumber) return;
                    (trackCues[trackNumber] = trackCues[trackNumber] || []).push(sub);
                });
                parser.on('finish', function () {
                    var output = trackMeta.map(function (t) {
                        var cues = trackCues[t.number] || [];
                        return Object.assign({}, t, {
                            data: buildAssDocument(t.header, cues),
                            // Surface the raw cue array on the track too —
                            // setupEmbeddedToOsHandover needs to know
                            // where the cue stream ends in playback time
                            // so it can wire the embedded→OS swap to the
                            // right moment, and the timing only lives
                            // here (the .data ASS document has the times
                            // formatted as text inside Dialogue lines).
                            cues: cues,
                        });
                    });
                    try {
                        console.log('[AniSync] embedded extraction finished:', output.map(function (t) {
                            return {
                                number: t.number,
                                language: t.language,
                                codecID: t.codecID,
                                cueCount: (trackCues[t.number] || []).length,
                                dataLength: t.data.length,
                            };
                        }));
                    } catch (_) {}
                    if (output.length > 0) {
                        setEmbedStatus(
                            output.length + ' embedded track' + (output.length === 1 ? '' : 's') + ' ready',
                            'success');
                    } else {
                        setEmbedStatus('No embedded subtitles in this file', 'none');
                    }
                    onComplete(output);
                });
                parser.on('error', function (e) {
                    console.warn('matroska parser error:', e);
                    setEmbedStatus('Embedded-subtitle parse failed', 'error');
                    onComplete([]);
                });

                fetch(url, { signal: abortCtl.signal, skipLoader: true })
                    .then(function (response) {
                        if (!response.ok || !response.body) {
                            onComplete([]);
                            return;
                        }
                        // Content-Length is the discriminator between
                        // "mid-file gap" and "tail gap". May be absent
                        // when the response is chunked or when an
                        // upstream proxy stripped it — in that case
                        // EARLY_EXIT_GAP_NO_LENGTH kicks in below.
                        try {
                            var lenHeader = response.headers.get('content-length');
                            if (lenHeader) contentLength = parseInt(lenHeader, 10) || 0;
                        } catch (_) {}
                        try {
                            console.log('[AniSync] embedded sub stream start: content-length=' +
                                (contentLength ? Math.round(contentLength / (1024 * 1024)) + ' MB' : 'unknown'));
                        } catch (_) {}
                        var reader = response.body.getReader();
                        function pump() {
                            // Cooperative bail-out: the 'tracks'
                            // handler can decide there's no English
                            // track and flip earlyExited, and the
                            // gap check below can do the same when
                            // we drift past the dialogue region.
                            // Both paths want the network closed
                            // promptly so the browser doesn't keep
                            // pulling MKV bytes we'll never look at.
                            if (earlyExited) {
                                try { reader.cancel(); } catch (_) {}
                                return;
                            }
                            return reader.read().then(function (result) {
                                if (result.done) { try { parser.end(); } catch (_) {} return; }
                                totalBytesRead += result.value.byteLength;
                                try { parser.write(result.value); } catch (e) { /* parser may abort early when EOS reached */ }

                                // Early-exit guard. Two-stage gate
                                // — see EARLY_EXIT_* declarations
                                // above for the rationale. Skipped
                                // until at least one cue has been
                                // seen so a cold-open + OP without
                                // dialogue can't trip the threshold
                                // before any sub arrives.
                                var gap = totalBytesRead - lastCueByteOffset;
                                var canBail;
                                if (contentLength > 0) {
                                    var inTail = totalBytesRead > contentLength * EARLY_EXIT_TAIL_FRACTION;
                                    canBail = inTail && gap > EARLY_EXIT_GAP_IN_TAIL;
                                } else {
                                    canBail = gap > EARLY_EXIT_GAP_NO_LENGTH;
                                }
                                if (seenAnyCue && canBail) {
                                    try {
                                        console.log('[AniSync] embedded sub early-exit: ' +
                                            Math.round(totalBytesRead / (1024 * 1024)) + ' MB read' +
                                            (contentLength ? ' / ' + Math.round(contentLength / (1024 * 1024)) + ' MB' : '') +
                                            ', ' + Math.round(gap / (1024 * 1024)) +
                                            ' MB since last cue; flushing parser.');
                                    } catch (_) {}
                                    earlyExited = true;
                                    try { reader.cancel(); } catch (_) {}
                                    try { parser.end(); } catch (_) {}
                                    return;
                                }
                                return pump();
                            });
                        }
                        return pump();
                    })
                    .catch(function (e) {
                        // AbortError on source switch is expected.
                        // TypeError "Failed to fetch" is almost always
                        // CORS on a debrid CDN: the <video> tag plays
                        // the same URL fine (media elements don't
                        // enforce CORS) but fetch() is strict and
                        // *.real-debrid.com / *.strem.fun don't send
                        // Access-Control-Allow-Origin. Hide the pill
                        // silently in that case and let OpenSubtitles
                        // fill in — a red "fetch failed" pill on an
                        // otherwise-playable stream is just noise.
                        if (!e || e.name === 'AbortError') {
                            // expected — source switch / unmount
                        } else if (e.name === 'TypeError') {
                            console.info('embedded sub stream unreachable (likely CORS on debrid CDN):', e.message);
                            setEmbedStatus(null);
                        } else {
                            console.warn('embedded sub stream failed:', e);
                            setEmbedStatus('Embedded-subtitle fetch failed', 'error');
                        }
                        onComplete([]);
                    });
                } // end runExtraction
            }

            // Best-effort ISO-639-2/B → friendly name. Returns the
            // raw code (upper-cased) when unmapped — anime sometimes
            // ships with non-standard or empty language entries.
            function prettyLanguage(code) {
                var c = (code || '').toLowerCase();
                var map = {
                    eng: 'English', spa: 'Spanish', por: 'Portuguese',
                    fre: 'French', fra: 'French', ger: 'German', deu: 'German',
                    ita: 'Italian', rus: 'Russian', ara: 'Arabic',
                    jpn: 'Japanese', chi: 'Chinese', zho: 'Chinese',
                    kor: 'Korean', tur: 'Turkish', pol: 'Polish',
                    dut: 'Dutch', nld: 'Dutch', und: 'Embedded',
                };
                return map[c] || (code ? code.toUpperCase() : 'Embedded');
            }

            // Stitches matroska-subtitles' header (the .ass file's
            // Script Info + V4+ Styles + Events header lines) with
            // accumulated cues into a complete .ass document that
            // jassub can render. Each cue's `text` is already the
            // Dialogue line text after the timestamp; we just prefix
            // Minimal ASS skeleton injected when the track header is
            // missing a [V4+ Styles] section. Necessary for S_TEXT/UTF8
            // tracks (plain text, no CodecPrivate) and for any release
            // whose ASS header was stripped before mux. JASSUB silently
            // renders nothing when the document lacks Script Info +
            // Styles, even if Dialogue: lines are present — so we
            // backfill a reasonable default.
            var MINIMAL_ASS_HEADER = [
                '[Script Info]',
                'ScriptType: v4.00+',
                'PlayResX: 1920',
                'PlayResY: 1080',
                'ScaledBorderAndShadow: yes',
                '',
                '[V4+ Styles]',
                'Format: Name, Fontname, Fontsize, PrimaryColour, SecondaryColour, OutlineColour, BackColour, Bold, Italic, Underline, StrikeOut, ScaleX, ScaleY, Spacing, Angle, BorderStyle, Outline, Shadow, Alignment, MarginL, MarginR, MarginV, Encoding',
                'Style: Default,Arial,42,&H00FFFFFF,&H000000FF,&H00000000,&H80000000,0,0,0,0,100,100,0,0,1,2,1,2,40,40,60,1',
                '',
                '[Events]',
                'Format: Layer, Start, End, Style, Name, MarginL, MarginR, MarginV, Effect, Text',
            ].join('\n');

            // with the standard Dialogue header per ASS spec.
            function buildAssDocument(header, cues) {
                var hasStyles = header && header.indexOf('[V4+ Styles]') >= 0;
                if (!hasStyles) header = MINIMAL_ASS_HEADER;
                if (!cues || cues.length === 0) return header;
                var lines = [];
                for (var i = 0; i < cues.length; i++) {
                    var c = cues[i];
                    // Drop empty / whitespace-only cues. matroska-
                    // subtitles emits these for some encodes and
                    // they trigger libass' "fontselect failed for
                    // glyph 0x0" noise downstream.
                    var rawText = (c.text || '').trim();
                    if (!rawText) continue;
                    var start = formatAssTime(c.time);
                    var end   = formatAssTime(c.time + (c.duration || 0));
                    // SRT-derived cues use \n for line breaks; ASS
                    // expects literal \N. Skip when the source is
                    // already ASS-styled (no raw newlines in those).
                    var text = rawText.replace(/\r?\n/g, '\\N');
                    lines.push('Dialogue: 0,' + start + ',' + end + ',Default,,0,0,0,,' + text);
                }
                return header + '\n' + lines.join('\n') + '\n';
            }
            function formatAssTime(ms) {
                if (!ms || ms < 0) ms = 0;
                var h  = Math.floor(ms / 3600000);
                var m  = Math.floor((ms % 3600000) / 60000);
                var s  = Math.floor((ms % 60000) / 1000);
                var cs = Math.floor((ms % 1000) / 10);
                return h + ':' + pad2(m) + ':' + pad2(s) + '.' + pad2(cs);
            }
            function pad2(n) { return (n < 10 ? '0' : '') + n; }

            // ASS → WebVTT converter, used as the safety net when
            // JASSUB can't initialise (CORS-tainted video, missing
            // fonts, postMessage non-cloneables, etc). Strips all the
            // styling JASSUB would have honoured and emits plain-text
            // VTT that ArtPlayer's native pipeline can load. Loses
            // colour / position / karaoke effects; keeps the dialogue
            // readable, which is what users actually need when the
            // styled path doesn't survive the environment.
            //
            // Each ASS Dialogue: row has 9 commas before the text
            // body (Layer, Start, End, Style, Name, MarginL, MarginR,
            // MarginV, Effect, Text). Times convert from h:MM:SS.cc
            // (ASS, centiseconds) to hh:mm:ss.mmm (VTT, milliseconds).
            // Override tags ({\…}) get stripped wholesale; \N becomes
            // a real newline.
            var ASS_TIME_RE = /^(\d+):(\d+):(\d+)\.(\d+)$/;
            var ASS_OVERRIDE_RE = /\{[^}]*\}/g;
            function assTimeToSeconds(s) {
                var m = ASS_TIME_RE.exec((s || '').trim());
                if (!m) return null;
                var h = parseInt(m[1], 10);
                var mm = parseInt(m[2], 10);
                var ss = parseInt(m[3], 10);
                // ASS uses centiseconds; pad-right then truncate to ms.
                var frac = (m[4] + '00').slice(0, 3);
                return h * 3600 + mm * 60 + ss + parseInt(frac, 10) / 1000;
            }
            function vttTimestamp(totalSec) {
                if (!isFinite(totalSec) || totalSec < 0) totalSec = 0;
                var h = Math.floor(totalSec / 3600);
                var m = Math.floor((totalSec % 3600) / 60);
                var s = totalSec % 60;
                var ms = Math.round((s - Math.floor(s)) * 1000);
                s = Math.floor(s);
                if (ms === 1000) { ms = 0; s++; }
                function pad(n, w) { var x = String(n); while (x.length < w) x = '0' + x; return x; }
                return pad(h, 2) + ':' + pad(m, 2) + ':' + pad(s, 2) + '.' + pad(ms, 3);
            }
            // Pulls PlayResX / PlayResY out of an ASS document's
            // [Script Info] block so the \pos(x,y) override tags can be
            // re-expressed as percentages for WebVTT. Defaults to
            // 1920x1080 — the modern-anime convention and what every
            // sane release tags. Older shows that ship 640x480 ASS
            // declare the actual values explicitly, so the fallback
            // only matters for malformed scripts.
            function parseAssPlayRes(assText) {
                var x = 1920, y = 1080;
                if (!assText) return { x: x, y: y };
                var lines = assText.split('\n');
                for (var i = 0; i < lines.length; i++) {
                    var ln = lines[i];
                    var mx = /^\s*PlayResX\s*:\s*(\d+)/i.exec(ln);
                    if (mx) x = parseInt(mx[1], 10) || x;
                    var my = /^\s*PlayResY\s*:\s*(\d+)/i.exec(ln);
                    if (my) y = parseInt(my[1], 10) || y;
                    // Once we leave [Script Info] there's nothing more
                    // to find — bail to avoid scanning the whole file.
                    if (/^\s*\[/.test(ln) && !/Script Info/i.test(ln)) break;
                }
                return { x: x, y: y };
            }

            // ASS uses numpad-style alignment (1..9) where 1=bottom-left,
            // 2=bottom-center, ..., 9=top-right. WebVTT splits that into
            // a (line, position, align) triple. The mapping below preserves
            // the on-screen anchor so sign translations, song-lyric
            // overlays, and side titles land in the same spots libass would
            // render them — without it every cue collapses to the centre,
            // which is what made our player look messy compared to the
            // libass-driven Stremio render.
            function vttSettingsForAlign(an) {
                var line, position, align;
                if (an === 7 || an === 8 || an === 9) line = '5%';      // top row
                else if (an === 4 || an === 5 || an === 6) line = '50%'; // middle
                else line = null;                                         // bottom = VTT default
                if (an === 1 || an === 4 || an === 7) { position = '5%';  align = 'start'; }
                else if (an === 3 || an === 6 || an === 9) { position = '95%'; align = 'end'; }
                else { position = null; align = null; } // centre = VTT default
                return { line: line, position: position, align: align };
            }

            function buildVttCueSettings(overrideText, playRes) {
                if (!overrideText) return '';
                var anMatch = /\\an([1-9])/.exec(overrideText);
                var aMatch  = /\\a(\d+)/.exec(overrideText); // legacy SSA alignment
                var posMatch = /\\pos\(\s*([\d.\-]+)\s*,\s*([\d.\-]+)\s*\)/.exec(overrideText);
                // \move(x1,y1,x2,y2[,t1,t2]) animates from (x1,y1) to
                // (x2,y2). VTT can't animate a cue, so snap to the
                // start coordinates — it lands at the right anchor and
                // stays put, which is closer to the intended rendering
                // than the default centre dump.
                var moveMatch = /\\move\(\s*([\d.\-]+)\s*,\s*([\d.\-]+)/.exec(overrideText);

                var line = null, position = null, align = null;
                var posSource = posMatch || moveMatch;

                if (posSource) {
                    var px = (parseFloat(posSource[1]) / playRes.x) * 100;
                    var py = (parseFloat(posSource[2]) / playRes.y) * 100;
                    if (px < 0) px = 0; else if (px > 100) px = 100;
                    if (py < 0) py = 0; else if (py > 100) py = 100;
                    position = px.toFixed(1) + '%';
                    line     = py.toFixed(1) + '%';
                    if (anMatch) {
                        var anA = parseInt(anMatch[1], 10);
                        if (anA === 1 || anA === 4 || anA === 7) align = 'start';
                        else if (anA === 3 || anA === 6 || anA === 9) align = 'end';
                        else align = 'center';
                    }
                } else if (anMatch) {
                    var s = vttSettingsForAlign(parseInt(anMatch[1], 10));
                    line = s.line; position = s.position; align = s.align;
                } else if (aMatch) {
                    // SSA legacy \a (bitmap): 1=left, 2=centre, 3=right
                    // + 4 = top, + 8 = middle. Translate to \an numpad
                    // so the same vttSettingsForAlign maps it cleanly.
                    var v = parseInt(aMatch[1], 10);
                    var legacyToAn = { 1: 1, 2: 2, 3: 3, 5: 7, 6: 8, 7: 9, 9: 4, 10: 5, 11: 6 };
                    var mapped = legacyToAn[v];
                    if (mapped) {
                        var s2 = vttSettingsForAlign(mapped);
                        line = s2.line; position = s2.position; align = s2.align;
                    }
                }

                var parts = [];
                if (line) parts.push('line:' + line);
                if (position) parts.push('position:' + position);
                if (align) parts.push('align:' + align);
                return parts.length ? ' ' + parts.join(' ') : '';
            }

            function assToVtt(assText) {
                if (!assText) return 'WEBVTT\n\n';
                var playRes = parseAssPlayRes(assText);
                var lines = assText.replace(/\r\n/g, '\n').split('\n');
                var out = ['WEBVTT', ''];
                for (var i = 0; i < lines.length; i++) {
                    var line = lines[i];
                    if (!/^Dialogue:/i.test(line)) continue;
                    var body = line.replace(/^Dialogue:\s*/i, '');
                    var commas = 0;
                    var split = -1;
                    for (var j = 0; j < body.length && commas < 9; j++) {
                        if (body[j] === ',') {
                            commas++;
                            if (commas === 9) split = j;
                        }
                    }
                    if (split < 0) continue;
                    var fields = body.substring(0, split).split(',');
                    if (fields.length < 9) continue;
                    var start = assTimeToSeconds(fields[1]);
                    var end   = assTimeToSeconds(fields[2]);
                    if (start === null || end === null || end <= start) continue;
                    var rawText = body.substring(split + 1);
                    // Concat every override block before stripping so the
                    // cue-settings parser sees positioning even when the
                    // ASS author split it across multiple {...} groups
                    // (e.g. {\an8}{\fad(200,200)}Lyrics…).
                    var overrideText = (rawText.match(ASS_OVERRIDE_RE) || []).join('');
                    var text = rawText
                        .replace(ASS_OVERRIDE_RE, '')
                        .replace(/\\N/g, '\n')
                        .replace(/\\h/g, ' ')
                        .trim();
                    if (!text) continue;
                    var settings = buildVttCueSettings(overrideText, playRes);
                    // Default bottom dialogue (no explicit line: in
                    // the settings) gets a `line:-2` snap-to-lines
                    // setting — the cue's bottom edge sits one text
                    // line up from the video's bottom. Tried line:80%
                    // / 90% first (percentage mode) but Chromium
                    // browsers appear to ignore percentage line
                    // offsets for bottom-anchored default cues; the
                    // snap-to-lines integer form (-1 = bottom, -2 =
                    // second-from-bottom) is the older mode and is
                    // honoured uniformly across Chrome / Brave /
                    // Safari / Firefox. \pos / \an cues that already
                    // declared a line stay untouched.
                    if (!/(^|\s)line:/.test(settings)) settings += ' line:-2';
                    out.push(vttTimestamp(start) + ' --> ' + vttTimestamp(end) + settings);
                    out.push(text);
                    out.push('');
                }
                return out.join('\n');
            }

            // Track-data → blob: URL cache so flipping back to an
            // SSA entry the user already picked doesn't rebuild the
            // VTT each time. Keyed by the ASS doc itself (length
            // suffices as a fingerprint here).
            var _vttBlobCache = {};
            function renderAssAsVtt(item) {
                if (!art || !item || !item.trackData) return;
                var cacheKey = item.trackData.length + ':' + (item.html || '');
                var url = _vttBlobCache[cacheKey];
                if (!url) {
                    var vtt = assToVtt(item.trackData);
                    url = URL.createObjectURL(new Blob([vtt], { type: 'text/vtt' }));
                    _vttBlobCache[cacheKey] = url;
                }
                setActiveSubtitleTrack(url, (item.html || 'Embedded') + ' (VTT)', item.lang);
            }

            function showFallback(stream, reason) {
                fallbackHost.hidden = false;
                fallbackHost.innerHTML = '';
                fallbackHost.setAttribute('data-fallback-reason', reason || 'decode');

                // Tailored copy per failure mode so the user gets a
                // diagnosis, not a generic "broken stream" wall:
                //   * decode  — browser literally can't play the codec.
                //     Real fix is an external player or another source.
                //   * network — fetch never reached the CDN. Most often
                //     the debrid link expired between resolve and play;
                //     re-picking the source mints a fresh URL.
                //   * timeout — initial fetch / metadata never fired.
                //     Could be slow CDN, geofence, or an actually-bad
                //     source. Worth waiting + a Retry click before
                //     giving up.
                var messages = {
                    decode: "Your browser can't decode this stream — the codec isn't supported. Open it in an external player, or try a different source below.",
                    network: "The stream couldn't be reached. The debrid link may have expired — pick the source again, or try a different one.",
                    timeout: IS_IOS_SAFARI
                        // iPad / iPhone Safari refuses to play most
                        // MKV files outright. Don't pretend it's
                        // just "slow" — tell the user up front that
                        // an external player is the right move.
                        ? "Safari on iPad / iPhone can't play most MKV streams. Tap Open externally to launch it in VLC, Infuse, or another video app."
                        : "This source hasn't started playing yet. It might just be slow — wait a bit, retry, or try another source below.",
                };
                var message = messages[reason] || "Couldn't play this stream. Try another source below, or open it externally.";
                fallbackHost.appendChild(el('p', { class: 'hint-text', style: 'margin: 0 0 0.75rem;' }, message));

                var row = el('div', { class: 'watch-fallback-actions' });

                // Retry — re-runs the full pick path for the same
                // stream. Refreshes the resolve, embedded-sub fetch,
                // and player init from scratch.
                var retry = el('button', { type: 'button', class: 'btn-ghost btn-ghost-sm' }, 'Retry');
                retry.addEventListener('click', function () {
                    hideFallback();
                    playStream(stream);
                });
                row.appendChild(retry);

                // Open externally — same dispatcher as the per-row
                // external-action button on the source list.
                // Android: native app chooser. Desktop: vlc:// probe
                // with .m3u download fallback. Keeps the two
                // entrypoints behaviour-identical so muscle memory
                // works either way.
                var firstLine = (stream.title || stream.name || '').split('\n')[0].trim();
                var open = el('button', { type: 'button', class: 'btn-ghost btn-ghost-sm' }, 'Open externally');
                open.addEventListener('click', function () {
                    // Same mid-launch feedback the per-row icon button
                    // shows — relabels to "Opening…" + disables clicks
                    // while resolvePlaybackUrl + openWithExternalPlayer
                    // is in flight, then restores on the next tick.
                    // Without this the 2–3s resolve looks like a no-op.
                    if (!open.dataset.originalLabel) {
                        open.dataset.originalLabel = open.textContent;
                    }
                    open.textContent = 'Opening…';
                    open.classList.add('is-loading');
                    open.disabled = true;
                    // Defer past the next paint so the "Opening…" /
                    // disabled state is visible before the OS prompt
                    // / handler fires — see the matching comment on
                    // buildExternalAction's click handler.
                    setTimeout(function () {
                        resolvePlaybackUrl(stream.url)
                            .then(function (resolvedUrl) {
                                openWithExternalPlayer(resolvedUrl, firstLine);
                            })
                            .finally(function () {
                                setTimeout(function () {
                                    if (open.dataset.originalLabel) {
                                        open.textContent = open.dataset.originalLabel;
                                        delete open.dataset.originalLabel;
                                    }
                                    open.classList.remove('is-loading');
                                    open.disabled = false;
                                }, 800);
                            });
                    }, 250);
                });
                row.appendChild(open);

                fallbackHost.appendChild(row);
            }

            function hideFallback() {
                fallbackHost.hidden = true;
                fallbackHost.innerHTML = '';
                fallbackHost.removeAttribute('data-fallback-reason');
            }

            // Stream watchdog. Fires when the chosen source hasn't
            // produced any sign of life (loadedmetadata / playing)
            // within STREAM_WATCHDOG_MS. The default 25s absorbs a
            // slow CDN warm-up and the Torrentio → RD resolve chain
            // without panicking; iOS Safari gets a much tighter 8s
            // because that browser silently refuses to attempt MKV
            // playback (no error event fires) and there's no point
            // making the user wait if we know the decode won't
            // happen — surfacing the Open externally button fast
            // gets them to VLC / Infuse sooner.
            var IS_IOS_SAFARI = (function () {
                var ua = navigator.userAgent || '';
                if (/iPad|iPhone|iPod/.test(ua)) return true;
                // iPadOS 13+ pretends to be Mac in the UA; touch
                // points are the give-away.
                if (/Macintosh/.test(ua) && navigator.maxTouchPoints > 1) return true;
                return false;
            })();
            var STREAM_WATCHDOG_MS = IS_IOS_SAFARI ? 8000 : 25000;
            var streamWatchdog = null;
            function startStreamWatchdog(stream) {
                cancelStreamWatchdog();
                streamWatchdog = setTimeout(function () {
                    streamWatchdog = null;
                    if (!art || !art.video) return;
                    var v = art.video;
                    // HAVE_CURRENT_DATA (2) or higher means decoding
                    // started — leave the user alone if so.
                    if (v.readyState >= 2 || v.currentTime > 0) return;
                    showFallback(stream, 'timeout');
                }, STREAM_WATCHDOG_MS);
            }
            function cancelStreamWatchdog() {
                if (streamWatchdog) {
                    clearTimeout(streamWatchdog);
                    streamWatchdog = null;
                }
            }

            function playStream(stream) {
                destroyPlayer();

                // Scroll the player into view so the user gets a
                // visible signal that "click → play" happened, even
                // when their click landed below the fold (long
                // source lists on mobile push the player off-screen).
                // The "Looking for embedded subtitles…" pill and the
                // first-frame paint then land in their viewport
                // rather than going unnoticed. `block: 'start'`
                // pins the top of the player area to the top of the
                // viewport; `behavior: 'smooth'` makes the motion
                // legible. Falls back to instant jump on browsers
                // without smooth-scroll support.
                if (playerHost && playerHost.scrollIntoView) {
                    try {
                        playerHost.scrollIntoView({ behavior: 'smooth', block: 'start' });
                    } catch (_) {
                        playerHost.scrollIntoView(true);
                    }
                }

                // First line of the stream's title is the release
                // filename — Torrentio puts it there before its size /
                // seeder annotations. We pass it to /anime/episode-
                // subtitles so OpenSubtitles can return release-matched
                // subs (correct timing for THIS file rather than a
                // generic search hit). Best-effort: any failure or
                // missing filename just falls through to a generic
                // imdb:s:e query.
                var firstLine = (stream.title || stream.name || '').split('\n')[0].trim();

                var subQs = 'id=' + encodeURIComponent(animeId)
                    + '&episode=' + encodeURIComponent(episode)
                    + (hasSeasons ? '&season=' + encodeURIComponent(season) : '')
                    + (firstLine ? '&filename=' + encodeURIComponent(firstLine) : '');

                // Resolve the stream URL through our server-side
                // redirect-follow first. For MediaFusion-style addons
                // that bind playback tokens to the IP that requested
                // /stream/ (which is AniSync's backend IP, not the
                // browser's), this trades the IP-bound /playback/ URL
                // for the post-redirect debrid CDN URL — token-
                // authenticated in the URL itself, no IP-binding, so
                // the browser can load it direct. For Torrentio
                // sources that already point at an RD CDN URL the
                // resolve is effectively a no-op. Runs in parallel
                // with the subtitle fetch so we don't add a serial
                // round-trip on the click → play path.
                var resolvePromise = resolvePlaybackUrl(stream.url);
                var subsPromise = fetch('/anime/episode-subtitles?' + subQs, {
                    credentials: 'same-origin',
                    headers: { 'Accept': 'application/json' },
                    skipLoader: true,
                })
                    .then(function (r) { return r.ok ? r.json() : { subtitles: [] }; })
                    .catch(function () { return { subtitles: [] }; });

                Promise.all([resolvePromise, subsPromise]).then(function (results) {
                    var resolvedUrl = results[0];
                    var data = results[1];
                    var subs = (data && data.subtitles) || [];
                    // Visibility into per-provider contribution.
                    // Logged to console (devtools-only, no UI cost
                    // for normal users) and rendered as a chip in
                    // the toolbar (visible to everyone) so the
                    // user can confirm at a glance whether each
                    // provider returned anything.
                    var pc = (data && data.providerCounts) || {};
                    try {
                        console.log(
                            '[AniSync] subtitles loaded:',
                            subs.length, 'tracks',
                            'opensubtitles=' + (pc.opensubtitles || 0),
                            subs);
                    } catch (_) {}
                    renderSubsProviderChip(pc);
                    var resolvedStream = Object.assign({}, stream, { url: resolvedUrl });
                    initPlayer(resolvedStream, subs);
                });
            }

            // Hands a stream URL to /anime/resolve-stream and returns
            // the post-redirect URL the server saw — usually a debrid
            // CDN URL (real-debrid.com / alldebrid.com / …) that's
            // not IP-bound and can be loaded from any client. Falls
            // back to the original URL on any failure so a misbehaving
            // resolver doesn't block playback entirely. Used by both
            // the inline player and the external-launcher paths.
            function resolvePlaybackUrl(originalUrl) {
                if (!originalUrl) return Promise.resolve(originalUrl);
                return fetch('/anime/resolve-stream?url=' + encodeURIComponent(originalUrl), {
                    credentials: 'same-origin',
                    headers: { 'Accept': 'application/json' },
                    skipLoader: true,
                })
                    .then(function (r) { return r.ok ? r.json() : null; })
                    .then(function (data) { return (data && data.resolvedUrl) || originalUrl; })
                    .catch(function () { return originalUrl; });
            }

            function initPlayer(stream, subtitles) {
                // ArtPlayer wipes its container on init, so the
                // placeholder paragraph + any stale DOM go away
                // automatically. Title flows through to the top-left
                // overlay; theme tints the active progress + buttons.

                // Pick the default subtitle: first English entry when
                // present, otherwise the first track. Used to mark
                // the initial pick in the settings selector + as the
                // ArtPlayer `subtitle:` config so something shows
                // immediately on play.
                // Default to the first English track when present;
                // otherwise leave at -1 so the "None" entry is selected.
                // We deliberately don't fall back to the first non-
                // English track — users with no English coverage from
                // OpenSubtitles are better served by no subs
                // than by a surprise Spanish / Russian / etc. overlay
                // they didn't ask for. They can still pick any track
                // manually from the selector.
                var defaultSubIdx = -1;
                for (var i = 0; i < subtitles.length; i++) {
                    if (/^en/i.test(subtitles[i].lang || '')) { defaultSubIdx = i; break; }
                }
                // Prime the menu-state vars so the initial selector
                // render matches the subtitle ArtPlayer auto-loads
                // via its `subtitle:` config below.
                if (defaultSubIdx >= 0) {
                    currentSubKind = 'vtt';
                    currentSubKey = subtitles[defaultSubIdx].url;
                } else {
                    currentSubKind = 'none';
                    currentSubKey = null;
                }

                // Subtitle picker is ALWAYS rendered with a "None"
                // option at the top so users can turn captions off
                // regardless of how many tracks are available. ASS
                // entries get added later (after MKV extraction
                // completes); they live alongside the VTT tracks in
                // the same selector and route through applySubtitle().
                function buildSubtitleSelector() {
                    // Default markers are driven by currentSubKind /
                    // currentSubKey rather than the initial pick so a
                    // mid-playback auto-promote (e.g. English embedded
                    // SSA arriving 30s in) shows up as checked in the
                    // menu instead of staying on whatever was selected
                    // at video load.
                    //
                    // Order: None → embedded SSA → external VTT.
                    // Embedded tracks come from the user's actual file
                    // so they're release-matched by definition and
                    // beat OpenSubtitles on accuracy almost
                    // always. Surfacing them right after "None" puts
                    // the highest-quality options at the top of the
                    // menu where the user looks first.
                    var options = [{
                        html: 'None',
                        kind: 'none',
                        "default": currentSubKind === 'none',
                    }];
                    embeddedTracks.forEach(function (t) {
                        // Label format intentionally drops the parens —
                        // "English SSA" reads as a track type tag at a
                        // glance, faster than "English (SSA)".
                        var label = (t.label || 'Embedded') + ' SSA';
                        options.push({
                            html: label,
                            kind: 'ass',
                            trackData: t.data,
                            "default": currentSubKind === 'ass' && currentSubKey === label,
                        });
                    });
                    subtitles.forEach(function (t) {
                        options.push({
                            html: t.label || t.lang || 'Subtitles',
                            kind: 'vtt',
                            url: t.url,
                            "default": currentSubKind === 'vtt' && currentSubKey === t.url,
                        });
                    });
                    return options;
                }

                var settings = [{
                    name: 'subtitles',
                    html: 'Subtitles',
                    tooltip: 'Subtitle track',
                    selector: buildSubtitleSelector(),
                    onSelect: function (item) {
                        applySubtitle(item);
                        return item.html;
                    },
                }];

                // Mark intro / outro on the progress bar so the user
                // sees the upcoming skip-points at a glance. Same data
                // wireSkipOverlay() uses for its corner-anchored
                // button — these are the visual cue, the button is
                // the action.
                var highlight = [];
                var times = lastData && lastData.skipTimes;
                if (times) {
                    if (times.intro) {
                        highlight.push({ time: times.intro.start, text: 'OP' });
                    }
                    if (times.outro) {
                        highlight.push({ time: times.outro.start, text: 'ED' });
                    }
                }

                // Mobile devices already paint the native fullscreen
                // mode landscape via autoOrientation, so the web-
                // fullscreen icon next to it is duplicative chrome. On
                // desktop it stays — sometimes a viewer wants the
                // letterboxed in-page big-frame view without losing
                // the URL bar. matchMedia is the standard "are we on
                // a phone-shaped viewport" check.
                var isMobile = window.matchMedia('(max-width: 640px)').matches;

                // Reusable SVG markup for the ±10s control buttons —
                // pre-encoded inline so ArtPlayer can drop them into
                // its toolbar without an extra fetch. Both icons mirror
                // each other; only the polyline + the digit shift.
                var rewindSvg = '<svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="11 17 6 12 11 7"/><polyline points="18 17 13 12 18 7"/></svg>';
                var forwardSvg = '<svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="13 17 18 12 13 7"/><polyline points="6 17 11 12 6 7"/></svg>';

                art = new Artplayer({
                    container: playerHost,
                    url: stream.url,
                    title: @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(episodeLabel)),
                    theme: '#7c3aed',
                    autoplay: true,
                    // Picture-in-Picture turned off intentionally. On
                    // mobile, swiping home while a video is playing
                    // fullscreen otherwise triggers the browser's auto-
                    // PiP behaviour and the video keeps running in a
                    // little floating window. We pair this option-off
                    // with disablePictureInPicture on the <video> below
                    // (the ArtPlayer flag drops the toolbar button;
                    // the HTML attribute is what actually blocks the
                    // browser's automatic PiP entry).
                    pip: false,
                    // screenshot / aspectRatio dropped from the toolbar —
                    // the screenshot icon and the aspect-ratio toggle
                    // were noise for the average viewer; users who want
                    // those can still get aspect-ratio via the settings
                    // menu's video-scaling entry if we ever surface one.
                    screenshot: false,
                    setting: true,
                    playbackRate: true,
                    aspectRatio: false,
                    fullscreen: true,
                    fullscreenWeb: !isMobile,
                    subtitleOffset: true,
                    // ArtPlayer's miniProgressBar paints a thin
                    // progress strip at the very bottom of the video
                    // when the full controls auto-hide. Disabled — on
                    // a phone in fullscreen the strip sits flush with
                    // the screen edge and reads as a stuck rendering
                    // glitch rather than a deliberate affordance.
                    // Users get back to the controls with a single tap
                    // anywhere on the video.
                    miniProgressBar: false,
                    // ArtPlayer's mobile gesture layer binds touchstart
                    // / touchmove to the <video> element itself: a
                    // horizontal swipe anywhere on the player surface
                    // scrubs the timeline (no visible seek track
                    // required). On a phone in fullscreen that
                    // collides with the system home-swipe — the user
                    // swipes up from the bottom of the screen, the
                    // gesture is read as a (slightly diagonal)
                    // horizontal drag first, and the playhead jumps
                    // before the OS gesture takes over. Disabling the
                    // gesture layer leaves tap-to-toggle-controls,
                    // double-tap-to-seek, and dragging the actual
                    // seek bar intact.
                    gesture: false,
                    autoOrientation: true,
                    hotkey: true,
                    airplay: true,
                    moreVideoAttr: {
                        playsInline: true,
                        // The HTML attribute that actually blocks the
                        // browser's automatic Picture-in-Picture entry
                        // when the user swipes home from a fullscreen
                        // video on iOS Safari / Android Chrome. The
                        // ArtPlayer pip: false flag only drops the
                        // toolbar button — without this attribute the
                        // browser still pops the floating PiP window
                        // on the home swipe.
                        disablePictureInPicture: true,
                        // Browser default for <video> preload is
                        // 'metadata' — fetches just enough to read
                        // duration / codec and then waits for play().
                        // 'auto' tells the browser it's free to keep
                        // buffering ahead aggressively, which makes
                        // initial start-up smoother and gives the
                        // decoder more runway when network jitter
                        // delays packets mid-stream. The browser
                        // still decides how far to read ahead, so
                        // this isn't a free upgrade — but on debrid
                        // CDN URLs it generally trades a couple of
                        // MB of speculative fetch for fewer stalls.
                        preload: 'auto',
                    },
                    // Subtitle rendering is driven by setActiveSubtitleTrack
                    // (browser-native <track>) instead of ArtPlayer's
                    // overlay, because the native renderer honours WebVTT
                    // cue settings (line / position / align) and the
                    // overlay doesn't. Pass an empty subtitle config so
                    // ArtPlayer doesn't auto-load the default sub into
                    // its own overlay and double-render alongside the
                    // native <track>.
                    subtitle: {},
                    settings: settings,
                    highlight: highlight,
                    controls: [
                        {
                            // ←10s — sits in the toolbar to the left of
                            // the play button. `index` orders custom
                            // controls within their position; play is at
                            // 10 by default, so 8 puts us just before it.
                            position: 'left',
                            index: 8,
                            html: rewindSvg,
                            tooltip: 'Rewind 10s',
                            click: function () {
                                var v = art && art.video;
                                if (v) art.seek = Math.max(0, (v.currentTime || 0) - 10);
                            },
                        },
                        {
                            // 10s→ — mirror of rewind, just after play.
                            position: 'left',
                            index: 12,
                            html: forwardSvg,
                            tooltip: 'Forward 10s',
                            click: function () {
                                var v = art && art.video;
                                if (!v) return;
                                var target = (v.currentTime || 0) + 10;
                                if (v.duration && target > v.duration) target = v.duration;
                                art.seek = target;
                            },
                        },
                    ],
                });

                // Belt + braces against the mobile scrub-while-hidden
                // gesture. ArtPlayer binds touchstart / touchmove to
                // .art-progress UNCONDITIONALLY on mobile (gestureInit
                // — option.gesture only governs the $video surface
                // swipe), so the seek bar inside .art-bottom catches
                // touches even when the bar has faded out. The CSS
                // override in site.css (pointer-events / touch-action
                // on .art-bottom + descendants while .art-hover is
                // missing) handles the steady-state case, but there's
                // still a race: a single tap that begins on the
                // hidden bar will, before the touchend, cause
                // clickInit to add .art-hover synchronously — which
                // restores pointer-events: auto on the seek track
                // inside the same gesture, so a touchstart-then-drag
                // home-swipe lands on the now-interactive track and
                // scrubs. We seal that race with a capture-phase
                // touchstart listener on the player root that
                // stopImmediatePropagation()s touches targeting
                // .art-progress while the player isn't already in
                // the hover state. ArtPlayer's bound listener runs
                // in the bubbling phase, so this cleanly preempts
                // it without unbinding anything (and the seek bar
                // still works once controls are visible — the guard
                // self-disables the moment .art-hover is present).
                try {
                    var $player = art.template && art.template.$player;
                    if ($player) {
                        $player.addEventListener('touchstart', function (e) {
                            if ($player.classList.contains('art-hover')) return;
                            var t = e.target;
                            while (t && t !== $player) {
                                if (t.classList && t.classList.contains('art-progress')) {
                                    e.stopImmediatePropagation();
                                    return;
                                }
                                t = t.parentNode;
                            }
                        }, { capture: true, passive: true });
                    }
                } catch (_) { /* defensive — non-fatal if template shape changes */ }

                // Initial subtitle-track activation. ArtPlayer's
                // built-in overlay is disabled (subtitle: {} above) so
                // sub rendering lives entirely on the <track> we
                // attach here — applySubtitle handles all later
                // changes, but the very first cue source has to be
                // primed manually because the player wasn't built with
                // a subtitle URL of its own to load.
                if (defaultSubIdx >= 0) {
                    var defaultSub = subtitles[defaultSubIdx];
                    setActiveSubtitleTrack(
                        defaultSub.url,
                        defaultSub.label || defaultSub.lang,
                        defaultSub.lang);
                }

                // ArtPlayer normalises the native HTMLVideoElement
                // through art.video; the "video:error" custom event
                // fires whenever the inner element errors. Map the
                // HTMLMediaElement error codes:
                //   1 ABORTED        — user / nav canceled, ignore.
                //   2 NETWORK        — fetch dropped, debrid URL may
                //                      have expired between resolve
                //                      and play. Show "network" copy.
                //   3 DECODE         — bytes arrived but can't decode.
                //                      Same UX as 4 effectively.
                //   4 SRC_NOT_SUPPORTED — browser doesn't speak the
                //                      codec / container. Show
                //                      "decode" copy.
                art.on('video:error', function () {
                    cancelStreamWatchdog();
                    var v = art.video;
                    var code = v && v.error && v.error.code;
                    if (code === 1) return; // user aborted, no UI needed
                    var reason = (code === 2) ? 'network' : 'decode';
                    showFallback(stream, reason);
                });

                // Buffer-underrun watchdog. The browser emits
                // `waiting` whenever playback pauses because the read
                // head outran the buffered range, and `stalled` when
                // the network has been idle while data was still
                // needed — both signal "the buffer isn't keeping up
                // with the decoder". A single hiccup is normal noise
                // (TCP slowstart, debrid CDN regional handoff,
                // browser tab backgrounded) so we only surface a
                // hint once underruns cluster: 3 events inside a
                // 30-second window. The hint uses ArtPlayer's notice
                // overlay (auto-dismissing, lives over the video so
                // the user can't miss it without being modal) and
                // routes the user to the external-player path, which
                // bypasses every browser-side bottleneck — HEVC
                // codec support, hardware-decode limits, the
                // per-tab MediaSource buffer caps — that AniSync
                // can't fix from JS. Once shown, the hint is
                // suppressed for the rest of the session so we
                // don't spam the user; they'll have already seen
                // the message and either acted on it or chosen not
                // to. The console.log keeps a per-event trail for
                // diagnosis if the user reports issues later.
                var bufferStallTimestamps = [];
                var bufferHintShown = false;
                function recordBufferStall(kind) {
                    var now = Date.now();
                    bufferStallTimestamps.push(now);
                    while (bufferStallTimestamps.length &&
                           now - bufferStallTimestamps[0] > 30000) {
                        bufferStallTimestamps.shift();
                    }
                    try {
                        var v = art && art.video;
                        var at = v && typeof v.currentTime === 'number'
                            ? v.currentTime.toFixed(1) + 's'
                            : '(unknown)';
                        console.log(
                            '[AniSync] buffer ' + kind + ' at',
                            at,
                            'recent stalls:', bufferStallTimestamps.length);
                    } catch (_) {}
                    if (bufferStallTimestamps.length >= 3 && !bufferHintShown) {
                        bufferHintShown = true;
                        try {
                            art.notice.show = 'Playback laggy? Use the external-player button next to the source for a smoother stream.';
                        } catch (_) {}
                    }
                }
                art.on('video:waiting', function () { recordBufferStall('waiting'); });
                art.on('video:stalled', function () { recordBufferStall('stalled'); });

                // Watchdog: if neither loadedmetadata nor playing has
                // fired within STREAM_WATCHDOG_MS, surface the
                // "hasn't started yet" fallback so the user has
                // actionable buttons (Retry / Open externally / Copy
                // URL) instead of staring at a spinner. The video
                // element keeps trying behind the scenes — if it
                // does eventually recover we hide the fallback
                // automatically via the playing handler below.
                startStreamWatchdog(stream);
                art.on('video:loadedmetadata', cancelStreamWatchdog);
                art.on('video:playing', function () {
                    cancelStreamWatchdog();
                    // Auto-dismiss any fallback that's up — if the
                    // video reached `playing`, whatever error or
                    // timeout we surfaced earlier resolved itself.
                    // Keeping the message visible alongside a
                    // playing video would just be confusing.
                    hideFallback();
                });

                // Auto-track: mark the episode as watched on the
                // user's primary tracker once playback crosses 70 %
                // of duration. timeupdate fires every ~250 ms which
                // is more than enough; the markEpisodeAsWatched
                // helper is idempotent + flag-guarded so multiple
                // fires inside the threshold cost nothing.
                //
                // Skip on suspiciously short durations — Real-Debrid
                // serves DMCA-removed entries as a 30-second
                // placeholder video saying "file removed for
                // copyright". 70 % of 30s = 21s, which the user
                // would otherwise blow past in seconds and end up
                // with a falsely-marked episode. Real anime
                // episodes are 4+ minutes even for shorts; 60s is
                // a safe floor.
                art.on('video:timeupdate', function () {
                    if (episodeMarkedAsWatched) return;
                    var v = art && art.video;
                    if (!v) return;
                    var dur = v.duration;
                    if (!isFinite(dur) || dur <= 0) return;
                    if (dur < 60) return; // RD placeholder, not a real episode
                    if ((v.currentTime || 0) / dur >= 0.7) {
                        markEpisodeAsWatched('70%-progress');
                    }
                });

                // ── Resume: read on metadata load, write throttled on
                // timeupdate, clear on completion. Metadata-load is the
                // first event that has a real duration + a seekable
                // <video>, so seek-back happens before the user sees
                // playback start (no visible "jump" mid-frame).
                var hasResumedThisSource = false;
                art.on('video:loadedmetadata', function () {
                    if (hasResumedThisSource) return;
                    hasResumedThisSource = true;
                    var v = art && art.video;
                    if (!v) return;
                    var dur = v.duration;
                    if (!isFinite(dur) || dur <= 60) return;
                    var pos = readResumePosition();
                    if (pos <= 0) return;
                    // Same near-completion guard as the read helper —
                    // belt + braces in case a previous save crossed
                    // the threshold but happened before the wipe
                    // landed (Safari background-tab limits, full
                    // localStorage, etc.).
                    if (pos / dur >= RESUME_COMPLETE_RATIO) return;
                    try {
                        art.seek = pos;
                        if (art.notice) {
                            art.notice.show = 'Resumed from ' + formatResumeTime(pos);
                        }
                    } catch (_) { /* defensive — non-fatal */ }
                });

                art.on('video:timeupdate', function () {
                    var v = art && art.video;
                    if (!v) return;
                    writeResumePosition(v.currentTime || 0, v.duration || 0);
                });

                // Pause is the most likely "I'm stepping away" signal
                // — capture the exact second so re-open lands on it.
                // Bypasses the 5s throttle inside writeResumePosition.
