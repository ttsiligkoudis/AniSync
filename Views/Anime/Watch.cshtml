                } else if (!pendingAddons && debrid.length === 0 && external.length === 0) {
                    var msg = data && data.anonymous
                        ? "Sign in and add a Stremio stream addon (Torrentio, MediaFusion, …) in Settings to find streaming sources for this episode."
                        : (data && !data.addonsConfigured
                            ? "No streaming sources found. Add a Stremio stream addon (Torrentio, MediaFusion, Comet, AIOStreams, …) in Settings to surface debrid-cached torrents."
                            : "No streaming sources found for this episode.");
                    sourcesBody.appendChild(el('p', { class: 'hint-text' }, msg));
                }
            }

            var qs = 'id=' + encodeURIComponent(animeId)
                + '&episode=' + encodeURIComponent(streamEpisode)
                + '&season=' + encodeURIComponent(streamSeason)
                + (isMovie ? '&type=movie' : '');

            // localStorage layer for the fan-out result. Lives in the
            // browser (not the server) because the upstream rate-limit
            // signal that the cache is meant to soften is per-id /
            // per-IP — a shared server cache wouldn't help two users
            // hitting the same episode at the same time anyway, and a
            // per-user server row would still pay a DB round-trip on
            // every render. localStorage is single-writer per browser,
            // survives reloads / Prev-Next nav, and the entries live
            // close to the device whose IP the debrid URLs were signed
            // for.
            var STREAM_CACHE_TTL_MS = 10 * 60 * 1000;
            var streamCacheKeyPrefix = configUid
                ? 'anisync.streams.' + configUid + '.'
                : '';
            var streamCacheKey = streamCacheKeyPrefix
                ? streamCacheKeyPrefix + animeId
                    + '|s=' + (streamSeason != null ? streamSeason : '_')
                    + '|e=' + (streamEpisode != null ? streamEpisode : '_')
                    + (isMovie ? '|movie' : '')
                : null;

            function readCachedStreamData() {
                if (!streamCacheKey) return null;
                var raw;
                try { raw = localStorage.getItem(streamCacheKey); }
                catch (_) { return null; }
                if (!raw) return null;
                try {
                    var entry = JSON.parse(raw);
                    if (!entry || typeof entry.ts !== 'number') return null;
                    if (Date.now() - entry.ts >= STREAM_CACHE_TTL_MS) return null;
                    return entry.data || null;
                } catch (_) { return null; }
            }

            function writeCachedStreamData(data) {
                if (!streamCacheKey || !data) return;
                // Don't cache the negative scenario — an empty fan-out
                // is the exact case the user wants the NEXT visit to
                // re-attempt (rate-limit window opens up, addon's
                // upstream scrape lands fresh). Caching zero results
                // would lock the user into the bad refresh for the
                // full TTL window.
                var debrid = (data && data.debridStreams) || [];
                if (debrid.length === 0) return;
                try {
                    localStorage.setItem(streamCacheKey, JSON.stringify({
                        ts: Date.now(),
                        data: data,
                    }));
                } catch (_) {
                    // Quota / private-mode failures are non-fatal —
                    // the page still renders from the live fetch.
                }
            }

            function applyStreamData(data) {
                lastData = data;
                // Hide the auto-skip toggle when AniSkip didn't
                // return any markers for this episode — the toggle
                // would have nothing to act on and just adds chrome
                // the user can't use. The corner skip button is
                // already gated on the same data inside
                // wireSkipOverlay, so it stays hidden too.
                if (skipAutoBtn) {
                    var sk = data && data.skipTimes;
                    skipAutoBtn.hidden = !sk || (!sk.intro && !sk.outro);
                }
                renderSources(data);
            }

            // Two-arrow refresh icon for the Sources header — clears the
            // localStorage entry for this episode and refetches. Lets the
            // user bypass the 10-min TTL when an empty / stale fan-out
            // shouldn't be the final word (e.g. a Stremio addon just came
            // back online, debrid cache just warmed).
            var REFRESH_ICON_SVG = '<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>';

            var refreshBtn = document.getElementById('watchSourcesRefresh');
            if (refreshBtn) refreshBtn.innerHTML = REFRESH_ICON_SVG;

            var streamsLoading = false;

            function fetchStreams() {
                if (streamsLoading) return;
                streamsLoading = true;
                if (refreshBtn) {
                    refreshBtn.disabled = true;
                    refreshBtn.classList.add('is-loading');
                }

                function finish() {
                    streamsLoading = false;
                    if (refreshBtn) {
                        refreshBtn.disabled = false;
                        refreshBtn.classList.remove('is-loading');
                    }
                }

                // Bootstrap: addon list + the addon-independent
                // extras (external links, AniSkip markers). The
                // per-addon debrid fetches fan out from the client
                // after this returns so the fastest addon's results
                // render the moment they arrive instead of being
                // gated on the slowest addon's response.
                fetch('/anime/episode-streams?' + qs, {
                    credentials: 'same-origin',
                    headers: { 'Accept': 'application/json' },
                    // The Sources panel renders its own "Looking for streams…"
                    // placeholder while the request is in flight — the global
                    // full-screen loader-overlay on top of that would just be
                    // double-loading.
                    skipLoader: true,
                })
                    .then(function (r) { return r.ok ? r.json() : null; })
                    .then(function (bootstrap) {
                        if (!bootstrap) {
                            sourcesBody.innerHTML = '<p class="hint-text">Couldn\'t load sources. Try refreshing.</p>';
                            finish();
                            return;
                        }

                        var addons = (bootstrap.addons) || [];
                        var combined = {
                            anonymous: bootstrap.anonymous,
                            addonsConfigured: bootstrap.addonsConfigured,
                            debridStreams: [],
                            externalLinks: bootstrap.externalLinks || [],
                            skipTimes: bootstrap.skipTimes,
                        };

                        if (addons.length === 0) {
                            // Nothing to fan out — render the
                            // external-links / empty-state path
                            // straight away. No cache write here:
                            // writeCachedStreamData skips empty
                            // debrid lists deliberately so the
                            // negative scenario stays re-attemptable
                            // (matches the legacy behaviour).
                            applyStreamData(combined);
                            finish();
                            return;
                        }

                        // Initial paint with the "0 / N" badge —
                        // gives the user immediate feedback that
                        // the addons are being queried while the
                        // first per-addon response is still
                        // arriving. external links + skip times are
                        // already populated so the AniSkip toggle
                        // and "Other sites" block render now too.
                        var progress = { completed: 0, total: addons.length };
                        applyStreamData(Object.assign({ progress: progress }, combined));

                        var settled = 0;
                        addons.forEach(function (a) {
                            fetch('/anime/episode-streams?' + qs + '&addonIndex=' + encodeURIComponent(a.index), {
                                credentials: 'same-origin',
                                headers: { 'Accept': 'application/json' },
                                skipLoader: true,
                            })
                                .then(function (r) { return r.ok ? r.json() : null; })
                                .then(function (resp) {
                                    var streams = (resp && resp.debridStreams) || [];
                                    if (streams.length > 0) {
                                        // Append in completion
                                        // order — fastest addon's
                                        // streams stay at the top
                                        // so the user can pick one
                                        // and start watching while
                                        // the slower addons are
                                        // still resolving.
                                        Array.prototype.push.apply(combined.debridStreams, streams);
                                    }
                                })
                                .catch(function () { /* swallow — empty addon, move on */ })
                                .then(function () {
                                    settled++;
                                    progress.completed = settled;
                                    var done = settled === addons.length;
                                    applyStreamData(Object.assign(
                                        { progress: done ? null : progress },
                                        combined));
                                    if (done) {
                                        // Cache the final combined
                                        // shape — same record the
                                        // legacy bundled endpoint
                                        // used to return, so cache
                                        // reads continue to work
                                        // unchanged across the
                                        // upgrade. writeCached
                                        // skips empty debrid lists
                                        // on its own.
                                        writeCachedStreamData(combined);
                                        finish();
                                    }
                                });
                        });
                    })
                    .catch(function () {
                        sourcesBody.innerHTML = '<p class="hint-text">Couldn\'t load sources. Try refreshing.</p>';
                        finish();
                    });
            }

            if (refreshBtn) {
                refreshBtn.addEventListener('click', function () {
                    if (streamsLoading) return;
                    if (streamCacheKey) {
                        try { localStorage.removeItem(streamCacheKey); } catch (_) {}
                    }
                    sourcesBody.innerHTML = '<p class="hint-text">Looking for streams…</p>';
                    fetchStreams();
                });
            }

            var cachedStreamData = readCachedStreamData();
            if (cachedStreamData) {
                applyStreamData(cachedStreamData);
            } else {
                fetchStreams();
            }
        })();
    </script>
}
