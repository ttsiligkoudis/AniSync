@model AnimeList.Controllers.WatchViewModel
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    var a = Model.Anime;
    var ep = Model.Current;
    // Optional Cloudflare Worker proxy that adds CORS headers to debrid CDN
    // responses, re-enabling the client-side matroska-subtitles extractor on
    // real-debrid / all-debrid / etc. (See cf-cors-proxy/ in the repo for the
    // worker source + deployment steps.) Unset → embedded-sub extraction stays
    // skipped on those hosts.
    var corsProxyUrl = (Configuration["CORS_PROXY_URL"]
        ?? Environment.GetEnvironmentVariable("CORS_PROXY_URL")
        ?? string.Empty).Trim();
    var corsProxySecret = (Configuration["CORS_PROXY_SECRET"]
        ?? Environment.GetEnvironmentVariable("CORS_PROXY_SECRET")
        ?? string.Empty).Trim();
    var episodeLabel = !string.IsNullOrEmpty(ep.name) ? ep.name
        : !string.IsNullOrEmpty(ep.title) ? ep.title
        : $"Episode {ep.episode}";
    var seasonNum = ep.season > 0 ? ep.season : 1;
    var hasSeasons = a.videos != null && a.videos.Any(v => (v.season > 0 ? v.season : 1) != seasonNum);
    var seasonLabel = hasSeasons ? $"S{seasonNum} · E{ep.episode}" : $"Episode {ep.episode}";
    ViewData["Title"] = $"{a.name} · {seasonLabel} · AniSync";
    ViewData["BodyClass"] = "watch-page";

    string PrevHref()
    {
        if (Model.Prev == null) return null;
        var ps = Model.Prev.season > 0 ? Model.Prev.season : 1;
        return hasSeasons
            ? $"/anime/{a.id}/watch/{ps}/{Model.Prev.episode}"
            : $"/anime/{a.id}/watch/{Model.Prev.episode}";
    }
    string NextHref()
    {
        if (Model.Next == null) return null;
        var ns = Model.Next.season > 0 ? Model.Next.season : 1;
        return hasSeasons
            ? $"/anime/{a.id}/watch/{ns}/{Model.Next.episode}"
            : $"/anime/{a.id}/watch/{Model.Next.episode}";
    }
}

@*
    ArtPlayer — feature-rich HTML5 player with the pro layout we want
    out of the box: center play with rewind / fast-forward arrows,
    progress bar with timestamps, settings menu for subtitles +
    playback speed + aspect ratio, web-fullscreen, picture-in-picture,
    auto-orientation on mobile. ArtPlayer ships its own CSS embedded
    in the JS bundle, so no separate stylesheet to wire in.
*@

<section class="watch-header">
    <a class="watch-back" href="/anime/@a.id">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="19" y1="12" x2="5" y2="12"></line>
            <polyline points="12 19 5 12 12 5"></polyline>
        </svg>
        <span>@a.name</span>
    </a>
    <h1 class="watch-title">@episodeLabel</h1>
    <p class="watch-meta">@seasonLabel @if (!string.IsNullOrEmpty(ep.released) && ep.released.Length >= 10) { <span class="watch-meta-dot">·</span> <span>@ep.released[..10]</span> }</p>
</section>

@* Only mount the inline player when the user actually has a way to
   resolve a playable URL — i.e. a Real-Debrid key on file. External-
   services alone navigate out via the source picker rows below, so
   the player would be a dead frame with nothing behind it. *@
@if (Model.HasRealDebridKey)
{
    <section class="watch-player-wrap">
        @* ArtPlayer owns the contents of #watchPlayer once a source is
           picked — it replaces children with its own <video> + chrome.
           The empty-state placeholder swaps out at that moment. The
           skip button is a sibling so ArtPlayer's wipe doesn't take
           it down; we appendChild() it back into the player host
           after init so it corner-anchors over the video frame. *@
        <div id="watchPlayer" class="watch-player">
            <div class="watch-player-empty">
                @* Layered preview frame:
                   - Bottom layer: the anime's hero backdrop, always
                     rendered when the meta has one. Acts as the
                     fallback when the episode-thumbnail layer fails
                     (unaired episodes ship with a stub URL Cinemeta
                     fills in before art exists — it 404s).
                   - Top layer: the episode-specific thumbnail. Hides
                     itself via onerror when it 404s, letting the
                     backdrop show through.
                   - Pill: "Pick a source below" overlay regardless. *@
                @if (!string.IsNullOrEmpty(a.background))
                {
                    <img class="watch-player-backdrop" src="@a.background" alt="" loading="lazy"
                         onerror="this.classList.add('is-missing');" />
                }
                @if (!string.IsNullOrEmpty(ep.thumbnail))
                {
                    <img class="watch-player-poster" src="@ep.thumbnail" alt="" loading="lazy"
                         onerror="this.classList.add('is-missing');" />
                }
                <span class="watch-player-prompt">Pick a source below to start watching.</span>
            </div>
        </div>
        @* AniSkip overlay: corner-anchored button rendered by JS when
           the playhead enters an intro / outro range. Hidden by default
           — wireSkipOverlay() bails cleanly when no skip markers are
           available for the episode. *@
        <button id="watchSkipButton" class="watch-skip-btn" type="button" hidden>Skip intro →</button>
        <div class="watch-player-toolbar">
            @* Auto-skip preference lives in localStorage so it persists
               across episodes — click once, intros / outros get jumped
               silently for every subsequent episode. *@
            <button id="watchSkipAuto" class="watch-toggle" type="button" aria-pressed="false">
                <span class="watch-toggle-dot" aria-hidden="true"></span>
                <span>Auto-skip intro / outro</span>
            </button>
            @* Embedded-subtitle status pill — surfaces the SSA / ASS
               extraction progress so the user can tell whether the
               pipeline is alive when nothing new appears in the
               Subtitles menu. Hidden until the pipeline kicks off. *@
            <span id="watchEmbeddedStatus" class="watch-embed-status" hidden></span>
            @* Per-provider subtitle count chip. Populated after the
               /anime/episode-subtitles fetch resolves so the user can
               see at a glance whether OpenSubtitles, Wyzie, or both
               returned anything. Hidden when no subtitles loaded. *@
            <span id="watchSubsProvider" class="watch-embed-status" hidden></span>
        </div>
        <div id="watchPlayerFallback" class="watch-player-fallback" hidden>
            @* Rendered by JS when the <video> element fires an error
               (codec mismatch — most often MKV with HEVC on Firefox/Safari
               or anything AV1-encoded on older browsers). *@
        </div>
    </section>
}

<nav class="watch-nav">
    @if (Model.Prev != null)
    {
        <a class="watch-nav-btn watch-nav-prev" href="@PrevHref()">
            <span class="watch-nav-direction">← Previous</span>
            <span class="watch-nav-label">Episode @Model.Prev.episode</span>
        </a>
    }
    else
    {
        <span class="watch-nav-btn watch-nav-btn-disabled" aria-hidden="true"></span>
    }
    @if (Model.Next != null)
    {
        <a class="watch-nav-btn watch-nav-next" href="@NextHref()">
            <span class="watch-nav-direction">Next →</span>
            <span class="watch-nav-label">Episode @Model.Next.episode</span>
        </a>
    }
    else
    {
        <span class="watch-nav-btn watch-nav-btn-disabled" aria-hidden="true"></span>
    }
</nav>

<section class="watch-sources" id="watchSources">
    <h2 class="watch-section-title">Sources</h2>
    <div id="watchSourcesBody" class="watch-sources-body">
        <p class="hint-text">Looking for streams…</p>
    </div>
</section>

@section Scripts {
    <script src="https://unpkg.com/artplayer@5/dist/artplayer.js"></script>
    @* SSA / ASS embedded subtitle support. matroska-subtitles parses
       the MKV stream client-side; jassub (a libass WebAssembly port)
       renders the result. Both ship ESM/Node-only on npm, so we go
       through esm.sh which auto-bundles for the browser. <script
       type="module"> is deferred by default — a load failure on
       either CDN URL can't freeze the page parser the way plain
       <script src> can. Each import is wrapped in try/catch so one
       library's absence doesn't break the other; the extraction +
       dispatch code below guards on `typeof MatroskaSubtitles ===
       'undefined'` and `typeof JASSUB === 'undefined'` and silently
       no-ops when either is missing. *@
    <script type="module">
        // Resolve `window.subtitleLibsReady` to { matroska, jassub }
        // when both imports are done (success or failure). The
        // extraction pipeline awaits this so it never fires the
        // "support unavailable" status just because the imports
        // hadn't completed by the time the user picked a source.
        //
        // Each library has a fallback CDN chain — esm.sh, esm.run
        // (jsDelivr ESM), skypack — and each attempt is wrapped in
        // a 6-second timeout. esm.sh occasionally hangs while it
        // compiles a Node-only package on first request, leaving
        // `await import(url)` pending for minutes; the timeout
        // forces a fall-through to the next CDN. Matroska + jassub
        // load in parallel to halve the worst-case wait.
        function timeoutPromise(ms, message) {
            return new Promise(function (_, reject) {
                setTimeout(function () { reject(new Error(message)); }, ms);
            });
        }
        async function tryImport(specifiers, timeoutMs) {
            timeoutMs = timeoutMs || 6000;
            for (const spec of specifiers) {
                try {
                    return await Promise.race([
                        import(spec),
                        timeoutPromise(timeoutMs, 'import timeout: ' + spec),
                    ]);
                } catch (e) {
                    console.warn('module load attempt failed:', spec, e && e.message);
                }
            }
            return null;
        }
        window.subtitleLibsReady = (async () => {
            const status = { matroska: false, jassub: false };
            // Vendored bundle first, CDN as fallback. esm.sh's UA-sniffed
            // target was downgrading matroska-subtitles' SubtitleParser
            // to ES5 (`_inherits` + `Writable.call(this)`) while leaving
            // its Writable superclass as an ES6 class — producing the
            // runtime "Class constructor E cannot be invoked without
            // 'new'" crash inside the parser as soon as we did
            // `new SubtitleParser()`. `?bundle&target=esnext` did not
            // make the issue go away in the wild (esm.sh keeps serving
            // mismatched targets even with the flag), so we ship our
            // own esbuild bundle of matroska-subtitles@3.3.2 from
            // ~/wwwroot/js/. Native `class extends` survives the build,
            // and we no longer depend on a CDN being healthy. The CDN
            // URLs stay as a defensive fallback for the rare case the
            // vendored asset is broken in production.
            //
            // jassub: kept on CDN — its WebAssembly worker file makes
            // vendoring an ESM bundle a separate, larger effort. When
            // (not if) jassub trips the same transpile mismatch we'll
            // vendor it too.
            const matroskaLocal = '@Url.Content("~/js/matroska-subtitles.bundle.js")';
            const [m, j] = await Promise.all([
                tryImport([
                    matroskaLocal,
                    'https://esm.sh/matroska-subtitles?bundle&target=esnext',
                    'https://esm.sh/matroska-subtitles?target=esnext',
                    'https://esm.run/matroska-subtitles',
                    'https://cdn.skypack.dev/matroska-subtitles',
                ]),
                tryImport([
                    // Pinned: newer jassub (1.7.18+) ships features
                    // that break in our environment — useLocalFonts
                    // tries to postMessage a function reference (not
                    // cloneable), and the WebCodecs render path needs
                    // CORS-clean video which RD doesn't provide.
                    // 1.7.17 still has the same option API to opt
                    // out of those via the constructor config below.
                    'https://esm.sh/jassub@1.7.17?bundle&target=esnext',
                    'https://esm.sh/jassub@1.7.17?target=esnext',
                    'https://esm.run/jassub@1.7.17',
                    'https://cdn.skypack.dev/jassub@1.7.17',
                ]),
            ]);
            if (m) {
                // Look for SubtitleParser as named export, on default,
                // or wrapped in a `parser` property — different ESM
                // bundlers (esm.sh / esm.run / skypack) sometimes
                // shape CJS-to-ESM differently for the same package.
                var Parser = m.SubtitleParser
                    || (m.default && m.default.SubtitleParser)
                    || m.default;
                if (typeof Parser === 'function') {
                    window.MatroskaSubtitles = { SubtitleParser: Parser };
                    status.matroska = true;
                } else {
                    console.warn('matroska-subtitles: SubtitleParser export not found; module shape:', Object.keys(m || {}));
                }
            }
            if (j) {
                var JassubCtor = (typeof j === 'function' && j)
                    || j.default
                    || j.JASSUB;
                if (typeof JassubCtor === 'function') {
                    window.JASSUB = JassubCtor;
                    status.jassub = true;
                } else {
                    console.warn('jassub: constructor export not found; module shape:', Object.keys(j || {}));
                }
            }
            return status;
        })();
    </script>
    <script>
        (function () {
            var animeId = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(a.id));
            var season  = @(Model.Current.season > 0 ? Model.Current.season : 1);
            var episode = @Model.Current.episode;
            var hasSeasons = @(hasSeasons ? "true" : "false");

            var sourcesBody = document.getElementById('watchSourcesBody');
            var playerHost  = document.getElementById('watchPlayer');
            var fallbackHost = document.getElementById('watchPlayerFallback');
            if (!sourcesBody || !playerHost) return;

            // Live ArtPlayer instance — recreated on every source pick
            // so the underlying <video> can be swapped cleanly.
            // art.destroy(true) detaches the player, removes its DOM,
            // and unbinds every listener it registered.
            var art = null;
            // Cached last /episode-streams response so playStream +
            // wireSkipOverlay can read the same skipTimes + subtitles
            // bundle without an extra fetch on every source pick.
            var lastData = null;

            // Live JASSUB renderer for SSA/ASS subtitle tracks. Spun
            // up when the user picks an ASS entry from the subtitle
            // selector, torn down when they switch to anything else
            // (None / VTT) or change source. Lives outside any single
            // function so the dispatcher can reach it across selector
            // changes.
            var jassubInstance = null;
            // Embedded MKV subtitle tracks discovered by streaming
            // matroska-subtitles over the current source. Empty until
            // extraction has progressed enough to surface tracks
            // metadata; refreshSubtitleSelector() repopulates the
            // settings menu when it's been updated.
            var embeddedTracks = [];
            // Cancellation token for the in-flight MKV extraction —
            // lets us abort the parse + fetch when the user picks a
            // new source mid-extraction.
            var embeddedExtractAbort = null;

            // jsDelivr serves the latest published version when no
            // tag is specified — matches the version-less imports
            // in the module bootstrap so the worker + wasm stay in
            // step with whatever jassub package the dynamic import
            // ended up resolving.
            // Same version pinning as the ESM bootstrap above. Without
            // a tag, jsdelivr serves the latest jassub which has
            // useLocalFonts + WebCodecs paths enabled by default;
            // both fail in our setup.
            var JASSUB_WORKER = 'https://cdn.jsdelivr.net/npm/jassub@1.7.17/dist/jassub-worker.js';
            var JASSUB_WASM   = 'https://cdn.jsdelivr.net/npm/jassub@1.7.17/dist/jassub-worker.wasm';

            // Browsers refuse `new Worker(crossOriginUrl)` even when
            // the script ships with `Access-Control-Allow-Origin: *`
            // — the Worker constructor enforces a stricter same-
            // origin policy than fetch. Workaround: fetch the worker
            // script as text (CORS-allowed, jsdelivr sends the
            // header), wrap it in a Blob, and construct the Worker
            // from the resulting blob: URL (same-origin to the page).
            // The WASM continues to load directly from the CDN —
            // that fetch happens INSIDE the worker via a regular
            // network request, which CORS handles fine.
            //
            // Cached per page so repeated SSA picks reuse one blob.
            var _jassubWorkerUrlPromise = null;
            function getJassubWorkerUrl() {
                if (_jassubWorkerUrlPromise) return _jassubWorkerUrlPromise;
                _jassubWorkerUrlPromise = fetch(JASSUB_WORKER)
                    .then(function (r) {
                        if (!r.ok) throw new Error('jassub worker fetch HTTP ' + r.status);
                        return r.text();
                    })
                    .then(function (text) {
                        var blob = new Blob([text], { type: 'application/javascript' });
                        return URL.createObjectURL(blob);
                    })
                    .catch(function (e) {
                        // Surface but don't trap — next pick can retry.
                        console.warn('jassub worker blob prep failed:', e);
                        _jassubWorkerUrlPromise = null;
                        throw e;
                    });
                return _jassubWorkerUrlPromise;
            }

            function el(tag, attrs, text) {
                var n = document.createElement(tag);
                if (attrs) Object.keys(attrs).forEach(function (k) {
                    if (k === 'class') n.className = attrs[k];
                    else n.setAttribute(k, attrs[k]);
                });
                if (text != null) n.textContent = text;
                return n;
            }

            function destroyPlayer() {
                // ArtPlayer.destroy(true) detaches the player, removes
                // its DOM, and unbinds every listener it registered.
                // Without the `true`, the player only pauses + retains
                // its DOM — we'd accumulate stale instances per source
                // pick.
                if (art) { try { art.destroy(true); } catch (_) {} art = null; }
                tearDownJassub();
                // Embedded extraction is source-scoped — cancel the
                // in-flight stream + parser when we leave this source
                // so the next source's pipeline starts clean.
                if (embeddedExtractAbort) {
                    try { embeddedExtractAbort.abort(); } catch (_) {}
                    embeddedExtractAbort = null;
                }
                embeddedTracks = [];
                playerHost.innerHTML = '';
                fallbackHost.hidden = true;
                fallbackHost.innerHTML = '';
            }

            function tearDownJassub() {
                if (jassubInstance) {
                    try { jassubInstance.destroy(); } catch (_) {}
                    jassubInstance = null;
                }
            }

            // Dispatcher fired when the user picks an entry from the
            // Subtitles selector. Three kinds:
            //   - "none": hide every subtitle overlay.
            //   - "vtt":  use ArtPlayer's native subtitle pipeline
            //             (already running through art.subtitle).
            //   - "ass":  hand off to a fresh JASSUB instance that
            //             renders SSA/ASS on a canvas over the video.
            // The two pipelines are mutually exclusive — tearDownJassub
            // + art.subtitle.show=false at the top of every branch
            // ensures only one overlay is live at a time.
            function applySubtitle(item) {
                tearDownJassub();
                if (!art) return;
                if (item.kind === 'none') {
                    art.subtitle.show = false;
                    return;
                }
                if (item.kind === 'vtt') {
                    art.subtitle.show = true;
                    art.subtitle.switch(item.url, { name: item.html });
                    return;
                }
                if (item.kind === 'ass') {
                    // ArtPlayer's native overlay stays off while
                    // jassub paints over the video.
                    art.subtitle.show = false;
                    if (typeof JASSUB === 'undefined' || !art.video) return;
                    // workerUrl must resolve to a same-origin blob: URL
                    // before Worker construction — see getJassubWorkerUrl()
                    // for the cross-origin workaround. The fetch + Blob
                    // are cheap after the first call (cached) so the
                    // async hop is one-shot per page load.
                    var capturedVideo = art.video;
                    var capturedItem = item;
                    getJassubWorkerUrl().then(function (workerUrl) {
                        // The user may have torn down the player or
                        // picked a different subtitle in the meantime
                        // — bail if the world has moved on.
                        if (!art || art.video !== capturedVideo) return;
                        try {
                            jassubInstance = new JASSUB({
                                video: capturedVideo,
                                subContent: capturedItem.trackData,
                                workerUrl: workerUrl,
                                wasmUrl: JASSUB_WASM,
                                // Disable the OS-font-query feature.
                                // Newer jassub tries to postMessage a
                                // function reference into the worker
                                // for local-font resolution; functions
                                // can't be structured-cloned and the
                                // entire init bails with DataCloneError.
                                useLocalFonts: false,
                                // Force the software/canvas render
                                // path. The default OffscreenCanvas +
                                // WebCodecs path constructs VideoFrame
                                // objects from the <video>, which the
                                // browser refuses when the source is
                                // cross-origin without CORS (every
                                // debrid stream). Software rendering
                                // doesn't touch the video pixels —
                                // only its dimensions + currentTime.
                                offscreenRender: false,
                                asyncRender: false,
                            });
                        } catch (e) {
                            console.warn('jassub init failed:', e);
                        }
                    }).catch(function (e) {
                        console.warn('jassub init failed (worker prep):', e);
                    });
                }
            }

            // Rebuild the subtitles selector inside ArtPlayer's
            // settings menu — called after the MKV extraction
            // surfaces new embedded tracks. ArtPlayer's settings
            // API across 5.x has shifted shape a few times; try the
            // documented paths in order until one succeeds. Final
            // fallback is remove + add, which always works.
            function refreshSubtitleSelector(rebuildFn) {
                if (!art || !art.setting) {
                    console.warn('refreshSubtitleSelector: no art.setting');
                    return;
                }
                var newOptions;
                try { newOptions = rebuildFn(); }
                catch (e) { console.warn('rebuildFn threw:', e); return; }

                var newEntry = {
                    name: 'subtitles',
                    html: 'Subtitles',
                    tooltip: 'Subtitle track',
                    selector: newOptions,
                    onSelect: function (item) {
                        applySubtitle(item);
                        return item.html;
                    },
                };

                // Path 1: setting.update — newest API, takes an
                // option object matched by `name`.
                try {
                    if (typeof art.setting.update === 'function') {
                        art.setting.update(newEntry);
                        return;
                    }
                } catch (e) { console.warn('setting.update failed:', e); }

                // Path 2: remove + add — works on older 5.x.
                try {
                    if (typeof art.setting.remove === 'function'
                        && typeof art.setting.add === 'function') {
                        art.setting.remove('subtitles');
                        art.setting.add(newEntry);
                        return;
                    }
                } catch (e) { console.warn('setting.remove+add failed:', e); }

                console.warn('No working ArtPlayer settings API found; selector not refreshed');
            }

            // Optional Cloudflare Worker CORS proxy. When set, debrid
            // URLs route through `<proxy>?url=<encoded>` so the bytes
            // come back with Access-Control-Allow-Origin: * — that
            // re-enables the matroska-subtitles extractor for hosts
            // that would otherwise be CORS-blocked.
            var CORS_PROXY_URL    = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(corsProxyUrl));
            var CORS_PROXY_SECRET = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(corsProxySecret));

            // Hosts that consistently block cross-origin `fetch()` on
            // the media URL. Media elements (`<video>`) play these
            // fine because they don't enforce CORS, but the
            // matroska-subtitles pipeline needs raw bytes via fetch.
            // Listed here so we can skip the extract attempt — or
            // route through CORS_PROXY_URL when configured.
            var CORS_BLOCKED_HOST_RE = /(?:^|\.)(?:real-debrid\.com|alldebrid\.com|debrid-link\.com|premiumize\.me|torbox\.app|offcloud\.com|strem\.fun)$/i;

            function viaCorsProxy(url) {
                if (!CORS_PROXY_URL) return null;
                var u = CORS_PROXY_URL.replace(/\/$/, '') + '/?url=' + encodeURIComponent(url);
                if (CORS_PROXY_SECRET) u += '&secret=' + encodeURIComponent(CORS_PROXY_SECRET);
                return u;
            }
            function isCorsBlockedHost(url) {
                try {
                    var h = new URL(url, window.location.href).hostname;
                    return CORS_BLOCKED_HOST_RE.test(h);
                } catch (_) {
                    return false;
                }
            }

            // Resolves a Torrentio resolver URL (strem.fun/resolve/…)
            // to the post-redirect debrid CDN URL. Required because
            // the Cloudflare Worker proxy can't hit Torrentio
            // directly — its own CF WAF rejects worker traffic with
            // a bot-challenge page — but the resolved
            // *.real-debrid.com URL has no CF in front of it, so the
            // Worker streams from it just fine.
            //
            // Two paths, raced:
            //
            //   1. /anime/resolve-stream — AniSync's server follows
            //      the 302 from its own (non-Cloudflare) network and
            //      returns the final URL. Reliable; the only cost is
            //      one tiny extra HTTP roundtrip per source pick.
            //
            //   2. Resource Timing API — watch for an entry on a
            //      debrid-CDN host. <video> sometimes records the
            //      post-redirect URL here, depending on browser; on
            //      Chrome it usually doesn't. Kept as a faster path
            //      when it does work, plus as a fallback if the
            //      server endpoint fails.
            //
            // Whichever resolves first wins. Falls back to the
            // original URL after the timeout so the pipeline at
            // least tries to run (and fails gracefully) rather than
            // hanging.
            var CDN_HOST_RE = /(?:^|\.)(?:real-debrid\.com|alldebrid\.com|debrid-link\.com|premiumize\.me|torbox\.app|offcloud\.com)$/i;
            function resolveStreamUrl(originalUrl, signal) {
                return new Promise(function (resolve) {
                    var TIMEOUT_MS = 10000;
                    var done = false;
                    var observer = null;

                    function finish(u) {
                        if (done) return;
                        done = true;
                        if (observer) { try { observer.disconnect(); } catch (_) {} }
                        resolve(u);
                    }

                    // Server-side resolver — primary path. AniSync's
                    // origin isn't on Cloudflare's bot blocklist, so
                    // the 302 follow goes through cleanly.
                    fetch('/anime/resolve-stream?url=' + encodeURIComponent(originalUrl), {
                        credentials: 'same-origin',
                        headers: { 'Accept': 'application/json' },
                        signal: signal,
                    })
                        .then(function (r) { return r.ok ? r.json() : null; })
                        .then(function (data) {
                            if (done) return;
                            var u = data && data.resolvedUrl;
                            if (!u) return;
                            try {
                                if (CDN_HOST_RE.test(new URL(u).hostname)) {
                                    finish(u);
                                }
                            } catch (_) {}
                        })
                        .catch(function () { /* swallow — Performance API may still pick it up */ });

                    // Resource Timing fallback (browsers that DO
                    // record the post-redirect URL via <video>).
                    function findResolved() {
                        try {
                            var entries = performance.getEntriesByType('resource');
                            for (var i = entries.length - 1; i >= 0; i--) {
                                var name = entries[i].name;
                                try {
                                    if (CDN_HOST_RE.test(new URL(name).hostname)) return name;
                                } catch (_) { /* not a URL */ }
                            }
                        } catch (_) { /* timing API unavailable */ }
                        return null;
                    }

                    var hit = findResolved();
                    if (hit) { finish(hit); return; }

                    try {
                        observer = new PerformanceObserver(function () {
                            var h = findResolved();
                            if (h) finish(h);
                        });
                        observer.observe({ entryTypes: ['resource'] });
                    } catch (_) { /* fall back to timeout-only */ }

                    if (signal) {
                        signal.addEventListener('abort', function () { finish(originalUrl); });
                    }
                    setTimeout(function () { finish(originalUrl); }, TIMEOUT_MS);
                });
            }

            // Stream the MKV via Range-aware fetch into
            // matroska-subtitles, accumulate per-track cues, and on
            // completion build a renderable ASS document for each
            // track. Progressive callback (onTracks) fires as soon
            // as the parser sees the Tracks element so the menu can
            // surface entries before full parse completes — final
            // (onComplete) fires once cue accumulation is done.
            function extractEmbeddedSubs(url, onTracks, onComplete) {
                var abortCtl = new AbortController();

                // Resolve the URL we'll actually fetch from. Three
                // outcomes for CORS-blocked hosts (debrid CDNs +
                // Torrentio resolver):
                //   * No CORS_PROXY_URL → skip silently. The pill
                //     stays hidden, OpenSubtitles fills the menu.
                //   * Proxy configured + Torrentio URL → wait for
                //     <video> to follow the redirect and capture the
                //     resolved debrid-CDN URL via Resource Timing,
                //     then route THAT through the proxy. (Going
                //     through the Worker directly to Torrentio trips
                //     Cloudflare's bot-block; going to RD doesn't.)
                //   * Proxy configured + URL already on a debrid CDN
                //     → route directly through the proxy.
                var urlPromise;
                if (isCorsBlockedHost(url)) {
                    if (!CORS_PROXY_URL) {
                        setEmbedStatus(null);
                        onComplete([]);
                        return abortCtl;
                    }
                    setEmbedStatus('Waiting for stream URL…', 'loading');
                    var originalUrl = url;
                    urlPromise = resolveStreamUrl(originalUrl, abortCtl.signal).then(function (resolved) {
                        return viaCorsProxy(resolved) || viaCorsProxy(originalUrl);
                    });
                } else {
                    urlPromise = Promise.resolve(url);
                }

                urlPromise.then(function (finalUrl) {
                    if (abortCtl.signal.aborted) return;
                    url = finalUrl;
                    setEmbedStatus('Looking for embedded subtitles…', 'loading');

                    // Wait on the global ready promise from the module
                    // bootstrap so we don't bail with "support unavailable"
                    // just because the imports were still in flight when
                    // the user picked a source.
                    var readyPromise = window.subtitleLibsReady
                        || Promise.resolve({ matroska: false, jassub: false });
                    readyPromise.then(function (status) {
                        if (abortCtl.signal.aborted) return;
                        if (!status.matroska || typeof MatroskaSubtitles === 'undefined' || !MatroskaSubtitles.SubtitleParser) {
                            setEmbedStatus('Embedded-subtitle support unavailable', 'error');
                            onComplete([]);
                            return;
                        }
                        runExtraction();
                    }).catch(function (e) {
                        // Defensive: anything thrown synchronously inside
                        // runExtraction's setup (parser ctor, listener wiring)
                        // would otherwise surface as an Uncaught (in promise)
                        // rejection. Treat as a soft failure — the status
                        // pill already reflects the specific cause when one
                        // is known, so just make sure onComplete fires.
                        console.warn('embedded sub readiness chain failed:', e);
                        onComplete([]);
                    });
                });
                return abortCtl;

                function runExtraction() {
                    if (abortCtl.signal.aborted) return;
                    var parser;
                    try { parser = new MatroskaSubtitles.SubtitleParser(); }
                    catch (e) {
                        // Surface the actual error so we can see whether
                        // it's a missing-API problem (Buffer / stream
                        // polyfills), a different export shape, or a
                        // genuine bug in the parser. Truncated to keep
                        // the pill readable.
                        var msg = (e && e.message) ? String(e.message) : 'unknown error';
                        console.warn('matroska parser init threw:', e);
                        setEmbedStatus('Parser init failed: ' + msg.slice(0, 80), 'error');
                        onComplete([]);
                        return;
                    }

                var trackMeta = [];   // [{ number, language, codecID, header }]
                var trackCues = {};   // number → array of { time, duration, text }

                parser.once('tracks', function (tracks) {
                    trackMeta = tracks.map(function (t) {
                        return {
                            number: t.number,
                            language: t.language || 'und',
                            codecID: t.type || '',
                            header: t.header || '',
                            // Friendly label for the selector — use
                            // an ISO-639-2/B → name mapping where we
                            // have one, otherwise echo the raw code.
                            label: prettyLanguage(t.language),
                        };
                    });
                    try {
                        console.log('[AniSync] embedded tracks seen:', trackMeta.map(function (t) {
                            return {
                                number: t.number,
                                language: t.language,
                                codecID: t.codecID,
                                headerLength: (t.header || '').length,
                                hasStyles: (t.header || '').indexOf('[V4+ Styles]') >= 0,
                            };
                        }));
                    } catch (_) {}
                    if (trackMeta.length > 0) {
                        setEmbedStatus(
                            'Found ' + trackMeta.length + ' embedded track' + (trackMeta.length === 1 ? '' : 's') + ' — parsing cues…',
                            'loading');
                    } else {
                        setEmbedStatus('No embedded subtitles in this file', 'none');
                    }
                    // Notify caller that track metadata is available;
                    // the cues themselves still need time to stream
                    // in, but the menu can update with the language
                    // list immediately.
                    onTracks(trackMeta);
                });
                parser.on('subtitle', function (sub, trackNumber) {
                    (trackCues[trackNumber] = trackCues[trackNumber] || []).push(sub);
                });
                parser.on('finish', function () {
                    var output = trackMeta.map(function (t) {
                        return Object.assign({}, t, {
                            data: buildAssDocument(t.header, trackCues[t.number] || []),
                        });
                    });
                    try {
                        console.log('[AniSync] embedded extraction finished:', output.map(function (t) {
                            return {
                                number: t.number,
                                language: t.language,
                                codecID: t.codecID,
                                cueCount: (trackCues[t.number] || []).length,
                                dataLength: t.data.length,
                            };
                        }));
                    } catch (_) {}
                    if (output.length > 0) {
                        setEmbedStatus(
                            output.length + ' embedded track' + (output.length === 1 ? '' : 's') + ' ready',
                            'success');
                    } else {
                        setEmbedStatus('No embedded subtitles in this file', 'none');
                    }
                    onComplete(output);
                });
                parser.on('error', function (e) {
                    console.warn('matroska parser error:', e);
                    setEmbedStatus('Embedded-subtitle parse failed', 'error');
                    onComplete([]);
                });

                fetch(url, { signal: abortCtl.signal })
                    .then(function (response) {
                        if (!response.ok || !response.body) {
                            onComplete([]);
                            return;
                        }
                        var reader = response.body.getReader();
                        function pump() {
                            return reader.read().then(function (result) {
                                if (result.done) { try { parser.end(); } catch (_) {} return; }
                                try { parser.write(result.value); } catch (e) { /* parser may abort early when EOS reached */ }
                                return pump();
                            });
                        }
                        return pump();
                    })
                    .catch(function (e) {
                        // AbortError on source switch is expected.
                        // TypeError "Failed to fetch" is almost always
                        // CORS on a debrid CDN: the <video> tag plays
                        // the same URL fine (media elements don't
                        // enforce CORS) but fetch() is strict and
                        // *.real-debrid.com / *.strem.fun don't send
                        // Access-Control-Allow-Origin. Hide the pill
                        // silently in that case and let OpenSubtitles
                        // fill in — a red "fetch failed" pill on an
                        // otherwise-playable stream is just noise.
                        if (!e || e.name === 'AbortError') {
                            // expected — source switch / unmount
                        } else if (e.name === 'TypeError') {
                            console.info('embedded sub stream unreachable (likely CORS on debrid CDN):', e.message);
                            setEmbedStatus(null);
                        } else {
                            console.warn('embedded sub stream failed:', e);
                            setEmbedStatus('Embedded-subtitle fetch failed', 'error');
                        }
                        onComplete([]);
                    });
                } // end runExtraction
            }

            // Best-effort ISO-639-2/B → friendly name. Returns the
            // raw code (upper-cased) when unmapped — anime sometimes
            // ships with non-standard or empty language entries.
            function prettyLanguage(code) {
                var c = (code || '').toLowerCase();
                var map = {
                    eng: 'English', spa: 'Spanish', por: 'Portuguese',
                    fre: 'French', fra: 'French', ger: 'German', deu: 'German',
                    ita: 'Italian', rus: 'Russian', ara: 'Arabic',
                    jpn: 'Japanese', chi: 'Chinese', zho: 'Chinese',
                    kor: 'Korean', tur: 'Turkish', pol: 'Polish',
                    dut: 'Dutch', nld: 'Dutch', und: 'Embedded',
                };
                return map[c] || (code ? code.toUpperCase() : 'Embedded');
            }

            // Stitches matroska-subtitles' header (the .ass file's
            // Script Info + V4+ Styles + Events header lines) with
            // accumulated cues into a complete .ass document that
            // jassub can render. Each cue's `text` is already the
            // Dialogue line text after the timestamp; we just prefix
            // Minimal ASS skeleton injected when the track header is
            // missing a [V4+ Styles] section. Necessary for S_TEXT/UTF8
            // tracks (plain text, no CodecPrivate) and for any release
            // whose ASS header was stripped before mux. JASSUB silently
            // renders nothing when the document lacks Script Info +
            // Styles, even if Dialogue: lines are present — so we
            // backfill a reasonable default.
            var MINIMAL_ASS_HEADER = [
                '[Script Info]',
                'ScriptType: v4.00+',
                'PlayResX: 1920',
                'PlayResY: 1080',
                'ScaledBorderAndShadow: yes',
                '',
                '[V4+ Styles]',
                'Format: Name, Fontname, Fontsize, PrimaryColour, SecondaryColour, OutlineColour, BackColour, Bold, Italic, Underline, StrikeOut, ScaleX, ScaleY, Spacing, Angle, BorderStyle, Outline, Shadow, Alignment, MarginL, MarginR, MarginV, Encoding',
                'Style: Default,Arial,42,&H00FFFFFF,&H000000FF,&H00000000,&H80000000,0,0,0,0,100,100,0,0,1,2,1,2,40,40,60,1',
                '',
                '[Events]',
                'Format: Layer, Start, End, Style, Name, MarginL, MarginR, MarginV, Effect, Text',
            ].join('\n');

            // with the standard Dialogue header per ASS spec.
            function buildAssDocument(header, cues) {
                var hasStyles = header && header.indexOf('[V4+ Styles]') >= 0;
                if (!hasStyles) header = MINIMAL_ASS_HEADER;
                if (!cues || cues.length === 0) return header;
                var lines = cues.map(function (c) {
                    var start = formatAssTime(c.time);
                    var end   = formatAssTime(c.time + (c.duration || 0));
                    // SRT-derived cues use \n for line breaks; ASS
                    // expects literal \N. Skip when the source is
                    // already ASS-styled (no raw newlines in those).
                    var text = (c.text || '').replace(/\r?\n/g, '\\N');
                    return 'Dialogue: 0,' + start + ',' + end + ',Default,,0,0,0,,' + text;
                });
                return header + '\n' + lines.join('\n') + '\n';
            }
            function formatAssTime(ms) {
                if (!ms || ms < 0) ms = 0;
                var h  = Math.floor(ms / 3600000);
                var m  = Math.floor((ms % 3600000) / 60000);
                var s  = Math.floor((ms % 60000) / 1000);
                var cs = Math.floor((ms % 1000) / 10);
                return h + ':' + pad2(m) + ':' + pad2(s) + '.' + pad2(cs);
            }
            function pad2(n) { return (n < 10 ? '0' : '') + n; }

            function showFallback(stream) {
                fallbackHost.hidden = false;
                fallbackHost.innerHTML = '';
                fallbackHost.appendChild(el('p', { class: 'hint-text', style: 'margin: 0 0 0.75rem;' },
                    "Your browser couldn't decode this stream. Open it in an external player or copy the URL."));
                var row = el('div', { class: 'watch-fallback-actions' });
                var open = el('a', {
                    class: 'btn-ghost btn-ghost-sm',
                    href: stream.url, target: '_blank', rel: 'noopener noreferrer',
                }, 'Open externally');
                var copy = el('button', { type: 'button', class: 'btn-ghost btn-ghost-sm' }, 'Copy URL');
                copy.addEventListener('click', function () {
                    navigator.clipboard.writeText(stream.url).then(function () {
                        copy.textContent = 'Copied';
                        setTimeout(function () { copy.textContent = 'Copy URL'; }, 1200);
                    });
                });
                row.appendChild(open);
                row.appendChild(copy);
                fallbackHost.appendChild(row);
            }

            function playStream(stream) {
                destroyPlayer();

                // First line of the stream's title is the release
                // filename — Torrentio puts it there before its size /
                // seeder annotations. We pass it to /anime/episode-
                // subtitles so OpenSubtitles can return release-matched
                // subs (correct timing for THIS file rather than a
                // generic search hit). Best-effort: any failure or
                // missing filename just falls through to a generic
                // imdb:s:e query.
                var firstLine = (stream.title || stream.name || '').split('\n')[0].trim();

                var subQs = 'id=' + encodeURIComponent(animeId)
                    + '&episode=' + encodeURIComponent(episode)
                    + (hasSeasons ? '&season=' + encodeURIComponent(season) : '')
                    + (firstLine ? '&filename=' + encodeURIComponent(firstLine) : '');

                fetch('/anime/episode-subtitles?' + subQs, {
                    credentials: 'same-origin',
                    headers: { 'Accept': 'application/json' },
                    skipLoader: true,
                })
                    .then(function (r) { return r.ok ? r.json() : { subtitles: [] }; })
                    .catch(function () { return { subtitles: [] }; })
                    .then(function (data) {
                        var subs = (data && data.subtitles) || [];
                        // Visibility into per-provider contribution.
                        // Logged to console (devtools-only, no UI cost
                        // for normal users) and rendered as a chip in
                        // the toolbar (visible to everyone) so the
                        // user can confirm at a glance whether each
                        // provider returned anything.
                        var pc = (data && data.providerCounts) || {};
                        try {
                            console.log(
                                '[AniSync] subtitles loaded:',
                                subs.length, 'tracks',
                                'opensubtitles=' + (pc.opensubtitles || 0),
                                'wyzie=' + (pc.wyzie || 0),
                                subs);
                        } catch (_) {}
                        renderSubsProviderChip(pc);
                        initPlayer(stream, subs);
                    });
            }

            function initPlayer(stream, subtitles) {
                // ArtPlayer wipes its container on init, so the
                // placeholder paragraph + any stale DOM go away
                // automatically. Title flows through to the top-left
                // overlay; theme tints the active progress + buttons.

                // Pick the default subtitle: first English entry when
                // present, otherwise the first track. Used to mark
                // the initial pick in the settings selector + as the
                // ArtPlayer `subtitle:` config so something shows
                // immediately on play.
                var defaultSubIdx = -1;
                for (var i = 0; i < subtitles.length; i++) {
                    if (/^en/i.test(subtitles[i].lang || '')) { defaultSubIdx = i; break; }
                }
                if (defaultSubIdx === -1 && subtitles.length > 0) defaultSubIdx = 0;

                // Subtitle picker is ALWAYS rendered with a "None"
                // option at the top so users can turn captions off
                // regardless of how many tracks are available. ASS
                // entries get added later (after MKV extraction
                // completes); they live alongside the VTT tracks in
                // the same selector and route through applySubtitle().
                function buildSubtitleSelector() {
                    var options = [{ html: 'None', kind: 'none', "default": defaultSubIdx < 0 }];
                    subtitles.forEach(function (t, i) {
                        options.push({
                            html: t.label || t.lang || 'Subtitles',
                            kind: 'vtt',
                            url: t.url,
                            "default": i === defaultSubIdx,
                        });
                    });
                    embeddedTracks.forEach(function (t) {
                        // Label format intentionally drops the parens —
                        // "English SSA" reads as a track type tag at a
                        // glance, faster than "English (SSA)".
                        options.push({
                            html: (t.label || 'Embedded') + ' SSA',
                            kind: 'ass',
                            trackData: t.data,
                            "default": false,
                        });
                    });
                    return options;
                }

                var settings = [{
                    name: 'subtitles',
                    html: 'Subtitles',
                    tooltip: 'Subtitle track',
                    selector: buildSubtitleSelector(),
                    onSelect: function (item) {
                        applySubtitle(item);
                        return item.html;
                    },
                }];

                // Mark intro / outro on the progress bar so the user
                // sees the upcoming skip-points at a glance. Same data
                // wireSkipOverlay() uses for its corner-anchored
                // button — these are the visual cue, the button is
                // the action.
                var highlight = [];
                var times = lastData && lastData.skipTimes;
                if (times) {
                    if (times.intro) {
                        highlight.push({ time: times.intro.start, text: 'OP' });
                    }
                    if (times.outro) {
                        highlight.push({ time: times.outro.start, text: 'ED' });
                    }
                }

                // Mobile devices already paint the native fullscreen
                // mode landscape via autoOrientation, so the web-
                // fullscreen icon next to it is duplicative chrome. On
                // desktop it stays — sometimes a viewer wants the
                // letterboxed in-page big-frame view without losing
                // the URL bar. matchMedia is the standard "are we on
                // a phone-shaped viewport" check.
                var isMobile = window.matchMedia('(max-width: 640px)').matches;

                // Reusable SVG markup for the ±10s control buttons —
                // pre-encoded inline so ArtPlayer can drop them into
                // its toolbar without an extra fetch. Both icons mirror
                // each other; only the polyline + the digit shift.
                var rewindSvg = '<svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="11 17 6 12 11 7"/><polyline points="18 17 13 12 18 7"/></svg>';
                var forwardSvg = '<svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="13 17 18 12 13 7"/><polyline points="6 17 11 12 6 7"/></svg>';

                art = new Artplayer({
                    container: playerHost,
                    url: stream.url,
                    title: @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(episodeLabel)),
                    theme: '#7c3aed',
                    autoplay: true,
                    pip: true,
                    // screenshot / aspectRatio dropped from the toolbar —
                    // the screenshot icon and the aspect-ratio toggle
                    // were noise for the average viewer; users who want
                    // those can still get aspect-ratio via the settings
                    // menu's video-scaling entry if we ever surface one.
                    screenshot: false,
                    setting: true,
                    playbackRate: true,
                    aspectRatio: false,
                    fullscreen: true,
                    fullscreenWeb: !isMobile,
                    subtitleOffset: true,
                    miniProgressBar: true,
                    autoOrientation: true,
                    hotkey: true,
                    airplay: true,
                    moreVideoAttr: { playsInline: true },
                    subtitle: defaultSubIdx >= 0 ? {
                        url: subtitles[defaultSubIdx].url,
                        type: 'vtt',
                        encoding: 'utf-8',
                        // escape: true keeps ArtPlayer HTML-escaping
                        // subtitle text — OpenSubtitles content is
                        // third-party and we don't want stray <script>
                        // / <img> tags landing in the captions overlay.
                        escape: true,
                        name: subtitles[defaultSubIdx].label || subtitles[defaultSubIdx].lang,
                    } : {},
                    settings: settings,
                    highlight: highlight,
                    controls: [
                        {
                            // ←10s — sits in the toolbar to the left of
                            // the play button. `index` orders custom
                            // controls within their position; play is at
                            // 10 by default, so 8 puts us just before it.
                            position: 'left',
                            index: 8,
                            html: rewindSvg,
                            tooltip: 'Rewind 10s',
                            click: function () {
                                var v = art && art.video;
                                if (v) art.seek = Math.max(0, (v.currentTime || 0) - 10);
                            },
                        },
                        {
                            // 10s→ — mirror of rewind, just after play.
                            position: 'left',
                            index: 12,
                            html: forwardSvg,
                            tooltip: 'Forward 10s',
                            click: function () {
                                var v = art && art.video;
                                if (!v) return;
                                var target = (v.currentTime || 0) + 10;
                                if (v.duration && target > v.duration) target = v.duration;
                                art.seek = target;
                            },
                        },
                    ],
                });

                // ArtPlayer normalises the native HTMLVideoElement
                // through art.video; the "video:error" custom event
                // fires whenever the inner element errors. code === 4
                // (MEDIA_ERR_SRC_NOT_SUPPORTED) is the definitive
                // "browser can't decode" signal we swap for the
                // external-open fallback.
                art.on('video:error', function () {
                    var v = art.video;
                    if (v && v.error && v.error.code === 4) showFallback(stream);
                });

                // Move the skip-intro overlay button into the player
                // host now that ArtPlayer has mounted its DOM there.
                // playerHost is position:relative; the button is
                // position:absolute, so this gives the button a stable
                // corner-anchor over the video frame regardless of
                // ArtPlayer's internal chrome size.
                if (skipButton) playerHost.appendChild(skipButton);

                wireSkipOverlay(art);
                paintSkipRanges(art);

                // Kick off embedded MKV subtitle extraction in
                // background. matroska-subtitles streams the file via
                // fetch + Range; track metadata surfaces as soon as
                // the parser hits the Tracks element (often within
                // the first MB), and the full ASS bodies finalise on
                // completion. We rebuild the Subtitles selector
                // twice — once on metadata, once on completion — so
                // the user sees the entries appear as they become
                // usable.
                embeddedExtractAbort = extractEmbeddedSubs(
                    stream.url,
                    function (meta) {
                        // Metadata-only step: tracks visible in the
                        // menu but trackData is empty; selecting one
                        // does nothing until completion fires.
                        embeddedTracks = meta.map(function (t) {
                            return Object.assign({}, t, { data: '' });
                        });
                        refreshSubtitleSelector(buildSubtitleSelector);
                    },
                    function (full) {
                        embeddedTracks = full;
                        refreshSubtitleSelector(buildSubtitleSelector);
                        // Auto-promote the SSA track when it lands —
                        // anime fansubs ship with styled embedded
                        // subs that almost always beat OpenSubtitles
                        // for accuracy, so default to that without
                        // requiring an extra click. Prefer the
                        // English track when present; fall back to
                        // the first track.
                        if (full.length > 0) {
                            var chosen = null;
                            for (var i = 0; i < full.length; i++) {
                                if (/^en/i.test(full[i].language || '')) { chosen = full[i]; break; }
                            }
                            chosen = chosen || full[0];
                            if (chosen && chosen.data) {
                                applySubtitle({
                                    kind: 'ass',
                                    html: (chosen.label || 'Embedded') + ' SSA',
                                    trackData: chosen.data,
                                });
                            }
                        }
                    });
            }

            // ── AniSkip skip-intro / skip-outro overlay ───────────────
            // Shows a corner-anchored button when the playhead enters
            // the intro or outro range. Click → seek to range.end + 1s
            // (the +1s puts the user just past the marker so they don't
            // immediately re-enter the trigger zone). Auto-skip is
            // persisted in localStorage so the user can flip it on once
            // and forget about it across episodes.
            var skipButton = document.getElementById('watchSkipButton');
            var skipAutoBtn = document.getElementById('watchSkipAuto');
            var embedStatusEl = document.getElementById('watchEmbeddedStatus');
            var subsProviderEl = document.getElementById('watchSubsProvider');

            // Render a "OpenSubtitles: X · Wyzie: Y" chip after the
            // subtitle fetch resolves. data-kind drives the colour so
            // a totally empty result reads visually distinct from a
            // partial one.
            function renderSubsProviderChip(counts) {
                if (!subsProviderEl) return;
                var os = (counts && counts.opensubtitles) || 0;
                var wy = (counts && counts.wyzie) || 0;
                if (os + wy === 0) {
                    subsProviderEl.hidden = false;
                    subsProviderEl.textContent = 'No remote subtitles';
                    subsProviderEl.setAttribute('data-kind', 'none');
                    return;
                }
                subsProviderEl.hidden = false;
                subsProviderEl.textContent = 'Subs · OS: ' + os + ' · Wyzie: ' + wy;
                subsProviderEl.setAttribute('data-kind', wy > 0 ? 'success' : 'loading');
            }

            // Surface the embedded-subtitle pipeline state to the user.
            // Without this they can't tell whether SSA extraction is
            // running, whether it finished with no tracks (some
            // releases bake subtitles into the video itself rather
            // than as a separate track), or whether the libraries
            // failed to load. `kind` drives the pill colour:
            // loading / success / none / error.
            function setEmbedStatus(text, kind) {
                if (!embedStatusEl) return;
                if (!text) {
                    embedStatusEl.hidden = true;
                    embedStatusEl.textContent = '';
                    embedStatusEl.removeAttribute('data-kind');
                    return;
                }
                embedStatusEl.hidden = false;
                embedStatusEl.textContent = text;
                embedStatusEl.setAttribute('data-kind', kind || '');
            }

            var autoSkip = localStorage.getItem('anisync.autoSkip') === '1';
            if (skipAutoBtn) {
                skipAutoBtn.setAttribute('aria-pressed', autoSkip ? 'true' : 'false');
                skipAutoBtn.classList.toggle('is-active', autoSkip);
                skipAutoBtn.addEventListener('click', function () {
                    autoSkip = !autoSkip;
                    localStorage.setItem('anisync.autoSkip', autoSkip ? '1' : '0');
                    skipAutoBtn.setAttribute('aria-pressed', autoSkip ? 'true' : 'false');
                    skipAutoBtn.classList.toggle('is-active', autoSkip);
                });
            }

            function wireSkipOverlay(art) {
                if (!skipButton) return;
                var times = lastData && lastData.skipTimes;
                if (!times || (!times.intro && !times.outro)) {
                    skipButton.hidden = true;
                    return;
                }
                var currentRange = null;
                function activeRange(t) {
                    if (times.intro && t >= times.intro.start && t < times.intro.end - 0.5) {
                        return { label: 'Skip intro', end: times.intro.end };
                    }
                    if (times.outro && t >= times.outro.start && t < times.outro.end - 0.5) {
                        return { label: 'Skip outro', end: times.outro.end };
                    }
                    return null;
                }
                // ArtPlayer exposes the underlying <video> on art.video.
                // The native "timeupdate" event fires at ~250ms cadence
                // which is fine for the once-every-few-seconds polling
                // the overlay needs.
                art.on('video:timeupdate', function () {
                    var t = art.currentTime || 0;
                    var r = activeRange(t);
                    if (!r) {
                        currentRange = null;
                        skipButton.hidden = true;
                        return;
                    }
                    if (autoSkip) {
                        art.seek = r.end + 1;
                        skipButton.hidden = true;
                        return;
                    }
                    if (currentRange !== r.label) {
                        currentRange = r.label;
                        skipButton.textContent = r.label + ' →';
                        skipButton.dataset.seekTo = String(r.end + 1);
                    }
                    skipButton.hidden = false;
                });
                skipButton.onclick = function () {
                    var t = parseFloat(skipButton.dataset.seekTo || '0');
                    if (t > 0) art.seek = t;
                };
            }

            // Paint a translucent fill over the OP / ED ranges on the
            // ArtPlayer progress bar. The existing `highlight: [...]`
            // option gives single-tick markers at intro.start /
            // outro.start; the range fill adds width so the user can
            // see at a glance how much they'd skip. The fill lives
            // inside ArtPlayer's progress element, so it dies with
            // the player on source switch — no cleanup needed.
            function paintSkipRanges(art) {
                var times = lastData && lastData.skipTimes;
                if (!times || (!times.intro && !times.outro)) return;
                // Need the video duration to convert seconds → %. On
                // some browsers metadata lands a beat after `ready`,
                // so listen on the earliest event that has duration
                // and bail if it still isn't there.
                function paint() {
                    var dur = art.duration || (art.video && art.video.duration) || 0;
                    if (!dur || !isFinite(dur)) return false;
                    var host = art.template && art.template.$progress;
                    if (!host) host = art.constructor.utils
                        ? art.constructor.utils.query('.art-control-progress', art.template && art.template.$player)
                        : null;
                    if (!host) host = (art.template && art.template.$player || document)
                        .querySelector('.art-control-progress');
                    if (!host) return false;
                    // Idempotent: nuke any prior fills before re-paint.
                    var prior = host.querySelectorAll('.watch-skip-range');
                    for (var i = 0; i < prior.length; i++) prior[i].remove();
                    function addBand(range, kind) {
                        if (!range) return;
                        var startPct = Math.max(0, Math.min(100, (range.start / dur) * 100));
                        var endPct = Math.max(0, Math.min(100, (range.end / dur) * 100));
                        var width = Math.max(0, endPct - startPct);
                        if (width <= 0) return;
                        var band = document.createElement('span');
                        band.className = 'watch-skip-range watch-skip-range-' + kind;
                        band.style.left = startPct + '%';
                        band.style.width = width + '%';
                        band.title = (kind === 'intro' ? 'Opening' : 'Ending')
                            + ' — ' + Math.round(range.start) + 's → ' + Math.round(range.end) + 's';
                        host.appendChild(band);
                    }
                    addBand(times.intro, 'intro');
                    addBand(times.outro, 'outro');
                    return true;
                }
                if (!paint()) {
                    // Duration not ready yet — retry on the next
                    // event that signals metadata is loaded.
                    var once = function () {
                        if (paint()) art.off('video:loadedmetadata', once);
                    };
                    art.on('video:loadedmetadata', once);
                    art.on('ready', once);
                }
            }


            // SVG icons reused by the per-row action buttons. Inline
            // so they pick up `currentColor` from the host button's
            // text colour — no separate icon font / sprite needed.
            var COPY_ICON_SVG = '<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>';
            var EXTERNAL_ICON_SVG = '<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>';

            // The external-player popup. Single instance attached to
            // <body> rather than per-row so it can position absolutely
            // and outlive the row's DOM (we mutate sourcesBody.innerHTML
            // on every refresh which would otherwise nuke an inline
            // menu mid-interaction).
            var externalMenu = null;
            function closeExternalMenu() {
                if (externalMenu && externalMenu.parentNode) {
                    externalMenu.parentNode.removeChild(externalMenu);
                }
                externalMenu = null;
            }
            document.addEventListener('click', function (e) {
                if (!externalMenu) return;
                if (!externalMenu.contains(e.target) && !e.target.closest('.episode-stream-action-external')) {
                    closeExternalMenu();
                }
            });
            document.addEventListener('keydown', function (e) {
                if (e.key === 'Escape') closeExternalMenu();
            });

            // Build the copy button. Uses the async Clipboard API
            // when available (HTTPS / localhost) with a textarea
            // fallback for older / insecure-context cases — the
            // dashboard isn't always served over HTTPS in self-host
            // setups so falling back rather than failing keeps the
            // button useful everywhere. Visual feedback by swapping
            // the icon to a check for 1.5s.
            function buildCopyAction(url) {
                var btn = el('button', {
                    type: 'button',
                    class: 'episode-stream-action',
                    title: 'Copy stream URL',
                });
                btn.innerHTML = COPY_ICON_SVG;
                btn.addEventListener('click', function (e) {
                    e.stopPropagation();
                    closeExternalMenu();
                    copyToClipboard(url).then(function (ok) {
                        if (!ok) return;
                        var prev = btn.innerHTML;
                        btn.classList.add('is-success');
                        btn.innerHTML = '<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>';
                        setTimeout(function () {
                            btn.classList.remove('is-success');
                            btn.innerHTML = prev;
                        }, 1500);
                    });
                });
                return btn;
            }

            function copyToClipboard(text) {
                if (navigator.clipboard && navigator.clipboard.writeText) {
                    return navigator.clipboard.writeText(text)
                        .then(function () { return true; })
                        .catch(function () { return copyFallback(text); });
                }
                return Promise.resolve(copyFallback(text));
            }
            function copyFallback(text) {
                try {
                    var ta = document.createElement('textarea');
                    ta.value = text;
                    ta.style.position = 'fixed';
                    ta.style.opacity = '0';
                    document.body.appendChild(ta);
                    ta.select();
                    var ok = document.execCommand('copy');
                    document.body.removeChild(ta);
                    return ok;
                } catch (_) {
                    return false;
                }
            }

            // Build the external-player launcher. Click → small menu
            // with one row per player. Each row maps to a URL scheme
            // the corresponding app registers (VLC / Infuse / IINA /
            // Outplayer) plus a "browser tab" fallback. Schemes are
            // tried by setting `location.href` to the custom URL — if
            // the app is installed the OS hands the URL off to it; if
            // not, the browser does nothing visible (we surface the
            // copy button right next to it so the user can still grab
            // the URL).
            function buildExternalAction(url, displayName) {
                var btn = el('button', {
                    type: 'button',
                    class: 'episode-stream-action episode-stream-action-external',
                    title: 'Watch in external player',
                });
                btn.innerHTML = EXTERNAL_ICON_SVG;
                btn.addEventListener('click', function (e) {
                    e.stopPropagation();
                    openExternalMenu(btn, url, displayName);
                });
                return btn;
            }

            function openExternalMenu(anchorBtn, url, displayName) {
                if (externalMenu) { closeExternalMenu(); return; }
                var encoded = encodeURIComponent(url);
                var encodedTitle = encodeURIComponent(displayName || 'AniSync');
                var options = [
                    { label: 'Open in browser tab', href: url, target: '_blank' },
                    { label: 'Open in VLC',         href: 'vlc://' + url },
                    { label: 'Open in Infuse',      href: 'infuse://x-callback-url/play?url=' + encoded },
                    { label: 'Open in Outplayer',   href: 'outplayer://' + url },
                    { label: 'Open in IINA',        href: 'iina://weblink?url=' + encoded + '&name=' + encodedTitle },
                ];
                externalMenu = document.createElement('div');
                externalMenu.className = 'episode-stream-external-menu';
                options.forEach(function (opt) {
                    var a = document.createElement('a');
                    a.href = opt.href;
                    a.textContent = opt.label;
                    if (opt.target) a.target = opt.target;
                    a.addEventListener('click', function () {
                        // Defer the close so the navigation actually
                        // happens before we remove the anchor element.
                        setTimeout(closeExternalMenu, 0);
                    });
                    externalMenu.appendChild(a);
                });
                document.body.appendChild(externalMenu);
                var rect = anchorBtn.getBoundingClientRect();
                var menuRect = externalMenu.getBoundingClientRect();
                var top = rect.bottom + window.scrollY + 4;
                var left = rect.right + window.scrollX - menuRect.width;
                // Keep the menu on-screen if the anchor sits near the
                // right edge of a narrow viewport.
                if (left < 8) left = 8;
                externalMenu.style.top = top + 'px';
                externalMenu.style.left = left + 'px';
            }


            function renderSources(data) {
                sourcesBody.innerHTML = '';

                var debrid = (data && data.debridStreams) || [];
                var external = (data && data.externalLinks) || [];

                if (debrid.length > 0) {
                    var h = el('h3', { class: 'watch-section-subtitle' }, 'Debrid streams');
                    sourcesBody.appendChild(h);
                    var list = el('ul', { class: 'episode-stream-list' });
                    debrid.forEach(function (s) {
                        var li = el('li', { class: 'episode-stream-row' });
                        var btn = el('button', { type: 'button', class: 'episode-stream-pick' });
                        btn.appendChild(el('span', { class: 'episode-stream-quality' }, s.quality || '—'));

                        var meta = el('span', { class: 'episode-stream-meta' });
                        var firstLine = (s.title || s.name || '').split('\n')[0];
                        meta.appendChild(el('span', { class: 'episode-stream-title' }, firstLine));
                        var sub = el('span', { class: 'episode-stream-sub' });
                        if (s.size) sub.appendChild(el('span', { class: 'episode-stream-size' }, s.size));
                        if (typeof s.seeders === 'number' && s.seeders > 0) {
                            sub.appendChild(el('span', { class: 'episode-stream-seeders' }, '👤 ' + s.seeders));
                        }
                        if (s.language) {
                            sub.appendChild(el('span', { class: 'episode-stream-language' }, s.language));
                        }
                        if (sub.childNodes.length > 0) meta.appendChild(sub);
                        btn.appendChild(meta);

                        btn.addEventListener('click', function () { playStream(s); });
                        li.appendChild(btn);

                        // Side actions: copy link + open externally.
                        // Sit alongside the main pick button rather
                        // than inside it so the click targets don't
                        // overlap. Both operate on s.url directly —
                        // it's the debrid CDN URL, which is what the
                        // user wants to hand off to VLC / Infuse /
                        // pasteboard / etc.
                        var actions = el('div', { class: 'episode-stream-actions' });
                        actions.appendChild(buildCopyAction(s.url));
                        actions.appendChild(buildExternalAction(s.url, firstLine));
                        li.appendChild(actions);

                        list.appendChild(li);
                    });
                    sourcesBody.appendChild(list);
                }

                if (external.length > 0) {
                    var h2 = el('h3', { class: 'watch-section-subtitle' },
                        debrid.length > 0 ? 'Other sites' : 'Watch on');
                    sourcesBody.appendChild(h2);
                    var ul = el('ul', { class: 'episode-stream-list episode-stream-list-external' });
                    external.forEach(function (l) {
                        var a = el('a', {
                            class: 'episode-stream-pick',
                            href: l.url, target: '_blank', rel: 'noopener noreferrer',
                        });
                        a.appendChild(el('span', { class: 'episode-stream-title' }, l.site));
                        var li = el('li', { class: 'episode-stream-row' });
                        li.appendChild(a);
                        ul.appendChild(li);
                    });
                    sourcesBody.appendChild(ul);
                }

                if (debrid.length === 0 && external.length === 0) {
                    var msg = data && data.anonymous
                        ? "Sign in and add a Real-Debrid key in Settings to find streaming sources for this episode."
                        : (data && !data.rdConfigured
                            ? "No streaming sources found. Add a Real-Debrid key in Settings to surface RD-cached torrents via Torrentio."
                            : "No streaming sources found for this episode.");
                    sourcesBody.appendChild(el('p', { class: 'hint-text' }, msg));
                }
            }

            var qs = 'id=' + encodeURIComponent(animeId)
                + '&episode=' + encodeURIComponent(episode)
                + (hasSeasons ? '&season=' + encodeURIComponent(season) : '');
            fetch('/anime/episode-streams?' + qs, {
                credentials: 'same-origin',
                headers: { 'Accept': 'application/json' },
                // The Sources panel renders its own "Looking for streams…"
                // placeholder while the request is in flight — the global
                // full-screen loader-overlay on top of that would just be
                // double-loading.
                skipLoader: true,
            })
                .then(function (r) { return r.ok ? r.json() : null; })
                .then(function (data) {
                    if (!data) {
                        sourcesBody.innerHTML = '<p class="hint-text">Couldn\'t load sources. Try refreshing.</p>';
                        return;
                    }
                    lastData = data;
                    // Hide the auto-skip toggle when AniSkip didn't
                    // return any markers for this episode — the toggle
                    // would have nothing to act on and just adds chrome
                    // the user can't use. The corner skip button is
                    // already gated on the same data inside
                    // wireSkipOverlay, so it stays hidden too.
                    if (skipAutoBtn) {
                        var sk = data && data.skipTimes;
                        skipAutoBtn.hidden = !sk || (!sk.intro && !sk.outro);
                    }
                    renderSources(data);
                })
                .catch(function () {
                    sourcesBody.innerHTML = '<p class="hint-text">Couldn\'t load sources. Try refreshing.</p>';
                });
        })();
    </script>
}
