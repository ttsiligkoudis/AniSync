@using AnimeList.Models
@{
    // Fixed Trakt-style media-type switch shown below the header on the
    // dashboard / Discover / Library. Renders only the modes the user enabled
    // in the chooser modal (so it's hidden when only one is enabled). The
    // dashboard variant prepends an "All" pill and filters its sections
    // client-side; Discover / Library reload into the chosen mode. Active state
    // + persistence are handled by media-type-switch.js (localStorage).
    var mtsEnabled = ViewData["MtsEnabled"] as List<MetaType> ?? new();
    var mtsActive = ViewData["MtsActive"] is MetaType aa ? aa : (mtsEnabled.Count > 0 ? mtsEnabled[0] : MetaType.anime);
    var mtsDashboard = ViewData["MtsDashboard"] as bool? ?? false;
    var mtsLabels = new Dictionary<MetaType, string>
    {
        [MetaType.anime] = "Anime",
        [MetaType.movie] = "Movies",
        [MetaType.series] = "Series",
    };
}
@if (mtsEnabled.Count > 1)
{
    <div class="mt-switch-bar" data-mt-switch="@(mtsDashboard ? "dashboard" : "navigate")">
        <div class="container mt-switch-inner">
            <div class="mt-switch" role="tablist" aria-label="Media type">
                @if (mtsDashboard)
                {
                    <button type="button" class="mt-switch-btn active" data-mt-value="all" role="tab" aria-selected="true">
                        <span class="mt-switch-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="3" y="3" width="7" height="7" rx="1.5" />
                                <rect x="14" y="3" width="7" height="7" rx="1.5" />
                                <rect x="3" y="14" width="7" height="7" rx="1.5" />
                                <rect x="14" y="14" width="7" height="7" rx="1.5" />
                            </svg>
                        </span>
                        <span class="mt-switch-label">All</span>
                    </button>
                }
                @foreach (var mt in mtsEnabled)
                {
                    var isActive = !mtsDashboard && mt == mtsActive;
                    <button type="button" class="mt-switch-btn @(isActive ? "active" : "")"
                            data-mt-value="@mt" role="tab" aria-selected="@(isActive ? "true" : "false")">
                        <span class="mt-switch-icon" aria-hidden="true">
                            @if (mt == MetaType.anime)
                            {
                                <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M12 3l1.9 5.6L19.5 10l-5.6 1.9L12 17.5l-1.9-5.6L4.5 10l5.6-1.4z" />
                                    <path d="M19 4l.6 1.8L21.5 6.5l-1.9.6L19 9l-.6-1.9L16.5 6.5l1.9-.7z" />
                                </svg>
                            }
                            else if (mt == MetaType.movie)
                            {
                                <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                    <rect x="3" y="4" width="18" height="16" rx="2" />
                                    <line x1="7" y1="4" x2="7" y2="20" />
                                    <line x1="17" y1="4" x2="17" y2="20" />
                                    <line x1="3" y1="12" x2="21" y2="12" />
                                </svg>
                            }
                            else
                            {
                                <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                    <rect x="2" y="7" width="20" height="13" rx="2" />
                                    <polyline points="8 3 12 7 16 3" />
                                </svg>
                            }
                        </span>
                        <span class="mt-switch-label">@mtsLabels[mt]</span>
                    </button>
                }
            </div>
        </div>
    </div>
}
