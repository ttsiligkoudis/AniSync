@model AnimeList.Models.PosterGridViewModel
@{
    // "scroll" → horizontal-overflow row used on the dashboard's Continue
    // Watching shelf; default → CSS-grid layout used by /library and /discover.
    var wrapperClass = Model.Variant == "scroll" ? "poster-scroll-row" : "library-grid";
}

@* Shared poster-grid renderer for the web-app pages (Library, Discover, future
   list-type tabs, future search). Cards link to /anime/{id} for the detail
   page; the modal opens from the detail page's Edit button or via the +1
   quick-action button on the card itself.

   StreamD-style card chrome:
     - Progress badge overlay (Ep N / Total) top-left when progress > 0 — only
       populated by user-list catalogs (Watching / Completed / etc.).
     - Score badge overlay (★ N.N) on the poster bottom-left when score > 0.
     - +1 button bottom-right — bumps user's progress by one episode without
       leaving the page (only when the entry has user-list context).
     - Title under the poster (clamped to 2 lines).
     - Info row "format · X eps · year" underneath the title. *@
@if (Model.Items?.Count > 0)
{
    <div class="@wrapperClass">
        @foreach (var meta in Model.Items)
        {
            // All cards link to the new /anime/{id} detail page regardless of
            // login state. Anonymous users can browse anime detail; the Edit
            // button on the detail page only renders for logged-in non-
            // anonymous users with a resolved UID.
            var detailHref = $"/anime/{meta.id}";

            // Build the format · eps · year info row from whichever bits the
            // service surfaced. Joined with a middle-dot separator to match the
            // StreamD cards' visual rhythm.
            var infoBits = new List<string>();
            if (!string.IsNullOrEmpty(meta.format)) infoBits.Add(meta.format);
            if (meta.episodes is int eps && eps > 0) infoBits.Add($"{eps} ep{(eps > 1 ? "s" : "")}");
            if (meta.year is int yr && yr > 0) infoBits.Add(yr.ToString());
            var infoLine = string.Join(" · ", infoBits);

            var hasScore = meta.score.HasValue && meta.score.Value > 0;
            var hasProgress = meta.progress.HasValue && meta.progress.Value > 0;
            var progressLabel = hasProgress
                ? (meta.episodes is int totalEps && totalEps > 0
                    ? $"{meta.progress!.Value} / {totalEps}"
                    : $"Ep {meta.progress!.Value}")
                : null;

            // Razor suppresses attributes whose value is null but emits them
            // with an empty value when the value is "" — null-coalesce so
            // the data-* attributes are absent when there's no entry, instead
            // of present-but-empty (which would still flip on the +1 button's
            // visibility check). Building these as string?s also keeps Razor
            // from HTML-encoding the value's framing quotes the way the old
            // @($"...") expressions did — that emitted
            // `data-meta-status=&quot;current&quot;`, which the browser parsed
            // as an unquoted value of `"current"` with literal quote characters,
            // breaking the +1 quick-action.
            string entryStatusAttr = string.IsNullOrEmpty(meta.entryStatus) ? null : meta.entryStatus;
            string progressAttr = meta.progress.HasValue ? meta.progress.Value.ToString() : null;
            string totalAttr = (meta.episodes is int totalE && totalE > 0) ? totalE.ToString() : null;

            <a class="library-card" href="@detailHref" title="@meta.name"
               data-meta-id="@meta.id" data-meta-name="@meta.name"
               data-meta-status="@entryStatusAttr"
               data-meta-progress="@progressAttr"
               data-meta-total="@totalAttr">
                <div class="library-card-poster-wrap">
                    @if (!string.IsNullOrEmpty(meta.poster))
                    {
                        <img class="library-card-poster" src="@meta.poster" alt="@meta.name" loading="lazy" />
                    }
                    else
                    {
                        <div class="library-card-poster library-card-poster-placeholder"></div>
                    }
                    @if (hasProgress)
                    {
                        <span class="library-card-progress">@progressLabel</span>
                    }
                    else if (meta.airingEpisode.HasValue)
                    {
                        <span class="library-card-progress" data-airing-at="@meta.airingAt">Ep @meta.airingEpisode.Value</span>
                    }
                    @if (hasScore)
                    {
                        <span class="library-card-score">★ @meta.score.Value.ToString("0.0")</span>
                    }
                    @if (!string.IsNullOrEmpty(meta.entryStatus))
                    {
                        <button type="button" class="library-card-plus"
                                aria-label="Mark next episode watched"
                                title="+1 episode">+1</button>
                    }
                </div>
                <span class="library-card-title">@meta.name</span>
                @if (infoBits.Count > 0)
                {
                    <span class="library-card-meta">@infoLine</span>
                }
            </a>
        }
    </div>
    @* Localize the unix-seconds airing time to the viewer's clock so a single
       cached shelf renders correctly for users in different timezones. *@
    <script>
        (function () {
            document.querySelectorAll('.library-card-progress[data-airing-at]').forEach(function (el) {
                var ts = parseInt(el.getAttribute('data-airing-at'), 10);
                if (!ts) return;
                var d = new Date(ts * 1000);
                var hh = String(d.getHours()).padStart(2, '0');
                var mm = String(d.getMinutes()).padStart(2, '0');
                el.textContent = el.textContent + ' · ' + hh + ':' + mm;
            });
        })();
    </script>
}
else if (!string.IsNullOrEmpty(Model.EmptyMessage))
{
    <p class="library-empty">@Model.EmptyMessage</p>
}
