@inject AnimeList.Services.Interfaces.IConfigStore _layoutConfigStore
@{
    // Session-derived identity used by the site-header pill + the drawer's
    // sign-in / disconnect CTA. Reading directly here keeps every page's
    // chrome consistent without each controller having to populate a
    // ViewData hint. Try/catch defends against malformed session payloads
    // — bad cookie shouldn't 500 every page.
    AnimeList.Models.TokenData layoutToken = null;
    var layoutSessionStr = Context.Session.GetString("AccessToken");
    if (!string.IsNullOrEmpty(layoutSessionStr))
    {
        try { layoutToken = JsonConvert.DeserializeObject<AnimeList.Models.TokenData>(layoutSessionStr); }
        catch { /* unparseable — render as anonymous */ }
    }
    var layoutLoggedIn = layoutToken != null && !layoutToken.anonymousUser;
    @* layoutHasSession covers both real accounts AND anonymous sessions —
       used to decide whether the header pill / drawer footer surfaces
       "Sign in" or "Disconnect". An anonymous user is still "connected
       (without account)" and shouldn't see a Sign in CTA when the
       Disconnect path on /configure is the only way to actually clear
       their session. *@
    var layoutHasSession = layoutToken != null;
    var activeNav = ViewData["ActiveNav"]?.ToString();

    // Resolve linked-secondary services so the drawer footer can read
    // "✓ Connected to AniList · MAL · Kitsu" rather than just the
    // primary. Two indexed SQLite calls per request — sub-millisecond,
    // and the drawer is rendered on every page so it's not worth
    // plumbing through every controller. try/catch swallows any
    // store/connection failure into "primary only" so a transient
    // SQLite error doesn't 500 the entire layout.
    var layoutConnectedServices = new List<string>();
    string layoutUid = null;
    if (layoutLoggedIn)
    {
        layoutConnectedServices.Add(layoutToken.anime_service.ToString());
        try
        {
            var (resolvedUid, _) = await _layoutConfigStore.FindUidByIdentityAsync(layoutToken);
            layoutUid = resolvedUid;
            if (!string.IsNullOrEmpty(layoutUid))
            {
                var layoutLinked = await _layoutConfigStore.GetLinkedTokensAsync(layoutUid);
                foreach (var lt in layoutLinked)
                {
                    if (lt.NeedsReauth || lt.TokenData == null || lt.TokenData.anonymousUser) continue;
                    layoutConnectedServices.Add(lt.Service.ToString());
                }
            }
        }
        catch { /* fall back to primary-only label */ }
    }
    var layoutConnectedLabel = string.Join(" · ", layoutConnectedServices);

    // Resolve the viewer's media-type mode for the chooser modal + the header
    // mode button. Logged-in users' stored setting wins; anonymous visitors
    // (and logged-in users whose row read failed) fall back to the cookie the
    // first-visit chooser stamps. Drives the modal's "current" highlight and
    // the header button's icon/label.
    var layoutMediaType = MetaType.anime;
    try
    {
        layoutMediaType = !string.IsNullOrEmpty(layoutUid)
            ? await _layoutConfigStore.GetMediaTypeAsync(layoutUid)
            : AnimeList.Services.MediaTypePreference.FromCookie(Context);
    }
    catch { layoutMediaType = AnimeList.Services.MediaTypePreference.FromCookie(Context); }
    var layoutMediaTypeLabel = layoutMediaType == MetaType.movie ? "Movies"
        : layoutMediaType == MetaType.series ? "Series"
        : "Anime";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    @* viewport-fit=cover is required for env(safe-area-inset-*) to resolve
       to non-zero in browser tabs (the app already pads the bottom-nav,
       drawer overlays and FABs against it). interactive-widget=resizes-content
       reflows the layout when the on-screen keyboard opens so inputs on the
       Kitsu login / search / manage-entry forms don't hide behind it. *@
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover, interactive-widget=resizes-content" />
    @* Strip the Referer header on outbound clicks. The configure page URL embeds
       the user's Config UID; without this meta tag, a click on any external link
       (or a redirect through a third-party OAuth provider) leaks the UID via
       Referer. no-referrer is the strictest setting — same protection applied to
       the Swagger UI page in Program.cs. *@
    <meta name="referrer" content="no-referrer" />
    @* Meta description — drives the SERP snippet and is what link-unfurlers
       (Discord / iMessage / Slack) fall back to. Per-page views can override
       via ViewData["Description"]; otherwise the app-level pitch (mirrors the
       manifest description) applies. *@
    <meta name="description" content="@(ViewData["Description"]?.ToString() ?? "Track and sync your anime across AniList, MyAnimeList and Kitsu — see what's airing, get new-episode alerts, and watch through Stremio.")" />
    @* PWA manifest + iOS / Android install hints. The manifest declares
       icons, start_url, theme_color etc.; Chromium uses it (plus an
       active service worker, registered by pwa-install.js) to decide
       install eligibility. theme-color paints the OS chrome (Android
       address bar, standalone-mode title bar) the same dark shade as
       the page so the seam disappears. apple-touch-icon is iOS Safari's
       fallback "Add to Home Screen" icon (it ignores the manifest). *@
    @* Warm up TCP+TLS to the poster / artwork CDNs before the grid's <img>
       requests fire, so connection setup isn't on the critical path to LCP.
       preconnect for the two primary poster hosts (AniList + Kitsu); the
       cheaper dns-prefetch for secondary artwork / thumbnail origins so we
       don't hold open more sockets than the above-the-fold path needs. No
       crossorigin attr — posters load as plain (non-CORS) <img>, so a
       crossorigin preconnect would open a separate, unused connection. *@
    <link rel="preconnect" href="https://s4.anilist.co" />
    <link rel="preconnect" href="https://media.kitsu.app" />
    <link rel="dns-prefetch" href="https://cdn.myanimelist.net" />
    <link rel="dns-prefetch" href="https://image.tmdb.org" />
    <link rel="dns-prefetch" href="https://episodes.metahub.space" />
    <link rel="manifest" href="/manifest.webmanifest" />
    @* Per-scheme theme-color so the OS chrome (Android address bar /
       standalone title bar, iOS status bar tint) matches whichever theme
       is showing. These cover the system-follows case and the no-JS /
       pre-paint case; theme-toggle.js appends an authoritative media-less
       <meta name="theme-color"> when the user makes a MANUAL light/dark
       choice that overrides the OS (a media-less meta always matches and,
       being last in DOM order, wins). *@
    <meta name="theme-color" content="#0A0A0A" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
    @* Pre-paint theme stamp — runs synchronously in <head> before the
       stylesheet applies so a stored light/dark preference is honoured
       without a flash of the default (dark) theme. "system" / unset leaves
       no attribute, letting the prefers-color-scheme CSS follow the OS.
       Mirrors the timezone-cookie stamp pattern below. *@
    <script>
        (function () {
            try {
                var t = localStorage.getItem('anisync-theme');
                if (t === 'light' || t === 'dark') {
                    document.documentElement.setAttribute('data-theme', t);
                }
            } catch (_) { /* storage blocked — fall back to OS preference */ }
        })();
    </script>
    <link rel="apple-touch-icon" href="/icons/icon-192.png" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="AniSync" />
    @{
        // Per-page title set via ViewData["Title"]; falls back to the plain
        // app name on pages that don't bother (errors, splash). Browser
        // history / bookmarks / tab labels pick up <title>, so giving each
        // page a unique title is what makes the history view in the screenshot
        // legible ("Re:ZERO · AniSync" instead of fifteen rows of "AniSync").
        var pageTitle = ViewData["Title"]?.ToString();
        var fullTitle = string.IsNullOrEmpty(pageTitle) ? "AniSync" : $"{pageTitle} · AniSync";
    }
    <title>@fullTitle</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AniSync.styles.css" asp-append-version="true" />
    @* jQuery + loader.js are `defer`-ed so they fetch during head parse but
       execute AFTER the document is parsed (in order, before DOMContentLoaded)
       — keeping ~94KB of script off the critical rendering path so first paint
       isn't blocked. jQuery is only needed for later interactions (the
       standalone ManageEntry page + the Configure/Stremio inline scripts, which
       now run on DOMContentLoaded), never at paint. loader.js's window.fetch
       wrap + guarded $.ajax hook install just after parse; the only parse-time
       scripts (theme stamp, tz cookie) issue no requests, so nothing of note
       escapes the spinner. *@
    <script src="~/lib/jquery/dist/jquery.min.js" defer></script>
    <script src="~/js/loader.js" asp-append-version="true" defer></script>
    @* Stamp the viewer's UTC offset (in minutes, JS getTimezoneOffset
       convention — positive = west of UTC) into a cookie so server-
       rendered "today" shelves (the dashboard's New Episodes Today, in
       particular) can bucket against the viewer's local calendar day
       rather than UTC. The cookie is set as early as possible so the
       NEXT navigation already has the right offset; first-time visitors
       see UTC-bucketed "today" on their initial render. *@
    <script>
        (function () {
            try {
                var offset = new Date().getTimezoneOffset();
                var existing = document.cookie.split('; ').find(function (c) { return c.indexOf('anisync_tz=') === 0; });
                if (existing === 'anisync_tz=' + offset) return;
                document.cookie = 'anisync_tz=' + offset + '; path=/; max-age=31536000; SameSite=Lax';
            } catch (_) { /* cookies disabled — server falls back to UTC */ }
        })();
    </script>
    @* bfcache revalidation registry. Defined inline in <head> so it exists
       before any parse-time inline hydration script (the dashboard shelves,
       etc.) can register with it. When the browser restores this page from
       the back/forward cache (instant, but with the DOM frozen as it was),
       `pageshow` fires with persisted=true; we then run every registered
       loader so the user sees fresh data instead of a stale snapshot. Each
       loader already gates on its own localStorage TTL, so a re-fire only
       hits the network when the cached data is actually stale. *@
    <script>
        (function () {
            var fns = [];
            window.AniSyncRevalidate = {
                on: function (fn) { if (typeof fn === 'function') fns.push(fn); },
                fire: function () {
                    for (var i = 0; i < fns.length; i++) {
                        try { fns[i](); } catch (_) { /* one loader's failure shouldn't stop the rest */ }
                    }
                }
            };
            window.addEventListener('pageshow', function (e) {
                if (e.persisted) window.AniSyncRevalidate.fire();
            });
        })();
    </script>
</head>
<body class="@ViewData["BodyClass"]">
    @* Persistent site chrome: slide-in drawer + mobile bottom-nav are lifted
       out of per-page views so every page gets the same shell. The site-
       header is rendered inside `main` (just below) so it inherits main's
       centered max-width — keeps the logo and hamburger aligned with the
       rest of the page content rather than floating against the viewport
       edges. The drawer toggle is a single-class flip on body — no
       framework, no jQuery dep, just a class on document.body. *@
    <aside class="nav-drawer" aria-label="Site navigation">
        <div class="nav-drawer-header">
            <a class="site-logo" href="/" aria-label="AniSync home">
                <img src="/logo.png" alt="AniSync" width="1024" height="1024" />
            </a>
            <button class="drawer-close" aria-label="Close menu"
                    onclick="document.body.classList.remove('drawer-open')">×</button>
        </div>
        <nav class="nav-drawer-nav">
            <a href="/" class="@(activeNav == "home" ? "active" : "")">
                <svg class="nav-icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M3 12L12 3l9 9"></path>
                    <path d="M5 10v10a1 1 0 0 0 1 1h4v-6h4v6h4a1 1 0 0 0 1-1V10"></path>
                </svg>
                <span class="nav-label">Home</span>
            </a>
            @* Library requires an authenticated non-anonymous session — the
               page just bounces back to / for anonymous visitors, so we omit
               the link entirely rather than offering a dead-end navigation. *@
            @if (layoutLoggedIn)
            {
                <a href="/library" class="@(activeNav == "library" ? "active" : "")">
                    <svg class="nav-icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"></path>
                    </svg>
                    <span class="nav-label">Library</span>
                </a>
            }
            <a href="/discover" class="@(activeNav == "discover" ? "active" : "")">
                <svg class="nav-icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <circle cx="11" cy="11" r="8"></circle>
                    <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                </svg>
                <span class="nav-label">Discover</span>
            </a>
            @* Movies & series fold into Discover now — it's media-type aware (the
               Anime / Movies / Series switch lives on Discover & Library), so the
               standalone nav items are gone. *@
            @* Settings consolidates the /configure (Account) + /stremio (addon
               configure) pages; the Stremio link is reachable from the
               Settings page rather than crowding the top-level nav. The active
               state lights up for both /configure and /stremio so navigating
               between them inside Settings keeps the same tab highlighted.
               Hidden for anonymous users — there's no settings to manage
               without a primary account; signing in is the prerequisite,
               surfaced by the drawer-footer Sign-in CTA below. *@
            @if (layoutLoggedIn)
            {
                <a href="@Url.Action("Account", "Home")" class="@(activeNav == "configure" || activeNav == "stremio" ? "active" : "")">
                    <svg class="nav-icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <circle cx="12" cy="12" r="3"></circle>
                        <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 1 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 1 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 1 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 1 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
                    </svg>
                    <span class="nav-label">Settings</span>
                </a>
            }
        </nav>
        <div class="nav-drawer-footer">
            @if (layoutHasSession)
            {
                <span class="nav-drawer-status">
                    @(layoutLoggedIn ? $"✓ Connected to {layoutConnectedLabel}" : "✓ Connected without account")
                </span>
                <a class="nav-drawer-cta nav-drawer-cta-secondary" href="@Url.Action("Logout", "Auth")" data-disconnect>Disconnect</a>
            }
            else
            {
                <a class="nav-drawer-cta nav-drawer-cta-primary" href="@Url.Action("Account", "Home")">Sign in</a>
            }
        </div>
    </aside>
    <div class="drawer-backdrop"
         onclick="document.body.classList.remove('drawer-open')"></div>

    @* Site header is intentionally OUTSIDE the page container so the
       sticky bar can paint edge-to-edge on desktop while its inner
       content stays aligned with the page via the inner .container. *@
    <header class="site-header">
        <div class="container site-header-inner">
            @* Universal back button — primarily for embedded-browser
               contexts (Stremio desktop opens our chip-link URLs in
               its in-app webview, which doesn't surface its own back
               UI, so a user who clicks a Tag / Studio / Manage Entry
               link gets stuck on the AniSync page with no way back
               to Stremio's meta view). Calls history.back() so it
               also doubles as a generic in-site back-nav for users
               who navigated AniSync → AniSync. The 500ms no-op
               fallback to "/" catches the cold-load case where the
               webview's history doesn't contain a previous entry. *@
            <button type="button" class="site-back-btn" aria-label="Go back" data-site-back>
                <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M15 18l-6-6 6-6"/>
                </svg>
            </button>
            <a class="site-logo" href="/" aria-label="AniSync home">
                <img src="/logo.png" alt="AniSync" width="1024" height="1024" />
            </a>
                @* Inline desktop nav — mirrors the slide-in drawer's links.
                   Hidden under 992px (lg) where the hamburger takes over.
                   Same href + active-class logic as the drawer so adding a
                   route here means updating both. *@
                <nav class="site-header-nav" aria-label="Primary">
                    <a href="/" class="@(activeNav == "home" ? "active" : "")">
                        <svg class="nav-icon" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="M3 12L12 3l9 9"></path>
                            <path d="M5 10v10a1 1 0 0 0 1 1h4v-6h4v6h4a1 1 0 0 0 1-1V10"></path>
                        </svg>
                        <span class="nav-label">Home</span>
                    </a>
                    @if (layoutLoggedIn)
                    {
                        <a href="/library" class="@(activeNav == "library" ? "active" : "")">
                            <svg class="nav-icon" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"></path>
                            </svg>
                            <span class="nav-label">Library</span>
                        </a>
                    }
                    <a href="/discover" class="@(activeNav == "discover" ? "active" : "")">
                        <svg class="nav-icon" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <circle cx="11" cy="11" r="8"></circle>
                            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                        </svg>
                        <span class="nav-label">Discover</span>
                    </a>
                    @* Movies & series fold into Discover (media-type aware). *@
                    @* Settings consolidates Account + Stremio addon pages —
                       same activeNav double-match as the drawer / bottom-nav
                       so navigating between /configure and /stremio keeps the
                       tab highlighted. Hidden for anonymous users — no
                       settings without a primary account; the header's
                       Sign-in CTA next to it is the right entry point. *@
                    @if (layoutLoggedIn)
                    {
                        <a href="@Url.Action("Account", "Home")" class="@(activeNav == "configure" || activeNav == "stremio" ? "active" : "")">
                            <svg class="nav-icon" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <circle cx="12" cy="12" r="3"></circle>
                                <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 1 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 1 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 1 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 1 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
                            </svg>
                            <span class="nav-label">Settings</span>
                        </a>
                    }
                </nav>
                @* Global anime search. Lives in the layout so every page has it.
                   Fires /api/v1/match once the query reaches 3 characters with a
                   ~250ms debounce; results dropdown renders absolutely below the
                   input. role=combobox + aria-* attributes describe the
                   typeahead pattern for screen readers. JS lives in
                   wwwroot/js/site-search.js. *@
                <form class="site-search" role="search" autocomplete="off"
                      onsubmit="return false;" aria-label="Search anime">
                    <span class="site-search-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" width="16" height="16" fill="none"
                             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="11" cy="11" r="7"></circle>
                            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                        </svg>
                    </span>
                    <input class="site-search-input"
                           type="search"
                           placeholder="Search anime…"
                           role="combobox"
                           aria-controls="site-search-results"
                           aria-expanded="false"
                           aria-autocomplete="list"
                           spellcheck="false"
                           autocorrect="off"
                           autocapitalize="off" />
                    <div class="site-search-results"
                         id="site-search-results"
                         role="listbox"
                         hidden></div>
                </form>
                @* Episode-release notifications. Bell + unread badge in the
                   header; dropdown panel renders the most recent 20 rows on
                   open. JS in /js/notifications.js polls /count every 60s
                   and re-renders the list on click. Only for logged-in
                   users — anonymous sessions have nothing to notify on. *@
                @if (layoutLoggedIn)
                {
                    <div class="notif-bell" data-notif-bell>
                        <button class="notif-bell-btn" type="button" aria-label="Notifications"
                                aria-expanded="false" aria-controls="notif-panel" data-notif-toggle>
                            <svg viewBox="0 0 24 24" width="18" height="18" fill="none"
                                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9"></path>
                                <path d="M13.73 21a2 2 0 0 1-3.46 0"></path>
                            </svg>
                            <span class="notif-bell-badge" data-notif-count hidden>0</span>
                        </button>
                        <div class="notif-panel" id="notif-panel" role="dialog" aria-label="Notifications" hidden>
                            <header class="notif-panel-header">
                                <span class="notif-panel-title">Notifications</span>
                                <button type="button" data-notif-read-all class="notif-read-all">Mark all read</button>
                            </header>
                            <div class="notif-panel-body" data-notif-list>
                                <div class="notif-empty" data-notif-empty>You're all caught up.</div>
                            </div>
                            <a class="notif-panel-footer" href="/notifications" data-notif-view-all>View all</a>
                        </div>
                    </div>
                }
                @* Theme toggle — a two-state light ⇄ dark switch. Lives in the
                   header so it's reachable on every viewport (the header is
                   never hidden; only the inline nav collapses on mobile). The
                   icon reflects the current theme and implies the tap action:
                   a sun while dark (tap → light), a moon while light (tap →
                   dark). theme-toggle.js owns the swap, persistence and the
                   theme-color meta sync via [data-when-theme]. *@
                @* Media-type mode switch — reopens the chooser modal. Shows the
                   current mode (Anime / Movies / Series); the icon mirrors the
                   modal's option glyphs. Lives in the header so it's reachable on
                   every viewport, like the theme toggle beside it. *@
                <button type="button" class="media-type-btn" data-media-type-open
                        aria-label="Change mode (currently @layoutMediaTypeLabel)" title="Change mode">
                    <span class="media-type-btn-icon" aria-hidden="true">
                        @if (layoutMediaType == MetaType.movie)
                        {
                            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="3" y="4" width="18" height="16" rx="2" />
                                <line x1="7" y1="4" x2="7" y2="20" /><line x1="17" y1="4" x2="17" y2="20" />
                                <line x1="3" y1="12" x2="21" y2="12" />
                            </svg>
                        }
                        else if (layoutMediaType == MetaType.series)
                        {
                            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="2" y="7" width="20" height="13" rx="2" />
                                <polyline points="8 3 12 7 16 3" />
                            </svg>
                        }
                        else
                        {
                            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M12 3l1.9 5.6L19.5 10l-5.6 1.9L12 17.5l-1.9-5.6L4.5 10l5.6-1.4z" />
                            </svg>
                        }
                    </span>
                    <span class="media-type-btn-label">@layoutMediaTypeLabel</span>
                </button>
                <button type="button" class="theme-toggle-btn" data-theme-toggle
                        aria-label="Switch theme" title="Switch theme">
                    @* Icon visibility is driven purely by CSS off the active
                       theme (data-theme / prefers-color-scheme), so it always
                       matches the theme regardless of JS timing or caching:
                       a sun while dark (tap → light), a moon while light. *@
                    <svg class="theme-icon-sun" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <circle cx="12" cy="12" r="4"></circle>
                        <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"></path>
                    </svg>
                    <svg class="theme-icon-moon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
                    </svg>
                </button>
                @* Desktop-only auth CTA — replaces what the drawer footer
                   exposes on mobile (Sign in / Disconnect). Hidden under
                   992px; the drawer keeps surfacing it on mobile. Treats
                   anonymous sessions the same as real accounts: a token
                   in any form means there's something to Disconnect, so
                   showing Sign in alongside it would be misleading. *@
                @if (layoutHasSession)
                {
                    <a class="site-header-cta site-header-cta-secondary" href="@Url.Action("Logout", "Auth")" data-disconnect>Disconnect</a>
                }
                else
                {
                    <a class="site-header-cta site-header-cta-primary" href="@Url.Action("Account", "Home")">Sign in</a>
                }
            <button class="hamburger-btn" aria-label="Open menu"
                    onclick="document.body.classList.toggle('drawer-open')">
                <span></span><span></span><span></span>
            </button>
        </div>
    </header>

    @* Upstream-outage banner — lights up when AniList GraphQL has returned a
       transport-level / 5xx failure in the last 5 minutes. AniList is the
       backbone for both AniList-primary users (their library + metadata) and
       the shared dashboard shelves (Popular This Season, New Episodes Today
       all read AniList anonymously). When the upstream is down we'd rather
       tell the user explicitly than show empty shelves. The banner clears
       automatically on the first successful call after recovery. *@
    @if (AnimeList.Services.AnilistHealthMonitor.IsDown)
    {
        <div class="container" role="status" aria-live="polite">
            <div style="margin: 12px 0; padding: 10px 14px; border-radius: 6px;
                        background: #5a2e00; color: #ffd9b3; border: 1px solid #8a4600;
                        font-size: 14px; line-height: 1.4;">
                <strong>AniList is having trouble right now.</strong>
                Some catalog data may be missing or stale.
                <a href="https://status.anilist.co/" target="_blank" rel="noopener"
                   style="color: #ffd9b3; text-decoration: underline;">Check status →</a>
            </div>
        </div>
    }

    <div class="container">
        <main role="main" style="min-height: 100vh;">
            @RenderBody()
        </main>
    </div>

    @* Mobile-first bottom nav. Home / Library / Discover are primary
       destinations; the right-most cell flips to a "More" toggle that
       opens the bottom-nav-more-panel above with Settings + Install +
       Sign-in/Disconnect. Hidden on wider viewports via media query in
       site.css — desktop users rely on the inline header nav and the
       hamburger drawer instead. *@
    <nav class="bottom-nav" aria-label="Primary">
        <a href="/" class="bottom-nav-item @(activeNav == "home" ? "active" : "")" aria-label="Home">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 12L12 3l9 9"></path>
                <path d="M5 10v10a1 1 0 0 0 1 1h4v-6h4v6h4a1 1 0 0 0 1-1V10"></path>
            </svg>
            <span class="bottom-nav-label">Home</span>
        </a>
        @* Library tab omitted for anonymous users — the page just redirects
           them back to /, so the cell would be a dead end on the bottom nav. *@
        @if (layoutLoggedIn)
        {
            <a href="/library" class="bottom-nav-item @(activeNav == "library" ? "active" : "")" aria-label="Library">
                <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"></path>
                </svg>
                <span class="bottom-nav-label">Library</span>
            </a>
        }
        <a href="/discover" class="bottom-nav-item @(activeNav == "discover" ? "active" : "")" aria-label="Discover">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="8"></circle>
                <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            </svg>
            <span class="bottom-nav-label">Discover</span>
        </a>
        @* "More" replaces the previous Settings tile. Tapping it lifts
           the sibling .bottom-nav-more-sheet — a rounded floating card
           anchored to the bottom-right corner — with Settings /
           Notifications / Install / Sign-in stacked as full-width rows.
           The button itself morphs into a Close affordance (✕ + "Close"
           label) so a second tap reads as the obvious dismiss. *@
        <button type="button" class="bottom-nav-item bottom-nav-more" aria-label="More"
                aria-expanded="false" aria-controls="bottom-nav-more-dome" data-bottom-nav-more-toggle>
            <span class="bottom-nav-more-icon" data-more-icon aria-hidden="true">
                <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="4" y1="7" x2="20" y2="7"></line>
                    <line x1="4" y1="12" x2="20" y2="12"></line>
                    <line x1="4" y1="17" x2="20" y2="17"></line>
                </svg>
            </span>
            <span class="bottom-nav-more-icon bottom-nav-more-icon-close" data-close-icon aria-hidden="true">
                <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
            </span>
            <span class="bottom-nav-label" data-more-label>More</span>
        </button>
    </nav>
    @* Floating "More" sheet — rounded card anchored to the bottom-right
       corner just above the bottom-nav. Replaces the previous half-circle
       dome (which had to squeeze every item onto a 64px arc chip with a
       sub-readable label). Vertical list of full-width rows gives every
       action a 44px tap target and a 0.92rem label; the card auto-shrinks
       when an item is gated off so anonymous visitors see a 1-2 row card
       and logged-in users see a 4-row card without any redistribution
       maths. The id stays as #bottom-nav-more-dome so the inline toggle
       script + the More button's aria-controls still wire up unchanged. *@
    <div class="bottom-nav-more-sheet" id="bottom-nav-more-dome" role="menu" hidden>
        @if (layoutLoggedIn)
        {
            <a href="@Url.Action("Account", "Home")" class="bottom-nav-more-row @(activeNav == "configure" || activeNav == "stremio" ? "active" : "")" role="menuitem">
                <svg class="bottom-nav-more-row-icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <circle cx="12" cy="12" r="3"></circle>
                    <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 1 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 1 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 1 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 1 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
                </svg>
                <span class="bottom-nav-more-row-label">Settings</span>
            </a>
            @* Notifications full-history page — same destination the bell
               panel's "View all" footer points at. Surfaces the link in
               the More menu for users who don't reach for the header bell
               (or whose bell is below-the-fold on tall mobile pages). *@
            <a href="/notifications" class="bottom-nav-more-row @(activeNav == "notifications" ? "active" : "")" role="menuitem">
                <svg class="bottom-nav-more-row-icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9"></path>
                    <path d="M13.73 21a2 2 0 0 1-3.46 0"></path>
                </svg>
                <span class="bottom-nav-more-row-label">Notifications</span>
            </a>
        }
        @* Install row — pwa-install.js toggles [data-pwa-install]'s `hidden`
           attribute on every matching element when beforeinstallprompt
           fires (and on appinstalled to hide them again). The list layout
           handles the row going away without any redistribution maths. *@
        <button type="button" class="bottom-nav-more-row" data-pwa-install role="menuitem" aria-label="Install app" hidden>
            <svg class="bottom-nav-more-row-icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M12 3v12"></path>
                <path d="M7 10l5 5 5-5"></path>
                <path d="M5 21h14"></path>
            </svg>
            <span class="bottom-nav-more-row-label">Install app</span>
        </button>
        @* Divider above the auth row so destructive Disconnect (or its
           Sign-in mirror image) sits visually segregated from the neutral
           navigation rows above — same pattern .entry-modal-actions uses
           to isolate Delete from Save/Cancel. *@
        <span class="bottom-nav-more-divider" aria-hidden="true"></span>
        @if (layoutHasSession)
        {
            <a href="@Url.Action("Logout", "Auth")" class="bottom-nav-more-row bottom-nav-more-row-danger" role="menuitem" data-disconnect>
                <svg class="bottom-nav-more-row-icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                    <polyline points="16 17 21 12 16 7"></polyline>
                    <line x1="21" y1="12" x2="9" y2="12"></line>
                </svg>
                <span class="bottom-nav-more-row-label">Disconnect</span>
            </a>
        }
        else
        {
            <a href="@Url.Action("Account", "Home")" class="bottom-nav-more-row" role="menuitem">
                <svg class="bottom-nav-more-row-icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"></path>
                    <polyline points="10 17 15 12 10 7"></polyline>
                    <line x1="15" y1="12" x2="3" y2="12"></line>
                </svg>
                <span class="bottom-nav-more-row-label">Sign in</span>
            </a>
        }
    </div>
    <script>
        (function () {
            var toggle = document.querySelector('[data-bottom-nav-more-toggle]');
            var sheet = document.getElementById('bottom-nav-more-dome');
            if (!toggle || !sheet) return;
            var label = toggle.querySelector('[data-more-label]');

            function close() {
                sheet.hidden = true;
                document.body.classList.remove('bottom-nav-more-open');
                toggle.setAttribute('aria-expanded', 'false');
                toggle.classList.remove('is-open');
                if (label) label.textContent = 'More';
                toggle.setAttribute('aria-label', 'More');
            }
            function open() {
                sheet.hidden = false;
                // Lets CSS hide the floating Save bar + scroll-to-top button so
                // they don't sit in front of the open menu sheet.
                document.body.classList.add('bottom-nav-more-open');
                toggle.setAttribute('aria-expanded', 'true');
                toggle.classList.add('is-open');
                if (label) label.textContent = 'Close';
                toggle.setAttribute('aria-label', 'Close menu');
            }
            toggle.addEventListener('click', function (e) {
                e.stopPropagation();
                if (sheet.hidden) open(); else close();
            });
            // Tapping a row navigates, then closes — same UX as the old
            // dome. The path-stamp click handler in the data-disconnect
            // chain still fires too because the row carries that marker.
            sheet.addEventListener('click', function (e) {
                if (e.target.closest('.bottom-nav-more-row')) close();
            });
            document.addEventListener('mousedown', function (e) {
                if (sheet.hidden) return;
                if (toggle.contains(e.target) || sheet.contains(e.target)) return;
                close();
            });
            document.addEventListener('keydown', function (e) {
                if (e.key === 'Escape' && !sheet.hidden) {
                    close();
                    toggle.focus();
                }
            });
        })();
    </script>

    @* Inline Manage Entry modal — single instance, hidden by default. The web-app
       pages (Library / Discover / Dashboard) intercept clicks on poster cards
       and open this modal instead of navigating to the standalone Manage Entry
       page; only logged-in non-anonymous users get the modal experience, since
       anonymous cards don't carry a data-meta-id attribute. The standalone page
       remains the fallback for non-JS browsers. *@
    @if (layoutLoggedIn)
    {
        <div class="entry-modal-backdrop" hidden></div>
        <div class="entry-modal" hidden role="dialog" aria-modal="true" aria-labelledby="entry-modal-title">
            <header class="entry-modal-header">
                <h3 class="entry-modal-title" id="entry-modal-title">Loading…</h3>
                <button class="entry-modal-close" type="button" aria-label="Close">×</button>
            </header>
            <div class="entry-modal-body">
                @* Skeleton field placeholders while the entry loads; the
                   sr-only text keeps the state announced for screen readers. *@
                <div class="entry-modal-loading" aria-live="polite" aria-busy="true">
                    <span class="sr-only">Loading…</span>
                    <span class="entry-modal-skeleton-field skeleton-shimmer"></span>
                    <span class="entry-modal-skeleton-field skeleton-shimmer"></span>
                    <span class="entry-modal-skeleton-field skeleton-shimmer entry-modal-skeleton-field-wide"></span>
                    <span class="entry-modal-skeleton-field skeleton-shimmer"></span>
                </div>
                <form class="entry-modal-form" hidden>
                    @* Season selector — hidden by default, shown only when the
                       opened anime is a franchise split across multiple service
                       entries (Attack on Titan, JoJo, Demon Slayer, etc.). The
                       options are populated by the modal JS from the
                       /api/library/entry response's seasons array. Changing the
                       selection re-fetches entry data for that cour. *@
                    <div class="entry-modal-field" data-season-field hidden>
                        <label class="entry-modal-label" for="entry-modal-season">Season</label>
                        <select id="entry-modal-season" name="season" class="entry-modal-select"></select>
                    </div>
                    <div class="entry-modal-field">
                        <label class="entry-modal-label" for="entry-modal-status">Status</label>
                        <select id="entry-modal-status" name="status" class="entry-modal-select"></select>
                    </div>
                    @* data-progress-field hooks an attribute selector in
                       manage-entry-modal.js that hides this whole wrapper
                       when totalEpisodes === 1 (movies + single-episode
                       OVAs). The status dropdown alone carries enough
                       state for those — there's nothing to "watch ep 4
                       of" when the show is one playthrough. *@
                    <div class="entry-modal-field" data-progress-field>
                        <label class="entry-modal-label" for="entry-modal-progress">Episodes Watched</label>
                        <div class="entry-modal-progress-row">
                            <input id="entry-modal-progress" type="number" name="progress" min="0" class="entry-modal-input" />
                            <span class="entry-modal-total" hidden></span>
                        </div>
                    </div>
                    <div class="entry-modal-field">
                        <label class="entry-modal-label" for="entry-modal-score">Score</label>
                        <input id="entry-modal-score" type="number" name="score" min="0" max="10" step="0.1" class="entry-modal-input" placeholder="0–10" />
                    </div>
                    @* Started + Finished dates side-by-side on wider viewports
                       so they don't burn vertical space in the modal. *@
                    <div class="entry-modal-field-row">
                        <div class="entry-modal-field">
                            <label class="entry-modal-label" for="entry-modal-started">Started</label>
                            <input id="entry-modal-started" type="date" name="startedAt" class="entry-modal-input" />
                        </div>
                        <div class="entry-modal-field">
                            <label class="entry-modal-label" for="entry-modal-finished">Finished</label>
                            <input id="entry-modal-finished" type="date" name="finishedAt" class="entry-modal-input" />
                        </div>
                    </div>
                    <div class="entry-modal-field">
                        <label class="entry-modal-label" for="entry-modal-rewatch">Rewatches</label>
                        <input id="entry-modal-rewatch" type="number" name="rewatchCount" min="0" class="entry-modal-input" placeholder="0" />
                    </div>
                    <div class="entry-modal-field">
                        <label class="entry-modal-label" for="entry-modal-notes">Notes</label>
                        <textarea id="entry-modal-notes" name="notes" rows="3" class="entry-modal-textarea" placeholder="Personal notes about this entry…"></textarea>
                    </div>
                    <div class="entry-modal-error" role="alert" hidden></div>
                    @* Delete sits at the leading edge so it's visually
                       separated from the Cancel/Save pair on the trailing
                       edge — destructive actions shouldn't be next to the
                       primary CTA where a misclick lands. Hidden by default;
                       the modal JS reveals it once load resolves with a
                       non-empty status (i.e. the entry actually exists). *@
                    <div class="entry-modal-actions">
                        <button type="button" class="entry-modal-delete" hidden>Delete</button>
                        <div class="entry-modal-actions-end">
                            <button type="button" class="entry-modal-cancel">Cancel</button>
                            <button type="submit" class="entry-modal-save">Save</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
        <script src="~/js/manage-entry-modal.js" asp-append-version="true" defer></script>
    }

    @* Media-type chooser modal — first-visit forced selection + reopen target
       for the header mode button. Rendered for every visitor; media-type.js
       opens it, persists the pick (localStorage + cookie + account setting when
       logged in) and reloads so the whole site re-renders for the chosen mode. *@
    @await Html.PartialAsync("_MediaTypeModal", new ViewDataDictionary(ViewData)
    {
        ["MediaTypeEnabled"] = AnimeList.Services.MediaTypePreference.EnabledFromCookie(Context),
        ["MediaTypeLoggedIn"] = layoutLoggedIn,
    })

    @* Toast container — receives "Saved!" / "Error" feedback from in-page
       actions that survive page reloads via sessionStorage. Always rendered
       (anonymous users can't trigger the modal but other future actions
       might fire toasts). The container is positioned fixed via site.css. *@
    <div id="toast-container" aria-live="polite" aria-atomic="true"></div>

    @* Global request loader. Single instance, hidden by default; loader.js
       reveals it whenever a fetch() / $.ajax() call is in flight (with a
       150ms grace delay so fast responses don't flash the spinner). *@
    <div id="global-loader-overlay" class="loader-overlay" aria-hidden="true" role="status">
        <div class="loader-spinner" aria-label="Loading"></div>
    </div>

    @* Back-to-top button — fixed bottom-right, hidden by default. scroll-top.js
       reveals it once the page has scrolled past a threshold and smooth-scrolls
       back to the top on click. Single instance for the whole site. *@
    <button id="scroll-top-btn" class="scroll-top-btn" type="button"
            aria-label="Scroll to top" hidden>
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none"
             stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="18 15 12 9 6 15"></polyline>
        </svg>
    </button>

    <script src="~/js/toast.js" asp-append-version="true" defer></script>
    <script src="~/js/media-type.js" asp-append-version="true" defer></script>
    <script src="~/js/theme-toggle.js" asp-append-version="true" defer></script>
    <script src="~/js/pwa-install.js" asp-append-version="true" defer></script>
    <script src="~/js/scroll-top.js" asp-append-version="true" defer></script>
    <script src="~/js/pull-to-refresh.js" asp-append-version="true" defer></script>
    <script src="~/js/site-search.js" asp-append-version="true" defer></script>
    <script src="~/js/storage-sweep.js" asp-append-version="true" defer></script>
    <script src="~/js/tap-feedback.js" asp-append-version="true" defer></script>
    @* D-pad / remote navigation for Android TV / Google TV / Fire TV. Self-gates
       to "TV mode" (UA / capability / ?tv=1) and is inert everywhere else, so it
       adds nothing for phone / desktop users. Pairs with the .tv-mode focus
       styling in site.css. *@
    <script src="~/js/tv-navigation.js" asp-append-version="true" defer></script>
    <script>
        // Universal back button. Lives in the layout so every page
        // has it — primarily a rescue valve for Stremio desktop's in-
        // app webview (clicking a Tag / Studio / Manage Entry chip
        // navigates the embedded view to AniSync with no native back
        // UI). Falls back to the AniSync home when history.back()
        // doesn't budge the URL within 500ms — covers the cold-load
        // case where the webview's history doesn't contain a previous
        // entry, so the click still resolves to something useful.
        // Shared-element view transition: name the tapped poster so
        // Chromium morphs it into the detail-page hero (which carries the
        // matching name in CSS). A single fixed name applied to ONLY the
        // clicked element guarantees uniqueness, so multi-shelf pages don't
        // trip the duplicate-name abort. Feature-gated and reduced-motion
        // aware; on browsers without view transitions the assignment is an
        // inert unknown-property write. Capture phase so the name is set
        // before any navigation begins.
        (function () {
            if (!('startViewTransition' in document)) return;
            try {
                if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
            } catch (_) { /* matchMedia unavailable — proceed */ }
            // Covers every poster→detail entry point: the shared _PosterGrid
            // cards (dashboard / discover / library / studio / tag, plus the
            // detail page's own related + recommendation rows — all rendered as
            // a.library-card) AND the header search dropdown (a.site-search-result,
            // its own poster class). The detail hero carries the matching
            // vt-shared-poster name in CSS, so the tapped poster morphs into it.
            // Only ONE element may carry vt-shared-poster at a time. Two would
            // be a duplicate transition name and Chromium aborts the WHOLE
            // transition — this is the "morph works once, then nothing until I
            // reload" bug: the previous click's inline stamp survives a bfcache
            // back-navigation (the DOM is restored frozen) and then collides
            // with the next poster's stamp. So clear any prior stamp before
            // applying a new one, and also on bfcache restore. The
            // data-vt-stamped marker lets us find the stale stamp even when it
            // came back via bfcache before this code ran.
            function clearStamp() {
                var prev = document.querySelectorAll('[data-vt-stamped]');
                for (var i = 0; i < prev.length; i++) {
                    prev[i].style.viewTransitionName = '';
                    prev[i].removeAttribute('data-vt-stamped');
                }
            }
            document.addEventListener('click', function (e) {
                var card = e.target.closest
                    ? e.target.closest('a.library-card, a.site-search-result')
                    : null;
                if (!card) return;
                var img = card.querySelector('.library-card-poster, .site-search-result-poster');
                if (!img) return;
                clearStamp();
                img.style.viewTransitionName = 'vt-shared-poster';
                img.setAttribute('data-vt-stamped', '');
            }, true);
            window.addEventListener('pageshow', function (e) { if (e.persisted) clearStamp(); });
        })();

        (function () {
            var btn = document.querySelector('[data-site-back]');
            if (!btn) return;
            btn.addEventListener('click', function () {
                var before = location.href;
                try { history.back(); } catch (_) { /* fall through */ }
                setTimeout(function () {
                    if (location.href === before) location.href = '/';
                }, 500);
            });
        })();

        // Disconnect intercept — wipe localStorage on every Disconnect
        // link click so the next session starts cold. Stats / continue-
        // watching / stream caches / video resume positions etc. all
        // live under anisync.* keys; for a clean disconnect the user
        // wants none of the previous identity's data sticking around.
        // Runs synchronously inside the click handler so the wipe is
        // done before the browser begins navigation to /Auth/Logout.
        // Doesn't preventDefault — the link still navigates as usual.
        document.querySelectorAll('[data-disconnect]').forEach(function (el) {
            // Stamp a returnUrl carrying the current page path onto the
            // anchor's href so the server-side whitelist (Logout honours
            // /account and /configure; everything else falls through to
            // home) gets a real value to compare against. Updated on
            // every click rather than at page load so deep navigations
            // that don't full-reload (rare here, but bfcache restores
            // count) still see the live path.
            el.addEventListener('click', function () {
                try { localStorage.clear(); } catch (_) { /* quota / private mode — best-effort */ }
                try { sessionStorage.clear(); } catch (_) { /* same */ }
                if (el.tagName === 'A') {
                    var base = el.getAttribute('href') || '';
                    // Strip any previously-stamped returnUrl so repeated
                    // clicks don't accumulate query params.
                    base = base.split('?')[0];
                    el.setAttribute('href',
                        base + '?returnUrl=' + encodeURIComponent(window.location.pathname));
                }
            });
        });
    </script>
    @if (layoutLoggedIn)
    {
        <script src="~/js/notifications.js" asp-append-version="true" defer></script>
    }

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
