@inject AnimeList.Services.Interfaces.IConfigStore _layoutConfigStore
@{
    // Session-derived identity used by the site-header pill + the drawer's
    // sign-in / disconnect CTA. Reading directly here keeps every page's
    // chrome consistent without each controller having to populate a
    // ViewData hint. Try/catch defends against malformed session payloads
    // — bad cookie shouldn't 500 every page.
    AnimeList.Models.TokenData layoutToken = null;
    var layoutSessionStr = Context.Session.GetString("AccessToken");
    if (!string.IsNullOrEmpty(layoutSessionStr))
    {
        try { layoutToken = JsonConvert.DeserializeObject<AnimeList.Models.TokenData>(layoutSessionStr); }
        catch { /* unparseable — render as anonymous */ }
    }
    var layoutLoggedIn = layoutToken != null && !layoutToken.anonymousUser;
    @* layoutHasSession covers both real accounts AND anonymous sessions —
       used to decide whether the header pill / drawer footer surfaces
       "Sign in" or "Disconnect". An anonymous user is still "connected
       (without account)" and shouldn't see a Sign in CTA when the
       Disconnect path on /configure is the only way to actually clear
       their session. *@
    var layoutHasSession = layoutToken != null;
    var activeNav = ViewData["ActiveNav"]?.ToString();

    // Resolve linked-secondary services so the drawer footer can read
    // "✓ Connected to AniList · MAL · Kitsu" rather than just the
    // primary. Two indexed SQLite calls per request — sub-millisecond,
    // and the drawer is rendered on every page so it's not worth
    // plumbing through every controller. try/catch swallows any
    // store/connection failure into "primary only" so a transient
    // SQLite error doesn't 500 the entire layout.
    var layoutConnectedServices = new List<string>();
    if (layoutLoggedIn)
    {
        layoutConnectedServices.Add(layoutToken.anime_service.ToString());
        try
        {
            var (layoutUid, _) = await _layoutConfigStore.FindUidByIdentityAsync(layoutToken);
            if (!string.IsNullOrEmpty(layoutUid))
            {
                var layoutLinked = await _layoutConfigStore.GetLinkedTokensAsync(layoutUid);
                foreach (var lt in layoutLinked)
                {
                    if (lt.NeedsReauth || lt.TokenData == null || lt.TokenData.anonymousUser) continue;
                    layoutConnectedServices.Add(lt.Service.ToString());
                }
            }
        }
        catch { /* fall back to primary-only label */ }
    }
    var layoutConnectedLabel = string.Join(" · ", layoutConnectedServices);
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    @* Strip the Referer header on outbound clicks. The configure page URL embeds
       the user's Config UID; without this meta tag, a click on any external link
       (or a redirect through a third-party OAuth provider) leaks the UID via
       Referer. no-referrer is the strictest setting — same protection applied to
       the Swagger UI page in Program.cs. *@
    <meta name="referrer" content="no-referrer" />
    @* PWA manifest + iOS / Android install hints. The manifest declares
       icons, start_url, theme_color etc.; Chromium uses it (plus an
       active service worker, registered by pwa-install.js) to decide
       install eligibility. theme-color paints the OS chrome (Android
       address bar, standalone-mode title bar) the same dark shade as
       the page so the seam disappears. apple-touch-icon is iOS Safari's
       fallback "Add to Home Screen" icon (it ignores the manifest). *@
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#0A0A0A" />
    <link rel="apple-touch-icon" href="/icons/icon-192.png" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="AniSync" />
    @{
        // Per-page title set via ViewData["Title"]; falls back to the plain
        // app name on pages that don't bother (errors, splash). Browser
        // history / bookmarks / tab labels pick up <title>, so giving each
        // page a unique title is what makes the history view in the screenshot
        // legible ("Re:ZERO · AniSync" instead of fifteen rows of "AniSync").
        var pageTitle = ViewData["Title"]?.ToString();
        var fullTitle = string.IsNullOrEmpty(pageTitle) ? "AniSync" : $"{pageTitle} · AniSync";
    }
    <title>@fullTitle</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AniSync.styles.css" asp-append-version="true" />
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    @* Load loader.js early (right after jQuery) so the fetch wrap and
       jQuery ajax hooks are in place before any other script can fire
       an HTTP request. *@
    <script src="~/js/loader.js" asp-append-version="true"></script>
</head>
<body class="@ViewData["BodyClass"]">
    @* Persistent site chrome: slide-in drawer + mobile bottom-nav are lifted
       out of per-page views so every page gets the same shell. The site-
       header is rendered inside `main` (just below) so it inherits main's
       centered max-width — keeps the logo and hamburger aligned with the
       rest of the page content rather than floating against the viewport
       edges. The drawer toggle is a single-class flip on body — no
       framework, no jQuery dep, just a class on document.body. *@
    <aside class="nav-drawer" aria-label="Site navigation">
        <div class="nav-drawer-header">
            <a class="site-logo" href="/" aria-label="AniSync home">
                <img src="/logo.png" alt="AniSync" />
            </a>
            <button class="drawer-close" aria-label="Close menu"
                    onclick="document.body.classList.remove('drawer-open')">×</button>
        </div>
        <nav class="nav-drawer-nav">
            <a href="/" class="@(activeNav == "home" ? "active" : "")">
                <svg class="nav-icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M3 12L12 3l9 9"></path>
                    <path d="M5 10v10a1 1 0 0 0 1 1h4v-6h4v6h4a1 1 0 0 0 1-1V10"></path>
                </svg>
                <span class="nav-label">Home</span>
            </a>
            @* My Library requires an authenticated non-anonymous session — the
               page just bounces back to / for anonymous visitors, so we omit
               the link entirely rather than offering a dead-end navigation. *@
            @if (layoutLoggedIn)
            {
                <a href="/library" class="@(activeNav == "library" ? "active" : "")">
                    <svg class="nav-icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"></path>
                    </svg>
                    <span class="nav-label">My Library</span>
                </a>
            }
            <a href="/discover" class="@(activeNav == "discover" ? "active" : "")">
                <svg class="nav-icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <circle cx="11" cy="11" r="8"></circle>
                    <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                </svg>
                <span class="nav-label">Discover</span>
            </a>
            @* Settings consolidates the /configure (Account) + /stremio (addon
               configure) pages; the Stremio link is reachable from the
               Settings page rather than crowding the top-level nav. The active
               state lights up for both /configure and /stremio so navigating
               between them inside Settings keeps the same tab highlighted. *@
            <a href="@Url.Action("Configure", "Home")" class="@(activeNav == "configure" || activeNav == "stremio" ? "active" : "")">
                <svg class="nav-icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <circle cx="12" cy="12" r="3"></circle>
                    <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 1 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 1 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 1 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 1 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
                </svg>
                <span class="nav-label">Settings</span>
            </a>
        </nav>
        <div class="nav-drawer-footer">
            @if (layoutHasSession)
            {
                <span class="nav-drawer-status">
                    @(layoutLoggedIn ? $"✓ Connected to {layoutConnectedLabel}" : "✓ Connected without account")
                </span>
                <a class="nav-drawer-cta nav-drawer-cta-secondary" href="@Url.Action("Logout", "Auth")">Disconnect</a>
            }
            else
            {
                <a class="nav-drawer-cta nav-drawer-cta-primary" href="@Url.Action("Configure", "Home")">Sign in</a>
            }
        </div>
    </aside>
    <div class="drawer-backdrop"
         onclick="document.body.classList.remove('drawer-open')"></div>

    @* Site header is intentionally OUTSIDE the page container so the
       sticky bar can paint edge-to-edge on desktop while its inner
       content stays aligned with the page via the inner .container. *@
    <header class="site-header">
        <div class="container site-header-inner">
            <a class="site-logo" href="/" aria-label="AniSync home">
                <img src="/logo.png" alt="AniSync" />
            </a>
                @* Inline desktop nav — mirrors the slide-in drawer's links.
                   Hidden under 992px (lg) where the hamburger takes over.
                   Same href + active-class logic as the drawer so adding a
                   route here means updating both. *@
                <nav class="site-header-nav" aria-label="Primary">
                    <a href="/" class="@(activeNav == "home" ? "active" : "")">
                        <svg class="nav-icon" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="M3 12L12 3l9 9"></path>
                            <path d="M5 10v10a1 1 0 0 0 1 1h4v-6h4v6h4a1 1 0 0 0 1-1V10"></path>
                        </svg>
                        <span class="nav-label">Home</span>
                    </a>
                    @if (layoutLoggedIn)
                    {
                        <a href="/library" class="@(activeNav == "library" ? "active" : "")">
                            <svg class="nav-icon" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"></path>
                            </svg>
                            <span class="nav-label">My Library</span>
                        </a>
                    }
                    <a href="/discover" class="@(activeNav == "discover" ? "active" : "")">
                        <svg class="nav-icon" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <circle cx="11" cy="11" r="8"></circle>
                            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                        </svg>
                        <span class="nav-label">Discover</span>
                    </a>
                    @* Settings consolidates Account + Stremio addon pages —
                       same activeNav double-match as the drawer / bottom-nav
                       so navigating between /configure and /stremio keeps the
                       tab highlighted. *@
                    <a href="@Url.Action("Configure", "Home")" class="@(activeNav == "configure" || activeNav == "stremio" ? "active" : "")">
                        <svg class="nav-icon" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <circle cx="12" cy="12" r="3"></circle>
                            <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 1 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 1 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 1 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 1 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
                        </svg>
                        <span class="nav-label">Settings</span>
                    </a>
                </nav>
                @* Global anime search. Lives in the layout so every page has it.
                   Fires /api/v1/match once the query reaches 3 characters with a
                   ~250ms debounce; results dropdown renders absolutely below the
                   input. role=combobox + aria-* attributes describe the
                   typeahead pattern for screen readers. JS lives in
                   wwwroot/js/site-search.js. *@
                <form class="site-search" role="search" autocomplete="off"
                      onsubmit="return false;" aria-label="Search anime">
                    <span class="site-search-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" width="16" height="16" fill="none"
                             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="11" cy="11" r="7"></circle>
                            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                        </svg>
                    </span>
                    <input class="site-search-input"
                           type="search"
                           placeholder="Search anime…"
                           role="combobox"
                           aria-controls="site-search-results"
                           aria-expanded="false"
                           aria-autocomplete="list"
                           spellcheck="false"
                           autocorrect="off"
                           autocapitalize="off" />
                    <div class="site-search-results"
                         id="site-search-results"
                         role="listbox"
                         hidden></div>
                </form>
                @* Episode-release notifications. Bell + unread badge in the
                   header; dropdown panel renders the most recent 20 rows on
                   open. JS in /js/notifications.js polls /count every 60s
                   and re-renders the list on click. Only for logged-in
                   users — anonymous sessions have nothing to notify on. *@
                @if (layoutLoggedIn)
                {
                    <div class="notif-bell" data-notif-bell>
                        <button class="notif-bell-btn" type="button" aria-label="Notifications"
                                aria-expanded="false" aria-controls="notif-panel" data-notif-toggle>
                            <svg viewBox="0 0 24 24" width="18" height="18" fill="none"
                                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9"></path>
                                <path d="M13.73 21a2 2 0 0 1-3.46 0"></path>
                            </svg>
                            <span class="notif-bell-badge" data-notif-count hidden>0</span>
                        </button>
                        <div class="notif-panel" id="notif-panel" role="dialog" aria-label="Notifications" hidden>
                            <header class="notif-panel-header">
                                <span class="notif-panel-title">Notifications</span>
                                <button type="button" data-notif-read-all class="notif-read-all">Mark all read</button>
                            </header>
                            <div class="notif-panel-body" data-notif-list>
                                <div class="notif-empty" data-notif-empty>You're all caught up.</div>
                            </div>
                        </div>
                    </div>
                }
                @* Install pill — hidden by default, revealed by
                   pwa-install.js once the browser fires
                   beforeinstallprompt (Chromium / Edge / Android Chrome)
                   and we've confirmed the page isn't already running in
                   standalone mode. iOS Safari users see a separate
                   one-time toast instead, since iOS doesn't expose an
                   install event. *@
                <button class="pwa-install-btn" type="button" data-pwa-install hidden
                        aria-label="Install AniSync">
                    <svg viewBox="0 0 24 24" width="16" height="16" fill="none"
                         stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M12 3v12"></path>
                        <path d="M7 10l5 5 5-5"></path>
                        <path d="M5 21h14"></path>
                    </svg>
                    <span>Install</span>
                </button>
                @* Desktop-only auth CTA — replaces what the drawer footer
                   exposes on mobile (Sign in / Disconnect). Hidden under
                   992px; the drawer keeps surfacing it on mobile. Treats
                   anonymous sessions the same as real accounts: a token
                   in any form means there's something to Disconnect, so
                   showing Sign in alongside it would be misleading. *@
                @if (layoutHasSession)
                {
                    <a class="site-header-cta site-header-cta-secondary" href="@Url.Action("Logout", "Auth")">Disconnect</a>
                }
                else
                {
                    <a class="site-header-cta site-header-cta-primary" href="@Url.Action("Configure", "Home")">Sign in</a>
                }
            <button class="hamburger-btn" aria-label="Open menu"
                    onclick="document.body.classList.toggle('drawer-open')">
                <span></span><span></span><span></span>
            </button>
        </div>
    </header>

    <div class="container">
        <main role="main" style="min-height: 100vh;">
            @RenderBody()
        </main>
    </div>

    @* Mobile-first bottom nav. Always 4 primary destinations matching the
       drawer's first four items so users have a quick-access bar without
       opening the drawer. Hidden on wider viewports via media query in
       site.css — desktop users rely on the hamburger drawer instead. *@
    <nav class="bottom-nav" aria-label="Primary">
        <a href="/" class="bottom-nav-item @(activeNav == "home" ? "active" : "")" aria-label="Home">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 12L12 3l9 9"></path>
                <path d="M5 10v10a1 1 0 0 0 1 1h4v-6h4v6h4a1 1 0 0 0 1-1V10"></path>
            </svg>
            <span class="bottom-nav-label">Home</span>
        </a>
        @* Library tab omitted for anonymous users — the page just redirects
           them back to /, so the cell would be a dead end on the bottom nav. *@
        @if (layoutLoggedIn)
        {
            <a href="/library" class="bottom-nav-item @(activeNav == "library" ? "active" : "")" aria-label="Library">
                <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"></path>
                </svg>
                <span class="bottom-nav-label">Library</span>
            </a>
        }
        <a href="/discover" class="bottom-nav-item @(activeNav == "discover" ? "active" : "")" aria-label="Discover">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="8"></circle>
                <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            </svg>
            <span class="bottom-nav-label">Discover</span>
        </a>
        <a href="@Url.Action("Configure", "Home")" class="bottom-nav-item @(activeNav == "configure" || activeNav == "stremio" ? "active" : "")" aria-label="Settings">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="3"></circle>
                <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 1 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 1 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 1 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 1 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
            </svg>
            <span class="bottom-nav-label">Settings</span>
        </a>
    </nav>

    @* Inline Manage Entry modal — single instance, hidden by default. The web-app
       pages (Library / Discover / Dashboard) intercept clicks on poster cards
       and open this modal instead of navigating to the standalone Manage Entry
       page; only logged-in non-anonymous users get the modal experience, since
       anonymous cards don't carry a data-meta-id attribute. The standalone page
       remains the fallback for non-JS browsers. *@
    @if (layoutLoggedIn)
    {
        <div class="entry-modal-backdrop" hidden></div>
        <div class="entry-modal" hidden role="dialog" aria-modal="true" aria-labelledby="entry-modal-title">
            <header class="entry-modal-header">
                <h3 class="entry-modal-title" id="entry-modal-title">Loading…</h3>
                <button class="entry-modal-close" type="button" aria-label="Close">×</button>
            </header>
            <div class="entry-modal-body">
                <div class="entry-modal-loading" aria-live="polite">Loading…</div>
                <form class="entry-modal-form" hidden>
                    @* Season selector — hidden by default, shown only when the
                       opened anime is a franchise split across multiple service
                       entries (Attack on Titan, JoJo, Demon Slayer, etc.). The
                       options are populated by the modal JS from the
                       /api/library/entry response's seasons array. Changing the
                       selection re-fetches entry data for that cour. *@
                    <div class="entry-modal-field" data-season-field hidden>
                        <label class="entry-modal-label" for="entry-modal-season">Season</label>
                        <select id="entry-modal-season" name="season" class="entry-modal-select"></select>
                    </div>
                    <div class="entry-modal-field">
                        <label class="entry-modal-label" for="entry-modal-status">Status</label>
                        <select id="entry-modal-status" name="status" class="entry-modal-select"></select>
                    </div>
                    @* data-progress-field hooks an attribute selector in
                       manage-entry-modal.js that hides this whole wrapper
                       when totalEpisodes === 1 (movies + single-episode
                       OVAs). The status dropdown alone carries enough
                       state for those — there's nothing to "watch ep 4
                       of" when the show is one playthrough. *@
                    <div class="entry-modal-field" data-progress-field>
                        <label class="entry-modal-label" for="entry-modal-progress">Episodes Watched</label>
                        <div class="entry-modal-progress-row">
                            <input id="entry-modal-progress" type="number" name="progress" min="0" class="entry-modal-input" />
                            <span class="entry-modal-total" hidden></span>
                        </div>
                    </div>
                    <div class="entry-modal-field">
                        <label class="entry-modal-label" for="entry-modal-score">Score</label>
                        <input id="entry-modal-score" type="number" name="score" min="0" max="10" step="0.1" class="entry-modal-input" placeholder="0–10" />
                    </div>
                    @* Started + Finished dates side-by-side on wider viewports
                       so they don't burn vertical space in the modal. *@
                    <div class="entry-modal-field-row">
                        <div class="entry-modal-field">
                            <label class="entry-modal-label" for="entry-modal-started">Started</label>
                            <input id="entry-modal-started" type="date" name="startedAt" class="entry-modal-input" />
                        </div>
                        <div class="entry-modal-field">
                            <label class="entry-modal-label" for="entry-modal-finished">Finished</label>
                            <input id="entry-modal-finished" type="date" name="finishedAt" class="entry-modal-input" />
                        </div>
                    </div>
                    <div class="entry-modal-field">
                        <label class="entry-modal-label" for="entry-modal-rewatch">Rewatches</label>
                        <input id="entry-modal-rewatch" type="number" name="rewatchCount" min="0" class="entry-modal-input" placeholder="0" />
                    </div>
                    <div class="entry-modal-field">
                        <label class="entry-modal-label" for="entry-modal-notes">Notes</label>
                        <textarea id="entry-modal-notes" name="notes" rows="3" class="entry-modal-textarea" placeholder="Personal notes about this entry…"></textarea>
                    </div>
                    <div class="entry-modal-error" role="alert" hidden></div>
                    @* Delete sits at the leading edge so it's visually
                       separated from the Cancel/Save pair on the trailing
                       edge — destructive actions shouldn't be next to the
                       primary CTA where a misclick lands. Hidden by default;
                       the modal JS reveals it once load resolves with a
                       non-empty status (i.e. the entry actually exists). *@
                    <div class="entry-modal-actions">
                        <button type="button" class="entry-modal-delete" hidden>Delete</button>
                        <div class="entry-modal-actions-end">
                            <button type="button" class="entry-modal-cancel">Cancel</button>
                            <button type="submit" class="entry-modal-save">Save</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
        <script src="~/js/manage-entry-modal.js" asp-append-version="true" defer></script>
    }

    @* Toast container — receives "Saved!" / "Error" feedback from in-page
       actions that survive page reloads via sessionStorage. Always rendered
       (anonymous users can't trigger the modal but other future actions
       might fire toasts). The container is positioned fixed via site.css. *@
    <div id="toast-container" aria-live="polite" aria-atomic="true"></div>

    @* Global request loader. Single instance, hidden by default; loader.js
       reveals it whenever a fetch() / $.ajax() call is in flight (with a
       150ms grace delay so fast responses don't flash the spinner). *@
    <div id="global-loader-overlay" class="loader-overlay" aria-hidden="true" role="status">
        <div class="loader-spinner" aria-label="Loading"></div>
    </div>

    @* Back-to-top button — fixed bottom-right, hidden by default. scroll-top.js
       reveals it once the page has scrolled past a threshold and smooth-scrolls
       back to the top on click. Single instance for the whole site. *@
    <button id="scroll-top-btn" class="scroll-top-btn" type="button"
            aria-label="Scroll to top" hidden>
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none"
             stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="18 15 12 9 6 15"></polyline>
        </svg>
    </button>

    <script src="~/js/toast.js" asp-append-version="true" defer></script>
    <script src="~/js/pwa-install.js" asp-append-version="true" defer></script>
    <script src="~/js/scroll-top.js" asp-append-version="true" defer></script>
    <script src="~/js/site-search.js" asp-append-version="true" defer></script>
    @if (layoutLoggedIn)
    {
        <script src="~/js/notifications.js" asp-append-version="true" defer></script>
    }
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
