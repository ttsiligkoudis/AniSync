@* Dashboard layout chooser — populated + driven by dashboard-layout.js. Lists
   the sections (present on the dashboard; all of them on /account); each row
   reorders (↑/↓) and toggles visibility. The layout persists to the account
   (logged-in) + localStorage and applies client-side. Shared by the dashboard
   and the account page so both can open it. *@
<div class="dash-modal-backdrop" data-dash-modal-backdrop hidden></div>
<div class="dash-modal" data-dash-modal role="dialog" aria-modal="true" aria-labelledby="dash-modal-title" hidden>
    <div class="dash-modal-card">
        <button type="button" class="dash-modal-close" aria-label="Close" data-dash-modal-close>×</button>
        <h2 class="dash-modal-title" id="dash-modal-title">Customize dashboard</h2>
        <p class="dash-modal-subtitle">Reorder sections and choose what shows. Synced to your account.</p>
        <ul class="dash-modal-list" data-dash-modal-list></ul>
        <div class="dash-modal-footer">
            <button type="button" class="dash-modal-reset" data-dash-reset>Reset to default</button>
            <button type="button" class="dash-modal-done" data-dash-modal-done>Done</button>
        </div>
    </div>
</div>

<script src="~/js/dashboard-layout.js" asp-append-version="true" defer></script>
