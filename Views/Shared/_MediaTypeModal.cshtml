@{
    // First-visit / reopen media-type chooser. MULTI-SELECT: the user picks one
    // or more modes (anime / movies / series). The dashboard combines shelves
    // across the selected set; Discover / Library offer a single-select toggle
    // limited to it. Rendered once in the layout for every visitor.
    // media-type.js owns open/close, selection state, persistence (localStorage
    // + cookie + the account setting when logged in) and the reload.
    var mtEnabled = ViewData["MediaTypeEnabled"] as List<MetaType> ?? new();
    var mtLoggedIn = ViewData["MediaTypeLoggedIn"] as bool? ?? false;
    // When set (the Stremio /configure page, which is anime-only), media-type.js
    // silently selects this mode for a first-time visitor instead of forcing the
    // chooser modal open.
    var mtAutoDefault = ViewData["MediaTypeAutoDefault"] as string;
    var mtOptions = new[]
    {
        (Type: MetaType.anime,  Title: "Anime",  Blurb: "Track across AniList, MAL & Kitsu"),
        (Type: MetaType.movie,  Title: "Movies",  Blurb: "Browse & track films"),
        (Type: MetaType.series, Title: "Series",  Blurb: "Browse & track TV shows"),
    };
}
<div class="mt-modal-backdrop" data-media-type-backdrop hidden></div>
<div class="mt-modal" data-media-type-modal role="dialog" aria-modal="true"
     aria-labelledby="mt-modal-title"
     data-logged-in="@(mtLoggedIn ? "true" : "false")"
     data-autodefault="@mtAutoDefault"
     hidden>
    <div class="mt-modal-card">
        <button type="button" class="mt-modal-close" aria-label="Close" data-media-type-close>×</button>
        <h2 class="mt-modal-title" id="mt-modal-title">What do you want to watch?</h2>
        <p class="mt-modal-subtitle">Pick one or more — your dashboard combines them, and you can switch between them on Discover &amp; Library. Change any time from the header.</p>
        <div class="mt-modal-options">
            @foreach (var opt in mtOptions)
            {
                var selected = mtEnabled.Contains(opt.Type);
                <button type="button" class="mt-modal-option @(selected ? "is-selected" : "")"
                        data-media-type-choice="@opt.Type"
                        aria-pressed="@(selected ? "true" : "false")">
                    <span class="mt-modal-option-icon" aria-hidden="true">
                        @if (opt.Type == MetaType.anime)
                        {
                            <svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M12 3l1.9 5.6L19.5 10l-5.6 1.9L12 17.5l-1.9-5.6L4.5 10l5.6-1.4z" />
                                <path d="M19 4l.6 1.8L21.5 6.5l-1.9.6L19 9l-.6-1.9L16.5 6.5l1.9-.7z" />
                            </svg>
                        }
                        else if (opt.Type == MetaType.movie)
                        {
                            <svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="3" y="4" width="18" height="16" rx="2" />
                                <line x1="7" y1="4" x2="7" y2="20" />
                                <line x1="17" y1="4" x2="17" y2="20" />
                                <line x1="3" y1="12" x2="21" y2="12" />
                            </svg>
                        }
                        else
                        {
                            <svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="2" y="7" width="20" height="13" rx="2" />
                                <polyline points="8 3 12 7 16 3" />
                            </svg>
                        }
                    </span>
                    <span class="mt-modal-option-body">
                        <span class="mt-modal-option-title">@opt.Title</span>
                        <span class="mt-modal-option-blurb">@opt.Blurb</span>
                    </span>
                    @* Check mark — CSS shows it only on .is-selected options. *@
                    <span class="mt-modal-option-check" aria-hidden="true">
                        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="20 6 9 17 4 12" />
                        </svg>
                    </span>
                </button>
            }
        </div>
        <div class="mt-modal-footer">
            <span class="mt-modal-hint" data-media-type-hint hidden>Select at least one mode.</span>
            <button type="button" class="mt-modal-confirm" data-media-type-confirm>Continue</button>
        </div>
    </div>
</div>
