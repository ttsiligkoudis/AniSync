@model AnimeList.Controllers.LibraryViewModel
@{
    ViewData["BodyClass"] = "library-page";
    ViewData["ActiveNav"] = "library";

    var labels = new Dictionary<ListType, string>
    {
        [ListType.Current]    = "Watching",
        [ListType.Completed]  = "Completed",
        [ListType.Planning]   = "Planning",
        [ListType.Paused]     = "Paused",
        [ListType.Dropped]    = "Dropped",
        [ListType.Repeating]  = "Rewatching",
    };

    var hasSearch = !string.IsNullOrEmpty(Model.Search);
    var activeLabel = labels[Model.ActiveList];

    // Title reflects the active tab / search state so browser history rows
    // for "Library > Completed" and "Library > Search" are distinguishable.
    ViewData["Title"] = hasSearch
        ? $"Search: {Model.Search} · Library"
        : $"{activeLabel} · Library";
}

<p class="page-subtitle">
    @if (hasSearch)
    {
        <text>Search results · @Model.AnimeService</text>
    }
    else
    {
        <text>@activeLabel on @Model.AnimeService</text>
    }
    <span class="library-back">·
        <a href="@Url.Action("Index", "Home")">back to dashboard</a>
    </span>
    @* Force-refresh: same ?nocache=1 escape hatch the dashboard exposes. Hidden
       during search since search results aren't cached anyway. *@
    @if (!hasSearch)
    {
        <a class="dashboard-refresh-btn library-refresh-btn"
           href="@Url.Action("Index", "Library", new { list = Model.ActiveList.ToString().ToLower(), nocache = true })"
           title="Refresh list — bypass the 10 min cache"
           aria-label="Refresh list">
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="23 4 23 10 17 10"></polyline>
                <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"></path>
            </svg>
        </a>
    }
</p>

@* Search input. Server-rendered <form> targeting the same page — submitting
   navigates to /library?search=... and the controller branches into search mode.
   Empty submit clears the search. The active list tab isn't preserved across
   search because the two are mutually exclusive in the controller; clearing
   search returns to the default tab (Watching). *@
<form method="get" action="@Url.Action("Index", "Library")" class="library-search">
    <input type="search"
           name="search"
           value="@Model.Search"
           placeholder="Search anime…"
           class="library-search-input"
           autocomplete="off" />
    @if (hasSearch)
    {
        <a class="library-search-clear" href="@Url.Action("Index", "Library")">Clear</a>
    }
</form>

@* Tab strip — hidden during search since search results span every list type
   and the visual cue would be misleading. *@
@if (!hasSearch)
{
    <nav class="library-tabs" role="tablist">
        @foreach (var t in Model.Tabs)
        {
            var isActive = t == Model.ActiveList;
            <a class="library-tab @(isActive ? "library-tab-active" : "")"
               href="@Url.Action("Index", "Library", new { list = t.ToString().ToLower() })"
               role="tab"
               aria-selected="@(isActive ? "true" : "false")">
                @labels[t]
            </a>
        }
    </nav>
}

@await Html.PartialAsync("_PosterGrid", new AnimeList.Models.PosterGridViewModel
{
    Items = Model.Items,
    ConfigUid = Model.ConfigUid,
    EmptyMessage = hasSearch
        ? $"No matches for \"{Model.Search}\"."
        : $"Nothing in your {activeLabel} list on {Model.AnimeService}.",
})
