@model AnimeList.Controllers.LibraryViewModel
@{
    ViewData["BodyClass"] = "library-page";
    ViewData["ActiveNav"] = "library";

    var labels = new Dictionary<ListType, string>
    {
        [ListType.Current]    = "Watching",
        [ListType.Completed]  = "Completed",
        [ListType.Planning]   = "Planning",
        [ListType.Paused]     = "Paused",
        [ListType.Dropped]    = "Dropped",
        [ListType.Repeating]  = "Rewatching",
    };

    var hasSearch = !string.IsNullOrEmpty(Model.Search);
    var hasGenre = !string.IsNullOrEmpty(Model.Genre);
    var activeLabel = labels[Model.ActiveList];
    var activeListSlug = Model.ActiveList.ToString().ToLower();

    ViewData["Title"] = hasSearch
        ? $"Search: {Model.Search} · Library"
        : hasGenre
            ? $"{Model.Genre} · {activeLabel} · Library"
            : $"{activeLabel} · Library";
}

@* List-type tabs lead the page (Watching / Completed / Planning / Paused /
   Dropped / Rewatching). Each is an anchor — clicking refreshes the page
   with the selected list. Active genre flows through so switching from
   Watching → Completed keeps the genre filter applied. *@
<nav class="library-tabs" role="tablist" aria-label="Library lists">
    @foreach (var t in Model.Tabs)
    {
        var isActive = t == Model.ActiveList;
        var values = new RouteValueDictionary { ["list"] = t.ToString().ToLower() };
        if (hasGenre) values["genre"] = Model.Genre;
        <a class="library-tab @(isActive ? "library-tab-active" : "")"
           href="@Url.Action("Index", "Library", values)"
           role="tab"
           aria-selected="@(isActive ? "true" : "false")">
            @labels[t]
        </a>
    }
</nav>

@* Combined filter form: search input + genre dropdown + explicit Search
   button. Nothing auto-submits — user picks their filters then commits
   them all at once. The hidden `list` input keeps the active tab pinned
   through submissions. *@
<form method="get" action="@Url.Action("Index", "Library")" class="filter-bar" role="search">
    <input type="hidden" name="list" value="@activeListSlug" />

    <input type="search"
           name="search"
           value="@Model.Search"
           placeholder="Search anime…"
           class="filter-bar-search"
           autocomplete="off" />

    <select name="genre" class="filter-bar-select" aria-label="Genre">
        <option value="">All genres</option>
        @foreach (var g in Model.AvailableGenres)
        {
            <option value="@g" selected="@(Model.Genre == g)">@g</option>
        }
    </select>

    <button type="submit" class="filter-bar-submit">Search</button>

    @if (hasSearch || hasGenre)
    {
        <a class="filter-bar-clear" href="@Url.Action("Index", "Library", new { list = activeListSlug })">Clear</a>
    }

</form>

@{
    var paneModel = new AnimeList.Models.LibraryPaneViewModel
    {
        Grid = new AnimeList.Models.PosterGridViewModel
        {
            Items = Model.Items,
            ConfigUid = Model.ConfigUid,
            EmptyMessage = hasSearch
                ? $"No matches for \"{Model.Search}\"."
                : hasGenre
                    ? $"No {Model.Genre.ToLower()} anime in your {activeLabel} list."
                    : $"Nothing in your {activeLabel} list on {Model.AnimeService}.",
        },
    };
}

@* Submitting the .filter-bar form normally would full-reload the page;
   filter-search.js intercepts the submit, hits /library/page for just
   the pane HTML, and swaps it into #library-results-pane. The same
   script also auto-fires the submit on script load when the pane
   carries data-needs-initial-load — that's what populates the page on
   the initial /library render now that the server skips the upstream
   list fetch and renders skeletons instead. *@
<div id="library-results-pane"
     data-needs-initial-load="@(Model.NeedsClientLoad ? "true" : null)">
    @if (Model.NeedsClientLoad)
    {
        @* Skeleton grid — same .library-grid shell + .library-card
           layout the real cards use, so the row dimensions don't
           shift when filter-search.js swaps the pane content. Twelve
           placeholders fill above the fold on common viewports. *@
        <div class="library-grid">
            @for (var i = 0; i < 12; i++)
            {
                <div class="library-card library-card-skeleton">
                    <div class="library-card-poster-wrap">
                        <div class="library-card-poster skeleton-shimmer"></div>
                    </div>
                    <span class="library-card-skeleton-line"></span>
                    <span class="library-card-skeleton-line library-card-skeleton-line-short"></span>
                </div>
            }
        </div>
    }
    else
    {
        @await Html.PartialAsync("_LibraryPane", paneModel)
    }
</div>

@section Scripts {
    <script src="~/js/filter-search.js" asp-append-version="true" defer></script>
}
