@model AnimeList.Controllers.ActorDetailViewModel
@{
    ViewData["BodyClass"] = "library-page";
    var title = string.IsNullOrEmpty(Model.Name) ? Model.Slug : Model.Name;
    ViewData["Title"] = $"{title} · AniSync";
    var initial = string.IsNullOrEmpty(title) ? "?" : title[..1];
    var hasAny = Model.Movies.Count > 0 || Model.Series.Count > 0;
}

<header class="page-header actor-header">
    <span class="actor-header-avatar">
        <span class="actor-header-avatar-initial" aria-hidden="true">@initial</span>
        @if (!string.IsNullOrEmpty(Model.Image))
        {
            <img class="actor-header-avatar-img" src="@Model.Image" alt="" loading="lazy"
                 decoding="async" onerror="this.remove()" />
        }
    </span>
    <span class="actor-header-text">
        <span class="page-subtitle">Movies &amp; Series</span>
        <h1 class="page-title">@title</h1>
    </span>
</header>

@if (!hasAny)
{
    <p class="hint-text">No titles found for @title.</p>
}
else
{
    @* Each group renders only when it has items, so an actor with only movies
       (or only series) shows a single section without an empty header. *@
    @if (Model.Movies.Count > 0)
    {
        <section class="discover-group">
            <h2 class="discover-group-title">Movies</h2>
            @await Html.PartialAsync("_PosterGrid", new AnimeList.Models.PosterGridViewModel
            {
                Items = Model.Movies,
                ConfigUid = Model.ConfigUid,
                VideoLinks = true,
            })
        </section>
    }
    @if (Model.Series.Count > 0)
    {
        <section class="discover-group">
            <h2 class="discover-group-title">Series</h2>
            @await Html.PartialAsync("_PosterGrid", new AnimeList.Models.PosterGridViewModel
            {
                Items = Model.Series,
                ConfigUid = Model.ConfigUid,
                VideoLinks = true,
            })
        </section>
    }
}
