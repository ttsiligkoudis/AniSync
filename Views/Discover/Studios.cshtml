@model List<AnimeList.Models.StudioSummary>
@{
    ViewData["Title"] = "Studios";
    ViewData["BodyClass"] = "library-page";
    ViewData["ActiveNav"] = "discover";
    ViewData["ShowMediaTypeSwitch"] = true;
    var studioSearch = ViewData["StudioSearch"] as string;
    var hasStudioSearch = !string.IsNullOrEmpty(studioSearch);
    // True when the controller skipped the upstream fetch on the
    // browse view; the paginator below renders skeleton tiles and JS
    // takes over to fetch page 1 + replace them.
    var studiosNeedsClientLoad = ViewData["StudiosNeedsClientLoad"] as bool? ?? false;
}

@* Shared Discover tab strip with the Studios pill active — keeps this
   page inside the same five-pill nav as /discover and /discover/tag,
   so users navigate between catalog views and Browse-by views without
   the chrome flipping under them. *@
@await Html.PartialAsync("_DiscoverTabs", new AnimeList.Controllers.DiscoverTabsViewModel
{
    ActiveBrowse = "studios",
})

@* Server-side search form. Studios are paginated (AniList has hundreds),
   so a client-side filter would only catch entries the user has already
   scrolled past — useless for finding a long-tail studio that lives on
   page 4. Posting through the existing studios() page query with the
   server-side `search` arg returns matches across the whole catalog.
   When a search is active, the paginator JS reads the URL and forwards
   the same term on subsequent page-fetches so infinite-scroll keeps
   working through the search results. *@
<form method="get" action="/discover/studio" class="filter-bar" role="search">
    <input type="search"
           name="search"
           value="@studioSearch"
           placeholder="Search studios…"
           class="filter-bar-search"
           autocomplete="off" />
    <button type="submit" class="filter-bar-submit">Search</button>
    @if (hasStudioSearch)
    {
        <a class="filter-bar-clear" href="/discover/studio">Clear</a>
    }
</form>

@if (studiosNeedsClientLoad)
{
    @* Skeleton tiles for the browse view — studio-pagination.js owns
       page 1 (server skipped the upstream call) and replaces the
       placeholders with real tiles once /discover/studio/page returns.
       data-page="0" + data-needs-initial-load="true" tells the script
       it's responsible for the first fetch. *@
    <div class="studio-paginator" data-page="0" data-needs-initial-load="true">
        <div class="studio-grid">
            @for (var i = 0; i < 12; i++)
            {
                <div class="studio-tile studio-tile-skeleton">
                    <span class="studio-tile-name skeleton-shimmer"></span>
                    <span class="studio-tile-count skeleton-shimmer"></span>
                </div>
            }
        </div>
        <div class="paginator-loader" hidden aria-hidden="true">
            <div class="paginator-loader-spinner"></div>
        </div>
        <div class="studio-sentinel" aria-hidden="true"></div>
    </div>
}
else if (Model == null || Model.Count == 0)
{
    @if (hasStudioSearch)
    {
        <p class="hint-text">No studios match "@studioSearch".</p>
    }
    else
    {
        <p class="hint-text">No studios available right now. Try again in a moment.</p>
    }
}
else
{
    @* Paginator wrapper carries the state the JS reads on startup: which
       AniList page we last rendered server-side. studio-pagination.js
       increments and fetches /discover/studio/page?page=N+1 as the
       sentinel scrolls into view, appending tiles directly into
       .studio-grid. *@
    <div class="studio-paginator" data-page="1">
        <div class="studio-grid">
            @await Html.PartialAsync("_StudioTiles", Model)
        </div>
        <div class="paginator-loader" hidden aria-hidden="true">
            <div class="paginator-loader-spinner"></div>
        </div>
        <div class="studio-sentinel" aria-hidden="true"></div>
    </div>
}

@section Scripts {
    <script src="~/js/studio-pagination.js" asp-append-version="true" defer></script>
}
