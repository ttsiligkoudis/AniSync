@model List<AnimeList.Models.StudioSummary>
@{
    ViewData["Title"] = "Studios";
    ViewData["BodyClass"] = "library-page";
    ViewData["ActiveNav"] = "discover";
}

@* Shared Discover tab strip with the Studios pill active — keeps this
   page inside the same five-pill nav as /discover and /discover/tag,
   so users navigate between catalog views and Browse-by views without
   the chrome flipping under them. *@
@await Html.PartialAsync("_DiscoverTabs", new AnimeList.Controllers.DiscoverTabsViewModel
{
    ActiveBrowse = "studios",
})

@if (Model == null || Model.Count == 0)
{
    <p class="hint-text">No studios available right now. Try again in a moment.</p>
}
else
{
    @* Paginator wrapper carries the state the JS reads on startup: which
       AniList page we last rendered server-side. studio-pagination.js
       increments and fetches /discover/studio/page?page=N+1 as the
       sentinel scrolls into view, appending tiles directly into
       .studio-grid. *@
    <div class="studio-paginator" data-page="1">
        <div class="studio-grid">
            @await Html.PartialAsync("_StudioTiles", Model)
        </div>
        <div class="paginator-loader" hidden aria-hidden="true">
            <div class="paginator-loader-spinner"></div>
        </div>
        <div class="studio-sentinel" aria-hidden="true"></div>
    </div>
}

@section Scripts {
    <script src="~/js/studio-pagination.js" asp-append-version="true" defer></script>
}
