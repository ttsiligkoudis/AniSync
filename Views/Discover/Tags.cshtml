@model List<AnimeList.Models.TagSummary>
@{
    ViewData["Title"] = "Tags";
    ViewData["BodyClass"] = "library-page";
    ViewData["ActiveNav"] = "discover";

    // Group by AniList category for scannability — the unsorted list
    // would be a few hundred undifferentiated tiles. Tags with no
    // category land under "Other" at the top of the page.
    var groups = (Model ?? new List<AnimeList.Models.TagSummary>())
        .GroupBy(t => string.IsNullOrWhiteSpace(t.Category) ? "Other" : t.Category)
        .OrderBy(g => g.Key, StringComparer.OrdinalIgnoreCase);
}

@* Shared Discover tab strip with the Tags pill active — keeps this
   page inside the same five-pill nav as /discover and /discover/studio,
   so users navigate between catalog views and Browse-by views without
   the chrome flipping under them. *@
@await Html.PartialAsync("_DiscoverTabs", new AnimeList.Controllers.DiscoverTabsViewModel
{
    ActiveBrowse = "tags",
})

@if (Model == null || Model.Count == 0)
{
    <p class="hint-text">No tags available right now. Try again in a moment.</p>
}
else
{
    foreach (var group in groups)
    {
        <section class="tag-group">
            <h2 class="tag-group-title">@group.Key</h2>
            <div class="tag-grid">
                @await Html.PartialAsync("_TagTiles", group.AsEnumerable())
            </div>
        </section>
    }
}
