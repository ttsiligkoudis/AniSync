@model AnimeList.Controllers.StudioDetailViewModel
@{
    ViewData["BodyClass"] = "library-page";
    var fallback = $"Studio #{Model.Id}";
    var title = string.IsNullOrEmpty(Model.Name) ? fallback : Model.Name;
    ViewData["Title"] = $"{title} · AniSync";

    var posterGridModel = new AnimeList.Models.PosterGridViewModel
    {
        Items = Model.Items,
        ConfigUid = Model.ConfigUid,
        EmptyMessage = $"No anime found for {title}.",
    };
    var hasItems = Model.Items?.Count > 0;
}

<header class="page-header">
    <p class="page-subtitle">From</p>
    <h1 class="page-title">@title</h1>
</header>

@if (hasItems)
{
    @* studio-detail-pagination.js fetches subsequent pages from
       /discover/studio/{id}/page on sentinel intersect and splices the
       returned poster cards into .library-grid. data-studio-id +
       data-page seed the JS's request state. *@
    <div class="studio-detail-paginator" data-studio-id="@Model.Id" data-page="1">
        @await Html.PartialAsync("_PosterGrid", posterGridModel)
        <div class="paginator-loader" hidden aria-hidden="true">
            <div class="paginator-loader-spinner"></div>
        </div>
        <div class="studio-detail-sentinel" aria-hidden="true"></div>
    </div>
}
else
{
    @await Html.PartialAsync("_PosterGrid", posterGridModel)
}

@section Scripts {
    @if (hasItems)
    {
        <script src="~/js/studio-detail-pagination.js" asp-append-version="true" defer></script>
    }
}
