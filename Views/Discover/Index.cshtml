@model AnimeList.Controllers.DiscoverViewModel
@{
    ViewData["BodyClass"] = "library-page";

    // Display labels for the three discover list types. Trending_Desc's underscore is
    // a code-side artifact; the URL synonym ?list=trending is also accepted by the
    // controller for cleanliness.
    var labels = new Dictionary<ListType, string>
    {
        [ListType.Trending_Desc] = "Trending",
        [ListType.Seasonal]      = "Seasonal",
        [ListType.Airing]        = "Airing",
    };

    // Map ListType to the URL slug the controller's ParseListType accepts. Trending
    // gets the friendly "trending" instead of "trending_desc".
    var slugs = new Dictionary<ListType, string>
    {
        [ListType.Trending_Desc] = "trending",
        [ListType.Seasonal]      = "seasonal",
        [ListType.Airing]        = "airing",
    };

    var activeLabel = labels[Model.ActiveList];
}

<h1 class="app-logo">Ani<span class="accent">Sync</span></h1>
<p class="app-subtitle">
    @activeLabel anime
    @if (!Model.AnonymousUser)
    {
        <text>· via @Model.AnimeService</text>
    }
    <span class="library-back">·
        <a href="@Url.Action("Index", "Home")">back to dashboard</a>
    </span>
</p>

@* Tab strip across the three discover catalogs. Same .library-tabs styling as
   the user-list tabs on /library — keeps the two pages visually consistent. *@
<nav class="library-tabs" role="tablist">
    @foreach (var t in Model.Tabs)
    {
        var isActive = t == Model.ActiveList;
        <a class="library-tab @(isActive ? "library-tab-active" : "")"
           href="@Url.Action("Index", "Discover", new { list = slugs[t] })"
           role="tab"
           aria-selected="@(isActive ? "true" : "false")">
            @labels[t]
        </a>
    }
</nav>

@await Html.PartialAsync("_PosterGrid", new AnimeList.Models.PosterGridViewModel
{
    Items = Model.Items,
    @* Anonymous users have no UID, so the partial renders inert cards. Logged-in
       users get the same Manage Entry hand-off as the library page. *@
    ConfigUid = Model.ConfigUid,
    EmptyMessage = $"Couldn't load {activeLabel.ToLower()} anime — try again later.",
})
