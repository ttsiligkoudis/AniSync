@model AnimeList.Controllers.DiscoverViewModel
@{
    ViewData["BodyClass"] = "library-page";
    ViewData["ActiveNav"] = "discover";

    var labels = new Dictionary<ListType, string>
    {
        [ListType.Trending_Desc] = "Trending",
        [ListType.Seasonal]      = "Seasonal",
        [ListType.Airing]        = "Airing",
    };

    var slugs = new Dictionary<ListType, string>
    {
        [ListType.Trending_Desc] = "trending",
        [ListType.Seasonal]      = "seasonal",
        [ListType.Airing]        = "airing",
    };

    var hasSearch = !string.IsNullOrEmpty(Model.Search);
    var hasGenre = !string.IsNullOrEmpty(Model.Genre);
    var hasTag = !string.IsNullOrEmpty(Model.Tag);
    var activeLabel = labels[Model.ActiveList];
    var activeSlug = slugs[Model.ActiveList];
    var isSeasonal = Model.ActiveList == ListType.Seasonal;

    // Distinguish browser-history rows: "Search: foo · Discover" vs "Action ·
    // Discover" vs "Trending · Discover".
    ViewData["Title"] = hasSearch ? $"Search: {Model.Search} · Discover"
        : hasTag ? $"#{Model.Tag} · Discover"
        : hasGenre ? $"{Model.Genre} · Discover"
        : isSeasonal ? $"{Model.Season} · Discover"
        : $"{activeLabel} · Discover";

    ViewData["MtActive"] = MetaType.anime;
    ViewData["MtReturnUrl"] = "/discover";
}

@* Single-select switch between the modes enabled in the chooser modal. *@
@await Html.PartialAsync("_MediaTypeToggle")

@if (hasTag)
{
    @* Tag-browse mode lights up when the user followed a Tag chip on a
       detail page. Suppresses the list-tab strip (tag results don't pivot
       on Trending / Seasonal / Airing — they're a flat popularity rank
       across every anime carrying the tag) and renders a header pill with
       a Clear link back to the default Discover view. *@
    <header class="page-header">
        <p class="page-subtitle">Tag</p>
        <h1 class="page-title">@Model.Tag</h1>
        <p><a class="filter-bar-clear" href="@Url.Action("Index", "Discover")">Clear tag</a></p>
    </header>
}

@if (hasTag) { <!-- list tabs / filter form hidden in tag-browse mode --> }
else
{
@* Tab strip is shared with the Studios / Tags Browse-by pages so the
   five-pill nav reads as one continuous Discover surface across all
   three routes. The partial preserves the catalog-side filters
   (genre / search / season) as query params on the Trending /
   Seasonal / Airing pills. *@
@await Html.PartialAsync("_DiscoverTabs", new AnimeList.Controllers.DiscoverTabsViewModel
{
    ActiveList = Model.ActiveList,
    Genre = Model.Genre,
    Search = Model.Search,
    Season = Model.Season,
})

@* Combined filter form. Search input + genre dropdown + (when Seasonal)
   season dropdown + an explicit Search button. Nothing auto-submits — the
   user picks their filters, then clicks Search to apply them all at once.
   The form's hidden `list` input keeps the active tab pinned through
   submissions so the user stays on Seasonal/Trending/Airing as they
   filter. *@
<form method="get" action="@Url.Action("Index", "Discover")" class="filter-bar" role="search">
    <input type="hidden" name="list" value="@activeSlug" />

    <input type="search"
           name="search"
           value="@Model.Search"
           placeholder="Search anime…"
           class="filter-bar-search"
           autocomplete="off" />

    <select name="genre" class="filter-bar-select" aria-label="Genre">
        <option value="">All genres</option>
        @foreach (var g in Model.AvailableGenres)
        {
            <option value="@g" selected="@(Model.Genre == g)">@g</option>
        }
    </select>

    @if (isSeasonal)
    {
        <select name="season" class="filter-bar-select" aria-label="Season">
            @foreach (var s in Model.AvailableSeasons)
            {
                <option value="@s" selected="@(Model.Season == s)">@s</option>
            }
        </select>
    }

    <button type="submit" class="filter-bar-submit">Search</button>

    @if (hasSearch || hasGenre)
    {
        @* "Clear" drops search + genre but keeps the list-tab (and the
           current season, when applicable). Resets the page to the default
           view for the chosen list type. *@
        var clearValues = new RouteValueDictionary { ["list"] = activeSlug };
        if (isSeasonal && !string.IsNullOrEmpty(Model.Season)) clearValues["season"] = Model.Season;
        <a class="filter-bar-clear" href="@Url.Action("Index", "Discover", clearValues)">Clear</a>
    }
</form>
}

@{
    var posterGridModel = new AnimeList.Models.PosterGridViewModel
    {
        Items = Model.Items,
        ConfigUid = Model.ConfigUid,
        EmptyMessage = hasSearch
            ? $"No matches for \"{Model.Search}\"."
            : hasTag
                ? $"No anime found with the tag \"{Model.Tag}\"."
                : hasGenre
                    ? $"No {Model.Genre.ToLower()} anime in {activeLabel.ToLower()} right now."
                    : $"Couldn't load {activeLabel.ToLower()} anime — try again later.",
    };
}

@* #discover-results-pane is the swap target for filter-search.js. The
   server returns just the inner <div class="library-grid">… (no paginator
   wrapper) on a Search-button submit and the JS drops it in here; the
   pagination-aware wrapper below is the initial server-rendered state
   for the non-search case. *@
<div id="discover-results-pane">
    @if (hasSearch)
    {
        @* Search results aren't paginated upstream (single-shot relevance rank),
           so render the bare partial without the infinite-scroll plumbing — and
           do it server-side because the relevance call sourced the data anyway. *@
        @await Html.PartialAsync("_PosterGrid", posterGridModel)
    }
    else
    {
        @* Wrapper carries the bookkeeping the discover-pagination.js needs:
           data-list (slug), data-genre (active filter), data-season (when on
           the Seasonal tab so paginated chunks fetch the same calendar window),
           data-page (last page already rendered — 0 here means the JS owns
           the first fetch). data-needs-initial-load tells the script to do
           an immediate page-1 fetch and replace the skeleton placeholders
           below with the real cards before normal infinite-scroll resumes. *@
        <div class="discover-paginator"
             data-list="@activeSlug"
             data-genre="@Model.Genre"
             data-season="@(isSeasonal ? Model.Season : null)"
             data-tag="@Model.Tag"
             data-page="@(Model.NeedsClientLoad ? 0 : 1)"
             data-needs-initial-load="@(Model.NeedsClientLoad ? "true" : null)">
            @if (Model.NeedsClientLoad)
            {
                @* Skeleton grid — same .library-grid shell + .library-card
                   layout the real cards use, so the row dimensions don't
                   shift when JS swaps the skeletons for real content.
                   Twelve placeholders fill above the fold on any common
                   mobile + desktop viewport. *@
                <div class="library-grid">
                    @for (var i = 0; i < 12; i++)
                    {
                        <div class="library-card library-card-skeleton">
                            <div class="library-card-poster-wrap">
                                <div class="library-card-poster skeleton-shimmer"></div>
                            </div>
                            <span class="library-card-skeleton-line"></span>
                            <span class="library-card-skeleton-line library-card-skeleton-line-short"></span>
                        </div>
                    }
                </div>
            }
            else
            {
                @await Html.PartialAsync("_PosterGrid", posterGridModel)
            }
            @* paginator-loader is hidden by default; discover-pagination.js
               reveals it while the next chunk is in flight. *@
            <div class="paginator-loader" hidden aria-hidden="true">
                <div class="paginator-loader-spinner"></div>
            </div>
            <div class="discover-sentinel" aria-hidden="true"></div>
        </div>
    }
</div>

@section Scripts {
    @* discover-pagination.js binds against any .discover-paginator on the
       page — both the skeleton state (data-needs-initial-load) and the
       normal infinite-scroll state run through the same script. Gate on
       !hasSearch because search results don't have a paginator wrapper
       to bind to. *@
    @if (!hasSearch)
    {
        <script src="~/js/discover-pagination.js" asp-append-version="true" defer></script>
    }
    <script src="~/js/filter-search.js" asp-append-version="true" defer></script>
}
