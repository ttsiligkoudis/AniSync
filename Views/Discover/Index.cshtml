@model AnimeList.Controllers.DiscoverViewModel
@{
    ViewData["BodyClass"] = "library-page";
    ViewData["ActiveNav"] = "discover";

    var labels = new Dictionary<ListType, string>
    {
        [ListType.Trending_Desc] = "Trending",
        [ListType.Seasonal]      = "Seasonal",
        [ListType.Airing]        = "Airing",
    };

    var slugs = new Dictionary<ListType, string>
    {
        [ListType.Trending_Desc] = "trending",
        [ListType.Seasonal]      = "seasonal",
        [ListType.Airing]        = "airing",
    };

    var hasSearch = !string.IsNullOrEmpty(Model.Search);
    var hasGenre = !string.IsNullOrEmpty(Model.Genre);
    var activeLabel = labels[Model.ActiveList];
}

<p class="page-subtitle">
    @if (hasSearch)
    {
        <text>Search results</text>
    }
    else if (hasGenre)
    {
        <text>@Model.Genre anime</text>
    }
    else
    {
        <text>@activeLabel anime</text>
    }
    @if (!Model.AnonymousUser)
    {
        <text>· via @Model.AnimeService</text>
    }
    <span class="library-back">·
        <a href="@Url.Action("Index", "Home")">back to dashboard</a>
    </span>
</p>

@* Same search-form pattern as /library — server-rendered, navigates on submit.
   The genre filter is preserved through search submission via a hidden input
   so the user can search WITHIN a genre. The list tab is dropped because
   search is mutually exclusive with the tab navigation. *@
<form method="get" action="@Url.Action("Index", "Discover")" class="library-search">
    <input type="search"
           name="search"
           value="@Model.Search"
           placeholder="Search anime…"
           class="library-search-input"
           autocomplete="off" />
    @if (hasGenre)
    {
        <input type="hidden" name="genre" value="@Model.Genre" />
    }
    @if (hasSearch)
    {
        <a class="library-search-clear" href="@(hasGenre ? Url.Action("Index", "Discover", new { genre = Model.Genre }) : Url.Action("Index", "Discover"))">Clear</a>
    }
</form>

@* Genre picker — native <select> with a JS-free auto-submit via onchange.
   Hidden during search because search results already span all genres and
   the picker would be confusingly orthogonal there. The current list type
   is preserved across genre changes so the user can browse e.g. "Trending
   Action" or "Seasonal Romance" — the controller passes both ?list= and
   ?genre= through to the per-service catalog query. *@
@if (!hasSearch)
{
    <form method="get" action="@Url.Action("Index", "Discover")" class="genre-picker">
        <input type="hidden" name="list" value="@slugs[Model.ActiveList]" />
        <select name="genre" onchange="this.form.submit()" class="genre-picker-select" aria-label="Genre">
            <option value="">All genres</option>
            @foreach (var g in Model.AvailableGenres)
            {
                <option value="@g" selected="@(Model.Genre == g)">@g</option>
            }
        </select>
        @if (hasGenre)
        {
            <a class="library-search-clear"
               href="@Url.Action("Index", "Discover", new { list = slugs[Model.ActiveList] })">Clear genre</a>
        }
    </form>
}

@if (!hasSearch)
{
    <nav class="library-tabs" role="tablist">
        @foreach (var t in Model.Tabs)
        {
            var isActive = t == Model.ActiveList;
            // Preserve the active genre across tab clicks so switching from
            // Trending → Seasonal keeps the genre filter applied rather than
            // dropping back to all genres.
            var tabRouteValues = hasGenre
                ? (object)new { list = slugs[t], genre = Model.Genre }
                : new { list = slugs[t] };
            <a class="library-tab @(isActive ? "library-tab-active" : "")"
               href="@Url.Action("Index", "Discover", tabRouteValues)"
               role="tab"
               aria-selected="@(isActive ? "true" : "false")">
                @labels[t]
            </a>
        }
    </nav>
}

@await Html.PartialAsync("_PosterGrid", new AnimeList.Models.PosterGridViewModel
{
    Items = Model.Items,
    ConfigUid = Model.ConfigUid,
    EmptyMessage = hasSearch
        ? $"No matches for \"{Model.Search}\"."
        : hasGenre
            ? $"No {Model.Genre.ToLower()} anime in {activeLabel.ToLower()} right now."
            : $"Couldn't load {activeLabel.ToLower()} anime — try again later.",
})
