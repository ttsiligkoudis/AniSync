<?xml version="1.0" encoding="utf-8"?>
<!--
  Scoped NuGet config for the AniSync MAUI/Web solution. The machine-wide config
  includes a private, auth-gated Azure DevOps feed (Classter.Repos) that 401s on
  public Microsoft.WindowsAppSDK.* / Windows SDK packages the MAUI head needs.
  Clearing inherited sources and using only nuget.org keeps this solution
  buildable without corporate credentials and independent of the parent repo.
-->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
