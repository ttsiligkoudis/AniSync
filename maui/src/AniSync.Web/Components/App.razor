<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <meta name="theme-color" content="#0b0d12" />
    <ResourcePreloader />
    <!-- Shared design system (verbatim site.css) from the AniSync.Client RCL. -->
    <link rel="stylesheet" href="_content/AniSync.Client/css/site.css" />
    <link rel="stylesheet" href="AniSync.Web.styles.css" />
    <ImportMap />
    <link rel="icon" href="_content/AniSync.Client/favicon.ico" />
    <!-- PWA: installable Web head (manifest + icons + conservative service worker). -->
    <link rel="manifest" href="manifest.webmanifest" />
    <link rel="apple-touch-icon" href="icons/icon-192.png" />
    <HeadOutlet @rendermode="InteractiveServer" />
</head>

<body>
    <Routes @rendermode="InteractiveServer" />
    <ReconnectModal />
    <script src="@Assets["_framework/blazor.web.js"]"></script>
    <!-- Shared shell behaviour (theme toggle, back button, mobile "More" sheet). -->
    <script src="_content/AniSync.Client/js/chrome.js"></script>
    <!-- Web-head HTML5 <video> driver (resume / progress / ended interop). -->
    <script src="js/watch-player.js"></script>
    <!-- Web Push opt-in interop (subscribe / unsubscribe). -->
    <script src="js/push.js"></script>
    <script>
        // Register the PWA service worker (network-first; safe across deploys).
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', function () {
                navigator.serviceWorker.register('/service-worker.js').catch(function () { /* ignore */ });
            });
        }
    </script>
</body>

</html>
