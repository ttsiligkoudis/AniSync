<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <meta name="theme-color" content="#0b0d12" />
    <!-- Stamp the saved theme on <html> before first paint so the page doesn't flash dark before
         MainLayout re-applies it once interactive. The theme preference lives in the settings store
         (ISecureStore), which on the web head is localStorage under "pref:theme". "system"/absent →
         leave it to prefers-color-scheme. -->
    <script>
        (function () {
            try {
                var t = localStorage.getItem('pref:theme');
                if (t === 'light' || t === 'dark') document.documentElement.setAttribute('data-theme', t);
            } catch (e) { /* storage blocked — CSS prefers-color-scheme decides */ }
        })();
    </script>
    <ResourcePreloader />
    @* Static assets go through @Assets[...] so MapStaticAssets serves them fingerprinted
       (Cache-Control: immutable, 1yr → "Add Expires headers") AND content-negotiated
       brotli/gzip ("Compress with gzip"). site.min.css is the rcssmin-minified build of
       site.css (the RCL source; MAUI keeps the unminified one). *@
    <link rel="stylesheet" href="@Assets["_content/AniSync.Client/css/site.min.css"]" />
    <link rel="stylesheet" href="@Assets["AniSync.Web.styles.css"]" />
    <ImportMap />
    <link rel="icon" href="@Assets["_content/AniSync.Client/favicon.ico"]" />
    <!-- PWA: installable Web head (manifest + icons + conservative service worker).
         manifest stays at a stable (unfingerprinted) URL so its scope is fixed. -->
    <link rel="manifest" href="manifest.webmanifest" />
    <link rel="apple-touch-icon" href="@Assets["icons/icon-192.png"]" />
    <HeadOutlet @rendermode="InteractiveServer" />
</head>

<body>
    <Routes @rendermode="InteractiveServer" />
    <ReconnectModal />
    <script src="@Assets["_framework/blazor.web.js"]"></script>
    <!-- Shared shell behaviour (theme apply hook, back button, mobile "More" sheet). -->
    <script src="@Assets["_content/AniSync.Client/js/chrome.js"]"></script>
    <!-- D-pad / remote spatial navigation for TV browsers (Android TV / Google TV / webOS / Tizen). Self-
         detects TV mode and no-ops on phone + desktop. -->
    <script src="@Assets["_content/AniSync.Client/js/tv-navigation.js"]"></script>
    <!-- ArtPlayer (large, third-party) + the 66 KB watch-player.js driver are NOT
         loaded here: they're only needed on /watch, so loading them on every page
         was dead weight + a render-blocking script + an extra third-party request.
         Html5MediaPlayer now injects both on the first source play via
         js/watch-loader.js (watch-player.js's play() already polls for window.Artplayer). -->
    <!-- Web Push opt-in interop (subscribe / unsubscribe). -->
    <script src="@Assets["js/push.js"]" defer></script>
    <script>
        // Register the PWA service worker (network-first; safe across deploys).
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', function () {
                navigator.serviceWorker.register('/service-worker.js').catch(function () { /* ignore */ });
            });
        }
    </script>
</body>

</html>
