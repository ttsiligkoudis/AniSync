<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Theme-aware window background so the launch + resume window-animation frame matches the system
         theme instead of flashing white in dark mode. The activity keeps this theme throughout (MAUI
         doesn't switch to a separate post-splash theme), so overriding android:windowBackground here covers
         both launch and resume. With the splash Color transparent, the splash background also falls back to
         this, giving a theme-following splash. -->
    <style name="AniSync.SplashTheme" parent="Maui.SplashTheme">
        <item name="android:windowBackground">@color/window_background</item>
    </style>

    <!-- Theme overlay applied (via ContextThemeWrapper) to the ExoPlayer PlayerView's context. It only
         redirects the selectable-item backgrounds to a focus-highlight drawable; with an empty parent it layers
         these overrides on top of the base context theme. This is what makes D-pad focus visible inside the
         gear/CC pop-up menus (speed/audio/subtitle lists), whose items inflate from this themed context. -->
    <style name="AniSync.ExoPlayerOverlay" parent="">
        <item name="android:selectableItemBackground">@drawable/tv_focus_selectable</item>
        <item name="android:selectableItemBackgroundBorderless">@drawable/tv_focus_selectable</item>
        <item name="selectableItemBackground">@drawable/tv_focus_selectable</item>
        <item name="selectableItemBackgroundBorderless">@drawable/tv_focus_selectable</item>
    </style>
</resources>
