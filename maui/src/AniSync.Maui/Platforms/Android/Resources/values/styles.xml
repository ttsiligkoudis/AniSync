<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Theme-aware splash: inherits MAUI's generated splash theme (so the logo + Android-12 splash
         animation are kept verbatim) and only swaps the background to a night-qualified color, so the
         native splash follows the system light/dark instead of a fixed dark. windowSplashScreenBackground
         is the Android 12+ (API 31) splash attribute; older devices keep the parent's background. The
         native splash can only follow the SYSTEM theme (it shows before any app code), which is what the
         app's default prefers-color-scheme follows too. -->
    <style name="AniSync.SplashTheme" parent="Maui.SplashTheme">
        <item name="android:windowSplashScreenBackground" tools:targetApi="31">@color/splash_background</item>
    </style>
</resources>
