@implements IAsyncDisposable
@inject AppState State
@inject IJSRuntime JS

@* One dashboard shelf — port of the .dashboard-section [data-shelf] blocks in
   Index.cshtml. Async-loads its first page via Fetch(null), shows skeleton cards
   while loading, renders the scroll-row PosterGrid when they arrive, and hides
   itself entirely when empty. A shelf is also hidden when the dashboard media-type
   filter excludes it.

   When Paginated, scrolling to the end of the row pulls the next page (Fetch(skip))
   and appends it — the same IntersectionObserver bridge the Discover grid uses, just
   sitting at the horizontal end of the shelf. Only the first page is ever cached
   server-side (Fetch(null)); later pages carry a skip offset and aren't cached. *@

@if (_visible)
{
    <section class="dashboard-section" data-dash-section="@DashSection" data-media-type="@MediaType" style="order:@Order">
        <div class="dashboard-section-header">
            <h2 class="dashboard-section-title">@Title</h2>
            @if (!string.IsNullOrEmpty(ViewAllHref))
            {
                <a class="dashboard-section-link" href="@ViewAllHref">
                    <span>View all</span>
                    <svg class="dashboard-section-link-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <line x1="5" y1="12" x2="19" y2="12"></line>
                        <polyline points="12 5 19 12 12 19"></polyline>
                    </svg>
                </a>
            }
            else if (!string.IsNullOrEmpty(MutedNote))
            {
                <span class="dashboard-section-link-muted">@MutedNote</span>
            }
        </div>
        <div data-shelf-container>
            @if (_loading)
            {
                <div class="poster-scroll-row">
                    @for (var i = 0; i < SkeletonCount; i++)
                    {
                        <div class="library-card library-card-skeleton">
                            <div class="library-card-poster-wrap">
                                <div class="library-card-poster skeleton-shimmer"></div>
                            </div>
                            <span class="library-card-skeleton-line"></span>
                            <span class="library-card-skeleton-line library-card-skeleton-line-short"></span>
                        </div>
                    }
                </div>
            }
            else
            {
                <PosterGrid Items="_items" Variant="scroll" VideoLinks="VideoLinks">
                    @if (Paginated && !_done)
                    {
                        <Trailing>
                            @if (_loadingMore)
                            {
                                <div class="shelf-loader" aria-hidden="true"><div class="paginator-loader-spinner"></div></div>
                            }
                            <div class="shelf-sentinel" @ref="_sentinel" aria-hidden="true"></div>
                        </Trailing>
                    }
                </PosterGrid>
            }
        </div>
    </section>
}

@code {
    [Parameter, EditorRequired] public string Title { get; set; } = "";
    [Parameter, EditorRequired] public string MediaType { get; set; } = "anime";
    [Parameter, EditorRequired] public string DashSection { get; set; } = "";
    // Fetch a page: the argument is the skip offset (null = first page). Non-paginated
    // shelves can ignore it — set Paginated=false so a second page is never requested.
    [Parameter, EditorRequired] public Func<string?, Task<IReadOnlyList<MetaDto>>> Fetch { get; set; } = default!;
    [Parameter] public string? ViewAllHref { get; set; }
    [Parameter] public string? MutedNote { get; set; }
    [Parameter] public bool VideoLinks { get; set; }
    // True for the discover-backed shelves (trending/popular/anticipated) whose endpoints
    // take a skip offset. Continue-watching / airing-today / video-list are single-shot.
    [Parameter] public bool Paginated { get; set; }
    // Skeleton placeholder count: discovery shelves fill the full scroll row (12);
    // Continue watching uses 6.
    [Parameter] public int SkeletonCount { get; set; } = 12;

    // CSS flex `order` + hidden state read from the saved layout (AppState.DashLayout).
    private int Order
    {
        get { var l = State.DashLayout; for (var i = 0; i < l.Count; i++) if (l[i].Key == DashSection) return i; return 999; }
    }
    private bool LayoutHidden => State.DashLayout.FirstOrDefault(e => e.Key == DashSection) is { Visible: false };

    private bool _loading = true;
    private bool _loadingMore;
    private bool _done;
    private readonly List<MetaDto> _items = new();
    private readonly HashSet<string> _seenIds = new(StringComparer.Ordinal);

    // Infinite-scroll interop (only wired when Paginated) — mirrors the Discover page.
    private ElementReference _sentinel;
    private IJSObjectReference? _scroll;
    private DotNetObjectReference<DashboardShelf>? _selfRef;
    private int _observerId;

    private bool _visible => PassesFilter && !LayoutHidden && (_loading || _items.Count > 0);

    private bool PassesFilter
        => State.DashboardFilter is "all" || State.DashboardFilter == MediaType
           || MediaType.Split(' ').Contains(State.DashboardFilter);

    protected override void OnInitialized() => State.Changed += OnFilterChanged;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var first = await Fetch(null);
            Append(first);
            // Non-paginated shelves (and an empty first page) have nothing more to pull.
            if (!Paginated || first.Count == 0) _done = true;
        }
        finally { _loading = false; }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!Paginated) return;
        if (firstRender)
        {
            _selfRef = DotNetObjectReference.Create(this);
            try { _scroll = await JS.InvokeAsync<IJSObjectReference>("import", "./_content/AniSync.Client/js/discover-scroll.js"); }
            catch { return; }
        }
        if (_scroll is null) return;

        // The sentinel only exists while the row is rendered with more pages to come.
        var sentinelRendered = !_loading && !_done && _items.Count > 0;
        if (sentinelRendered && _observerId == 0)
        {
            try { _observerId = await _scroll.InvokeAsync<int>("observe", _sentinel, _selfRef); } catch { }
        }
        else if (!sentinelRendered && _observerId != 0)
        {
            try { await _scroll.InvokeVoidAsync("disconnect", _observerId); } catch { }
            _observerId = 0;
        }
    }

    [JSInvokable]
    public async Task OnSentinelVisibleAsync()
    {
        if (!Paginated || _done || _loadingMore) return;
        _loadingMore = true;
        StateHasChanged();

        IReadOnlyList<MetaDto> page;
        try { page = await Fetch(_items.Count.ToString()); }
        catch { page = Array.Empty<MetaDto>(); }

        // Dedupe by id — a provider that ignores skip would otherwise repeat a page.
        var added = Append(page);
        if (added == 0) _done = true;

        _loadingMore = false;
        StateHasChanged();

        // Re-arm so a short page that left the sentinel in view keeps pulling.
        if (_observerId != 0 && !_done && _scroll is not null)
        {
            try { await _scroll.InvokeVoidAsync("reobserve", _observerId); } catch { }
        }
    }

    private int Append(IReadOnlyList<MetaDto> page)
    {
        var added = 0;
        foreach (var m in page)
        {
            if (string.IsNullOrEmpty(m.Id) || _seenIds.Add(m.Id)) { _items.Add(m); added++; }
        }
        return added;
    }

    private void OnFilterChanged() => StateHasChanged();

    public async ValueTask DisposeAsync()
    {
        State.Changed -= OnFilterChanged;
        if (_scroll is not null)
        {
            if (_observerId != 0) { try { await _scroll.InvokeVoidAsync("disconnect", _observerId); } catch { } }
            try { await _scroll.DisposeAsync(); } catch { }
        }
        _selfRef?.Dispose();
    }
}
