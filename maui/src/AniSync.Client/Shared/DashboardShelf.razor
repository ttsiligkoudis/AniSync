@implements IAsyncDisposable
@inject AppState State
@inject IJSRuntime JS
@inject IClientCache Cache

@* One dashboard shelf — port of the .dashboard-section [data-shelf] blocks in
   Index.cshtml. Async-loads its first page via Fetch(null), shows skeleton cards
   while loading, renders the scroll-row PosterGrid when they arrive, and hides
   itself entirely when empty. A shelf is also hidden when the dashboard media-type
   filter excludes it.

   When Paginated, scrolling to the end of the row pulls the next page (Fetch(skip))
   and appends it — the same IntersectionObserver bridge the Discover grid uses, just
   sitting at the horizontal end of the shelf. Only the first page is ever cached
   server-side (Fetch(null)); later pages carry a skip offset and aren't cached. *@

@if (_visible)
{
    <section class="dashboard-section @(_loading && !_started ? "is-deferred" : "")" @ref="_section" data-dash-section="@DashSection" data-media-type="@MediaType" style="order:@Order">
        <div class="dashboard-section-header">
            <h2 class="dashboard-section-title">@Title</h2>
            @if (!string.IsNullOrEmpty(ViewAllHref))
            {
                <a class="dashboard-section-link" href="@ViewAllHref">
                    <span>View all</span>
                    <svg class="dashboard-section-link-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <line x1="5" y1="12" x2="19" y2="12"></line>
                        <polyline points="12 5 19 12 12 19"></polyline>
                    </svg>
                </a>
            }
            else if (!string.IsNullOrEmpty(MutedNote))
            {
                <span class="dashboard-section-link-muted">@MutedNote</span>
            }
        </div>
        <div data-shelf-container>
            @if (_loading)
            {
                <div class="poster-scroll-row">
                    @for (var i = 0; i < SkeletonCount; i++)
                    {
                        <div class="library-card library-card-skeleton">
                            <div class="library-card-poster-wrap">
                                <div class="library-card-poster skeleton-shimmer"></div>
                            </div>
                            <span class="library-card-skeleton-line"></span>
                            <span class="library-card-skeleton-line library-card-skeleton-line-short"></span>
                        </div>
                    }
                </div>
            }
            else
            {
                <PosterGrid Items="_items" Variant="scroll" VideoLinks="VideoLinks">
                    @* Trailing must be the ONLY child of PosterGrid (it has no ChildContent slot),
                       so the condition lives INSIDE the slot rather than wrapping it. *@
                    <Trailing>
                        @if (Paginated && !_done)
                        {
                            @if (_loadingMore)
                            {
                                @* One shimmering skeleton card at the row's end while the next page
                                   loads — same look as the initial-load placeholders, nicer than a
                                   spinner. (Discover keeps its inline spinner.) *@
                                <div class="library-card library-card-skeleton" aria-hidden="true">
                                    <div class="library-card-poster-wrap">
                                        <div class="library-card-poster skeleton-shimmer"></div>
                                    </div>
                                    <span class="library-card-skeleton-line"></span>
                                    <span class="library-card-skeleton-line library-card-skeleton-line-short"></span>
                                </div>
                            }
                            <div class="shelf-sentinel" @ref="_sentinel" aria-hidden="true"></div>
                        }
                    </Trailing>
                </PosterGrid>
            }
        </div>
    </section>
}

@code {
    [Parameter, EditorRequired] public string Title { get; set; } = "";
    [Parameter, EditorRequired] public string MediaType { get; set; } = "anime";
    [Parameter, EditorRequired] public string DashSection { get; set; } = "";
    // Fetch a page: the argument is the skip offset (null = first page). Non-paginated
    // shelves can ignore it — set Paginated=false so a second page is never requested.
    [Parameter, EditorRequired] public Func<string?, Task<IReadOnlyList<MetaDto>>> Fetch { get; set; } = default!;
    [Parameter] public string? ViewAllHref { get; set; }
    [Parameter] public string? MutedNote { get; set; }
    [Parameter] public bool VideoLinks { get; set; }
    // True for the discover-backed shelves (trending/popular/anticipated) whose endpoints
    // take a skip offset. Continue-watching / airing-today / video-list are single-shot.
    [Parameter] public bool Paginated { get; set; }
    // Skeleton placeholder count: discovery shelves fill the full scroll row (12);
    // Continue watching uses 6.
    [Parameter] public int SkeletonCount { get; set; } = 12;

    // Client-cache key + TTL for the first page. Set together (e.g. "shelf.anime-trending" + 24h) to
    // serve this shelf instantly from the two-tier cache on revisit / restart; leave null to never
    // persist (user-scoped shelves like continue-watching, which change as you watch). Only the FIRST
    // page is cached — later pages carry a skip offset and stay live, matching the server.
    [Parameter] public string? CacheKey { get; set; }
    [Parameter] public TimeSpan? CacheTtl { get; set; }

    // When true, the cached first page is rendered instantly and then ALWAYS refetched in the
    // background (not only when past TTL) — for user-scoped lists like Continue watching, where the
    // cache is just a paint-instantly seed and the live list is authoritative. An empty refetch is
    // then taken at face value (you finished everything → the shelf clears and self-hides), whereas a
    // plain cached shelf treats an empty refetch as a blip and keeps the stale rows.
    [Parameter] public bool AlwaysRevalidate { get; set; }

    // CSS flex `order` + hidden state read from the saved layout (AppState.DashLayout).
    private int Order
    {
        get { var l = State.DashLayout; for (var i = 0; i < l.Count; i++) if (l[i].Key == DashSection) return i; return 999; }
    }
    private bool LayoutHidden => State.DashLayout.FirstOrDefault(e => e.Key == DashSection) is { Visible: false };

    private bool _loading = true;
    private bool _loadingMore;
    private bool _done;
    // _fetched: the first page has been resolved (from cache or a fetch) — guards against a double
    // load. _started: the real fetch has begun (drives the shimmer; a cache hit never sets it).
    // _needsRefresh: a stale entry was rendered instantly; a silent background refetch is pending
    // (deferred until the shelf is on-screen so a TV doesn't refresh every stale shelf at once).
    // _firstPageCount: size of the rendered first page, to skip the refresh-swap if the user has
    // already paginated past it.
    private bool _fetched;
    private bool _started;
    private bool _needsRefresh;
    private int _firstPageCount;
    private readonly List<MetaDto> _items = new();
    private readonly HashSet<string> _seenIds = new(StringComparer.Ordinal);

    // Infinite-scroll interop (only wired when Paginated) — mirrors the Discover page.
    private ElementReference _sentinel;
    private IJSObjectReference? _scroll;
    private DotNetObjectReference<DashboardShelf>? _selfRef;
    private int _observerId;

    // Vertical lazy-load: the shelf's own <section>, observed until its first page is fetched so a
    // cache-miss shelf below the fold defers its request (and its shimmer) until it scrolls in.
    private ElementReference _section;
    private int _visId;

    private bool _visible => PassesFilter && !LayoutHidden && (_loading || _items.Count > 0);

    private bool PassesFilter
        => State.DashboardFilter is "all" || State.DashboardFilter == MediaType
           || MediaType.Split(' ').Contains(State.DashboardFilter);

    protected override void OnInitialized() => State.Changed += OnFilterChanged;

    protected override async Task OnInitializedAsync()
    {
        // Cached entry (any age) → paint instantly from the first page, no skeleton. Then refetch in
        // the background once the shelf is on-screen — for AlwaysRevalidate (user lists) every time,
        // otherwise only when the entry is past TTL (stale-while-revalidate). Only the first page is
        // cached; pagination stays live, so a paginated shelf isn't marked _done.
        if (CacheTtl is { } ttl && !string.IsNullOrEmpty(CacheKey))
        {
            var (found, stale, cached) = await Cache.ReadAsync<List<MetaDto>>(CacheKey, ttl);
            if (found && cached is { Count: > 0 })
            {
                Append(cached);
                _firstPageCount = _items.Count;
                _fetched = true;
                _needsRefresh = stale || AlwaysRevalidate;
                if (!Paginated) _done = true;
                _loading = false;
                return;
            }
        }
        // True miss → defer: stay in the (static) skeleton state; EnsureFetchedAsync fires the request
        // once the shelf scrolls into view (OnShelfVisibleAsync). Above-the-fold shelves trigger
        // almost immediately, so there's no perceptible delay for what's actually on screen.
    }

    // Resolve the first page on demand — invoked once, when the shelf scrolls into view (or right away
    // for a miss that's already on-screen). Shows the shimmer while the fetch is in flight.
    private async Task EnsureFetchedAsync()
    {
        if (_fetched) return;
        _fetched = true;
        _started = true;   // shimmer the skeleton now that a real fetch is in flight
        StateHasChanged();
        try
        {
            var first = await Fetch(null);
            Append(first);
            _firstPageCount = _items.Count;
            if (!Paginated || first.Count == 0) _done = true;
            // Persist the first page (only) for instant revisits — skip empty/uncacheable shelves.
            if (first.Count > 0 && CacheTtl is not null && !string.IsNullOrEmpty(CacheKey))
                await Cache.SetAsync(CacheKey, _items.ToList());
        }
        finally { _loading = false; StateHasChanged(); }
    }

    // Revalidate: a first page is already on screen (from a stale or AlwaysRevalidate cache entry) —
    // quietly refetch it, swap it in, and re-prime the cache. Runs only once the shelf is on-screen.
    private async Task RefreshStaleAsync()
    {
        IReadOnlyList<MetaDto> fresh;
        try { fresh = await Fetch(null); }
        catch { return; }                 // network hiccup → keep showing what's already there

        // Don't disturb a shelf the user has paginated past — swapping mid-scroll would yank loaded
        // rows out from under them. The cache is still re-primed/dropped so the next visit is correct.
        var canSwap = !_loadingMore && _items.Count == _firstPageCount;

        if (fresh.Count == 0)
        {
            // A discover shelf shouldn't legitimately empty out, so treat an empty refetch as a blip and
            // keep the stale rows. A user list (AlwaysRevalidate) genuinely empties when you finish
            // everything → drop the cache and clear the rows so the shelf self-hides.
            if (!AlwaysRevalidate) return;
            if (!string.IsNullOrEmpty(CacheKey)) await Cache.RemoveAsync(CacheKey);
            if (canSwap) { _items.Clear(); _seenIds.Clear(); _firstPageCount = 0; StateHasChanged(); }
            return;
        }

        if (!string.IsNullOrEmpty(CacheKey)) await Cache.SetAsync(CacheKey, fresh.ToList());
        if (!canSwap) return;
        _items.Clear();
        _seenIds.Clear();
        Append(fresh);
        _firstPageCount = _items.Count;
        StateHasChanged();
    }

    [JSInvokable]
    public async Task OnShelfVisibleAsync()
    {
        if (!_fetched) await EnsureFetchedAsync();
        else if (_needsRefresh) { _needsRefresh = false; await RefreshStaleAsync(); }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // The JS module backs both observers: the vertical trigger (the first-page fetch on a miss,
        // or the silent stale refresh) and, for paginated shelves, the horizontal end-of-row pager. A
        // fresh cached, non-paginated shelf needs neither, so it never imports the module.
        var needsModule = !_fetched || _needsRefresh || Paginated;
        if (firstRender && needsModule)
        {
            _selfRef ??= DotNetObjectReference.Create(this);
            try { _scroll = await JS.InvokeAsync<IJSObjectReference>("import", "./_content/AniSync.Client/js/shelf-scroll.js"); }
            catch { return; }
        }
        if (_scroll is null) return;

        // Vertical observer: attach while the shelf still has work to do on scroll-in — fetch its first
        // page (miss) or run the silent stale refresh — and its section is on the page. Drops once the
        // work is done (or when the filter tears the section out of the DOM).
        var awaitingWork = _visible && (!_fetched || _needsRefresh);
        if (awaitingWork && _visId == 0)
        {
            try { _visId = await _scroll.InvokeAsync<int>("observeVisible", _section, _selfRef); } catch { }
        }
        else if (!awaitingWork && _visId != 0)
        {
            try { await _scroll.InvokeVoidAsync("disconnectVisible", _visId); } catch { }
            _visId = 0;
        }

        if (!Paginated) return;

        // The sentinel only exists while the row is rendered with more pages to come.
        // Include _visible: when the media-type filter hides this shelf the row (and sentinel)
        // is torn out of the DOM, so the listener must drop and re-attach to the fresh row when
        // the shelf comes back — otherwise it's left bound to a destroyed element.
        var sentinelRendered = _visible && !_loading && !_done && _items.Count > 0;
        if (sentinelRendered && _observerId == 0)
        {
            try { _observerId = await _scroll.InvokeAsync<int>("observe", _sentinel, _selfRef); } catch { }
        }
        else if (!sentinelRendered && _observerId != 0)
        {
            try { await _scroll.InvokeVoidAsync("disconnect", _observerId); } catch { }
            _observerId = 0;
        }
    }

    [JSInvokable]
    public async Task OnSentinelVisibleAsync()
    {
        if (!Paginated || _done || _loadingMore) return;
        _loadingMore = true;
        StateHasChanged();

        IReadOnlyList<MetaDto> page;
        try { page = await Fetch(_items.Count.ToString()); }
        catch { page = Array.Empty<MetaDto>(); }

        // Dedupe by id — a provider that ignores skip would otherwise repeat a page.
        var added = Append(page);
        if (added == 0) _done = true;

        _loadingMore = false;
        StateHasChanged();

        // After the new cards render, keep pulling if the row still isn't scrolled-full
        // (short page / row not yet overflowing); otherwise this re-arms the scroll trigger.
        if (_observerId != 0 && !_done && _scroll is not null)
        {
            try { await _scroll.InvokeVoidAsync("recheck", _observerId); } catch { }
        }
    }

    private int Append(IReadOnlyList<MetaDto> page)
    {
        var added = 0;
        foreach (var m in page)
        {
            if (string.IsNullOrEmpty(m.Id) || _seenIds.Add(m.Id)) { _items.Add(m); added++; }
        }
        return added;
    }

    private void OnFilterChanged() => StateHasChanged();

    public async ValueTask DisposeAsync()
    {
        State.Changed -= OnFilterChanged;
        if (_scroll is not null)
        {
            if (_observerId != 0) { try { await _scroll.InvokeVoidAsync("disconnect", _observerId); } catch { } }
            if (_visId != 0) { try { await _scroll.InvokeVoidAsync("disconnectVisible", _visId); } catch { } }
            try { await _scroll.DisposeAsync(); } catch { }
        }
        _selfRef?.Dispose();
    }
}
