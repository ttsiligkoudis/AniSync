@inject IAniSyncApi Api
@inject NavigationManager Nav

@* Account card — Blazor port of _AccountSection.cshtml (the "Account" card only;
   linked accounts live in LinkedAccountsSection). Renders the service-toggle pills
   and, when logged in, the connected / disconnect badge.

   Pre-login the picker shows the available providers (selectable — clicking sets the
   page's selected service, which drives the login form below). Post-login it shrinks
   to "primary (active) + each healthy linked account"; clicking a non-active pill
   promotes that account to primary via Api.PromotePrimaryAsync (the framework
   adaptation of the original's POST /Auth/SetPrimary), then reloads. The service-
   toggle-hint shows when there's at least one healthy linked account to swap to. *@

<section class="section-card">
    <span class="section-title">Account</span>

    @if (HasSwappableLinks)
    {
        <p class="service-toggle-hint">Tap another account below to make it your primary.</p>
    }

    <div class="service-toggle" id="serviceToggle">
        @foreach (var pill in Pills)
        {
            <span class="label @(pill.Active ? "active" : "")" id="@pill.Id" data-service="@pill.DataService" data-service-name="@pill.DataName"
                  role="button" tabindex="0"
                  @onclick="() => OnPillAsync(pill)"
                  @onkeydown="@(e => { if (e.Key is "Enter" or " ") _ = OnPillAsync(pill); })">@pill.Display</span>
        }
    </div>

    @if (Config is not null)
    {
        <div class="account-status">
            <span class="success-badge">✓ Connected to @Pretty(Config.AnimeService)</span>
            <button id="disconnectBtn" type="button" class="account-disconnect-btn" data-disconnect @onclick="Disconnect">Disconnect</button>
        </div>
        @if (!string.IsNullOrEmpty(_message))
        {
            <p class="account-status">@_message</p>
        }
    }
</section>

@code {
    [Parameter] public ConfigStateDto? Config { get; set; }
    [Parameter] public EventCallback OnReload { get; set; }

    // Pre-login surface: the providers the backend can start sign-in for, and the
    // currently selected one (two-way bound to the page so the login form follows).
    [Parameter] public List<(string Key, string Display)> Available { get; set; } = new();
    [Parameter] public string SelectedService { get; set; } = "Kitsu";
    [Parameter] public EventCallback<string> SelectedServiceChanged { get; set; }

    private string? _busy;
    private string? _message;

    private bool LoggedIn => Config is not null;

    // Post-login: at least one healthy (not needs-reauth) linked account to swap to.
    private bool HasSwappableLinks =>
        LoggedIn && Config!.Linked.Any(l => !l.NeedsReauth);

    private sealed record Pill(string Id, int DataService, string DataName, string Display, bool Active);

    private List<Pill> Pills
    {
        get
        {
            var list = new List<Pill>();
            if (LoggedIn)
            {
                // Primary (active) + each healthy linked account.
                AddPill(list, Config!.AnimeService, active: true);
                foreach (var l in Config!.Linked.Where(l => !l.NeedsReauth))
                {
                    if (string.Equals(l.Service, Config!.AnimeService, StringComparison.OrdinalIgnoreCase)) continue;
                    AddPill(list, l.Service, active: false);
                }
            }
            else
            {
                foreach (var p in Available)
                {
                    AddPill(list, p.Key, active: string.Equals(p.Key, SelectedService, StringComparison.OrdinalIgnoreCase), p.Display);
                }
            }
            return list;
        }
    }

    private static void AddPill(List<Pill> list, string? service, bool active, string? display = null)
    {
        var (id, idx, name, def) = Meta(service);
        if (id is null) return;
        list.Add(new Pill(id, idx, name!, display ?? def!, active));
    }

    // Maps a service to the exact pill ids / data attributes the original renders.
    private static (string? Id, int Index, string? DataName, string? Display) Meta(string? service) => service switch
    {
        "Kitsu" => ("labelKitsu", 0, "Kitsu", "Kitsu"),
        "Anilist" => ("labelAnilist", 1, "Anilist", "AniList"),
        "MyAnimeList" => ("labelMal", 2, "MyAnimeList", "MyAnimeList"),
        "Trakt" => ("labelTrakt", 3, "Trakt", "Trakt"),
        _ => (null, 0, null, null),
    };

    private async Task OnPillAsync(Pill pill)
    {
        if (LoggedIn)
        {
            // Active pill = current primary, no-op. Any other rendered pill is a
            // healthy linked account — promote it to primary.
            if (pill.Active) return;
            await PromoteAsync(pill.DataName);
        }
        else
        {
            SelectedService = pill.DataName;
            await SelectedServiceChanged.InvokeAsync(pill.DataName);
        }
    }

    private async Task PromoteAsync(string service, bool force = false)
    {
        _busy = service; _message = null;
        var result = await Api.PromotePrimaryAsync(service, force);
        if (result is { Ok: true })
        {
            _message = $"{Pretty(service)} is now your primary account.";
            await OnReload.InvokeAsync();
        }
        else if (result?.Reason == "collision" && !force)
        {
            _message = "Switching anyway — this may overwrite differing entries.";
            await PromoteAsync(service, force: true);
            return;
        }
        else
        {
            _message = result?.Reason switch
            {
                "needs-reauth" => $"{Pretty(service)} needs re-authentication first.",
                "not-linked" => $"{Pretty(service)} isn't linked.",
                _ => "Couldn't switch primary account right now.",
            };
        }
        _busy = null;
    }

    // Disconnect — the original's #disconnectBtn navigates to /Auth/Logout; the
    // replica routes through /logout, which performs the disconnect on both heads.
    private void Disconnect() => Nav.NavigateTo("/logout");

    private static string Pretty(string? service) => service switch
    {
        "Anilist" => "AniList",
        "MyAnimeList" => "MyAnimeList",
        null or "" => "—",
        _ => service,
    };
}
