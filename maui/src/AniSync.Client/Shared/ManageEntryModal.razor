@inject IAniSyncApi Api

@* Manage-entry dialog — the Blazor equivalent of the server-rendered ManageEntry
   modal, driven by the clean JSON API (/api/v1/me/entries/{id}). Status options
   are the canonical ListStatus names the POST expects; the loaded entry's
   service-specific status is normalised onto them. Supports progress, score,
   rewatch count, start/finish dates, notes, and removal (DELETE). Reuses the
   entry-modal-* classes from site.css. *@

@if (Visible)
{
    <div class="entry-modal-backdrop" @onclick="Close"></div>
    <div class="entry-modal" role="dialog" aria-modal="true" aria-labelledby="entry-modal-title" @onclick:stopPropagation>
        <header class="entry-modal-header">
            <h3 class="entry-modal-title" id="entry-modal-title">@Name</h3>
            <button type="button" class="entry-modal-close" aria-label="Close" @onclick="Close">×</button>
        </header>
        <div class="entry-modal-body">
            @if (_loading)
            {
                <div class="entry-modal-loading">
                    <div class="entry-modal-skeleton-field"></div>
                    <div class="entry-modal-skeleton-field entry-modal-skeleton-field-wide"></div>
                </div>
            }
            else
            {
                <form class="entry-modal-form" @onsubmit="Save" @onsubmit:preventDefault>
                    @* Season selector — only for franchises split across multiple service
                       entries (a cross-service id mapped to ≥ 2 cours). Picking a cour
                       refetches that mapping's saved entry and rebinds the form. Mirrors
                       the MVC ManageEntry #seasonSelect. *@
                    @if (_seasons.Count > 1)
                    {
                        <div class="entry-modal-field">
                            <label class="entry-modal-label" for="entry-modal-season">Season</label>
                            <select id="entry-modal-season" class="entry-modal-select"
                                    value="@_selectedEntryId" @onchange="OnSeasonChanged">
                                @foreach (var s in _seasons)
                                {
                                    <option value="@s.Id">@s.Label</option>
                                }
                            </select>
                        </div>
                    }
                    <div class="entry-modal-field">
                        <label class="entry-modal-label" for="entry-modal-status">Status</label>
                        <select id="entry-modal-status" class="entry-modal-select" @bind="_status">
                            <option value="">— Not in list —</option>
                            <option value="Watching">Watching</option>
                            <option value="Completed">Completed</option>
                            <option value="Planning">Planning</option>
                            <option value="Paused">Paused</option>
                            <option value="Dropped">Dropped</option>
                            <option value="Rewatching">Rewatching</option>
                        </select>
                    </div>
                    <div class="entry-modal-field">
                        <label class="entry-modal-label" for="entry-modal-progress">Episodes Watched</label>
                        <div class="entry-modal-progress-row">
                            <input id="entry-modal-progress" class="entry-modal-input" type="number" min="0"
                                   max="@(_total?.ToString())" @bind="_progress" />
                            @if (_total is int t && t > 0)
                            {
                                <span class="entry-modal-total">/ @t</span>
                            }
                        </div>
                    </div>
                    <div class="entry-modal-field">
                        <label class="entry-modal-label" for="entry-modal-score">Score</label>
                        <div class="entry-modal-progress-row">
                            <input id="entry-modal-score" class="entry-modal-input" type="number" min="0"
                                   max="@_scoreMax" step="@_scoreStep" placeholder="@($"0–{_scoreMax}")" @bind="_score" />
                            <span class="entry-modal-total">/ @_scoreMax</span>
                        </div>
                    </div>
                    <div class="entry-modal-field-row">
                        <div class="entry-modal-field">
                            <label class="entry-modal-label" for="entry-modal-started">Started</label>
                            <input id="entry-modal-started" class="entry-modal-input" type="date" @bind="_startedAt" />
                        </div>
                        <div class="entry-modal-field">
                            <label class="entry-modal-label" for="entry-modal-finished">Finished</label>
                            <input id="entry-modal-finished" class="entry-modal-input" type="date" @bind="_finishedAt" />
                        </div>
                    </div>
                    <div class="entry-modal-field">
                        <label class="entry-modal-label" for="entry-modal-rewatch">Rewatches</label>
                        <input id="entry-modal-rewatch" class="entry-modal-input" type="number" min="0" placeholder="0" @bind="_rewatchCount" />
                    </div>
                    <div class="entry-modal-field">
                        <label class="entry-modal-label" for="entry-modal-notes">Notes</label>
                        <textarea id="entry-modal-notes" class="entry-modal-textarea" rows="3" placeholder="Personal notes about this entry…" @bind="_notes"></textarea>
                    </div>
                    @if (!string.IsNullOrEmpty(_error))
                    {
                        <div class="entry-modal-error" role="alert">@_error</div>
                    }
                    <div class="entry-modal-actions">
                        @if (_inList)
                        {
                            <button type="button" class="entry-modal-delete" disabled="@_saving" @onclick="Remove">
                                @(_removing ? "Removing…" : "Delete")
                            </button>
                        }
                        <div class="entry-modal-actions-end">
                            <button type="button" class="entry-modal-cancel" @onclick="Close">Cancel</button>
                            <button type="submit" class="entry-modal-save" disabled="@(_saving || string.IsNullOrEmpty(_status))">
                                @(_saving && !_removing ? "Saving…" : "Save")
                            </button>
                        </div>
                    </div>
                </form>
            }
        </div>
    </div>
}

@code {
    [Parameter, EditorRequired] public string Id { get; set; } = "";
    [Parameter] public string Name { get; set; } = "";
    [Parameter] public int? Season { get; set; }
    [Parameter] public bool Visible { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnSaved { get; set; }

    private bool _loading;
    private bool _saving;
    private bool _removing;
    private string? _error;
    private string _status = "";
    private int _progress;
    private double? _score;
    private int _rewatchCount;
    private DateOnly? _startedAt;
    private DateOnly? _finishedAt;
    private string? _notes;
    private int? _total;
    private bool _inList;
    private bool _loadedFor;

    // Per-cour season picker state for cross-service franchises. _seasons is the
    // dropdown options; _selectedEntryId is the resolved per-cour id we fetch + save
    // against (the MVC currentEntryId()). _service is the primary AnimeService int
    // (0 Kitsu, 1 AniList, 2 MyAnimeList, 3 Trakt) — drives the score range below.
    private List<EntrySeasonDto> _seasons = new();
    private string? _selectedEntryId;
    private int? _service;

    // The id the Save / Delete go through: the picked cour for a franchise, else the
    // original id. Mirrors the MVC ManageEntry currentEntryId().
    private string CurrentEntryId => string.IsNullOrEmpty(_selectedEntryId) ? Id : _selectedEntryId;

    // Per-service score range — mirrors the MVC ManageEntry scoreMax/scoreStep:
    // AniList 0–100 step 0.1; MyAnimeList 0–10 step 1; Kitsu 0–10 step 0.5.
    // 1 == AniList, 2 == MyAnimeList (AnimeService enum); everything else is the
    // 0–10 default (Kitsu / Trakt / unknown).
    private string _scoreMax = "10";
    private string _scoreStep = "0.5";

    private void ApplyScoreRange()
    {
        (_scoreMax, _scoreStep) = _service switch
        {
            1 => ("100", "0.1"), // AniList
            2 => ("10", "1"),    // MyAnimeList
            _ => ("10", "0.5"),  // Kitsu / Trakt / default
        };
    }

    protected override async Task OnParametersSetAsync()
    {
        if (Visible && !_loadedFor)
        {
            _loadedFor = true;
            await LoadAsync();
        }
        else if (!Visible)
        {
            _loadedFor = false;
        }
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;
        _seasons = new();
        _selectedEntryId = null;
        _service = null;
        var resp = await Api.GetEntryAsync(Id, Season);
        _seasons = resp?.Seasons ?? new();
        _selectedEntryId = resp?.SelectedEntryId;
        _service = resp?.Service;
        ApplyScoreRange();
        BindEntry(resp?.Entry);
        _loading = false;
    }

    // Maps a loaded entry (or null = not on this cour's list) onto the form fields.
    // Shared by the initial load and the per-cour refetch.
    private void BindEntry(AnimeEntryDto? entry)
    {
        if (entry is not null)
        {
            _status = Canonicalize(entry.Status);
            _inList = !string.IsNullOrEmpty(_status);
            _progress = entry.Progress;
            _score = entry.Score is > 0 ? entry.Score : null;
            _rewatchCount = entry.RewatchCount;
            _startedAt = entry.StartedAt is DateTime sd ? DateOnly.FromDateTime(sd) : null;
            _finishedAt = entry.FinishedAt is DateTime fd ? DateOnly.FromDateTime(fd) : null;
            _notes = entry.Notes;
            _total = entry.TotalEpisodes;
        }
        else
        {
            _status = "";
            _inList = false;
            _progress = 0;
            _score = null;
            _rewatchCount = 0;
            _startedAt = _finishedAt = null;
            _notes = null;
            _total = null;
        }
    }

    // User picked a different cour from the dropdown → refetch that mapping's saved
    // entry by its id and rebind. Mirrors the MVC #seasonSelect change handler, which
    // re-reads StremioGetEntry for the chosen cour's id.
    private async Task OnSeasonChanged(ChangeEventArgs e)
    {
        var courId = e.Value?.ToString();
        if (string.IsNullOrEmpty(courId)) return;
        _selectedEntryId = courId;
        _loading = true;
        _error = null;
        StateHasChanged();
        // Fetch the entry for the picked cour. The new id is native (anilist:N / kitsu:N /
        // mal:N), so the server short-circuits the season resolution and returns just that
        // cour's entry; we keep our existing _seasons / _service.
        var resp = await Api.GetEntryAsync(courId);
        BindEntry(resp?.Entry);
        // Mirror the MVC change handler's data-total fallback: when the cour's entry
        // carries no episode count, fall back to the picked option's count so the
        // progress max + "/ N" still reflect the cour.
        if ((_total is null or 0) &&
            _seasons.FirstOrDefault(s => s.Id == courId)?.TotalEpisodes is int opt && opt > 0)
            _total = opt;
        _loading = false;
    }

    private async Task Save()
    {
        if (string.IsNullOrEmpty(_status)) { _error = "Pick a status, or use Remove to take it off your list."; return; }
        _saving = true;
        _error = null;
        // Send the resolved per-cour id so the server writes the right anime — see
        // CurrentEntryId / the MVC currentEntryId().
        var resp = await Api.SaveEntryAsync(CurrentEntryId, new EntrySaveRequest
        {
            Status = _status,
            Progress = _progress,
            Score = _score,
            RewatchCount = _rewatchCount,
            StartedAt = _startedAt?.ToString("yyyy-MM-dd"),
            FinishedAt = _finishedAt?.ToString("yyyy-MM-dd"),
            Notes = _notes,
        }, Season);
        _saving = false;
        if (resp is { Ok: true })
        {
            await OnSaved.InvokeAsync();
            await Close();
        }
        else
        {
            _error = "Couldn't save — check your connection and try again.";
        }
    }

    private async Task Remove()
    {
        _saving = true;
        _removing = true;
        _error = null;
        var resp = await Api.DeleteEntryAsync(CurrentEntryId, Season);
        _saving = false;
        _removing = false;
        if (resp is { Ok: true })
        {
            await OnSaved.InvokeAsync();
            await Close();
        }
        else
        {
            _error = "Couldn't remove this entry — try again.";
        }
    }

    private Task Close() => OnClose.InvokeAsync();

    // Map a tracker's service-specific status onto the canonical ListStatus the
    // save endpoint expects (AniList CURRENT, MAL watching, Kitsu current, …).
    private static string Canonicalize(string? s) => (s ?? "").ToLowerInvariant() switch
    {
        "current" or "watching" => "Watching",
        "completed" => "Completed",
        "planning" or "planned" or "plan_to_watch" => "Planning",
        "paused" or "on_hold" => "Paused",
        "dropped" => "Dropped",
        "repeating" or "rewatching" => "Rewatching",
        _ => "",
    };
}
