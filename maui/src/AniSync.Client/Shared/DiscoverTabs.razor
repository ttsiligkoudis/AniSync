@* Shared Discover tab strip — 1:1 port of Views/Discover/_DiscoverTabs.cshtml.
   Rendered on the anime catalog (Discover), Studios, and Tags pages so the five-pill
   nav reads as one continuous surface. Catalog pills preserve the active genre / search
   / season as query params so the filter state survives a Trending → Seasonal → Airing
   round-trip; the Studios / Tags pills carry no filter state of their own. The Hidden
   pill renders for logged-in users (ShowHidden). *@
<nav class="library-tabs" role="tablist" aria-label="Discover lists">
    @foreach (var (slug, label) in Catalog)
    {
        var active = ActiveList == slug;
        <a class="library-tab @(active ? "library-tab-active" : "")"
           href="@CatalogHref(slug)" role="tab" aria-selected="@(active ? "true" : "false")">@label</a>
    }
    <a class="library-tab @(ActiveBrowse == "studios" ? "library-tab-active" : "")"
       href="/discover/studio" role="tab" aria-selected="@(ActiveBrowse == "studios" ? "true" : "false")">Studios</a>
    <a class="library-tab @(ActiveBrowse == "tags" ? "library-tab-active" : "")"
       href="/discover/tag" role="tab" aria-selected="@(ActiveBrowse == "tags" ? "true" : "false")">Tags</a>
    @if (ShowHidden)
    {
        <a class="library-tab @(HiddenActive ? "library-tab-active" : "")"
           href="/discover?list=hidden" role="tab" aria-selected="@(HiddenActive ? "true" : "false")">Hidden</a>
    }
</nav>

@code {
    /// <summary>Active catalog slug (trending/popular/seasonal/airing), or null on a Browse-by page.</summary>
    [Parameter] public string? ActiveList { get; set; }
    /// <summary>Active Browse-by surface ("studios"/"tags"), or null on the catalog view.</summary>
    [Parameter] public string? ActiveBrowse { get; set; }
    [Parameter] public string? Genre { get; set; }
    [Parameter] public string? Search { get; set; }
    [Parameter] public string? Season { get; set; }
    [Parameter] public bool ShowHidden { get; set; }
    [Parameter] public bool HiddenActive { get; set; }

    private static readonly (string Slug, string Label)[] Catalog =
    {
        ("trending", "Trending"), ("popular", "Popular"), ("seasonal", "Seasonal"), ("airing", "Airing"),
    };

    private string CatalogHref(string slug)
    {
        var q = new List<string> { $"list={slug}" };
        if (!string.IsNullOrWhiteSpace(Genre)) q.Add($"genre={Uri.EscapeDataString(Genre)}");
        if (!string.IsNullOrWhiteSpace(Search)) q.Add($"search={Uri.EscapeDataString(Search)}");
        if (slug == "seasonal" && !string.IsNullOrWhiteSpace(Season)) q.Add($"season={Uri.EscapeDataString(Season)}");
        return "/discover?" + string.Join("&", q);
    }
}
