@inject AppState State
@inject IAniSyncApi Api
@inject IJSRuntime JS
@implements IAsyncDisposable

@* Customize dashboard modal — Blazor port of _DashCustomize.cshtml + dashboard-layout.js's modal.
   Lists the sections present on this dashboard (gated by the enabled media types); each row
   drag-reorders (by its grip handle, like the stream-addon list) and toggles visibility. Edits a
   draft; Save lifts it into AppState.DashLayout (which the sections read for their CSS order +
   hidden state) and persists it to the account (/api/v1/me/dashboard-layout). Closing/cancelling
   discards the draft. The drag uses the shared configure.js pointer-drag interop (bindReorder);
   like the original it doesn't mutate the DOM — Blazor re-renders from the staged order. *@
@if (_open)
{
    <div class="dash-modal-backdrop" @onclick="Close"></div>
    <div class="dash-modal" role="dialog" aria-modal="true" aria-labelledby="dash-modal-title">
        <div class="dash-modal-card">
            <button type="button" class="dash-modal-close" aria-label="Close" @onclick="Close">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
            </button>
            <h2 class="dash-modal-title" id="dash-modal-title">Customize dashboard</h2>
            <p class="dash-modal-subtitle">Drag to reorder sections and choose what shows. Synced to your account.</p>
            <ul class="dash-modal-list" @ref="_listRef">
                @foreach (var entry in _draft.Where(e => _present.Contains(e.Key)))
                {
                    var key = entry.Key;
                    <li class="dash-modal-row @(entry.Visible ? "" : "is-hidden")" data-key="@key" @key="key">
                        <span class="dash-row-handle" aria-label="Drag to reorder" title="Drag to reorder">
                            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <line x1="3" y1="9" x2="21" y2="9"></line>
                                <line x1="3" y1="15" x2="21" y2="15"></line>
                            </svg>
                        </span>
                        <span class="dash-row-label">@DashboardLayout.LabelFor(key)</span>
                        <button type="button" class="dash-row-toggle" aria-pressed="@(entry.Visible ? "true" : "false")"
                                aria-label="@(entry.Visible ? "Hide section" : "Show section")" @onclick="() => ToggleVisible(key)">
                            @(entry.Visible ? "Shown" : "Hidden")
                        </button>
                    </li>
                }
            </ul>
            <div class="dash-modal-footer">
                <button type="button" class="dash-modal-reset" @onclick="Reset">Reset to default</button>
                <button type="button" class="dash-modal-done" @onclick="Save">Save</button>
            </div>
        </div>
    </div>
}

@code {
    private bool _open;
    private List<LayoutEntry> _draft = new();
    private HashSet<string> _present = new(StringComparer.Ordinal);

    private ElementReference _listRef;
    private IJSObjectReference? _js;
    private DotNetObjectReference<DashCustomizeModal>? _selfRef;
    private bool _reorderBound;

    /// <summary>Open the chooser — snapshot the current layout into an editable draft.</summary>
    public void Open()
    {
        _draft = State.DashLayout.Select(e => new LayoutEntry { Key = e.Key, Visible = e.Visible }).ToList();
        _present = PresentKeys();
        _open = true;
        _reorderBound = false;   // the list element is re-created each open → rebind the drag
        StateHasChanged();
    }

    private void Close() => _open = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Bind the pointer-drag reorder once the list is in the DOM (only while open).
        // Reuses the stream-addon list's interop with dash-specific selectors + callback.
        if (!_open || _reorderBound) return;
        try
        {
            _js ??= await JS.InvokeAsync<IJSObjectReference>("import", "./_content/AniSync.Client/js/configure.js");
            _selfRef ??= DotNetObjectReference.Create(this);
            await _js.InvokeVoidAsync("bindReorder", _listRef, _selfRef, new
            {
                rowSelector = ".dash-modal-row",
                handleSelector = ".dash-row-handle",
                dataAttr = "data-key",
                method = "OnDashReorder",
            });
            _reorderBound = true;
        }
        catch { /* JS unavailable (prerender) — binds on the interactive pass */ }
    }

    [JSInvokable]
    public void OnDashReorder(string[] keys)
    {
        // Drag drop: rearrange the staged draft to the new on-screen key order. Only the
        // displayed (present) keys move; non-present entries keep their absolute slots and
        // every entry keeps its visible flag — mirrors dashboard-layout.js applyDraggedOrder.
        if (keys is null || keys.Length == 0) return;
        var byKey = _draft.ToDictionary(e => e.Key, StringComparer.Ordinal);
        var inDrag = new HashSet<string>(keys, StringComparer.Ordinal);
        var queue = new Queue<string>(keys.Where(byKey.ContainsKey));
        for (var i = 0; i < _draft.Count; i++)
            if (inDrag.Contains(_draft[i].Key) && queue.Count > 0)
                _draft[i] = byKey[queue.Dequeue()];
        StateHasChanged();
    }

    private async Task Save()
    {
        _open = false;
        State.SetDashLayout(_draft);
        // Persist to the account so the layout follows the user across devices (best-effort).
        if (State.LoggedIn) await Api.SaveDashboardLayoutAsync(DashboardLayout.ToJson(_draft));
    }

    private void Reset() => _draft = DashboardLayout.Default();

    private void ToggleVisible(string key)
    {
        var e = _draft.FirstOrDefault(x => x.Key == key);
        if (e is not null) e.Visible = !e.Visible;
    }

    // The sections actually rendered on this dashboard, gated by the user's enabled media types
    // (continue-watching + stats need a login). Mirrors what Home renders + the web's present().
    private HashSet<string> PresentKeys()
    {
        var keys = new HashSet<string>(StringComparer.Ordinal);
        var loggedIn = State.LoggedIn;
        if (loggedIn) keys.Add("stats");
        if (State.EnabledMediaTypes.Contains(MetaType.anime))
        {
            if (loggedIn) keys.Add("anime-continue");
            keys.Add("anime-new-episodes");
            keys.Add("anime-trending");
            keys.Add("anime-popular");
            keys.Add("anime-anticipated");
        }
        foreach (var vt in State.EnabledMediaTypes.Where(t => t != MetaType.anime))
        {
            var slug = vt == MetaType.movie ? "movie" : "series";
            if (loggedIn) keys.Add($"video-continue-{slug}");
            keys.Add($"video-trending-{slug}");
            keys.Add($"video-popular-{slug}");
            keys.Add($"video-anticipated-{slug}");
        }
        keys.Add("browse");
        return keys;
    }

    public async ValueTask DisposeAsync()
    {
        if (_js is not null) { try { await _js.DisposeAsync(); } catch { } }
        _selfRef?.Dispose();
    }
}
