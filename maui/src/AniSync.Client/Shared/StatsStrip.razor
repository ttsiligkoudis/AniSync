@implements IDisposable
@inject IAniSyncApi Api
@inject AppState State
@inject IJSRuntime JS

@* "Your stats" panel — port of the stats-section in Index.cshtml. Anime row sources from
   AniList, the movies/series row from Trakt; group labels show only when both are present
   ("combined"). Rows hide per the dashboard media-type filter. While the AniList / Trakt
   fetches are in flight the panel renders a loading skeleton (the cells + a shimmer block
   in place of each number, sized like the final value) so it doesn't pop in empty — the
   numbers fill once the fetch lands. Which groups show during loading is predicted from the
   enabled media types; any that come back without data collapse once loading clears. *@

@if (!LayoutHidden && (ShowAnimeGroup || ShowTraktGroup))
{
    <section class="dashboard-section stats-section" data-dash-section="stats" data-media-type="@_statsTypes" style="order:@Order">
        <div class="dashboard-section-header">
            <h2 class="dashboard-section-title">Your stats</h2>
        </div>

        @if (ShowAnimeGroup && ShowAnime)
        {
            <div class="stats-group" data-media-type="anime" data-stats-loading="@LoadingAttr">
                <div class="stats-group-head">
                    @if (_combined)
                    {
                        <span class="stats-group-label">Anime</span>
                    }
                    <span class="dashboard-section-actions stats-group-actions">
                        <span class="dashboard-section-link-muted">via AniList</span>
                        @* Info popover (click-driven in the web via inline JS; markup
                           rendered here for parity. Click-driven via Blazor (toggles .is-open, which the
                           CSS reveals); the refresh link force-refetches the AniList stats + re-primes the
                           24 h cache. *@
                        <span class="dashboard-stats-info @(_infoOpen ? "is-open" : "")">
                            <button class="dashboard-stats-info-btn"
                                    type="button"
                                    aria-label="About these stats"
                                    aria-expanded="@(_infoOpen ? "true" : "false")"
                                    aria-controls="dashboardStatsInfoTooltip"
                                    @onclick="() => _infoOpen = !_infoOpen">
                                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                    <circle cx="12" cy="12" r="10"></circle>
                                    <line x1="12" y1="16" x2="12" y2="12"></line>
                                    <line x1="12" y1="8" x2="12.01" y2="8"></line>
                                </svg>
                            </button>
                            <span id="dashboardStatsInfoTooltip" class="dashboard-stats-info-tooltip">
                                AniList recomputes your stats on its own schedule
                                (typically every 24-48 hours). To force an
                                immediate refresh, click "Update Stats" on
                                <a href="https://anilist.co/settings/lists" target="_blank" rel="noopener noreferrer">AniList's list settings</a>
                                and then
                                <a href="#" @onclick="RefreshAnimeStatsAsync" @onclick:preventDefault>refresh your stats</a>.
                            </span>
                        </span>
                    </span>
                </div>
                <div class="stats-strip">
                    <div class="stats-cell" data-stat="watching">
                        <span class="stats-icon stats-icon-blue">
                            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="2" y="7" width="20" height="15" rx="2" ry="2"></rect>
                                <polyline points="17 2 12 7 7 2"></polyline>
                            </svg>
                        </span>
                        <div class="stats-number">@(_anime is not null ? _anime.Watching.ToString() : "—")</div>
                        <div class="stats-label">Watching</div>
                    </div>
                    <div class="stats-cell" data-stat="completed">
                        <span class="stats-icon stats-icon-green">
                            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                                <polyline points="22 4 12 14.01 9 11.01"></polyline>
                            </svg>
                        </span>
                        <div class="stats-number">@(_anime is not null ? _anime.Completed.ToString() : "—")</div>
                        <div class="stats-label">Completed</div>
                    </div>
                    @* Mean / Hours sit [hidden] until their value proves non-zero; the
                       [data-stats-loading] CSS reveals them while the skeleton is up so the
                       loading card shows the same cells as the loaded one. *@
                    <div class="stats-cell" data-stat="mean" hidden="@(_anime?.MeanScore is not > 0)">
                        <span class="stats-icon stats-icon-purple">
                            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
                            </svg>
                        </span>
                        <div class="stats-number">@(_anime?.MeanScore is { } ms && ms > 0 ? ms.ToString("0.0") : "—")</div>
                        <div class="stats-label">Mean</div>
                    </div>
                    <div class="stats-cell" data-stat="hours" hidden="@(_anime is not { TotalHoursWatched: > 0 })">
                        <span class="stats-icon stats-icon-amber">
                            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="12" cy="12" r="10"></circle>
                                <polyline points="12 6 12 12 16 14"></polyline>
                            </svg>
                        </span>
                        <div class="stats-number">@(_anime is { TotalHoursWatched: > 0 } ah ? ah.TotalHoursWatched.ToString() : "—")</div>
                        <div class="stats-label">Hours</div>
                    </div>
                </div>
            </div>
        }

        @if (ShowTraktGroup && ShowVideo)
        {
            <div class="stats-group" data-media-type="movie series" data-stats-loading="@LoadingAttr">
                <div class="stats-group-head">
                    @if (_combined)
                    {
                        <span class="stats-group-label">Movies &amp; Series</span>
                    }
                    <span class="dashboard-section-actions stats-group-actions">
                        <span class="dashboard-section-link-muted">via Trakt</span>
                    </span>
                </div>
                <div class="stats-strip">
                    <div class="stats-cell" data-trakt-stat="movies">
                        <span class="stats-icon stats-icon-blue">
                            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="3" y="4" width="18" height="16" rx="2"></rect>
                                <line x1="7" y1="4" x2="7" y2="20"></line><line x1="17" y1="4" x2="17" y2="20"></line>
                                <line x1="3" y1="12" x2="21" y2="12"></line>
                            </svg>
                        </span>
                        <div class="stats-number">@(_trakt is not null ? _trakt.MoviesWatched.ToString() : "—")</div>
                        <div class="stats-label">Movies</div>
                    </div>
                    <div class="stats-cell" data-trakt-stat="shows">
                        <span class="stats-icon stats-icon-green">
                            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="2" y="7" width="20" height="13" rx="2"></rect>
                                <polyline points="8 3 12 7 16 3"></polyline>
                            </svg>
                        </span>
                        <div class="stats-number">@(_trakt is not null ? _trakt.ShowsWatched.ToString() : "—")</div>
                        <div class="stats-label">Shows</div>
                    </div>
                    <div class="stats-cell" data-trakt-stat="episodes">
                        <span class="stats-icon stats-icon-purple">
                            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="2" y="3" width="20" height="14" rx="2"></rect>
                                <line x1="8" y1="21" x2="16" y2="21"></line><line x1="12" y1="17" x2="12" y2="21"></line>
                            </svg>
                        </span>
                        <div class="stats-number">@(_trakt is not null ? _trakt.EpisodesWatched.ToString() : "—")</div>
                        <div class="stats-label">Episodes</div>
                    </div>
                    <div class="stats-cell" data-trakt-stat="hours" hidden="@(_trakt is not { TotalHoursWatched: > 0 })">
                        <span class="stats-icon stats-icon-amber">
                            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="12" cy="12" r="10"></circle>
                                <polyline points="12 6 12 12 16 14"></polyline>
                            </svg>
                        </span>
                        <div class="stats-number">@(_trakt is { TotalHoursWatched: > 0 } th ? th.TotalHoursWatched.ToString() : "—")</div>
                        <div class="stats-label">Hours</div>
                    </div>
                </div>
            </div>
        }
    </section>
}

@code {
    // CSS flex `order` + hidden state for the "stats" section, read from the saved layout.
    private int Order { get { var l = State.DashLayout; for (var i = 0; i < l.Count; i++) if (l[i].Key == "stats") return i; return 0; } }
    private bool LayoutHidden => State.DashLayout.FirstOrDefault(e => e.Key == "stats") is { Visible: false };

    private AnilistUserStatsDto? _anime;
    private TraktUserStatsDto? _trakt;
    private bool _loading = true;

    // Stats-info popover open state (the web used inline JS; this is the Blazor-native toggle — the CSS
    // reveals the tooltip via .dashboard-stats-info.is-open).
    private bool _infoOpen;
    private bool _refreshing;

    // A group shows only when its media type is ENABLED (the "What do you want to watch?" modal —
    // not just the All/single view toggle), AND there's something to show: while loading we predict
    // from the enabled types (login-gated, so anonymous shows no skeleton); once loaded, only when the
    // tracker actually returned data. Gating on the enabled set in BOTH states is what hides the Anime
    // row when only Movies/Series are enabled (and vice-versa), even though the linked account still
    // has data behind it.
    private bool ShowAnimeGroup => State.EnabledMediaTypes.Contains(MetaType.anime)
        && (_loading ? State.LoggedIn : _anime is not null);
    private bool ShowTraktGroup => State.EnabledMediaTypes.Any(t => t != MetaType.anime)
        && (_loading ? State.LoggedIn : _trakt is not null);
    private bool _combined => ShowAnimeGroup && ShowTraktGroup;

    // null omits the attribute; "" renders data-stats-loading="" which the skeleton CSS matches.
    private string? LoadingAttr => _loading ? "" : null;

    // Union of the media types whose row is present — mirrors the web's statsTypes so the
    // dashboard switch hides the whole panel only when neither row matches the active filter.
    private string _statsTypes => string.Join(" ",
        (ShowAnimeGroup ? new[] { "anime" } : Array.Empty<string>())
        .Concat(ShowTraktGroup ? new[] { "movie", "series" } : Array.Empty<string>()));

    private bool ShowAnime => State.DashboardFilter is "all" or "anime";
    private bool ShowVideo => State.DashboardFilter is "all" or "movie" or "series";

    protected override void OnInitialized() => State.Changed += OnFilterChanged;

    protected override async Task OnInitializedAsync()
    {
        // No account → no per-user stats; skip the /me/* calls entirely (the groups are LoggedIn-gated
        // above, so the strip stays hidden anyway).
        if (!State.LoggedIn) { _loading = false; return; }

        // AniList stats are cached client-side for 24 h — the server deliberately doesn't cache them
        // (AnilistService.GetUserStatsAsync), so a fresh cache entry skips the AniList round-trip on every
        // dashboard load; the "refresh your stats" link force-refetches + re-primes it. Trakt has no cache.
        var traktTask = Api.TraktStatsAsync();
        _anime = await ReadCachedAnimeStatsAsync() ?? await FetchAndCacheAnimeStatsAsync();
        _trakt = await traktTask;
        _loading = false;
    }

    private void OnFilterChanged() => StateHasChanged();

    // "refresh your stats" link in the popover — force a fresh AniList fetch and re-prime the 24 h cache
    // (after the user clicks "Update Stats" on AniList this picks up the recomputed numbers). Closes the
    // popover and guards against double-clicks while the fetch is in flight.
    private async Task RefreshAnimeStatsAsync()
    {
        if (_refreshing) return;
        _refreshing = true;
        _infoOpen = false;
        StateHasChanged();
        try { _anime = await FetchAndCacheAnimeStatsAsync(); }
        finally { _refreshing = false; StateHasChanged(); }
    }

    // ── AniList stats client cache (24 h, localStorage) ──────────────────────────────────────────────
    private const string AnimeStatsCacheKey = "anisync.stats.anilist";
    private static readonly long StatsTtlMs = (long)TimeSpan.FromHours(24).TotalMilliseconds;
    private sealed record AnimeStatsCache(long Ts, AnilistUserStatsDto? Stats);

    // Return the cached stats when they're under 24 h old; null (→ fetch) on miss/stale/parse error, or
    // when JS isn't available. Cleared on auth transitions by /auth/complete so a new user starts fresh.
    private async Task<AnilistUserStatsDto?> ReadCachedAnimeStatsAsync()
    {
        try
        {
            var raw = await JS.InvokeAsync<string?>("localStorage.getItem", AnimeStatsCacheKey);
            if (string.IsNullOrEmpty(raw)) return null;
            var entry = System.Text.Json.JsonSerializer.Deserialize<AnimeStatsCache>(raw);
            if (entry?.Stats is null) return null;
            var age = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds() - entry.Ts;
            return age >= 0 && age < StatsTtlMs ? entry.Stats : null;   // stale / clock skew → refetch
        }
        catch { return null; }
    }

    // Fetch from the server (which queries AniList) and stamp the result into the 24 h cache.
    private async Task<AnilistUserStatsDto?> FetchAndCacheAnimeStatsAsync()
    {
        var stats = await Api.AnilistStatsAsync();
        if (stats is not null)
        {
            try
            {
                var json = System.Text.Json.JsonSerializer.Serialize(
                    new AnimeStatsCache(DateTimeOffset.UtcNow.ToUnixTimeMilliseconds(), stats));
                await JS.InvokeVoidAsync("localStorage.setItem", AnimeStatsCacheKey, json);
            }
            catch { /* storage blocked → just skip caching */ }
        }
        return stats;
    }

    public void Dispose() => State.Changed -= OnFilterChanged;
}
