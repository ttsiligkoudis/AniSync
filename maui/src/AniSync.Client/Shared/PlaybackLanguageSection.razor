@inject IAppEnvironment Env

@* Default playback languages (per-account, synced). Subtitle applies to both heads; audio is the
   native player only (the browser can't switch audio tracks). This is a controlled component — the
   Account page owns the values and persists them on the shared "Save changes" bar, so changing a
   dropdown just marks the form dirty (it doesn't save on its own). *@
<section class="section-card">
    <span class="section-title">Playback languages</span>
    <p class="section-description">
        Preferred languages applied automatically when a video starts — you can still switch tracks in the
        player. Subtitles fall back to English (then off); audio falls back to English (then the first track).
    </p>
    <div class="streams-grid">
        <div class="stream-option">
            <span class="option-name">Default subtitle language</span>
            <select class="lang-select" @onchange="OnSubtitleChanged">
                @foreach (var (langCode, name) in PlaybackLanguages.Options)
                {
                    <option value="@langCode" selected="@(langCode == Subtitle)">@name</option>
                }
            </select>
        </div>
        @if (Env.SupportsNativePlayback)
        {
            <div class="stream-option">
                <span class="option-name">Default audio language</span>
                <select class="lang-select" @onchange="OnAudioChanged">
                    @foreach (var (langCode, name) in PlaybackLanguages.Options)
                    {
                        <option value="@langCode" selected="@(langCode == Audio)">@name</option>
                    }
                </select>
            </div>
        }
    </div>
</section>

@code {
    [Parameter] public string Audio { get; set; } = PlaybackLanguages.Default;
    [Parameter] public string Subtitle { get; set; } = PlaybackLanguages.Default;
    [Parameter] public EventCallback<string> AudioChanged { get; set; }
    [Parameter] public EventCallback<string> SubtitleChanged { get; set; }

    private Task OnSubtitleChanged(ChangeEventArgs e)
        => SubtitleChanged.InvokeAsync(PlaybackLanguages.Normalize(e.Value?.ToString()));

    private Task OnAudioChanged(ChangeEventArgs e)
        => AudioChanged.InvokeAsync(PlaybackLanguages.Normalize(e.Value?.ToString()));
}
