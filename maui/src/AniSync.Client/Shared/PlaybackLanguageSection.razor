@inject IAniSyncApi Api
@inject IAppEnvironment Env

@* Default playback languages (per-account, synced). Subtitle applies to both heads; audio is the
   native player only (the browser can't switch audio tracks). Saved immediately on change. *@
<section class="section-card">
    <span class="section-title">Playback languages</span>
    <p class="section-description">
        Preferred languages applied automatically when a video starts — you can still switch tracks in the
        player. Subtitles fall back to English (then off); audio falls back to English (then the first track).
    </p>
    <div class="streams-grid">
        <div class="stream-option">
            <span class="option-name">Default subtitle language</span>
            <select class="custom-select" @onchange="OnSubtitleChanged" disabled="@_busy">
                @foreach (var (code, name) in PlaybackLanguages.Options)
                {
                    <option value="@code" selected="@(code == _subtitle)">@name</option>
                }
            </select>
        </div>
        @if (Env.SupportsNativePlayback)
        {
            <div class="stream-option">
                <span class="option-name">Default audio language</span>
                <select class="custom-select" @onchange="OnAudioChanged" disabled="@_busy">
                    @foreach (var (code, name) in PlaybackLanguages.Options)
                    {
                        <option value="@code" selected="@(code == _audio)">@name</option>
                    }
                </select>
            </div>
        }
    </div>
    @if (!string.IsNullOrEmpty(_status))
    {
        <p class="hint-text">@_status</p>
    }
</section>

@code {
    private string _audio = PlaybackLanguages.Default;
    private string _subtitle = PlaybackLanguages.Default;
    private bool _busy;
    private string? _status;

    protected override async Task OnInitializedAsync()
    {
        // Reading the stored prefs needs the header credential (interactive pass only).
        if (!RendererInfo.IsInteractive) return;
        var langs = await Api.GetPlaybackLanguagesAsync();
        _audio = PlaybackLanguages.Normalize(langs?.Audio);
        _subtitle = PlaybackLanguages.Normalize(langs?.Subtitle);
        StateHasChanged();
    }

    private async Task OnSubtitleChanged(ChangeEventArgs e)
    {
        _subtitle = PlaybackLanguages.Normalize(e.Value?.ToString());
        await SaveAsync();
    }

    private async Task OnAudioChanged(ChangeEventArgs e)
    {
        _audio = PlaybackLanguages.Normalize(e.Value?.ToString());
        await SaveAsync();
    }

    private async Task SaveAsync()
    {
        _busy = true; _status = "Saving…"; StateHasChanged();
        var ok = await Api.SavePlaybackLanguagesAsync(_audio, _subtitle);
        _busy = false;
        _status = ok ? "Saved." : "Couldn't save — try again.";
        StateHasChanged();
    }
}
