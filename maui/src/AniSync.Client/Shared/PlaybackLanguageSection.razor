@inject IAppEnvironment Env
@inject IJSRuntime JS
@implements IAsyncDisposable

@* Default playback languages (per-account, synced). Subtitle applies to both heads; audio is the
   native player only (the browser can't switch audio tracks). Controlled by the Account page, which
   owns the values and persists them on the shared "Save changes" bar — changing a dropdown only marks
   the form dirty. The DOM <select> value is set explicitly via JS after render (lang-select.js):
   Blazor's value binding leaves a native select blank when the value loads async / across prerender,
   so we pin it ourselves once the options exist. @onchange bubbles the pick up to the page. *@
<section class="section-card">
    <span class="section-title">Playback languages</span>
    <p class="section-description">
        Preferred languages applied automatically when a video starts — you can still switch tracks in the
        player. Subtitles fall back to English (then off); audio falls back to English (then the first track).
    </p>
    <div class="streams-grid">
        <div class="stream-option">
            <span class="option-name">Default subtitle language</span>
            <select class="lang-select" @ref="_subRef" @onchange="OnSubtitleChanged">
                @foreach (var (langCode, name) in PlaybackLanguages.Options)
                {
                    <option value="@langCode">@name</option>
                }
            </select>
        </div>
        @if (Env.SupportsNativePlayback)
        {
            <div class="stream-option">
                <span class="option-name">Default audio language</span>
                <select class="lang-select" @ref="_audRef" @onchange="OnAudioChanged">
                    @foreach (var (langCode, name) in PlaybackLanguages.Options)
                    {
                        <option value="@langCode">@name</option>
                    }
                </select>
            </div>
        }
    </div>
</section>

@code {
    [Parameter] public string Audio { get; set; } = PlaybackLanguages.Default;
    [Parameter] public string Subtitle { get; set; } = PlaybackLanguages.Default;
    [Parameter] public EventCallback<string> AudioChanged { get; set; }
    [Parameter] public EventCallback<string> SubtitleChanged { get; set; }

    private string _audio = PlaybackLanguages.Default;
    private string _subtitle = PlaybackLanguages.Default;
    private ElementReference _subRef;
    private ElementReference _audRef;
    private IJSObjectReference? _js;

    protected override void OnParametersSet()
    {
        _audio = PlaybackLanguages.Normalize(Audio);
        _subtitle = PlaybackLanguages.Normalize(Subtitle);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!RendererInfo.IsInteractive) return;
        try
        {
            _js ??= await JS.InvokeAsync<IJSObjectReference>("import", "./_content/AniSync.Client/js/lang-select.js");
            await _js.InvokeVoidAsync("setValue", _subRef, _subtitle);
            if (Env.SupportsNativePlayback) await _js.InvokeVoidAsync("setValue", _audRef, _audio);
        }
        catch { /* prerender / disposed circuit */ }
    }

    // Update the local value first (so the post-render JS pin matches the user's pick with no flicker),
    // then bubble it up to the page to mark the form dirty.
    private Task OnSubtitleChanged(ChangeEventArgs e)
    {
        _subtitle = PlaybackLanguages.Normalize(e.Value?.ToString());
        return SubtitleChanged.InvokeAsync(_subtitle);
    }

    private Task OnAudioChanged(ChangeEventArgs e)
    {
        _audio = PlaybackLanguages.Normalize(e.Value?.ToString());
        return AudioChanged.InvokeAsync(_audio);
    }

    public async ValueTask DisposeAsync()
    {
        if (_js is not null)
        {
            try { await _js.DisposeAsync(); } catch { }
        }
    }
}
