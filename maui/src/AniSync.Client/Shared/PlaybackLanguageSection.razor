@inject IAppEnvironment Env

@* Default playback languages (per-account, synced). Subtitle applies to both heads; audio is the
   native player only (the browser can't switch audio tracks). Controlled by the Account page, which
   owns the values and persists them on the shared "Save changes" bar — changing a dropdown only marks
   the form dirty. The selects bind to local fields (synced from the params in OnParametersSet) with
   plain @bind, so Blazor reliably applies the select value even though the DB value loads async after
   the options render; @bind:after bubbles the pick up to the page. *@
<section class="section-card">
    <span class="section-title">Playback languages</span>
    <p class="section-description">
        Preferred languages applied automatically when a video starts — you can still switch tracks in the
        player. Subtitles fall back to English (then off); audio falls back to English (then the first track).
    </p>
    <div class="streams-grid">
        <div class="stream-option">
            <span class="option-name">Default subtitle language</span>
            <select class="lang-select" @bind="_subtitle" @bind:after="PushSubtitle">
                @foreach (var (langCode, name) in PlaybackLanguages.Options)
                {
                    <option value="@langCode">@name</option>
                }
            </select>
        </div>
        @if (Env.SupportsNativePlayback)
        {
            <div class="stream-option">
                <span class="option-name">Default audio language</span>
                <select class="lang-select" @bind="_audio" @bind:after="PushAudio">
                    @foreach (var (langCode, name) in PlaybackLanguages.Options)
                    {
                        <option value="@langCode">@name</option>
                    }
                </select>
            </div>
        }
    </div>
</section>

@code {
    [Parameter] public string Audio { get; set; } = PlaybackLanguages.Default;
    [Parameter] public string Subtitle { get; set; } = PlaybackLanguages.Default;
    [Parameter] public EventCallback<string> AudioChanged { get; set; }
    [Parameter] public EventCallback<string> SubtitleChanged { get; set; }

    private string _audio = PlaybackLanguages.Default;
    private string _subtitle = PlaybackLanguages.Default;

    protected override void OnParametersSet()
    {
        _audio = PlaybackLanguages.Normalize(Audio);
        _subtitle = PlaybackLanguages.Normalize(Subtitle);
    }

    private Task PushSubtitle() => SubtitleChanged.InvokeAsync(_subtitle);
    private Task PushAudio() => AudioChanged.InvokeAsync(_audio);
}
