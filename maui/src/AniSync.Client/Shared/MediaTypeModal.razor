@inject AppState State
@inject IJSRuntime JS
@inject NavigationManager Nav
@implements IAsyncDisposable

@* First-visit / reopen media-type chooser. MULTI-SELECT: the user picks one or
   more modes (anime / movies / series). The dashboard combines shelves across the
   selected set; Discover / Library offer a single-select toggle limited to it.
   Rendered once in the layout for every visitor — a 1:1 port of
   _MediaTypeModal.cshtml. media-type.js owns the storage keys + cookie logic +
   the reload; open/close + selection state live here (the original's IIFE). *@
<div class="mt-modal-backdrop" data-media-type-backdrop hidden="@(!_open)" @onclick="CloseAsync"></div>
<div class="mt-modal" data-media-type-modal role="dialog" aria-modal="true"
     aria-labelledby="mt-modal-title"
     hidden="@(!_open)">
    <div class="mt-modal-card">
        <button type="button" class="mt-modal-close" aria-label="Close" data-media-type-close
                hidden="@_forced" @onclick="CloseAsync">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="18" y1="6" x2="6" y2="18"></line>
                <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
        </button>
        <h2 class="mt-modal-title" id="mt-modal-title">What do you want to watch?</h2>
        <p class="mt-modal-subtitle">Pick one or more — your dashboard combines them, and you can switch between them on Discover &amp; Library. Change any time from the header.</p>
        <div class="mt-modal-options">
            @foreach (var opt in _options)
            {
                var selected = _selected.Contains(opt.Type);
                <button type="button" class="mt-modal-option @(selected ? "is-selected" : "")"
                        data-media-type-choice="@opt.Type"
                        aria-pressed="@(selected ? "true" : "false")"
                        @onclick="@(() => Toggle(opt.Type))">
                    <span class="mt-modal-option-icon" aria-hidden="true">
                        @if (opt.Type == MetaType.anime)
                        {
                            <svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M12 3l1.9 5.6L19.5 10l-5.6 1.9L12 17.5l-1.9-5.6L4.5 10l5.6-1.4z" />
                                <path d="M19 4l.6 1.8L21.5 6.5l-1.9.6L19 9l-.6-1.9L16.5 6.5l1.9-.7z" />
                            </svg>
                        }
                        else if (opt.Type == MetaType.movie)
                        {
                            <svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="3" y="4" width="18" height="16" rx="2" />
                                <line x1="7" y1="4" x2="7" y2="20" />
                                <line x1="17" y1="4" x2="17" y2="20" />
                                <line x1="3" y1="12" x2="21" y2="12" />
                            </svg>
                        }
                        else
                        {
                            <svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="2" y="7" width="20" height="13" rx="2" />
                                <polyline points="8 3 12 7 16 3" />
                            </svg>
                        }
                    </span>
                    <span class="mt-modal-option-body">
                        <span class="mt-modal-option-title">@opt.Title</span>
                        <span class="mt-modal-option-blurb">@opt.Blurb</span>
                    </span>
                    @* Check mark — CSS shows it only on .is-selected options. *@
                    <span class="mt-modal-option-check" aria-hidden="true">
                        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="20 6 9 17 4 12" />
                        </svg>
                    </span>
                </button>
            }
        </div>
        <div class="mt-modal-footer">
            <span class="mt-modal-hint" data-media-type-hint hidden="@(_selected.Count > 0)">Select at least one mode.</span>
            <button type="button" class="mt-modal-confirm" data-media-type-confirm
                    disabled="@(_selected.Count == 0)" @onclick="ConfirmAsync">Continue</button>
        </div>
    </div>
</div>

@code {
    private bool _open;
    private bool _forced;
    private readonly HashSet<MetaType> _selected = new();

    private IJSObjectReference? _js;
    private DotNetObjectReference<MediaTypeModal>? _selfRef;

    // Same option order / titles / blurbs as _MediaTypeModal.cshtml.
    private static readonly (MetaType Type, string Title, string Blurb)[] _options =
    {
        (MetaType.anime,  "Anime",  "Track across AniList, MAL & Kitsu"),
        (MetaType.movie,  "Movies", "Browse & track films"),
        (MetaType.series, "Series", "Browse & track TV shows"),
    };

    protected override void OnInitialized()
    {
        // The header mode button (RequestMediaTypeModal) reopens the chooser —
        // mirrors the original's [data-media-type-open] trigger.
        State.MediaTypeModalRequested += OnReopenRequested;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // First-visit logic runs once, interactive only (prerender has no JS /
        // localStorage). Mirrors the original IIFE's bottom block.
        if (!firstRender) return;
        if (!RendererInfo.IsInteractive) return;
        try
        {
            _js ??= await JS.InvokeAsync<IJSObjectReference>("import", "./_content/AniSync.Client/js/media-type.js");
            var stored = await _js.InvokeAsync<string[]>("getEnabled");
            // Already chosen → nothing to do (the set is only changed by the modal).
            if (stored is { Length: > 0 }) return;

            // Single-mode pages (the Stremio /configure page, which is anime-only)
            // silently commit anime instead of forcing the chooser — no reload: the
            // server/app already renders the unset state as that same default mode.
            var relative = Nav.ToBaseRelativePath(Nav.Uri).Split('?', '#')[0].Trim('/');
            var autodefault = relative == "configure" ? "anime" : null;
            if (autodefault == "anime")
            {
                await _js.InvokeVoidAsync("save", "anime", "anime");
                State.SetEnabledMediaTypes(new[] { MetaType.anime }, MetaType.anime);
            }
            else
            {
                await OpenAsync(forced: true);
            }
        }
        catch { /* prerender / no JS */ }
    }

    private void OnReopenRequested()
    {
        // Preselect from the stored set, then open un-forced (closable).
        InvokeAsync(async () =>
        {
            await PreselectFromStoreAsync();
            await OpenAsync(forced: false);
        });
    }

    private async Task PreselectFromStoreAsync()
    {
        _selected.Clear();
        try
        {
            _js ??= await JS.InvokeAsync<IJSObjectReference>("import", "./_content/AniSync.Client/js/media-type.js");
            var stored = await _js.InvokeAsync<string[]>("getEnabled");
            foreach (var s in stored)
            {
                if (Enum.TryParse<MetaType>(s, out var mt)) _selected.Add(mt);
            }
        }
        catch { /* prerender / no JS */ }
    }

    private async Task OpenAsync(bool forced)
    {
        _open = true;
        _forced = forced;
        try
        {
            _js ??= await JS.InvokeAsync<IJSObjectReference>("import", "./_content/AniSync.Client/js/media-type.js");
            _selfRef ??= DotNetObjectReference.Create(this);
            await _js.InvokeVoidAsync("setBodyOpen", true);
            await _js.InvokeVoidAsync("bindEscape", _selfRef);
        }
        catch { }
        StateHasChanged();
    }

    private async Task CloseAsync()
    {
        // Forced (first-visit) chooser can't be dismissed — matches the original.
        if (_forced) return;
        _open = false;
        try
        {
            _js ??= await JS.InvokeAsync<IJSObjectReference>("import", "./_content/AniSync.Client/js/media-type.js");
            await _js.InvokeVoidAsync("setBodyOpen", false);
            await _js.InvokeVoidAsync("unbindEscape");
        }
        catch { }
    }

    private void Toggle(MetaType type)
    {
        if (!_selected.Add(type)) _selected.Remove(type);
    }

    private async Task ConfirmAsync()
    {
        if (_selected.Count == 0) return;

        var set = _options.Select(o => o.Type).Where(_selected.Contains).ToList(); // ordered anime/movie/series

        // Active mode: keep the current one if it's still enabled, else the first
        // of the new set.
        var active = _selected.Contains(State.MediaType) ? State.MediaType : set[0];

        var setCsv = string.Join(",", set.Select(t => t.ToString()));
        try
        {
            _js ??= await JS.InvokeAsync<IJSObjectReference>("import", "./_content/AniSync.Client/js/media-type.js");
            await _js.InvokeVoidAsync("save", setCsv, active.ToString());
        }
        catch { }

        // Apply the pick and just close the chooser — no full-page reload. The dashboard,
        // the media-type switch, Discover and Library all subscribe to State.Changed and
        // re-render / re-fetch for the new modes, so the SPA updates in place. (The original
        // reloaded only because it was server-rendered.)
        State.SetEnabledMediaTypes(set, active);
        _forced = false;          // a confirmed pick dismisses even the forced first-visit modal
        await CloseAsync();
    }

    [JSInvokable]
    public Task CloseFromJs()
    {
        if (!_open || _forced) return Task.CompletedTask;
        return InvokeAsync(async () => { await CloseAsync(); StateHasChanged(); });
    }

    public async ValueTask DisposeAsync()
    {
        State.MediaTypeModalRequested -= OnReopenRequested;
        if (_js is not null)
        {
            try { await _js.InvokeVoidAsync("unbindEscape"); } catch { }
            try { await _js.DisposeAsync(); } catch { }
        }
        _selfRef?.Dispose();
    }
}
