@page "/discover/tag/{Tag}"
@inject IAniSyncApi Api

@* Anime tagged with {Tag} — port of Views/Discover/TagDetail.cshtml. Poster grid
   with skip-offset "Load more" (the server reports HasNextPage). *@

<PageTitle>@Tag · AniSync</PageTitle>

<section>
    <header class="page-header">
        <p class="page-subtitle">Tag</p>
        <h1 class="page-title">@Tag</h1>
    </header>

    @if (_loading && _items.Count == 0)
    {
        <div class="library-grid">
            @for (var i = 0; i < 12; i++)
            {
                <div class="library-card library-card-skeleton">
                    <div class="library-card-poster-wrap"><div class="library-card-poster skeleton-shimmer"></div></div>
                    <span class="library-card-skeleton-line"></span>
                </div>
            }
        </div>
    }
    else if (HasItems)
    {
        <div class="tag-detail-paginator" data-tag="@Tag" data-page="1">
            <PosterGrid Items="_items" EmptyMessage="@EmptyMessage" />
            <div class="paginator-loader" hidden="@(!_loading)" aria-hidden="true">
                <div class="paginator-loader-spinner"></div>
            </div>
            <div class="tag-detail-sentinel" aria-hidden="true"></div>
        </div>
    }
    else
    {
        <PosterGrid Items="_items" EmptyMessage="@EmptyMessage" />
    }

    @if (_canLoadMore)
    {
        <div class="discover-pagination">
            <button type="button" class="discover-paginator" disabled="@_loading" @onclick="LoadMore">
                @(_loading ? "Loading…" : "Load more")
            </button>
        </div>
    }
</section>

@code {
    [Parameter] public string Tag { get; set; } = "";

    private readonly List<MetaDto> _items = new();
    private bool _loading;
    private bool _canLoadMore;

    private bool HasItems => _items.Count > 0;
    private string EmptyMessage => $"No anime found for the {Tag} tag.";

    protected override async Task OnParametersSetAsync()
    {
        _items.Clear();
        _canLoadMore = false;
        await Load();
    }

    private Task LoadMore() => Load();

    private async Task Load()
    {
        _loading = true;
        StateHasChanged();
        var skip = _items.Count > 0 ? _items.Count.ToString() : null;
        var resp = await Api.DiscoverByTagAsync(Tag, skip);
        _items.AddRange(resp.Items);
        _canLoadMore = resp.HasNextPage;
        _loading = false;
        StateHasChanged();
    }
}
