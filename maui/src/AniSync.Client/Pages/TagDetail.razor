@page "/discover/tag/{Tag}"
@implements IAsyncDisposable
@inject IAniSyncApi Api
@inject IJSRuntime JS
@inject IPrerenderSession Prerender

@* Anime tagged with {Tag} — port of Views/Discover/TagDetail.cshtml. Poster grid with
   infinite scroll: tag-detail-pagination.js watches .tag-detail-sentinel and pulls the
   next 1-indexed page (server reports HasNextPage). Here the JS owns only the
   IntersectionObserver (discover-scroll.js); the fetch + append stay in Blazor,
   mirroring the sibling Studios.razor listing page. *@

<PageTitle>@Tag · AniSync</PageTitle>

<section>
    <header class="page-header">
        <p class="page-subtitle">Tag</p>
        <h1 class="page-title">@Tag</h1>
    </header>

    @if (_loading && _items.Count == 0)
    {
        <div class="library-grid">
            @for (var i = 0; i < 12; i++)
            {
                <div class="library-card library-card-skeleton">
                    <div class="library-card-poster-wrap"><div class="library-card-poster skeleton-shimmer"></div></div>
                    <span class="library-card-skeleton-line"></span>
                </div>
            }
        </div>
    }
    else if (HasItems)
    {
        <div class="tag-detail-paginator" data-tag="@Tag" data-page="@_page">
            <PosterGrid Items="_items" EmptyMessage="@EmptyMessage" />
            <div class="paginator-loader" hidden="@(!_loading)" aria-hidden="true">
                <div class="paginator-loader-spinner"></div>
            </div>
            <div class="tag-detail-sentinel" @ref="_sentinel" aria-hidden="true"></div>
        </div>
    }
    else
    {
        <PosterGrid Items="_items" EmptyMessage="@EmptyMessage" />
    }
</section>

@code {
    [Parameter] public string Tag { get; set; } = "";

    private readonly List<MetaDto> _items = new();
    private bool _loading;
    private bool _done;
    private int _page = 1;   // 1-indexed; the next page to request is _page (see LoadPageAsync).

    private ElementReference _sentinel;
    private IJSObjectReference? _scroll;
    private DotNetObjectReference<TagDetail>? _selfRef;
    private int _observerId;

    private bool HasItems => _items.Count > 0;
    private string EmptyMessage => $"No anime found for the {Tag} tag.";

    protected override async Task OnParametersSetAsync()
    {
        var key = PersistKey();

        // Interactive remount after a prerender: replay the stashed first page instead of resetting to
        // the skeleton + refetching, so a refresh doesn't flash content → skeleton → content. Infinite
        // scroll resumes from the replayed _page. Native + client-side navigations fall through.
        if (RendererInfo.IsInteractive && _appliedKey != key
            && Prerender.TryReplay<PersistedTag?>(key, out var snap) && snap is not null)
        {
            _appliedKey = key;
            RestoreTag(snap);
            return;
        }
        if (_appliedKey == key) return;   // already loaded/replayed this exact view; ignore redundant re-renders

        _items.Clear();
        _page = 1;
        _done = false;
        _loading = true;
        StateHasChanged();
        await LoadPageAsync(initial: true);

        _appliedKey = key;
        // Prerender: stash the first-page snapshot so the interactive remount replays it. Web-only.
        if (!RendererInfo.IsInteractive)
            Prerender.Persist<PersistedTag>(key, RendererInfo.IsInteractive, Snapshot);
    }

    private string? _appliedKey;
    private string PersistKey() => $"tag:{Tag}";

    private sealed record PersistedTag(List<MetaDto> Items, int Page, bool Done);

    private PersistedTag Snapshot() => new(_items.ToList(), _page, _done);

    private void RestoreTag(PersistedTag snap)
    {
        _items.Clear();
        _items.AddRange(snap.Items);
        _page = snap.Page;
        _done = snap.Done;
        _loading = false;
    }

    [JSInvokable]
    public async Task OnSentinelVisibleAsync()
    {
        if (_done || _loading) return;
        await LoadPageAsync(initial: false);
    }

    private async Task LoadPageAsync(bool initial)
    {
        if (!initial && (_loading || _done)) return;
        _loading = true;
        if (!initial) StateHasChanged();

        TagMediaResponse resp;
        try { resp = await Api.DiscoverByTagAsync(Tag, _page); }
        catch { resp = new(); }

        _items.AddRange(resp.Items);
        if (!resp.HasNextPage) _done = true;
        else _page++;

        _loading = false;
        StateHasChanged();
        if (_observerId != 0 && !_done && _scroll is not null)
        {
            try { await _scroll.InvokeVoidAsync("reobserve", _observerId); } catch { }
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _selfRef = DotNetObjectReference.Create(this);
            try { _scroll = await JS.InvokeAsync<IJSObjectReference>("import", "./_content/AniSync.Client/js/discover-scroll.js"); }
            catch { return; }
        }
        if (_scroll is null) return;

        var paginatorRendered = HasItems && !_done;   // sentinel only renders with the grid
        if (paginatorRendered && _observerId == 0)
        {
            try { _observerId = await _scroll.InvokeAsync<int>("observe", _sentinel, _selfRef); } catch { }
        }
        else if (!paginatorRendered && _observerId != 0)
        {
            try { await _scroll.InvokeVoidAsync("disconnect", _observerId); } catch { }
            _observerId = 0;
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_scroll is not null)
        {
            if (_observerId != 0) { try { await _scroll.InvokeVoidAsync("disconnect", _observerId); } catch { } }
            try { await _scroll.DisposeAsync(); } catch { }
        }
        _selfRef?.Dispose();
    }
}
