@page "/discover/studio"
@implements IAsyncDisposable
@inject IAniSyncApi Api
@inject AppState State
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject IPrerenderSession Prerender

@* Browse by studio — 1:1 port of Views/Discover/Studios.cshtml. Shared Discover tab strip
   (Studios pill active) + a server-side search + a popularity-sorted studio-tile grid with
   infinite scroll. Tapping a tile opens /discover/studio/{id}. Anime-only surface — a switch
   to movies/series bounces to /discover. *@

<PageTitle>Studios</PageTitle>

<DiscoverTabs ActiveBrowse="studios" />

<form class="filter-bar" role="search" @onsubmit="ApplySearch">
    <input type="search" @bind="_searchInput" @bind:event="oninput"
           placeholder="Search studios…" class="filter-bar-search" autocomplete="off" />
    <button type="submit" class="filter-bar-submit">Search</button>
    @if (!string.IsNullOrWhiteSpace(Search))
    {
        <a class="filter-bar-clear" href="/discover/studio">Clear</a>
    }
</form>

@if (_loading && _studios.Count == 0)
{
    <div class="studio-paginator">
        <div class="studio-grid">
            @for (var i = 0; i < 12; i++)
            {
                <div class="studio-tile studio-tile-skeleton">
                    <span class="studio-tile-name skeleton-shimmer"></span>
                    <span class="studio-tile-count skeleton-shimmer"></span>
                </div>
            }
        </div>
    </div>
}
else if (_studios.Count == 0)
{
    <p class="hint-text">@(string.IsNullOrWhiteSpace(Search)
        ? "No studios available right now. Try again in a moment."
        : $"No studios match \"{Search}\".")</p>
}
else
{
    <div class="studio-paginator">
        <div class="studio-grid">
            @foreach (var s in _studios)
            {
                <a class="studio-tile" href="@($"/discover/studio/{s.Id}")" data-studio-id="@s.Id">
                    <span class="studio-tile-name">@s.Name</span>
                    <span class="studio-tile-count">@s.AnimeCount anime</span>
                </a>
            }
        </div>
        <div class="paginator-loader" hidden="@(!(_loading && _studios.Count > 0))" aria-hidden="true">
            <div class="paginator-loader-spinner"></div>
        </div>
        <div class="studio-sentinel" @ref="_sentinel" aria-hidden="true"></div>
    </div>
}

@code {
    [SupplyParameterFromQuery] public string? Search { get; set; }

    private readonly List<StudioSummaryDto> _studios = new();
    private string _searchInput = "";
    private bool _loading;
    private bool _done;
    private int _page = 1;

    private ElementReference _sentinel;
    private IJSObjectReference? _scroll;
    private DotNetObjectReference<Studios>? _selfRef;
    private int _observerId;

    protected override void OnInitialized() => State.Changed += OnStateChanged;

    protected override async Task OnParametersSetAsync()
    {
        var key = PersistKey();

        // Interactive remount after a prerender: replay the stashed first page (keyed by the active
        // search) instead of refetching, so a refresh doesn't flash content → skeleton → content.
        // Consumed once; a real client-side navigation changes the key and falls through to a fresh load.
        if (RendererInfo.IsInteractive && _appliedKey != key
            && Prerender.TryReplay<PersistedStudios?>(key, out var snap) && snap is not null)
        { _appliedKey = key; RestoreStudios(snap); return; }
        if (_appliedKey == key) return;

        // Anime-only surface; a movie/series preference belongs on /discover's video browse.
        if (State.MediaTypesHydrated && State.MediaType != MetaType.anime) { Nav.NavigateTo("/discover"); return; }

        _searchInput = Search ?? "";
        _studios.Clear();
        _page = 1;
        _done = false;
        _loading = true;
        StateHasChanged();
        await LoadPageAsync(initial: true);

        _appliedKey = key;
        // Prerender: stash the loaded first page so the interactive remount replays it (above). Web-only;
        // no-op on native and on the interactive pass.
        if (!RendererInfo.IsInteractive) Prerender.Persist<PersistedStudios>(key, RendererInfo.IsInteractive, Snapshot);
    }

    // ── Prerender → interactive replay (web only; no-op on native) ──────────────────────────────
    private string? _appliedKey;

    // Keyed by the active search so a stashed page is never replayed onto a different query.
    private string PersistKey() => $"studios:{Search}";

    private sealed record PersistedStudios(List<StudioSummaryDto> Studios, int Page, bool Done);

    private PersistedStudios Snapshot() => new(_studios.ToList(), _page, _done);

    private void RestoreStudios(PersistedStudios snap)
    {
        _studios.Clear();
        _studios.AddRange(snap.Studios);
        _page = snap.Page;
        _done = snap.Done;
        _searchInput = Search ?? "";
        _loading = false;
    }

    [JSInvokable]
    public async Task OnSentinelVisibleAsync()
    {
        if (_done || _loading) return;
        await LoadPageAsync(initial: false);
    }

    private async Task LoadPageAsync(bool initial)
    {
        if (!initial && (_loading || _done)) return;
        _loading = true;
        if (!initial) StateHasChanged();

        StudiosListResponse resp;
        try { resp = await Api.StudiosAsync(_page, string.IsNullOrWhiteSpace(Search) ? null : Search); }
        catch { resp = new(); }

        _studios.AddRange(resp.Studios);
        if (resp.Studios.Count == 0 || !resp.HasNextPage) _done = true;
        else _page++;

        _loading = false;
        StateHasChanged();
        if (_observerId != 0 && !_done && _scroll is not null)
        {
            try { await _scroll.InvokeVoidAsync("reobserve", _observerId); } catch { }
        }
    }

    private void ApplySearch()
    {
        var s = _searchInput.Trim();
        Nav.NavigateTo(string.IsNullOrWhiteSpace(s) ? "/discover/studio" : $"/discover/studio?search={Uri.EscapeDataString(s)}");
    }

    private void OnStateChanged()
    {
        if (State.MediaType != MetaType.anime) Nav.NavigateTo("/discover");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _selfRef = DotNetObjectReference.Create(this);
            try { _scroll = await JS.InvokeAsync<IJSObjectReference>("import", "./_content/AniSync.Client/js/discover-scroll.js"); }
            catch { return; }
        }
        if (_scroll is null) return;

        var paginatorRendered = _studios.Count > 0;   // sentinel only renders with the tile grid
        if (paginatorRendered && _observerId == 0)
        {
            try { _observerId = await _scroll.InvokeAsync<int>("observe", _sentinel, _selfRef); } catch { }
        }
        else if (!paginatorRendered && _observerId != 0)
        {
            try { await _scroll.InvokeVoidAsync("disconnect", _observerId); } catch { }
            _observerId = 0;
        }
    }

    public async ValueTask DisposeAsync()
    {
        State.Changed -= OnStateChanged;
        if (_scroll is not null)
        {
            if (_observerId != 0) { try { await _scroll.InvokeVoidAsync("disconnect", _observerId); } catch { } }
            try { await _scroll.DisposeAsync(); } catch { }
        }
        _selfRef?.Dispose();
    }
}
