@page "/discover/tag"
@implements IDisposable
@inject IAniSyncApi Api
@inject AppState State
@inject NavigationManager Nav

@* Browse by tag — 1:1 port of Views/Discover/Tags.cshtml. Shared Discover tab strip (Tags pill
   active) + every AniList tag grouped by category, with a client-side name filter (Esc clears).
   Tapping a tile opens /discover/tag/{name}. Anime-only surface — a switch to movies/series
   bounces to /discover. *@

<PageTitle>Tags</PageTitle>

<DiscoverTabs ActiveBrowse="tags" />

@if (_loading)
{
    <p class="hint-text">Loading tags…</p>
}
else if (_tags.Count == 0)
{
    <p class="hint-text">No tags available right now. Try again in a moment.</p>
}
else
{
    <div class="filter-bar" role="search">
        <input type="search" class="filter-bar-search" placeholder="Filter tags…" autocomplete="off"
               spellcheck="false" aria-label="Filter tags"
               @bind="_filter" @bind:event="oninput" @onkeydown="OnKeyDown" />
    </div>

    @if (!_grouped.Any())
    {
        <p class="hint-text">No tags match.</p>
    }
    else
    {
        @foreach (var group in _grouped)
        {
            <section class="tag-group">
                <h2 class="tag-group-title">@group.Key</h2>
                <div class="tag-grid">
                    @foreach (var t in group)
                    {
                        <a class="tag-tile" href="@TagHref(t.Name)" data-tag-name="@t.Name" title="@t.Description">
                            <span class="tag-tile-name">@t.Name</span>
                        </a>
                    }
                </div>
            </section>
        }
    }
}

@code {
    private IReadOnlyList<TagSummaryDto> _tags = Array.Empty<TagSummaryDto>();
    private bool _loading = true;
    private string _filter = "";

    protected override void OnInitialized() => State.Changed += OnStateChanged;

    protected override async Task OnInitializedAsync()
    {
        if (State.MediaTypesHydrated && State.MediaType != MetaType.anime) { Nav.NavigateTo("/discover"); return; }
        _tags = await Api.TagsAsync();
        _loading = false;
    }

    // Group by AniList category (uncategorised → "Other"), filtered by the live name query.
    private IEnumerable<IGrouping<string, TagSummaryDto>> _grouped =>
        _tags
            .Where(t => string.IsNullOrWhiteSpace(_filter)
                        || (t.Name?.Contains(_filter.Trim(), StringComparison.OrdinalIgnoreCase) ?? false))
            .GroupBy(t => string.IsNullOrWhiteSpace(t.Category) ? "Other" : t.Category!)
            .OrderBy(g => g.Key, StringComparer.OrdinalIgnoreCase);

    private void OnKeyDown(KeyboardEventArgs e) { if (e.Key == "Escape") _filter = ""; }

    private void OnStateChanged()
    {
        if (State.MediaType != MetaType.anime) Nav.NavigateTo("/discover");
    }

    private static string TagHref(string name) => $"/discover/tag/{Uri.EscapeDataString(name)}";

    public void Dispose() => State.Changed -= OnStateChanged;
}
