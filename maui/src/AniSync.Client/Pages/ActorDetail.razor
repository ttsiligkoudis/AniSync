@page "/discover/actor/tmdb/{TmdbId:int}"
@page "/discover/actor/{Slug}"
@inject IAniSyncApi Api
@inject IPrerenderSession Prerender

@* Actor filmography — port of Views/Discover/ActorDetail.cshtml. Movies + series
   credits (Trakt-backed) as poster grids that link into the video detail pages.
   Reached two ways: the /discover/actors directory links by TMDB id (tmdb/{id}, bridged to a Trakt slug
   server-side), and the video detail cast cards link by Trakt slug ({slug}, e.g. "ray-lui-443355"). *@

<PageTitle>@Title · AniSync</PageTitle>

<section>
    <header class="page-header actor-header">
        <span class="actor-header-avatar">
            <span class="actor-header-avatar-initial" aria-hidden="true">@Initial</span>
            @if (!string.IsNullOrEmpty(_credits?.Image))
            {
                <img class="actor-header-avatar-img" src="@_credits.Image" alt="" loading="lazy"
                     decoding="async" onerror="this.remove()" />
            }
        </span>
        <span class="actor-header-text">
            <span class="page-subtitle">Movies &amp; Series</span>
            <h1 class="page-title">@Title</h1>
        </span>
    </header>

    @if (_loading)
    {
        @* Skeleton mirroring the loaded layout (Movies + Series poster groups) instead of a bare
           "Loading…" line — same idiom as the other poster pages (StaffDetail / StudioDetail). *@
        @foreach (var group in new[] { "Movies", "Series" })
        {
            <section class="discover-group">
                <h2 class="discover-group-title">@group</h2>
                <div class="library-grid">
                    @for (var i = 0; i < 12; i++)
                    {
                        <div class="library-card library-card-skeleton">
                            <div class="library-card-poster-wrap"><div class="library-card-poster skeleton-shimmer"></div></div>
                            <span class="library-card-skeleton-line"></span>
                        </div>
                    }
                </div>
            </section>
        }
    }
    else if (_credits is null || (_credits.Movies.Count == 0 && _credits.Series.Count == 0))
    {
        <p class="hint-text">No titles found for @Title.</p>
    }
    else
    {
        @if (_credits.Movies.Count > 0)
        {
            <section class="discover-group">
                <h2 class="discover-group-title">Movies</h2>
                <PosterGrid Items="_credits.Movies" VideoLinks="true" />
            </section>
        }
        @if (_credits.Series.Count > 0)
        {
            <section class="discover-group">
                <h2 class="discover-group-title">Series</h2>
                <PosterGrid Items="_credits.Series" VideoLinks="true" />
            </section>
        }
    }
</section>

@code {
    // Exactly one is set per route: TmdbId from /discover/actor/tmdb/{id}, Slug from /discover/actor/{slug}.
    [Parameter] public int TmdbId { get; set; }
    [Parameter] public string? Slug { get; set; }

    private ActorCreditsResponse? _credits;
    private bool _loading = true;

    private string Title => string.IsNullOrEmpty(_credits?.Name) ? "Actor" : _credits!.Name!;
    private string Initial => string.IsNullOrEmpty(Title) ? "?" : Title[..1];

    protected override async Task OnParametersSetAsync()
    {
        var key = PersistKey();

        // Interactive remount after a prerender: replay the stashed credits instead of resetting to the
        // skeleton + refetching, so a refresh doesn't flash content → "Loading…" → content. Native and
        // client-side navigations (no stash) fall through to a normal load.
        if (RendererInfo.IsInteractive && _appliedKey != key
            && Prerender.TryReplay<PersistedActor?>(key, out var snap) && snap is not null)
        {
            _appliedKey = key;
            RestoreActor(snap);
            return;
        }
        if (_appliedKey == key) return;   // already loaded/replayed this exact view; ignore redundant re-renders

        _loading = true;
        // Slug route → look up the Trakt person directly; tmdb route → bridge the id to a slug server-side.
        _credits = string.IsNullOrEmpty(Slug)
            ? await Api.ActorCreditsAsync(TmdbId)
            : await Api.ActorCreditsBySlugAsync(Slug);
        _loading = false;

        _appliedKey = key;
        // Prerender: stash a snapshot so the interactive remount replays it. Web-only; no-op otherwise.
        if (!RendererInfo.IsInteractive)
            Prerender.Persist<PersistedActor>(key, RendererInfo.IsInteractive, Snapshot);
    }

    private string? _appliedKey;
    private string PersistKey() => $"actor:{(string.IsNullOrEmpty(Slug) ? "tmdb" + TmdbId : Slug)}";

    private sealed record PersistedActor(ActorCreditsResponse? Credits);

    private PersistedActor Snapshot() => new(_credits);

    private void RestoreActor(PersistedActor snap)
    {
        _credits = snap.Credits;
        _loading = false;
    }
}
