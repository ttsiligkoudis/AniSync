@page "/library"
@implements IDisposable
@inject IAniSyncApi Api
@inject AppState State
@inject NavigationManager Nav

@* Library — port of Views/Library/Index.cshtml. Status tabs (Watching /
   Completed / Planning / Paused / Dropped / Rewatching) over /api/v1/me/list,
   plus a search filter, rendered as a poster grid. User-scoped, so it needs the
   config credential; when streaming/sign-in isn't set up it shows the same
   "sign in" prompt the web app does for anonymous visitors. *@

<PageTitle>Library · AniSync</PageTitle>

<section>
    @if (string.IsNullOrEmpty(State.StreamConfig))
    {
        <h1 class="dashboard-section-title">Library</h1>
        <p class="hint-text">
            <a href="/login">Sign in</a> to see your tracked library here.
        </p>
    }
    else
    {
        <nav class="library-tabs" role="tablist" aria-label="Library lists">
            @foreach (var (status, label) in Tabs)
            {
                <button type="button" role="tab"
                        class="library-tab @(_status == status ? "library-tab-active" : "")"
                        aria-selected="@(_status == status)"
                        @onclick="() => SetStatus(status)">
                    @label
                </button>
            }
        </nav>

        <form class="filter-bar" role="search" @onsubmit:preventDefault>
            <input type="search" class="filter-bar-search" placeholder="Search your list…"
                   value="@_search" @oninput="OnSearch" autocomplete="off" />
            @if (_genreOptions.Count > 0)
            {
                <select class="filter-bar-select" @bind="_genre">
                    <option value="">All genres</option>
                    @foreach (var g in _genreOptions)
                    {
                        <option value="@g">@g</option>
                    }
                </select>
            }
            <select class="filter-bar-select" @bind="_sort">
                <option value="default">Default order</option>
                <option value="az">A–Z</option>
                <option value="za">Z–A</option>
            </select>
        </form>

        <div class="library-results-pane">
            @if (_loading)
            {
                <div class="library-grid">
                    @for (var i = 0; i < 12; i++)
                    {
                        <div class="library-card library-card-skeleton">
                            <div class="library-card-poster-wrap"><div class="library-card-poster skeleton-shimmer"></div></div>
                            <span class="library-card-skeleton-line"></span>
                            <span class="library-card-skeleton-line library-card-skeleton-line-short"></span>
                        </div>
                    }
                </div>
            }
            else
            {
                <PosterGrid Items="_filtered" Variant="grid" VideoLinks="@(!IsAnime)"
                            EmptyMessage="@($"Nothing in your {_activeLabel} list.")" />
            }
        </div>
    }
</section>

@code {
    // Anime tracks the merged tracker lists (six statuses); movies / series come from
    // Trakt, which only maps onto Continue Watching / Watched / Watchlist.
    private static readonly (string Status, string Label)[] AnimeTabs =
    {
        ("current", "Watching"), ("completed", "Completed"), ("planning", "Planning"),
        ("paused", "Paused"), ("dropped", "Dropped"), ("repeating", "Rewatching"),
    };
    private static readonly (string Status, string Label)[] VideoTabs =
    {
        ("current", "Continue Watching"), ("completed", "Watched"), ("planning", "Watchlist"),
    };

    private bool IsAnime => State.MediaType == MetaType.anime;
    private (string Status, string Label)[] Tabs => IsAnime ? AnimeTabs : VideoTabs;

    private string _status = "current";
    private string _search = "";
    private string _genre = "";
    private string _sort = "default";
    private bool _loading;
    private IReadOnlyList<MetaDto> _items = Array.Empty<MetaDto>();

    private string _activeLabel => Tabs.FirstOrDefault(t => t.Status == _status).Label ?? "";

    // Genre options are derived from the loaded list so they always match what's
    // actually filterable (the list API doesn't take a genre parameter).
    private IReadOnlyList<string> _genreOptions =>
        _items.Where(m => m.Genres is { Count: > 0 })
            .SelectMany(m => m.Genres!)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(g => g)
            .ToList();

    private IReadOnlyList<MetaDto> _filtered
    {
        get
        {
            IEnumerable<MetaDto> q = _items;
            if (!string.IsNullOrWhiteSpace(_search))
                q = q.Where(m => m.Name.Contains(_search.Trim(), StringComparison.OrdinalIgnoreCase));
            if (!string.IsNullOrEmpty(_genre))
                q = q.Where(m => m.Genres is { Count: > 0 }
                                 && m.Genres!.Contains(_genre, StringComparer.OrdinalIgnoreCase));
            q = _sort switch
            {
                "az" => q.OrderBy(m => m.Name, StringComparer.OrdinalIgnoreCase),
                "za" => q.OrderByDescending(m => m.Name, StringComparer.OrdinalIgnoreCase),
                _ => q,
            };
            return q.ToList();
        }
    }

    protected override void OnInitialized() => State.Changed += OnStateChanged;

    protected override Task OnInitializedAsync() => Load();

    private async Task Load()
    {
        if (string.IsNullOrEmpty(State.StreamConfig)) return;
        // The active tab may not exist for the current media type (e.g. switching to
        // movies while on the anime-only "Rewatching" tab) — clamp to a valid one.
        if (!Tabs.Any(t => t.Status == _status)) _status = "current";

        _loading = true;
        StateHasChanged();
        _items = IsAnime
            ? await Api.ListAsync(_status)
            : await Api.VideoListAsync(State.MediaType == MetaType.movie ? "movie" : "series", _status);
        _loading = false;
        StateHasChanged();
    }

    private async void SetStatus(string status)
    {
        if (_status == status) return;
        _status = status;
        _search = "";
        _genre = "";
        await Load();
    }

    private void OnSearch(ChangeEventArgs e) => _search = e.Value?.ToString() ?? "";

    private async void OnStateChanged() => await InvokeAsync(Load);

    public void Dispose() => State.Changed -= OnStateChanged;
}
