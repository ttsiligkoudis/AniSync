@page "/library"
@implements IDisposable
@inject IAniSyncApi Api
@inject AppState State
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject IPrerenderSession Prerender

@* Library — port of Views/Library/Index.cshtml. Status tabs (Watching /
   Completed / Planning / Paused / Dropped / Rewatching) over /api/v1/me/list
   (anime) or /api/v1/me/video-list (movies / series, Trakt), plus a server-side
   genre + search filter, rendered as a poster grid. The active tab + filters live
   in the query string so the page deep-links like the original (the dashboard
   "View all · …" links carry ?list=&type=, and the back button works). User-scoped,
   so it needs the config credential; when sign-in isn't set up it shows the same
   "sign in" prompt the web app does for anonymous visitors. *@

<PageTitle>@_pageTitle</PageTitle>

@* No wrapper element: the tabs / filter bar / results pane are direct children of <main> so they
   pick up its column gap (var(--space-5)) — same as Discover. A wrapping <section> would collapse
   them into one flex child and the page would render with no spacing between the filter bar and grid. *@

@* Content shows as soon as we have a credential — seeded server-side from the anisync_uid cookie
       during prerender, replayed on the interactive remount (_replayed), or hydrated from localStorage.
       Only once we KNOW there's no credential (ConfigHydrated && none) do we show "Sign in"; before
       that we render a neutral skeleton rather than flashing the signed-out prompt. *@
    @if (_replayed || !string.IsNullOrEmpty(State.StreamConfig))
    {
        @* List-type tabs lead the page. Each is an anchor — clicking navigates with
           the selected list. The active genre flows through so switching from
           Watching → Completed keeps the genre filter applied (the original does
           the same: genre rides every tab href, search does not). *@
        <nav class="library-tabs" role="tablist" aria-label="Library lists">
            @foreach (var (status, label) in Tabs)
            {
                var isActive = _status == status;
                <a class="library-tab @(isActive ? "library-tab-active" : "")"
                   href="@TabHref(status)"
                   role="tab"
                   aria-selected="@(isActive ? "true" : "false")">
                    @label
                </a>
            }
        </nav>

        @* Combined filter form: search input + genre dropdown + explicit Search
           button. Nothing auto-submits — the user picks filters then commits them
           together. Submitting navigates (deep-linkable + back-button friendly);
           the server does the genre filter + ScoreMatch search ranking. *@
        <form class="filter-bar" role="search" @onsubmit="ApplyFilters" @onsubmit:preventDefault>
            <input type="search" class="filter-bar-search" placeholder="@($"Search {_noun}…")"
                   @bind="_searchInput" @bind:event="oninput" autocomplete="off" />
            @* The genre dropdown is an AniList/MAL/Kitsu catalog filter — it doesn't apply to
               the Trakt-sourced movie / series lists, so it's anime-only. *@
            @if (IsAnime)
            {
                <select class="filter-bar-select" aria-label="Genre" @bind="_genreInput">
                    <option value="">All genres</option>
                    @foreach (var g in PopularGenres)
                    {
                        <option value="@g">@g</option>
                    }
                </select>
            }
            <button type="submit" class="filter-bar-submit">Search</button>
            @if (_hasSearch || _hasGenre)
            {
                <a class="filter-bar-clear" href="@ClearHref()">Clear</a>
            }
        </form>

        <div id="library-results-pane">
            @* Skeleton only when there's nothing to show. On a reload we keep the current PosterGrid
               mounted (items aren't cleared until the new ones arrive in Load) so the posters don't
               blank then re-flash — @key on the cards preserves the ones that carry over. *@
            @if (_loading && _items.Count == 0)
            {
                <div class="library-grid">
                    @for (var i = 0; i < 12; i++)
                    {
                        <div class="library-card library-card-skeleton">
                            <div class="library-card-poster-wrap"><div class="library-card-poster skeleton-shimmer"></div></div>
                            <span class="library-card-skeleton-line"></span>
                            <span class="library-card-skeleton-line library-card-skeleton-line-short"></span>
                        </div>
                    }
                </div>
            }
            else
            {
                <PosterGrid Items="_items" Variant="grid" VideoLinks="@(!IsAnime)"
                            EmptyMessage="@_emptyMessage" />
            }
        </div>
    }
    else if (State.ConfigHydrated)
    {
        <h1 class="dashboard-section-title">Library</h1>
        <p class="hint-text">
            <a href="/login">Sign in</a> to see your tracked library here.
        </p>
    }
    else
    {
        <h1 class="dashboard-section-title">Library</h1>
        <div class="library-grid">
            @for (var i = 0; i < 12; i++)
            {
                <div class="library-card library-card-skeleton">
                    <div class="library-card-poster-wrap"><div class="library-card-poster skeleton-shimmer"></div></div>
                    <span class="library-card-skeleton-line"></span>
                    <span class="library-card-skeleton-line library-card-skeleton-line-short"></span>
                </div>
            }
        </div>
    }

@code {
    // ── Query string: deep-link entry points; tabs + the filter bar navigate by rewriting these. ──
    [SupplyParameterFromQuery] public string? List { get; set; }
    [SupplyParameterFromQuery] public string? Genre { get; set; }
    [SupplyParameterFromQuery] public string? Search { get; set; }
    [SupplyParameterFromQuery] public string? Type { get; set; }

    // Same vocabulary for both anime and video now — video's Paused / Dropped ride
    // AniSync-managed Trakt personal lists. Anime adds the extra Rewatching tab;
    // video stops at Dropped (no Repeating list type upstream). Order = LibraryController's
    // UserListTypes / VideoListTypes.
    private static readonly (string Status, string Label)[] AnimeTabs =
    {
        ("current", "Watching"), ("completed", "Completed"), ("planning", "Planning"),
        ("paused", "On Hold"), ("dropped", "Dropped"), ("repeating", "Rewatching"),
    };
    private static readonly (string Status, string Label)[] VideoTabs =
    {
        ("current", "Watching"), ("completed", "Completed"), ("planning", "Planning"),
        ("paused", "On Hold"), ("dropped", "Dropped"),
    };

    // Mirrors LibraryController.PopularGenres (== DiscoverController.PopularGenres) — the
    // fixed anime-genre picker, surfaced as a server-side filter on the merged list.
    private static readonly string[] PopularGenres =
    {
        "Action", "Adventure", "Comedy", "Drama", "Slice of Life",
        "Romance", "Fantasy", "Sci-Fi", "Mystery", "Psychological",
        "Sports", "Supernatural", "Music", "Horror", "Thriller",
    };

    private bool IsAnime => State.MediaType == MetaType.anime;
    private (string Status, string Label)[] Tabs => IsAnime ? AnimeTabs : VideoTabs;

    // ── Surface state, recomputed each Refresh() from the query string. ──
    private string _status = "current";
    private bool _hasSearch;
    private bool _hasGenre;
    private bool _loading;
    private IReadOnlyList<MetaDto> _items = Array.Empty<MetaDto>();
    private string _pageTitle = "Library · AniSync";
    private string _emptyMessage = "";

    // ── Filter inputs (applied together on the Search button / Enter). ──
    private string _searchInput = "";
    private string _genreInput = "";

    // ── Trakt-configured detection for the video empty-state copy (mirrors
    //    LibraryController.VideoPaneAsync's _traktService.IsConfigured). The
    //    server-authoritative video-modes set carries Trakt-only modes only when
    //    the server has Trakt configured, so its presence is the signal. ──
    private bool? _traktConfigured;
    private Task<IReadOnlyList<VideoModeDto>>? _videoModesTask;

    // The user's primary anime service, for the anime empty-state copy
    // ("Nothing in your {label} list on {AnimeService}."). Fetched lazily + cached;
    // /api/v1/me/list doesn't carry it, and LinkedResponse.Primary is the raw
    // anime_service.ToString() the original Model.AnimeService renders. MainLayout
    // already hits this endpoint at startup, so it's typically warm.
    private string? _animeService;
    private Task<LinkedResponse?>? _linkedTask;

    // ── Media-type deep-link bookkeeping (mirrors Discover.razor). ──
    private MetaType _surfaceMediaType;
    private MetaType? _pendingPersistType;

    private string _activeLabel => Tabs.FirstOrDefault(t => t.Status == _status).Label ?? "";

    private string _noun => State.MediaType switch
    {
        MetaType.movie => "movies",
        MetaType.series => "series",
        _ => "anime",
    };

    protected override void OnInitialized()
    {
        _surfaceMediaType = State.MediaType;
        State.Changed += OnStateChanged;
    }

    protected override async Task OnParametersSetAsync()
    {
        var key = LibraryKey();

        // Interactive remount after a prerender: replay the list the prerender stashed (keyed by this
        // exact query) instead of refetching, so a logged-in refresh doesn't flash content → skeleton →
        // content. Consumed once; a later client-side navigation (different query, or nothing stashed)
        // falls through to a normal load.
        if (RendererInfo.IsInteractive && !_replayed
            && Prerender.TryReplay<PersistedLibrary?>(key, out var snap) && snap is not null)
        {
            _replayedKey = key;
            RestoreLibrary(snap);
            return;
        }

        // Already replayed this exact query — don't let a parent (layout) re-render after the credential
        // hydrates re-invoke OnParametersSet and refetch over the replayed list (that would re-introduce
        // the flash). A real client-side navigation changes the key and falls through to a fresh load.
        if (_replayed && _replayedKey == key) return;

        // A ?type= deep-link (dashboard "View all · Series" etc.) overrides the active media
        // mode + persists it; the surface then follows State.MediaType. SetMediaType fires
        // Changed → OnStateChanged → Refresh, so return here to avoid loading twice.
        if (!string.IsNullOrWhiteSpace(Type) && Enum.TryParse<MetaType>(Type, true, out var t) && t != State.MediaType)
        {
            _pendingPersistType = t;
            _surfaceMediaType = t;
            State.SetMediaType(t);
            return;
        }
        await Refresh();
    }

    // ── Prerender → interactive replay (web only; no-op on native) ──────────────────────────────
    private bool _replayed;
    private string? _replayedKey;

    // Keyed by the exact query so a stashed list is never replayed onto a different tab/filter.
    private string LibraryKey() => $"lib:{Type}:{List}:{Search}:{Genre}";

    private sealed record PersistedLibrary(
        List<MetaDto> Items, MetaType Surface, string Status,
        string SearchInput, string GenreInput, bool HasSearch, bool HasGenre,
        string EmptyMessage, string PageTitle);

    private PersistedLibrary SnapshotLibrary() => new(
        _items.ToList(), _surfaceMediaType, _status,
        _searchInput, _genreInput, _hasSearch, _hasGenre, _emptyMessage, _pageTitle);

    private void RestoreLibrary(PersistedLibrary snap)
    {
        _items = snap.Items;
        _surfaceMediaType = snap.Surface;
        _status = snap.Status;
        _searchInput = snap.SearchInput;
        _genreInput = snap.GenreInput;
        _hasSearch = snap.HasSearch;
        _hasGenre = snap.HasGenre;
        _emptyMessage = snap.EmptyMessage;
        _pageTitle = snap.PageTitle;
        _loading = false;
        _replayed = true;
    }

    private async Task Refresh()
    {
        if (string.IsNullOrEmpty(State.StreamConfig)) return;

        _status = ParseStatus(List);
        _hasSearch = !string.IsNullOrWhiteSpace(Search);
        _hasGenre = IsAnime && !string.IsNullOrWhiteSpace(Genre);
        _searchInput = Search ?? "";
        _genreInput = IsAnime ? (Genre ?? "") : "";
        _pageTitle = BuildTitle();

        await Load();
    }

    // Parse ?list= against the active media type's tab set; default to Watching and
    // silently coerce unknown values (matches LibraryController.ParseListType's tolerance).
    private string ParseStatus(string? raw)
    {
        var slug = (raw ?? "").Trim().ToLowerInvariant();
        return Tabs.Any(t => t.Status == slug) ? slug : "current";
    }

    private async Task Load()
    {
        _loading = true;
        // Don't clear _items here — keep the current grid mounted during the fetch so the posters
        // don't blank then re-flash on a reload. The fetch below replaces _items once it returns
        // (the skeleton only shows when _items is empty, i.e. the very first load).
        StateHasChanged();

        if (IsAnime)
        {
            _items = await Api.ListAsync(_status,
                genre: _hasGenre ? Genre : null,
                search: _hasSearch ? Search : null);
            // Only needed for the no-filter empty-state copy; fetch lazily then.
            if (_items.Count == 0 && !_hasSearch && !_hasGenre)
                await EnsureAnimeServiceAsync();
        }
        else
        {
            // Resolve Trakt-configured once (drives the empty-state copy) alongside the list.
            await EnsureTraktConfiguredAsync();
            _items = await Api.VideoListAsync(
                State.MediaType == MetaType.movie ? "movie" : "series", _status,
                search: _hasSearch ? Search : null);
        }

        _emptyMessage = BuildEmptyMessage();
        _loading = false;
        StateHasChanged();

        // Prerender (cookie-seeded credential): stash this list so the interactive remount replays it
        // instead of refetching. Web-only; no-op on native and on the interactive pass.
        if (!RendererInfo.IsInteractive)
            Prerender.Persist<PersistedLibrary>(LibraryKey(), RendererInfo.IsInteractive, SnapshotLibrary);
    }

    // ── Filter-bar submit + tab / clear hrefs (genre rides every tab + the clear link). ──
    private void ApplyFilters()
    {
        var q = new List<string> { $"list={_status}" };
        if (IsAnime && !string.IsNullOrWhiteSpace(_genreInput)) q.Add($"genre={Uri.EscapeDataString(_genreInput)}");
        if (!string.IsNullOrWhiteSpace(_searchInput)) q.Add($"search={Uri.EscapeDataString(_searchInput.Trim())}");
        q.Add($"type={State.MediaType}");
        Nav.NavigateTo("/library?" + string.Join("&", q));
    }

    private string TabHref(string status)
    {
        var q = new List<string> { $"list={status}" };
        // Preserve the active genre across tab switches (the original keeps it; search does not ride).
        if (IsAnime && _hasGenre) q.Add($"genre={Uri.EscapeDataString(Genre!)}");
        q.Add($"type={State.MediaType}");
        return "/library?" + string.Join("&", q);
    }

    private string ClearHref()
    {
        var q = new List<string> { $"list={_status}", $"type={State.MediaType}" };
        return "/library?" + string.Join("&", q);
    }

    private string BuildTitle()
    {
        if (_hasSearch) return $"Search: {Search} · Library";
        if (_hasGenre) return $"{Genre} · {_activeLabel} · Library";
        return $"{_activeLabel} · Library";
    }

    // Empty-state copy: anime mirrors LibraryController (search → genre → default list);
    // video mirrors VideoPaneAsync's Trakt-specific copy + the "not configured" variant.
    private string BuildEmptyMessage()
    {
        if (IsAnime)
        {
            if (_hasSearch) return $"No matches for \"{Search!.Trim()}\".";
            if (_hasGenre) return $"No {Genre!.ToLower()} anime in your {_activeLabel} list.";
            // "…on {AnimeService}." — fall back to the bare sentence if the service is unknown.
            return string.IsNullOrEmpty(_animeService)
                ? $"Nothing in your {_activeLabel} list."
                : $"Nothing in your {_activeLabel} list on {_animeService}.";
        }

        if (_traktConfigured == false)
            return "Trakt isn't configured on this server, so movie / series lists aren't available.";
        if (_hasSearch) return $"No matches for \"{Search!.Trim()}\".";
        var kind = State.MediaType == MetaType.movie ? "movies" : "series";
        var videoLabel = VideoLabel(_status);
        return $"Nothing in your {kind} {videoLabel} on Trakt. Connect Trakt from your Account to track {kind}.";
    }

    // The video tab labels VideoPaneAsync uses in its empty-state copy differ from the
    // tab-strip labels (Continue Watching / Watched / Watchlist for the three Trakt-native
    // lists; On Hold / Dropped keep their strip label).
    private static string VideoLabel(string status) => status switch
    {
        "current" => "Continue Watching",
        "completed" => "Watched",
        "planning" => "Watchlist",
        "paused" => "On Hold",
        "dropped" => "Dropped",
        _ => status,
    };

    private async Task EnsureTraktConfiguredAsync()
    {
        if (_traktConfigured.HasValue) return;
        // The video-modes set is server-authoritative + Trakt-gated: Trakt-only modes
        // (trending/anticipated/watched) appear only when the server has Trakt configured;
        // the Cinemeta-only "popular" is always present. So >1 mode (or any non-popular
        // mode) ⇒ configured. Cache the task so it's fetched at most once.
        _videoModesTask ??= Api.VideoModesAsync();
        var modes = await _videoModesTask;
        // An empty set means the modes call itself failed (the server always returns at least
        // "popular") — leave it unknown so a transient failure doesn't mislabel as "not configured".
        if (modes.Count == 0) { _traktConfigured = null; return; }
        _traktConfigured = modes.Any(m => !string.Equals(m.Slug, "popular", StringComparison.OrdinalIgnoreCase));
    }

    private async Task EnsureAnimeServiceAsync()
    {
        if (_animeService is not null) return;
        _linkedTask ??= Api.LinkedAsync();
        var linked = await _linkedTask;
        _animeService = linked?.Primary ?? "";
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_pendingPersistType is { } pt)
        {
            _pendingPersistType = null;
            await PersistActiveTypeAsync(pt);
        }
    }

    private async Task PersistActiveTypeAsync(MetaType t)
    {
        try
        {
            var mt = await JS.InvokeAsync<IJSObjectReference>("import", "./_content/AniSync.Client/js/media-type.js");
            await mt.InvokeVoidAsync("setActiveOnly", t.ToString());
            await mt.DisposeAsync();
        }
        catch { /* prerender / no JS */ }
    }

    private async void OnStateChanged()
    {
        // Reload only on a genuine media-type switch, and only once media types have hydrated — the
        // cascade of hydration Changed events (config credential, media-type prefs) fires while
        // State.MediaType may still be the transient default, and reloading on that would refetch the
        // already-shown list (the "results render twice" double) or briefly load the wrong surface.
        if (State.MediaTypesHydrated && _surfaceMediaType != State.MediaType)
        {
            _surfaceMediaType = State.MediaType;
            _traktConfigured = null;   // re-derive per surface (anime path ignores it)
            await InvokeAsync(Refresh);
        }
        else
        {
            await InvokeAsync(StateHasChanged);
        }
    }

    public void Dispose() => State.Changed -= OnStateChanged;
}
