@page "/discover/actors"
@implements IAsyncDisposable
@inject IAniSyncApi Api
@inject AppState State
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject IPrerenderSession Prerender

@* Browse by actor — 1:1 port of Views/Discover/Actors.cshtml. The video Discover mode strip
   (Actors pill active) + a TMDB person search + a photo-tile grid with infinite scroll. Each tile
   opens the Trakt-backed filmography at /discover/actor/tmdb/{id}. Movies/series surface — anime
   defaults to movies (there's no anime actor directory), matching the controller. *@

<PageTitle>Actors</PageTitle>

<VideoModeTabs Modes="_modes" ActorsActive="true" Type="@_type" />

<form class="filter-bar" role="search" @onsubmit="ApplySearch">
    <input type="search" @bind="_searchInput" @bind:event="oninput"
           placeholder="Search actors…" class="filter-bar-search" autocomplete="off" />
    <button type="submit" class="filter-bar-submit">Search</button>
    @if (!string.IsNullOrWhiteSpace(Search))
    {
        <a class="filter-bar-clear" href="/discover/actors">Clear</a>
    }
</form>

@if (_loading && _actors.Count == 0)
{
    <p class="hint-text">Loading…</p>
}
else if (_actors.Count == 0)
{
    <p class="hint-text">@(string.IsNullOrWhiteSpace(Search)
        ? "No actors available right now. Try again in a moment."
        : $"No actors match \"{Search}\".")</p>
}
else
{
    <div class="actor-paginator">
        <div class="actor-grid">
            @foreach (var a in _actors)
            {
                <a class="actor-tile" href="@($"/discover/actor/tmdb/{a.TmdbId}")" data-actor-id="@a.TmdbId">
                    <span class="actor-tile-avatar">
                        <span class="actor-tile-initial" aria-hidden="true">@(string.IsNullOrEmpty(a.Name) ? "?" : a.Name[..1])</span>
                        @if (!string.IsNullOrEmpty(a.Image))
                        {
                            <img class="actor-tile-img" src="@a.Image" alt="" loading="lazy" decoding="async" onerror="this.remove()" />
                        }
                    </span>
                    <span class="actor-tile-name">@a.Name</span>
                </a>
            }
        </div>
        <div class="paginator-loader" hidden="@(!(_loading && _actors.Count > 0))" aria-hidden="true">
            <div class="paginator-loader-spinner"></div>
        </div>
        <div class="actor-sentinel" @ref="_sentinel" aria-hidden="true"></div>
    </div>
}

@code {
    [SupplyParameterFromQuery] public string? Type { get; set; }
    [SupplyParameterFromQuery] public string? Search { get; set; }

    private readonly List<ActorSummaryDto> _actors = new();
    private IReadOnlyList<VideoModeDto> _modes = Array.Empty<VideoModeDto>();
    private string _searchInput = "";
    private string _type = "movie";
    private bool _loading;
    private bool _done;
    private int _page = 1;

    private ElementReference _sentinel;
    private IJSObjectReference? _scroll;
    private DotNetObjectReference<Actors>? _selfRef;
    private int _observerId;

    protected override async Task OnInitializedAsync() => _modes = await Api.VideoModesAsync();

    protected override async Task OnParametersSetAsync()
    {
        // Movies + series directory; honour ?type=, else the active video mode. Anime → movie
        // (no anime actor directory), and reflect that in the layout switch so it isn't stranded.
        _type = (Type is "movie" or "series") ? Type!
            : State.MediaType == MetaType.series ? "series" : "movie";
        if (State.MediaType == MetaType.anime)
            State.SetMediaType(_type == "series" ? MetaType.series : MetaType.movie);

        var key = PersistKey();

        // Interactive remount after a prerender: replay the stashed first page (keyed by the resolved
        // type + search) instead of refetching, so a refresh doesn't flash content → skeleton → content.
        // Consumed once; a real client-side navigation changes the key and falls through to a fresh load.
        if (RendererInfo.IsInteractive && _appliedKey != key
            && Prerender.TryReplay<PersistedActors?>(key, out var snap) && snap is not null)
        { _appliedKey = key; RestoreActors(snap); return; }
        if (_appliedKey == key) return;

        _searchInput = Search ?? "";
        _actors.Clear();
        _page = 1;
        _done = false;
        _loading = true;
        StateHasChanged();
        await LoadPageAsync(initial: true);

        _appliedKey = key;
        // Prerender: stash the loaded first page so the interactive remount replays it (above). Web-only;
        // no-op on native and on the interactive pass.
        if (!RendererInfo.IsInteractive) Prerender.Persist<PersistedActors>(key, RendererInfo.IsInteractive, Snapshot);
    }

    // ── Prerender → interactive replay (web only; no-op on native) ──────────────────────────────
    private string? _appliedKey;

    // Keyed by the resolved type + active search so a stashed page is never replayed onto a different query.
    private string PersistKey() => $"actors:{_type}:{Search}";

    private sealed record PersistedActors(List<ActorSummaryDto> Actors, int Page, bool Done);

    private PersistedActors Snapshot() => new(_actors.ToList(), _page, _done);

    private void RestoreActors(PersistedActors snap)
    {
        _actors.Clear();
        _actors.AddRange(snap.Actors);
        _page = snap.Page;
        _done = snap.Done;
        _searchInput = Search ?? "";
        _loading = false;
    }

    [JSInvokable]
    public async Task OnSentinelVisibleAsync()
    {
        if (_done || _loading) return;
        await LoadPageAsync(initial: false);
    }

    private async Task LoadPageAsync(bool initial)
    {
        if (!initial && (_loading || _done)) return;
        _loading = true;
        if (!initial) StateHasChanged();

        ActorsListResponse resp;
        try { resp = await Api.ActorsAsync(_page, string.IsNullOrWhiteSpace(Search) ? null : Search); }
        catch { resp = new(); }

        _actors.AddRange(resp.Actors);
        if (resp.Actors.Count == 0 || !resp.HasNextPage) _done = true;
        else _page++;

        _loading = false;
        StateHasChanged();
        if (_observerId != 0 && !_done && _scroll is not null)
        {
            try { await _scroll.InvokeVoidAsync("reobserve", _observerId); } catch { }
        }
    }

    private void ApplySearch()
    {
        var s = _searchInput.Trim();
        var q = new List<string> { $"type={_type}" };
        if (!string.IsNullOrWhiteSpace(s)) q.Add($"search={Uri.EscapeDataString(s)}");
        Nav.NavigateTo("/discover/actors?" + string.Join("&", q));
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _selfRef = DotNetObjectReference.Create(this);
            try { _scroll = await JS.InvokeAsync<IJSObjectReference>("import", "./_content/AniSync.Client/js/discover-scroll.js"); }
            catch { return; }
        }
        if (_scroll is null) return;

        var paginatorRendered = _actors.Count > 0;
        if (paginatorRendered && _observerId == 0)
        {
            try { _observerId = await _scroll.InvokeAsync<int>("observe", _sentinel, _selfRef); } catch { }
        }
        else if (!paginatorRendered && _observerId != 0)
        {
            try { await _scroll.InvokeVoidAsync("disconnect", _observerId); } catch { }
            _observerId = 0;
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_scroll is not null)
        {
            if (_observerId != 0) { try { await _scroll.InvokeVoidAsync("disconnect", _observerId); } catch { } }
            try { await _scroll.DisposeAsync(); } catch { }
        }
        _selfRef?.Dispose();
    }
}
