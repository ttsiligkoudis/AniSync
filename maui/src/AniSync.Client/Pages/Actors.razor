@page "/discover/actors"
@inject IAniSyncApi Api

@* Browse by actor — port of Views/Discover/Actors.cshtml. TMDB popular people
   (or a name search) as photo tiles with page-based "Load more"; each tile opens
   the Trakt-backed filmography at /discover/actor/tmdb/{id}. *@

<PageTitle>Actors · AniSync</PageTitle>

<section>
    @* Same Discover video nav as /discover with the Actors pill active, so this
       stays inside the Discover surface. The catalog mode pills are server/
       session-driven (Trakt config + login) and aren't exposed to the client,
       so only the always-present active Actors pill is rendered here. *@
    <nav class="library-tabs" role="tablist" aria-label="Discover modes">
        <a class="library-tab library-tab-active" href="/discover/actors" role="tab" aria-selected="true">Actors</a>
    </nav>

    @* Search form — TMDB person search. Posts a full reload (the directory is
       paginated, so a client-side filter would only catch loaded tiles). *@
    <form method="get" action="/discover/actors" class="filter-bar" role="search"
          @onsubmit="Reload" @onsubmit:preventDefault>
        <input type="search"
               name="search"
               value="@_search"
               @oninput="e => _search = e.Value?.ToString() ?? string.Empty"
               placeholder="Search actors…"
               class="filter-bar-search"
               autocomplete="off" />
        <button type="submit" class="filter-bar-submit">Search</button>
        @if (HasSearch)
        {
            <a class="filter-bar-clear" href="/discover/actors" @onclick="Clear" @onclick:preventDefault>Clear</a>
        }
    </form>

    @if (_actors.Count == 0)
    {
        @if (HasSearch)
        {
            <p class="hint-text">No actors match "@_search".</p>
        }
        else
        {
            <p class="hint-text">No actors available right now. Try again in a moment.</p>
        }
    }
    else
    {
        <div class="actor-paginator" data-page="1" data-has-next="@(_canLoadMore ? "true" : "false")" data-search="@_search">
            <div class="actor-grid">
                @foreach (var a in _actors)
                {
                    <a class="actor-tile" href="@($"/discover/actor/tmdb/{a.TmdbId}")" data-actor-id="@a.TmdbId">
                        <span class="actor-tile-avatar">
                            <span class="actor-tile-initial" aria-hidden="true">@(string.IsNullOrEmpty(a.Name) ? "?" : a.Name[..1])</span>
                            @if (!string.IsNullOrEmpty(a.Image))
                            {
                                <img class="actor-tile-img" src="@a.Image" alt="" loading="lazy"
                                     decoding="async" onerror="this.remove()" />
                            }
                        </span>
                        <span class="actor-tile-name">@a.Name</span>
                    </a>
                }
            </div>
            <div class="paginator-loader" hidden="@(!_loading)" aria-hidden="true">
                <div class="paginator-loader-spinner"></div>
            </div>
            <div class="actor-sentinel" aria-hidden="true"></div>
        </div>

        @if (_canLoadMore)
        {
            <div class="discover-pagination">
                <button type="button" class="discover-paginator" disabled="@_loading" @onclick="LoadMore">
                    @(_loading ? "Loading…" : "Load more")
                </button>
            </div>
        }
    }
</section>

@code {
    private readonly List<ActorSummaryDto> _actors = new();
    private string _search = "";
    private bool _loading;
    private bool _canLoadMore;
    private int _page = 1;

    private bool HasSearch => !string.IsNullOrEmpty(_search);

    protected override Task OnInitializedAsync() => Load();

    private async Task Reload()
    {
        _actors.Clear();
        _page = 1;
        _canLoadMore = false;
        await Load();
    }

    private async Task Clear()
    {
        _search = "";
        await Reload();
    }

    private Task LoadMore() => Load();

    private async Task Load()
    {
        _loading = true;
        StateHasChanged();
        var resp = await Api.ActorsAsync(_page, string.IsNullOrWhiteSpace(_search) ? null : _search.Trim());
        _actors.AddRange(resp.Actors);
        _canLoadMore = resp.HasNextPage;
        if (resp.Actors.Count > 0) _page++;
        _loading = false;
        StateHasChanged();
    }
}
