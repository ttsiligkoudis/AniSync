@page "/"
@inject IAniSyncApi Api
@inject AppState State
@inject IJSRuntime JS
@implements IAsyncDisposable

@* Home dashboard — full port of Views/Home/Index.cshtml's section order: the
   optional stream-setup nudge, the "Customize" float, the "Your stats" strip,
   then the anime shelves (Continue watching / New episodes today / Trending /
   Most popular / Most anticipated), then the movie / series (video) shelves for
   the modes the user enabled, the "Browse By" grid, and the layout-chooser modal.
   The fixed media-type switch lives in the layout; each section carries
   data-media-type and hides itself when the dashboard filter excludes it
   (handled inside StatsStrip / DashboardShelf). Every shelf loads independently
   from the existing JSON API. *@

<PageTitle>AniSync</PageTitle>

@* Streaming nudge — logged-in users who haven't configured a stream addon yet.
   The shared banner self-hides via its own client wiring (localStorage dismiss);
   here it's gated on the stored stream config being absent. *@
@if (State.LoggedIn && string.IsNullOrEmpty(State.StreamConfig))
{
    @* Shared "set up streaming" nudge (dismissible variant) — inlined port of
       Views/Shared/_StreamSetupNudge.cshtml. Ships hidden; the global nudge
       wiring reveals it after checking the localStorage dismiss flag. *@
    <section class="stream-nudge" data-stream-nudge hidden>
        <button class="stream-nudge-dismiss" type="button" aria-label="Dismiss" data-stream-nudge-dismiss>
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="18" y1="6" x2="6" y2="18"></line>
                <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
        </button>
        <div class="stream-nudge-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polygon points="5 3 19 12 5 21 5 3"></polygon>
            </svg>
        </div>
        <div class="stream-nudge-body">
            <h3 class="stream-nudge-title">Watch right here, in AniSync</h3>
            <p class="stream-nudge-text">
                Add a stream addon to surface debrid-cached sources on every episode's player.
            </p>
            <div class="stream-nudge-actions">
                <a class="stream-nudge-cta" href="/account#streams">Set up streaming →</a>
                <button class="stream-nudge-learn"
                        type="button"
                        aria-expanded="false"
                        aria-controls="@_nudgeDetailId"
                        data-stream-nudge-toggle>
                    How it works
                </button>
            </div>
            <div id="@_nudgeDetailId" class="stream-nudge-detail">
                <p>
                    A <strong>stream addon</strong> (Torrentio, MediaFusion, Comet,
                    AIOStreams, …) finds torrents for an episode and hands AniSync
                    a list of ready-to-play sources.
                </p>
                <p>
                    Pair it with a <strong>debrid</strong> service (Real-Debrid,
                    AllDebrid, Premiumize, …): paste your debrid API key and the
                    addon unlocks instantly-streamable, cached copies — no
                    downloads, no seeding. The quick setup on
                    <a href="/account#streams">Account → Streams</a> wires both up
                    in one step.
                </p>
            </div>
        </div>
    </section>
}

@* Dashboard customisation entry point — opens the layout chooser modal
   (_DashCustomize, at the bottom). The "is-on-switch-row" modifier lifts it
   onto the pills row only when that bar is present (more than one media type
   enabled); otherwise it sits at the top-right of the content. *@
@if (!State.ConfigHydrated || !State.DashLayoutLoaded)
{
    @* Config credential / saved layout not resolved yet (prerender, pre-hydration, or the
       layout fetch in flight) — render neutral skeleton shelves. Gating on ConfigHydrated
       (not SessionHydrated, which the prerender bridge flips true early for the chrome) means
       the shelves/stats only render once the X-AniSync-Config credential is available, so they
       fetch WITH it (no "logged out on refresh" empty dashboard), AND paint once in the saved
       order/visibility rather than flashing the default order then reordering. *@
    @for (var s = 0; s < 3; s++)
    {
        <section class="dashboard-section">
            <div class="dashboard-section-header">
                <h2 class="dashboard-section-title"><span class="library-card-skeleton-line" style="display:inline-block;width:180px;height:1.1em"></span></h2>
            </div>
            <div data-shelf-container>
                <div class="poster-scroll-row">
                    @for (var i = 0; i < 12; i++)
                    {
                        <div class="library-card library-card-skeleton">
                            <div class="library-card-poster-wrap">
                                <div class="library-card-poster skeleton-shimmer"></div>
                            </div>
                            <span class="library-card-skeleton-line"></span>
                            <span class="library-card-skeleton-line library-card-skeleton-line-short"></span>
                        </div>
                    }
                </div>
            </div>
        </section>
    }
}
else
{
<div class="dash-customize-float @(_combined ? "is-on-switch-row" : "")">
    <button type="button" class="dash-customize-btn" @onclick="() => _customize?.Open()">
        <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="4" y1="21" x2="4" y2="14"></line><line x1="4" y1="10" x2="4" y2="3"></line>
            <line x1="12" y1="21" x2="12" y2="12"></line><line x1="12" y1="8" x2="12" y2="3"></line>
            <line x1="20" y1="21" x2="20" y2="16"></line><line x1="20" y1="12" x2="20" y2="3"></line>
            <line x1="1" y1="14" x2="7" y2="14"></line><line x1="9" y1="8" x2="15" y2="8"></line><line x1="17" y1="16" x2="23" y2="16"></line>
        </svg>
        <span>Customize</span>
    </button>
</div>

<StatsStrip />

@if (_animeEnabled)
{
    @* Continue watching is the user's own progress — only render (and fetch) it when signed in, so a
       logged-out visitor doesn't briefly see the shelf skeleton before it self-hides on an empty fetch. *@
    @if (State.LoggedIn)
    {
        <DashboardShelf Title="@($"Continue watching{_animeSuffix}")"
                        MediaType="anime"
                        DashSection="anime-continue"
                        SkeletonCount="6"
                        CacheKey="shelf.anime-continue"
                        CacheTtl="ShelfTtl"
                        AlwaysRevalidate="true"
                        ViewAllHref="/library?list=current&type=anime"
                        Fetch="@(_ => Api.ContinueWatchingAsync())" />
    }

    <DashboardShelf Title="@($"New Episodes Today{_animeSuffix}")"
                    MediaType="anime"
                    DashSection="anime-new-episodes"
                    MutedNote="Refreshes daily"
                    Fetch="@(_ => Api.AiringTodayAsync())" />

    <DashboardShelf Title="@($"Trending{_animeSuffix}")"
                    MediaType="anime"
                    DashSection="anime-trending"
                    Paginated="true"
                    CacheKey="shelf.anime-trending"
                    CacheTtl="ShelfTtl"
                    ViewAllHref="/discover?list=trending&type=anime"
                    Fetch='@(skip => Api.DiscoverAsync("trending", skip: skip))' />

    <DashboardShelf Title="@($"Most Popular{_animeSuffix}")"
                    MediaType="anime"
                    DashSection="anime-popular"
                    Paginated="true"
                    CacheKey="shelf.anime-popular"
                    CacheTtl="ShelfTtl"
                    ViewAllHref="/discover?list=popular&type=anime"
                    Fetch='@(skip => Api.DiscoverAsync("popular", skip: skip))' />

    <DashboardShelf Title="@($"Most Anticipated{_animeSuffix}")"
                    MediaType="anime"
                    DashSection="anime-anticipated"
                    Paginated="true"
                    CacheKey="shelf.anime-anticipated"
                    CacheTtl="ShelfTtl"
                    ViewAllHref="/discover?list=seasonal&type=anime"
                    Fetch='@(skip => Api.DiscoverAsync("seasonal", skip: skip))' />
}

@* Movie / series (Trakt-backed) shelves — grouped by list type so the page reads
   down the list types (all Continue watching, then all Trending, …), matching the
   web. Continue watching needs a Trakt link, so it self-hides when empty. Titles
   carry the "· Movies / · Series" suffix only when more than one mode is enabled. *@
@if (State.LoggedIn)
{
    @foreach (var vt in _videoTypes)
    {
        <DashboardShelf Title="@($"Continue watching{VideoSuffix(vt)}")"
                        MediaType="@VideoSlug(vt)"
                        DashSection="@($"video-continue-{VideoSlug(vt)}")"
                        VideoLinks="true"
                        SkeletonCount="6"
                        CacheKey="@($"shelf.video-continue-{VideoSlug(vt)}")"
                        CacheTtl="ShelfTtl"
                        AlwaysRevalidate="true"
                        ViewAllHref="@($"/library?list=current&type={VideoSlug(vt)}")"
                        Fetch="@(_ => Api.VideoListAsync(VideoSlug(vt), "current"))" />
    }
}

@foreach (var vt in _videoTypes)
{
    <DashboardShelf Title="@($"Trending{VideoSuffix(vt)}")"
                    MediaType="@VideoSlug(vt)"
                    DashSection="@($"video-trending-{VideoSlug(vt)}")"
                    VideoLinks="true"
                    Paginated="true"
                    CacheKey="@($"shelf.video-trending-{VideoSlug(vt)}")"
                    CacheTtl="ShelfTtl"
                    ViewAllHref="@($"/discover?list=trending&type={VideoSlug(vt)}")"
                    Fetch="@(skip => Api.DiscoverVideoAsync(VideoSlug(vt), "trending", skip))" />
}

@foreach (var vt in _videoTypes)
{
    <DashboardShelf Title="@($"Most Popular{VideoSuffix(vt)}")"
                    MediaType="@VideoSlug(vt)"
                    DashSection="@($"video-popular-{VideoSlug(vt)}")"
                    VideoLinks="true"
                    Paginated="true"
                    CacheKey="@($"shelf.video-popular-{VideoSlug(vt)}")"
                    CacheTtl="ShelfTtl"
                    ViewAllHref="@($"/discover?list=popular&type={VideoSlug(vt)}")"
                    Fetch="@(skip => Api.DiscoverVideoAsync(VideoSlug(vt), "popular", skip))" />
}

@foreach (var vt in _videoTypes)
{
    <DashboardShelf Title="@($"Most Anticipated{VideoSuffix(vt)}")"
                    MediaType="@VideoSlug(vt)"
                    DashSection="@($"video-anticipated-{VideoSlug(vt)}")"
                    VideoLinks="true"
                    Paginated="true"
                    CacheKey="@($"shelf.video-anticipated-{VideoSlug(vt)}")"
                    CacheTtl="ShelfTtl"
                    ViewAllHref="@($"/discover?list=anticipated&type={VideoSlug(vt)}")"
                    Fetch="@(skip => Api.DiscoverVideoAsync(VideoSlug(vt), "anticipated", skip))" />
}

@* Browse By: secondary discovery surfaces. Four browse paths per mode — all
   functional, all under /discover. Trending shows for every mode (no ?type so it
   respects the selected type). *@
<section class="dashboard-section" data-dash-section="browse" style="order:@BrowseOrder" hidden="@BrowseHidden">
    <div class="dashboard-section-header">
        <h2 class="dashboard-section-title">Browse By</h2>
        <span class="dashboard-section-link-muted">Find your next favourite</span>
    </div>
    <div class="browse-grid">
        <div data-media-type="anime movie series" style="display:contents">
        <a class="browse-tile" href="/discover?list=trending">
            <span class="browse-tile-icon browse-tile-icon-blue">
                <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="23 6 13.5 15.5 8.5 10.5 1 18"></polyline>
                    <polyline points="17 6 23 6 23 12"></polyline>
                </svg>
            </span>
            <div class="browse-tile-body">
                <h3 class="browse-tile-title">Trending</h3>
                <p class="browse-tile-text">What's hot right now</p>
            </div>
        </a>
        </div>
        @if (_animeEnabled)
        {
        <div data-media-type="anime" style="display:contents">
        <a class="browse-tile" href="/discover?list=seasonal&type=anime">
            <span class="browse-tile-icon browse-tile-icon-blue">
                <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                    <line x1="16" y1="2" x2="16" y2="6"></line>
                    <line x1="8" y1="2" x2="8" y2="6"></line>
                    <line x1="3" y1="10" x2="21" y2="10"></line>
                </svg>
            </span>
            <div class="browse-tile-body">
                <h3 class="browse-tile-title">Seasons</h3>
                <p class="browse-tile-text">Browse by release season</p>
            </div>
        </a>

        <a class="browse-tile" href="/discover/studio?type=anime">
            <span class="browse-tile-icon browse-tile-icon-amber">
                <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="4" y="3" width="16" height="18" rx="1"></rect>
                    <line x1="9" y1="8" x2="9" y2="8.01"></line>
                    <line x1="15" y1="8" x2="15" y2="8.01"></line>
                    <line x1="9" y1="12" x2="9" y2="12.01"></line>
                    <line x1="15" y1="12" x2="15" y2="12.01"></line>
                    <line x1="9" y1="16" x2="9" y2="16.01"></line>
                    <line x1="15" y1="16" x2="15" y2="16.01"></line>
                </svg>
            </span>
            <div class="browse-tile-body">
                <h3 class="browse-tile-title">Studios</h3>
                <p class="browse-tile-text">Browse by studio</p>
            </div>
        </a>

        <a class="browse-tile" href="/discover/tag?type=anime">
            <span class="browse-tile-icon browse-tile-icon-purple">
                <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path>
                    <line x1="7" y1="7" x2="7.01" y2="7"></line>
                </svg>
            </span>
            <div class="browse-tile-body">
                <h3 class="browse-tile-title">Tags</h3>
                <p class="browse-tile-text">Browse by tag</p>
            </div>
        </a>
        </div>
        }
        @if (_videoTypes.Count > 0)
        {
        <div data-media-type="movie series" style="display:contents">
        <a class="browse-tile" href="/discover?list=popular">
            <span class="browse-tile-icon browse-tile-icon-green">
                <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"></circle>
                    <polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"></polygon>
                </svg>
            </span>
            <div class="browse-tile-body">
                <h3 class="browse-tile-title">Popular</h3>
                <p class="browse-tile-text">Most-watched picks</p>
            </div>
        </a>

        <a class="browse-tile" href="/discover?list=watched">
            <span class="browse-tile-icon browse-tile-icon-amber">
                <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M1 12s4-7 11-7 11 7 11 7-4 7-11 7-11-7-11-7z"></path>
                    <circle cx="12" cy="12" r="3"></circle>
                </svg>
            </span>
            <div class="browse-tile-body">
                <h3 class="browse-tile-title">Most Watched</h3>
                <p class="browse-tile-text">This week's top plays</p>
            </div>
        </a>

        <a class="browse-tile" href="/discover?list=anticipated">
            <span class="browse-tile-icon browse-tile-icon-purple">
                <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
                </svg>
            </span>
            <div class="browse-tile-body">
                <h3 class="browse-tile-title">Anticipated</h3>
                <p class="browse-tile-text">Upcoming releases</p>
            </div>
        </a>

        <a class="browse-tile" href="/discover/actors">
            <span class="browse-tile-icon browse-tile-icon-blue">
                <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                    <circle cx="12" cy="7" r="4"></circle>
                </svg>
            </span>
            <div class="browse-tile-body">
                <h3 class="browse-tile-title">Actors</h3>
                <p class="browse-tile-text">Browse by actor</p>
            </div>
        </a>
        </div>
        }
    </div>
</section>
}

@* Dashboard layout chooser — Blazor port of _DashCustomize.cshtml (reorder + hide, persisted to
   the account). Opened by the "Customize" trigger up top; sections read their order/visibility
   from AppState.DashLayout and reorder via CSS flex `order`. *@
<DashCustomizeModal @ref="_customize" />

@code {
    // Discover shelves (trending/popular/anticipated/seasonal) barely change and are public, so their
    // first page is cached client-side for 24 h — instant on revisit / restart, and no request at all
    // while fresh. The Continue-watching lists are also cached (so they paint instantly instead of
    // skeleton-flashing on every Home visit) but with AlwaysRevalidate: the cache is just a paint seed
    // and the live list is refetched in the background every time and swapped in silently. User-scoped
    // entries are safe to cache under plain keys because the cache is wiped on logout / account switch
    // (Cache.ClearAsync in Logout/Advanced). The daily "New episodes" shelf stays uncached.
    private static readonly TimeSpan ShelfTtl = TimeSpan.FromHours(24);

    private bool _animeEnabled => State.EnabledMediaTypes.Contains(MetaType.anime);
    private List<MetaType> _videoTypes => State.EnabledMediaTypes.Where(t => t != MetaType.anime).ToList();
    private bool _combined => State.EnabledMediaTypes.Count > 1;
    private string _animeSuffix => _combined ? " · Anime" : "";

    private static string VideoSlug(MetaType vt) => vt == MetaType.movie ? "movie" : "series";
    private string VideoSuffix(MetaType vt) => _combined ? " · " + (vt == MetaType.movie ? "Movies" : "Series") : "";

    // Browse section's CSS order + hidden state from the saved layout (key "browse").
    private int BrowseOrder { get { var l = State.DashLayout; for (var i = 0; i < l.Count; i++) if (l[i].Key == "browse") return i; return 999; } }
    private bool BrowseHidden => State.DashLayout.FirstOrDefault(e => e.Key == "browse") is { Visible: false };

    // Unique id so the nudge's aria-controls stays valid (matches the web's
    // Guid-derived detail id).
    private readonly string _nudgeDetailId = "streamNudgeDetail-" + Guid.NewGuid().ToString("N")[..8];

    private DashCustomizeModal? _customize;
    private bool _layoutLoaded;
    private IJSObjectReference? _js;
    private IJSObjectReference? _nudgeModule;

    protected override void OnInitialized()
    {
        // Page components don't re-render on the layout's re-render, so subscribe: refresh the
        // shelf blocks when the enabled media types hydrate + when the saved layout loads / changes.
        State.Changed += OnStateChanged;
        _ = TryLoadLayoutAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // body.dash-page (original's ViewData["BodyClass"]) makes <main> the containing
        // block for the absolutely-positioned "Customize" float and tucks the content
        // under the sticky media-type pills. Set once, on the first interactive render.
        if (firstRender)
        {
            try
            {
                _js ??= await JS.InvokeAsync<IJSObjectReference>("import", "./_content/AniSync.Client/js/dashboard.js");
                await _js.InvokeVoidAsync("setDashPage", true);
            }
            catch { /* prerender / no JS */ }
        }

        // Wire the shared "set up streaming" nudge (reveal-after-dismiss-check + the
        // "How it works" expander) once it's in the DOM — the inline <script> from
        // _StreamSetupNudge.cshtml ported to the watch-sources.js module. Without this
        // the dismissible dashboard nudge ships hidden and never appears. Runs each
        // render (idempotent on the JS side) so it catches the nudge appearing after
        // hydration; gated to when it's actually shown.
        if (State.LoggedIn && string.IsNullOrEmpty(State.StreamConfig))
        {
            try
            {
                _nudgeModule ??= await JS.InvokeAsync<IJSObjectReference>(
                    "import", "./_content/AniSync.Client/js/watch-sources.js");
                await _nudgeModule.InvokeVoidAsync("wireNudges");
            }
            catch { /* interop best-effort — the CTA link still works without JS */ }
        }
    }

    // Resolve the saved dashboard layout BEFORE the shelves paint, so they render once in the
    // saved order/visibility instead of flashing the default order then reordering. The shelves
    // are gated on State.DashLayoutLoaded; this drives it to true in every case (loaded from the
    // account, or "default stands" for an anonymous / no-config visitor, or on fetch failure so
    // the skeleton never hangs). DashLayoutLoaded survives navigation, so revisiting Home neither
    // re-gates nor re-fetches.
    private async Task TryLoadLayoutAsync()
    {
        if (State.DashLayoutLoaded || _layoutLoaded) return;   // already resolved, or a fetch is in flight
        // Wait for the credential to be read from storage — not SessionHydrated, which the
        // prerender bridge flips true before StreamConfig exists. Resolving earlier would take
        // the anonymous branch (default layout) and skip the user's saved layout entirely.
        if (!State.ConfigHydrated) return;

        if (State.LoggedIn && !string.IsNullOrEmpty(State.StreamConfig))
        {
            _layoutLoaded = true;
            try
            {
                var json = await Api.GetDashboardLayoutAsync();
                if (!string.IsNullOrWhiteSpace(json))
                    State.SetDashLayout(DashboardLayout.Merge(json));   // sets DashLayoutLoaded + fires Changed
                else
                    State.MarkDashLayoutResolved();                     // nothing saved → default stands
            }
            catch
            {
                State.MarkDashLayoutResolved();                         // fetch failed → keep default, don't hang
            }
            return;
        }

        // Anonymous → read the layout the Customize modal saved to localStorage so a logged-out
        // visitor's reorder/hide survives a reload; default order stands when nothing's stored. The
        // shelves keep their skeleton until this resolves (gated on DashLayoutLoaded), so they paint
        // once in the saved order rather than flashing the default then reordering.
        _layoutLoaded = true;
        try
        {
            _js ??= await JS.InvokeAsync<IJSObjectReference>("import", "./_content/AniSync.Client/js/dashboard.js");
            var json = await _js.InvokeAsync<string>("getLayout");
            if (!string.IsNullOrWhiteSpace(json))
                State.SetDashLayout(DashboardLayout.Merge(json));
            else
                State.MarkDashLayoutResolved();
        }
        catch
        {
            State.MarkDashLayoutResolved();
        }
    }

    private async void OnStateChanged()
    {
        await TryLoadLayoutAsync();
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        State.Changed -= OnStateChanged;
        if (_js is not null)
        {
            try { await _js.InvokeVoidAsync("setDashPage", false); } catch { }
            try { await _js.DisposeAsync(); } catch { }
        }
        if (_nudgeModule is not null)
        {
            try { await _nudgeModule.DisposeAsync(); } catch { }
        }
    }
}
