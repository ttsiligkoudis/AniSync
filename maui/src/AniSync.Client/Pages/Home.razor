@page "/"
@implements IDisposable
@inject IAniSyncApi Api
@inject AppState State

@* Home dashboard — ported shell of Views/Home/Index.cshtml. The media-type
   switch now lives in the layout (MediaTypeSwitch); this page reacts to its
   "All / Anime / Movies / Series" filter via AppState.DashboardFilter and
   shows/hides sections by their data-media-type, matching media-type-switch.js.
   Stats + Trakt shelves need JSON endpoints (see README roadmap); the Trending
   anime shelf is wired to the existing /api/v1/discover as a working slice. *@

<PageTitle>AniSync</PageTitle>

@* Your stats — structure only for this milestone (awaiting JSON stats API). *@
<section class="dashboard-section stats-section" data-dash-section="stats">
    <h2 class="dashboard-section-title">Your stats</h2>
    <p class="hint-text">Stats wiring lands with the <code>/api/v1/stats</code> endpoints (see README roadmap).</p>
</section>

@* Trending · Anime — working slice via /api/v1/discover/trending. *@
@if (Visible("anime"))
{
    <section class="dashboard-section" data-dash-section="trending" data-media-type="anime">
        <div class="dashboard-section-header">
            <h2 class="dashboard-section-title">Trending · Anime</h2>
        </div>

        @if (_loading)
        {
            <p class="hint-text">Loading…</p>
        }
        else if (_trending.Count == 0)
        {
            <p class="hint-text">Nothing to show yet.</p>
        }
        else
        {
            <div class="library-grid">
                @foreach (var card in _trending)
                {
                    <a class="library-card" href="@($"/detail/{Uri.EscapeDataString(card.Id)}")" title="@card.Name">
                        <div class="library-card-poster-wrap">
                            @if (!string.IsNullOrEmpty(card.Poster))
                            {
                                <img class="library-card-poster" src="@card.Poster" alt="@card.Name" loading="lazy" />
                            }
                            else
                            {
                                <div class="library-card-poster-placeholder" aria-hidden="true">
                                    <span class="library-card-poster-placeholder-title">@card.Name</span>
                                </div>
                            }
                        </div>
                    </a>
                }
            </div>
        }
    </section>
}

@code {
    private bool _loading = true;
    private List<MetaCard> _trending = new();

    protected override void OnInitialized() => State.Changed += OnFilterChanged;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var items = await Api.DiscoverAsync("trending");
            _trending = items.Take(20).ToList();
        }
        finally
        {
            _loading = false;
        }
    }

    // A section shows when the dashboard filter is "All" or matches its media type.
    private bool Visible(string mediaType)
        => State.DashboardFilter is "all" || State.DashboardFilter == mediaType;

    private void OnFilterChanged() => StateHasChanged();

    public void Dispose() => State.Changed -= OnFilterChanged;
}
