@page "/"
@inject IAniSyncApi Api

@* Home dashboard — full port of Views/Home/Index.cshtml's section order: the
   "Your stats" strip, then the anime shelves (Continue watching / New episodes
   today / Trending / Most popular). The fixed media-type switch lives in the
   layout; each section carries data-media-type and hides itself when the
   dashboard filter excludes it (handled inside StatsStrip / DashboardShelf).
   Every shelf loads independently from the existing JSON API. *@

<PageTitle>AniSync</PageTitle>

<StatsStrip />

<DashboardShelf Title="Continue watching"
                MediaType="anime"
                DashSection="anime-continue"
                ViewAllHref="/library?list=current&type=anime"
                Fetch="@(() => Api.ContinueWatchingAsync())" />

<DashboardShelf Title="New Episodes Today"
                MediaType="anime"
                DashSection="anime-new-episodes"
                MutedNote="Refreshes daily"
                Fetch="@(() => Api.AiringTodayAsync())" />

<DashboardShelf Title="Trending"
                MediaType="anime"
                DashSection="anime-trending"
                ViewAllHref="/discover?list=trending&type=anime"
                Fetch='@(() => Api.DiscoverAsync("trending"))' />

<DashboardShelf Title="Most Popular"
                MediaType="anime"
                DashSection="anime-popular"
                ViewAllHref="/discover?list=popular&type=anime"
                Fetch='@(() => Api.DiscoverAsync("popular"))' />
