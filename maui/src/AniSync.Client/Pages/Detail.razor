@page "/meta/{Id}"
@inject IAniSyncApi Api
@inject NavigationManager Nav
@inject AppState State
@inject IJSRuntime JS
@inject IPrerenderSession Prerender
@inject IClientCache Cache
@inject IAppEnvironment Env

@* Anime/title detail — port of Views/Meta/Detail.cshtml (anime path). Hero
   (backdrop + poster + score + title + info + airing status + user-state pill +
   quick-add heart + Hide/Unhide + watch-next CTA + genre + source chips incl.
   Stremio), collapsible synopsis, lazy trailer, episodes list (season tabs for
   multi-cour, rows navigate to /watch, airingAt-first future gating), related +
   recommendations carousels, supplementary credit chips (tag/studio/staff →
   Discover), and streaming-service links. Reuses the anime-detail-* classes from
   site.css. The movie / series (Trakt) video-detail rendering path is deferred. *@

<PageTitle>@(_meta?.Name ?? "Details") · AniSync</PageTitle>

@if (_loading)
{
    @* Hero skeleton — mirrors the loaded layout (poster + title + info + chips + CTA)
       so the page reads as "loading this title" and doesn't jump when the real meta
       lands. Flat-hero (no backdrop) until we know whether there's banner art. *@
    <section class="anime-detail-hero anime-detail-hero-flat anime-detail-hero-skeleton" aria-busy="true" aria-live="polite">
        <span class="sr-only">Loading…</span>
        <div class="anime-detail-hero-body">
            <div class="anime-detail-poster-wrap">
                <div class="anime-detail-skeleton-poster skeleton-shimmer"></div>
            </div>
            <div class="anime-detail-meta">
                <div class="anime-detail-skeleton-bar anime-detail-skeleton-title skeleton-shimmer"></div>
                <div class="anime-detail-skeleton-bar anime-detail-skeleton-info skeleton-shimmer"></div>
                <div class="anime-detail-skeleton-chips">
                    <span class="anime-detail-skeleton-chip skeleton-shimmer"></span>
                    <span class="anime-detail-skeleton-chip skeleton-shimmer"></span>
                </div>
                <div class="anime-detail-skeleton-bar anime-detail-skeleton-cta skeleton-shimmer"></div>
            </div>
        </div>
    </section>
}
else if (_meta is null)
{
    <section><p class="hint-text">Couldn't load this title.</p></section>
}
else
{
    var a = _meta;
    @* TV: a visible Back control (the remote's Back works too, but this is a clear D-pad target),
       mirroring the /watch header's back link. No autofocus — initial focus stays on the Watch CTA. *@
    @if (Env.IsTv)
    {
        <button type="button" class="watch-back anime-detail-back" @onclick="GoBack">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="19" y1="12" x2="5" y2="12"></line>
                <polyline points="12 19 5 12 12 5"></polyline>
            </svg>
            <span>Back</span>
        </button>
    }
    <section class="anime-detail-hero @(string.IsNullOrEmpty(a.Background) ? "anime-detail-hero-flat" : "")">
        @if (!string.IsNullOrEmpty(a.Background))
        {
            <div class="anime-detail-backdrop" style="background-image: url('@a.Background');"></div>
            <div class="anime-detail-backdrop-shade"></div>
        }
        <div class="anime-detail-hero-body">
            <div class="anime-detail-poster-wrap">
                @if (!string.IsNullOrEmpty(a.Poster))
                {
                    <img class="anime-detail-poster" src="@a.Poster" alt="@a.Name" decoding="async" />
                }
                else
                {
                    <div class="anime-detail-poster anime-detail-poster-placeholder"></div>
                }
                @if (a.Score is > 0)
                {
                    <span class="anime-detail-score anime-detail-poster-score">★ @a.Score!.Value.ToString("0.0")</span>
                }
            </div>
            <div class="anime-detail-meta">
                <h1 class="anime-detail-title">@a.Name</h1>
                @if (_infoLine is { Length: > 0 })
                {
                    <div class="anime-detail-info">@_infoLine</div>
                }
                <div class="anime-detail-badges">
                    @if (!string.IsNullOrEmpty(a.AirStatus))
                    {
                        <span class="anime-detail-status anime-detail-status-@(a.AirStatus!.ToLowerInvariant().Replace(" ", "-"))">
                            @if (a.AirStatus == "Airing")
                            {
                                <span class="anime-detail-status-dot" aria-hidden="true"></span>
                            }
                            @a.AirStatus
                        </span>
                    }
                    @* User-state pill — cobalt "{Status} · Ep N / T" + pencil when the
                       title is on the user's list, "Add to List" + plus otherwise.
                       Omitted entirely for anonymous viewers (no "you" to talk about);
                       clicking opens the Manage Entry modal either way. The anime path
                       gates on LoggedIn; the video (movie / series) path gates on Trakt
                       being connected — the tracker behind video state (the original's
                       (isVideo || traktAnime) && TraktConnected). The pill's modal stamps
                       the media type so its GET / save route through Trakt. *@
                    @if ((IsVideo && _traktConnected) || (!IsVideo && LoggedIn))
                    {
                        <button type="button" class="anime-detail-user-state" @onclick="OpenModal">
                            <span>@EntryPillLabel()</span>
                            @if (HasEntry)
                            {
                                <svg class="anime-detail-user-state-icon" viewBox="0 0 24 24" width="14" height="14" fill="none"
                                     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                    <path d="M12 20h9"></path>
                                    <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path>
                                </svg>
                            }
                            else
                            {
                                <svg class="anime-detail-user-state-icon" viewBox="0 0 24 24" width="14" height="14" fill="none"
                                     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                    <path d="M12 5v14"></path>
                                    <path d="M5 12h14"></path>
                                </svg>
                            }
                        </button>
                    }
                    @* Quick-add heart — one-click Currently Watching toggle. Shown only
                       when the entry is NOT on any list (outline → adds) or already
                       Watching (filled → removes); hidden when it's in some other list
                       (managed via the modal), for anonymous viewers, anime movies, and
                       multi-cour franchise umbrellas (one ep number can't speak for the
                       franchise). For video it shows on movies too (Trakt tracks them),
                       gated on Trakt being connected. *@
                    @if (ShowHeart)
                    {
                        <button type="button"
                                class="anime-detail-heart @(_heartFilled ? "anime-detail-heart-filled" : "")"
                                aria-pressed="@(_heartFilled ? "true" : "false")"
                                aria-label="@HeartLabel" title="@HeartLabel"
                                disabled="@_heartBusy"
                                @onclick="ToggleHeart">
                            <svg viewBox="0 0 24 24" width="18" height="18" fill="none"
                                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
                            </svg>
                        </button>
                    }
                    @* Hide / Unhide from Discover. Logged-in only; label + pressed
                       state reflect the entry's current hidden status. *@
                    @if (LoggedIn)
                    {
                        <button type="button"
                                class="anime-detail-hide @(_isHidden ? "anime-detail-hide-on" : "")"
                                aria-pressed="@(_isHidden ? "true" : "false")"
                                aria-label="@HideLabel" title="@HideLabel"
                                disabled="@_hideBusy"
                                @onclick="ToggleHide">
                            <svg viewBox="0 0 24 24" width="14" height="14" fill="none"
                                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path>
                                <line x1="1" y1="1" x2="23" y2="23"></line>
                            </svg>
                            <span class="anime-detail-hide-label">@(_isHidden ? "Unhide" : "Hide")</span>
                        </button>
                    }
                </div>

                @* Continue-watching CTA — its own centered row beneath the badges.
                   Hidden when nothing's playable (movie has its own CTA below the
                   synopsis), the show is completed, progress is past the last loaded
                   episode, or the next unseen episode hasn't aired yet (same gate
                   that makes the corresponding episode row inert). *@
                @if (_showWatchCta)
                {
                    <div class="anime-detail-watch-next-wrap">
                        @* On TV this is the primary action — autofocus it so the remote lands on Play. *@
                        <a class="anime-detail-watch-next" href="@_watchCtaHref" aria-label="@_watchCtaLabel" autofocus="@(Env.IsTv ? "autofocus" : null)">
                            <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true">
                                <polygon points="6 4 20 12 6 20 6 4"></polygon>
                            </svg>
                            <span>@_watchCtaLabel</span>
                        </a>
                    </div>
                }

                @if (!Env.IsTv && a.Genres is { Count: > 0 })
                {
                    <ul class="anime-detail-link-list anime-detail-genre-list">
                        @foreach (var g in a.Genres.Take(8))
                        {
                            <li><a class="anime-detail-link" href="@($"/discover?genre={Uri.EscapeDataString(g)}")">@g</a></li>
                        }
                    </ul>
                }
                @if (!Env.IsTv && _sourceChips.Count > 0)
                {
                    <div class="anime-detail-sources" aria-label="Open on external sites">
                        @foreach (var c in _sourceChips)
                        {
                            @if (c.Brand == "stremio")
                            {
                                @* href is the web fallback (right-click / middle-click /
                                   copy-link all work); data-stremio-app-url is the native
                                   protocol the JS tries first. *@
                                <a class="source-chip source-chip-stremio"
                                   href="@c.Url" data-stremio-app-url="@c.AppUrl"
                                   target="_blank" rel="noreferrer noopener"
                                   aria-label="Open on Stremio">
                                    <span class="source-chip-mark" aria-hidden="true">@c.Mark</span>
                                    <span class="source-chip-label">@c.Label</span>
                                </a>
                            }
                            else
                            {
                                <a class="source-chip source-chip-@c.Brand"
                                   href="@c.Url" target="_blank" rel="noreferrer noopener"
                                   aria-label="Open on @c.Label">
                                    <span class="source-chip-mark" aria-hidden="true">@c.Mark</span>
                                    @if (c.Brand != "imdb")
                                    {
                                        <span class="source-chip-label">@c.Label</span>
                                    }
                                </a>
                            }
                        }
                    </div>
                }

                @* Synopsis lives inside the hero (the open space right of the poster) rather than as
                   a separate section below — fills the dead space, especially on movies. On TV it's
                   never collapsed (no "Show more"); on pointer heads the long-text toggle stays. *@
                @if (!string.IsNullOrEmpty(a.Description))
                {
                    var isLong = a.Description!.Length > 180;
                    <div class="anime-detail-hero-synopsis">
                        <h2 class="anime-detail-section-title">Synopsis</h2>
                        <div class="anime-detail-synopsis-wrap" data-collapsed="@((!Env.IsTv && isLong && !_synopsisExpanded).ToString().ToLowerInvariant())">
                            <p class="anime-detail-synopsis">@a.Description</p>
                            @if (!Env.IsTv && isLong)
                            {
                                <button type="button" class="anime-detail-synopsis-toggle"
                                        aria-expanded="@_synopsisExpanded"
                                        @onclick="() => _synopsisExpanded = !_synopsisExpanded">
                                    @(_synopsisExpanded ? "Show less" : "Show more")
                                </button>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>

    @if (!Env.IsTv && !string.IsNullOrEmpty(_trailerId))
    {
        <section class="anime-detail-section">
            <h2 class="anime-detail-section-title">Trailer</h2>
            <a class="anime-detail-trailer-card"
               href="https://www.youtube.com/watch?v=@_trailerId"
               target="_blank"
               rel="noreferrer noopener"
               aria-label="Play trailer"
               data-yt-id="@_trailerId">
                <img src="https://img.youtube.com/vi/@_trailerId/hqdefault.jpg"
                     alt="" loading="lazy"
                     class="anime-detail-trailer-thumb" />
                <span class="anime-detail-trailer-shade" aria-hidden="true"></span>
                <span class="anime-detail-trailer-play" aria-hidden="true">
                    <svg viewBox="0 0 24 24" width="36" height="36" fill="currentColor">
                        <path d="M8 5v14l11-7z"></path>
                    </svg>
                </span>
            </a>
        </section>
    }

    @if (_episodes.Count > 0)
    {
        <section class="anime-detail-section anime-detail-episodes-wrap" data-collapsed="@(_episodesCollapsed ? "true" : null)">
            <div class="anime-detail-episodes-header">
                <h2 class="anime-detail-section-title">Episodes <span class="anime-detail-section-count">(@_episodes.Count)</span></h2>
                @if (_episodes.Count > 1)
                {
                    <input type="search"
                           class="anime-detail-episodes-filter"
                           placeholder="Filter episodes…"
                           aria-label="Filter episodes by number or title"
                           autocomplete="off"
                           spellcheck="false"
                           value="@_filter" @oninput="OnFilter" />
                }
                <button type="button" class="anime-detail-episodes-toggle"
                        aria-expanded="@((!_episodesCollapsed).ToString().ToLowerInvariant())"
                        aria-controls="anime-detail-episodes-body"
                        @onclick="() => _episodesCollapsed = !_episodesCollapsed">
                    <span class="anime-detail-episodes-toggle-label">@(_episodesCollapsed ? "Expand" : "Collapse")</span>
                    <svg class="anime-detail-episodes-toggle-icon" viewBox="0 0 24 24" width="14" height="14"
                         fill="none" stroke="currentColor" stroke-width="2.2"
                         stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <polyline points="6 9 12 15 18 9"></polyline>
                    </svg>
                </button>
            </div>

            @if (_seasons.Count > 1)
            {
                @* Horizontally-scrollable season tab strip — each tab filters the
                   single shared list below to its cour. Rendered outside the
                   scroll body so the switcher stays anchored above long lists. *@
                <nav class="season-tabs" role="tablist" aria-label="Seasons">
                    @foreach (var s in _seasons)
                    {
                        <button type="button"
                                class="season-tab @(s == _activeSeason ? "season-tab-active" : "")"
                                role="tab"
                                aria-selected="@(s == _activeSeason ? "true" : "false")"
                                @onclick="() => _activeSeason = s">
                            Season @s
                        </button>
                    }
                </nav>
            }

            <div class="anime-detail-episodes-body" id="anime-detail-episodes-body">
                <ol class="anime-detail-episodes" reversed="false" data-active-season="@_activeSeason">
                    @{ var tvEpAutofocusUsed = false; }
                    @foreach (var ep in _filteredEpisodes)
                    {
                        var future = IsFuture(ep);
                        var watched = (_state?.Progress ?? 0) > 0 && ep.Episode <= (_state!.Progress);
                        var displayDate = DisplayDate(ep);
                        var description = ep.Overview;
                        var classes = new List<string> { "anime-detail-episode" };
                        if (watched) classes.Add("anime-detail-episode-watched");
                        if (future) classes.Add("anime-detail-episode-future");
                        if (_seasons.Count > 1 && ep.Season != _activeSeason) classes.Add("anime-detail-episode-hidden");
                        @* TV initial focus: when there's no Watch CTA above (so this is the first
                           focusable target), land on the first VISIBLE episode — not the action
                           buttons. The Watch-Ep / Watch-movie CTAs come first in the DOM, so they win
                           when present (autoFocus picks the first [autofocus]). *@
                        var epAutofocus = Env.IsTv && !tvEpAutofocusUsed
                            && (_seasons.Count <= 1 || ep.Season == _activeSeason);
                        if (epAutofocus) { tvEpAutofocusUsed = true; }
                        <li class="@string.Join(" ", classes)"
                            data-episode-num="@ep.Episode"
                            data-season-num="@ep.Season"
                            role="button" tabindex="0"
                            autofocus="@(epAutofocus ? "autofocus" : null)"
                            @onclick="@(() => OnEpisodeActivate(ep, future))">
                            <div class="anime-detail-episode-thumb-wrap">
                                @if (!string.IsNullOrEmpty(ep.Thumbnail))
                                {
                                    @* On a broken thumbnail URL, hide the img and flip the wrap to the
                                       striped placeholder state instead of the browser's broken-image icon. *@
                                    <img class="anime-detail-episode-thumb" src="@ep.Thumbnail" alt="" loading="lazy" decoding="async"
                                         onerror="this.style.display='none';this.parentElement.classList.add('anime-detail-episode-thumb-failed')" />
                                }
                                else
                                {
                                    <div class="anime-detail-episode-thumb anime-detail-episode-thumb-placeholder"></div>
                                }
                                <span class="anime-detail-episode-play" aria-hidden="true">
                                    <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
                                        <path d="M12 4l8 8-8 8-8-8z"></path>
                                    </svg>
                                </span>
                                @if (watched)
                                {
                                    <span class="anime-detail-episode-eye" aria-label="Watched">
                                        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                                            <circle cx="12" cy="12" r="3"></circle>
                                        </svg>
                                    </span>
                                }
                            </div>
                            <div class="anime-detail-episode-body">
                                <div class="anime-detail-episode-row">
                                    <span class="anime-detail-episode-title">
                                        @ep.Episode. @(string.IsNullOrEmpty(ep.Title) ? $"Episode {ep.Episode}" : ep.Title)
                                    </span>
                                    @if (!string.IsNullOrEmpty(displayDate))
                                    {
                                        <span class="anime-detail-episode-date @(future ? "anime-detail-episode-date-future" : "")">
                                            @displayDate
                                        </span>
                                    }
                                </div>
                                @if (!string.IsNullOrEmpty(description))
                                {
                                    <p class="anime-detail-episode-desc">@description</p>
                                }
                            </div>
                        </li>
                    }
                </ol>
            </div>
        </section>
    }
    else if (IsMovie)
    {
        @* Movie meta has no per-episode list, so the user has no click target to
           reach the watch page — surface a single CTA. Anime movies route to
           /meta/{id}/watch/1 (the watch route treats episode 1 as the movie body);
           video movies use /meta/{id}/watch?type=movie (no episode segment), matching
           Detail.cshtml's movie CTA href. *@
        <section class="anime-detail-section anime-detail-movie-cta-wrap">
            <a class="anime-detail-movie-cta" href="@MovieCtaHref" autofocus="@(Env.IsTv ? "autofocus" : null)">
                <svg viewBox="0 0 24 24" width="20" height="20" fill="none"
                     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <polygon points="6 4 20 12 6 20 6 4"></polygon>
                </svg>
                <span>Watch movie</span>
            </a>
        </section>
    }

    @* Video (Trakt-enriched) cast — rendered from the single video meta call. Cast
       names come from Trakt (no headshots in its API → the initial shows through);
       clicking an actor opens their filmography. Mirrors Detail.cshtml's
       video-cast-scroll / video-cast-card. Anime uses its own (deferred) path. *@
    @if (!Env.IsTv && IsVideo && _videoCast.Count > 0)
    {
        <section class="anime-detail-section">
            <h2 class="anime-detail-section-title">Cast</h2>
            <div class="video-cast-scroll">
                @foreach (var c in _videoCast)
                {
                    <a class="video-cast-card" href="@(string.IsNullOrEmpty(c.Slug) ? null : $"/discover/actor/{c.Slug}")">
                        <span class="video-cast-avatar">
                            <span class="video-cast-avatar-initial" aria-hidden="true">@(string.IsNullOrEmpty(c.Name) ? "?" : c.Name![..1])</span>
                            @if (!string.IsNullOrEmpty(c.Image))
                            {
                                <img class="video-cast-avatar-img" src="@c.Image" alt="" loading="lazy" decoding="async" onerror="this.remove()" />
                            }
                        </span>
                        <span class="video-cast-name">@c.Name</span>
                        @if (!string.IsNullOrEmpty(c.Character))
                        {
                            <span class="video-cast-char">@c.Character</span>
                        }
                    </a>
                }
            </div>
        </section>
    }

    @if (!Env.IsTv && _related.Count > 0)
    {
        <section class="anime-detail-section">
            <h2 class="anime-detail-section-title">Related</h2>
            <PosterGrid Items="_related" Variant="scroll" />
        </section>
    }

    @if (!Env.IsTv && _recommendations.Count > 0)
    {
        <section class="anime-detail-section">
            <h2 class="anime-detail-section-title">Recommended</h2>
            @* Video recommended cards are movies / series (tt ids) → VideoLinks routes
               each to /meta/{id}?type=…, matching the original's _PosterGrid VideoLinks. *@
            <PosterGrid Items="_recommendations" Variant="scroll" VideoLinks="IsVideo" />
        </section>
    }

    @if (!Env.IsTv && _supplementary.Count > 0)
    {
        @foreach (var group in _supplementary.GroupBy(l => string.IsNullOrEmpty(l.Category) ? "Links" : l.Category!))
        {
            <section class="anime-detail-section">
                <h2 class="anime-detail-section-title">@group.Key</h2>
                <ul class="anime-detail-link-list">
                    @foreach (var l in group)
                    {
                        <li>
                            @if (SuppInternal(l))
                            {
                                <a class="anime-detail-link" href="@SuppHref(l)">@l.Name</a>
                            }
                            else
                            {
                                <a class="anime-detail-link" href="@SuppHref(l)" target="_blank" rel="noreferrer noopener">@l.Name</a>
                            }
                        </li>
                    }
                </ul>
            </section>
        }
    }

    @if (!Env.IsTv && _streams.Count > 0)
    {
        <section class="anime-detail-section">
            <h2 class="anime-detail-section-title">Watch on</h2>
            <ul class="anime-detail-link-list">
                @foreach (var s in _streams)
                {
                    <li><a class="anime-detail-link" href="@s.Url" target="_blank" rel="noreferrer noopener">@s.Site</a></li>
                }
            </ul>
        </section>
    }
}

<ManageEntryModal Id="@Id" Name="@(_meta?.Name ?? string.Empty)"
                  MediaType="@(IsVideo ? VideoMediaType : null)"
                  Visible="_modalOpen"
                  OnClose="() => _modalOpen = false"
                  OnSaved="OnEntrySaved" />

@code {
    [Parameter] public string Id { get; set; } = "";

    private bool _modalOpen;
    private bool _loading = true;
    private MetaDto? _meta;
    private DetailStateDto? _state;
    private IReadOnlyList<EpisodeInfoDto> _episodes = Array.Empty<EpisodeInfoDto>();
    private IReadOnlyList<StreamingLinkDto> _streams = Array.Empty<StreamingLinkDto>();
    private IReadOnlyList<MetaDto> _related = Array.Empty<MetaDto>();
    private IReadOnlyList<MetaDto> _recommendations = Array.Empty<MetaDto>();
    private IReadOnlyList<LinkDto> _supplementary = Array.Empty<LinkDto>();
    // Raw anime source-link inputs, retained so the prerender snapshot can rebuild the
    // source chips on the interactive replay (BuildSourceChips needs them).
    private AnimeSourceLinksDto? _sourceLinks;
    private string? _trailerId;
    private readonly List<SourceChip> _sourceChips = new();
    private bool _synopsisExpanded;
    private bool _episodesCollapsed;
    private string _filter = "";
    private string? _infoLine;
    private List<int> _seasons = new();
    private int _activeSeason = 1;
    private bool _multiSeason;
    private string? _typeQuery;

    // ── Video (movie / series) detail state ──────────────────────────────────
    // Populated only when the id is a Cinemeta video (?type=movie|series) — the
    // Trakt-enriched path that renders the video-cast-scroll, certification on the
    // info line, and the Trakt-backed status pill / heart. Anime leaves these empty.
    private IReadOnlyList<VideoCastDto> _videoCast = Array.Empty<VideoCastDto>();
    private string? _certification;
    private bool _traktConnected;

    // The id is a movie / series (the ?type= query was present). Drives the whole
    // video-detail rendering branch; mirrors the original's isVideo.
    // An anime-scheme id (anilist:/mal:/kitsu:) is ALWAYS anime, even if a stray ?type=series
    // rode in on the link — otherwise the video/Trakt path tries to resolve an AniList id and
    // dead-ends on "couldn't load this title". Mirrors the server's id→type resolution.
    private bool IsVideo => (_typeQuery == "movie" || _typeQuery == "series") && !IsAnimeSchemeId;
    private bool IsAnimeSchemeId =>
        Id.StartsWith("anilist:", StringComparison.OrdinalIgnoreCase)
        || Id.StartsWith("mal:", StringComparison.OrdinalIgnoreCase)
        || Id.StartsWith("kitsu:", StringComparison.OrdinalIgnoreCase);
    // The Trakt media type stamped on the pill / heart / hide triggers (the original's
    // traktPillType / heartMediaType / hideMediaType for video).
    private string VideoMediaType => _typeQuery == "movie" ? "movie" : "series";

    // Heart / hide local UI state (mirrors the server-computed initial state, then
    // flips optimistically on toggle).
    private bool _heartFilled;
    private bool _heartHidden; // entry is in some other list → drop the heart
    private bool _heartBusy;
    private bool _isHidden;
    private bool _hideBusy;
    private IJSObjectReference? _module;
    private bool _jsBound;

    private record SourceChip(string Label, string Url, string Brand, string Mark, string? AppUrl = null);

    private bool LoggedIn => !string.IsNullOrEmpty(State.StreamConfig);
    // Movie when the meta type says so, or the ?type=movie query is set (a Cinemeta
    // video movie — the query is authoritative for the video path).
    private bool IsMovie => _typeQuery == "movie"
        || string.Equals(_meta?.Type, "movie", StringComparison.OrdinalIgnoreCase);

    protected override async Task OnParametersSetAsync()
    {
        _typeQuery = QueryValue("type");

        // On the interactive pass right after a prerender, replay the snapshot the prerender
        // stashed instead of resetting to the skeleton and refetching — otherwise the page
        // flashes prerendered content → skeleton → content (and double-hits the API). Native
        // (no-op session) and client-side navigations (no prerender stash) fall through to a
        // normal load + skeleton, which is the right behaviour there.
        if (RendererInfo.IsInteractive && TryReplaySnapshot(out var snap) && snap is { Meta: not null })
        {
            RestoreFrom(snap);
            _ = Cache.SetAsync(PersistKey(), snap);   // prime the client cache so a later back-nav is instant
            return;
        }

        // Client-cache replay — instant restore of the last view of this title on back-navigation or
        // app restart (no skeleton, none of the load below). The in-memory tier serves the live session;
        // localStorage bridges a restart. Per-user bits (pill/heart) are refreshed in the background.
        if (await TryRestoreFromCacheAsync())
            return;

        _loading = true;
        _jsBound = false;
        _sourceChips.Clear();
        _state = null;
        _heartFilled = _heartHidden = _isHidden = _traktConnected = false;
        _videoCast = Array.Empty<VideoCastDto>();
        _certification = null;
        _sourceLinks = null;
        _related = Array.Empty<MetaDto>();
        _supplementary = Array.Empty<LinkDto>();
        _streams = Array.Empty<StreamingLinkDto>();
        _recommendations = Array.Empty<MetaDto>();
        _trailerId = null;

        if (IsVideo)
        {
            await LoadVideoAsync();
        }
        else
        {
            await LoadAnimeAsync();
            // No explicit ?type= and the anime lookup returned nothing for a Cinemeta-style id (tt.../
            // tmdb:) → it isn't an anime-mapped title, so it's a movie/series. The original server
            // resolved type from the id (MetaController.MediaTypeFor: an unmapped tt id falls through to
            // video); replicate that by retrying the video path here. Cinemeta needs the right kind, so
            // try series then movie. (Anime with tt ids ARE mapped, so they load on the anime path above
            // and never reach this fallback.)
            if (_meta is null && string.IsNullOrEmpty(_typeQuery)
                && (Id.StartsWith("tt", StringComparison.Ordinal) || Id.StartsWith("tmdb:", StringComparison.Ordinal)))
            {
                _typeQuery = "series";
                await LoadVideoAsync();
                if (_meta is null) { _typeQuery = "movie"; await LoadVideoAsync(); }
                if (_meta is null) _typeQuery = null;   // give up → the neutral "couldn't load this title"
            }
        }

        _seasons = _episodes.Select(e => e.Season > 0 ? e.Season : 1).Distinct().OrderBy(s => s).ToList();
        if (_seasons.Count == 0) _seasons.Add(1);
        _multiSeason = _seasons.Count > 1;
        _activeSeason = PickDefaultSeason();
        ApplyUserState();
        ComputeWatchCta();
        _loading = false;

        // Prerender: stash a snapshot so the interactive remount replays it (above) with no flash
        // and no second API round-trip. Web-only; no-op on native and on the interactive pass.
        // Also stash it in the two-tier client cache (30 min) so navigating back to this title — or
        // reopening the app — restores it instantly instead of refetching everything above.
        if (_meta is not null)
        {
            var snapshot = Snapshot();
            Prerender.Persist<PersistedDetail>(PersistKey(), RendererInfo.IsInteractive, () => snapshot);
            await Cache.SetAsync(PersistKey(), snapshot);
        }
    }

    // Per-page-instance key (type + id) — only one detail page prerenders per request, but keying by
    // the title keeps a stale snapshot from ever being replayed onto a different one.
    // Keyed on the URL's ?type= (read fresh, not _typeQuery — which the anime→video fallback may mutate)
    // + the id, so the prerender and interactive passes compute the SAME key and the replay matches even
    // when the type was resolved during load. The snapshot carries the resolved type (restored below).
    private string PersistKey() => $"detail:{QueryValue("type")}:{Id}";

    // Best-effort replay: a deserialise hiccup falls back to a normal load (the skeleton), never a
    // broken page.
    private bool TryReplaySnapshot(out PersistedDetail? snap)
    {
        try { return Prerender.TryReplay<PersistedDetail?>(PersistKey(), out snap); }
        catch { snap = null; return false; }
    }

    // How long a detail snapshot stays replayable from the client cache. Short — the in-memory tier
    // makes the live session instant regardless; this mainly bounds the restart-restore window.
    private static readonly TimeSpan DetailCacheTtl = TimeSpan.FromMinutes(30);

    // Replay the last view of this title from the two-tier client cache when one is fresh. Restores
    // instantly (no skeleton, no API calls), then refreshes the per-user bits (pill/heart/hidden) in
    // the background since those can change while the cached content stays valid.
    private async Task<bool> TryRestoreFromCacheAsync()
    {
        PersistedDetail? snap;
        try { snap = await Cache.GetAsync<PersistedDetail>(PersistKey(), DetailCacheTtl); }
        catch { return false; }
        if (snap is not { Meta: not null }) return false;

        RestoreFrom(snap);
        if (LoggedIn) _ = RefreshUserStateAsync();
        return true;
    }

    // Refetch the hero's user-state (pill + heart + hide) and re-derive the CTA. Shared by the
    // post-cache-restore background refresh and the modal's save/remove callback.
    private async Task RefreshUserStateAsync()
    {
        _state = await Api.DetailStateAsync(Id, type: IsVideo ? VideoMediaType : null) ?? _state;
        ApplyUserState();
        ComputeWatchCta();
        StateHasChanged();
    }

    // Everything the render needs that came off the network, captured at the end of the prerender load.
    // Only public API DTOs (already JSON-round-tripped across the API) are stored; the derived bits
    // (chips / info line / seasons / CTA / heart) are recomputed verbatim in RestoreFrom.
    private sealed record PersistedDetail(
        MetaDto? Meta,
        List<EpisodeInfoDto> Episodes,
        List<StreamingLinkDto> Streams,
        List<MetaDto> Related,
        List<MetaDto> Recommendations,
        List<LinkDto> Supplementary,
        string? TrailerId,
        DetailStateDto? State,
        AnimeSourceLinksDto? Links,
        List<VideoCastDto> VideoCast,
        string? Certification,
        string? TypeQuery);

    private PersistedDetail Snapshot() => new(
        _meta,
        _episodes.ToList(),
        _streams.ToList(),
        _related.ToList(),
        _recommendations.ToList(),
        _supplementary.ToList(),
        _trailerId,
        _state,
        _sourceLinks,
        _videoCast.ToList(),
        _certification,
        _typeQuery);

    // Reinstate the loaded data and re-derive everything exactly as the load path does, so the
    // interactive first render is identical to the prerendered DOM (no flash).
    private void RestoreFrom(PersistedDetail snap)
    {
        // Reinstate the type the load RESOLVED (the anime→video fallback may have changed it from the
        // URL's ?type=), so IsVideo / the chips / the rendering branch match the prerendered DOM.
        _typeQuery = snap.TypeQuery;
        _meta = snap.Meta;
        _episodes = snap.Episodes;
        _streams = snap.Streams;
        _related = snap.Related;
        _recommendations = snap.Recommendations;
        _supplementary = snap.Supplementary;
        _trailerId = snap.TrailerId;
        _state = snap.State;
        _sourceLinks = snap.Links;
        _videoCast = snap.VideoCast;
        _certification = snap.Certification;
        _traktConnected = _state?.TraktConnected ?? false;

        _jsBound = false;
        _sourceChips.Clear();
        if (IsVideo) BuildVideoSourceChips(); else BuildSourceChips(_sourceLinks);
        _infoLine = BuildInfoLine(_meta, IsVideo ? _certification : null);

        _seasons = _episodes.Select(e => e.Season > 0 ? e.Season : 1).Distinct().OrderBy(s => s).ToList();
        if (_seasons.Count == 0) _seasons.Add(1);
        _multiSeason = _seasons.Count > 1;
        _activeSeason = PickDefaultSeason();
        ApplyUserState();
        ComputeWatchCta();
        _loading = false;
    }

    // Anime path — the token-less /api/v1/anime/{id} + the per-anime extras
    // endpoints, plus the logged-in per-user state. Unchanged from the original
    // single-shape load.
    private async Task LoadAnimeAsync()
    {
        // Core content first (gates the page); extras are best-effort and never
        // block render — each degrades to empty on failure.
        var meta = Api.AnimeAsync(Id);
        var eps = Api.EpisodesAsync(Id);
        var streams = Api.StreamsAsync(Id);
        var related = Api.RelatedAsync(Id);
        var recs = Api.RecommendationsAsync(Id);
        var supp = Api.SupplementaryAsync(Id);
        var trailer = Api.TrailerAsync(Id);
        var links = Api.SourceLinksAsync(Id);
        // Per-user state (pill + heart + hide) only when logged in — the token-less
        // /api/v1/anime/{id} can't carry it. Mirrors the MVC Detail action computing
        // Model.Entry + Model.IsHidden server-side.
        var stateTask = LoggedIn ? Api.DetailStateAsync(Id) : Task.FromResult<DetailStateDto?>(null);
        await Task.WhenAll(meta, eps, streams, related, recs, supp, trailer, links, stateTask);

        _meta = meta.Result;
        _episodes = eps.Result;
        _streams = streams.Result;
        _related = related.Result;
        _recommendations = recs.Result;
        _supplementary = supp.Result;
        _trailerId = trailer.Result;
        _state = stateTask.Result;
        _sourceLinks = links.Result;
        BuildSourceChips(_sourceLinks);
        _infoLine = BuildInfoLine(_meta, null);
    }

    // Video (movie / series) path — the single Trakt-enriched /api/v1/video/{type}/{id}
    // (meta + cast + certification + merged episodes + recommended + trailer), plus the
    // Trakt-backed per-user state. Mirrors the MVC VideoDetail action. The anime-only
    // extras (related / supplementary / external streams) are skipped — their sources
    // are AniList-only.
    private async Task LoadVideoAsync()
    {
        var videoTask = Api.VideoAsync(VideoMediaType, Id);
        // Trakt state (pill + heart + hide) only when logged in.
        var stateTask = LoggedIn ? Api.DetailStateAsync(Id, type: VideoMediaType) : Task.FromResult<DetailStateDto?>(null);
        await Task.WhenAll(videoTask, stateTask);

        var video = videoTask.Result;
        _meta = video?.Meta;
        _episodes = video?.Episodes ?? new List<EpisodeInfoDto>();
        _recommendations = video?.Recommended ?? new List<MetaDto>();
        _videoCast = video?.Cast ?? new List<VideoCastDto>();
        _certification = video?.Certification;
        _trailerId = video?.TrailerYoutubeId;
        _state = stateTask.Result;
        _traktConnected = _state?.TraktConnected ?? false;
        BuildVideoSourceChips();
        _infoLine = BuildInfoLine(_meta, _certification);
    }

    // After (re)render, bind the Stremio chip deep-link probe + trailer lazy-embed
    // once the relevant DOM exists. Idempotent per element on the JS side.
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_loading || _meta is null || _jsBound) return;
        _jsBound = true;
        try
        {
            _module ??= await JS.InvokeAsync<IJSObjectReference>(
                "import", "./_content/AniSync.Client/js/detail.js");
            await _module.InvokeVoidAsync("init");
        }
        catch (Exception) { /* interop best-effort — chips still link to the web fallback */ }
    }

    // Seed the heart / hide / pill state from the server-computed per-user state.
    private void ApplyUserState()
    {
        _isHidden = _state?.IsHidden ?? false;
        var norm = NormalizeStatus(_state?.Status);
        // Heart shows only when not-on-list (add) or already Watching (remove);
        // any other list status drops it (managed via the modal).
        _heartHidden = norm != null && norm != "watching";
        _heartFilled = norm == "watching";
    }

    private void BuildSourceChips(AnimeSourceLinksDto? l)
    {
        if (l is null) return;
        if (l.AnilistId is int al && al > 0) _sourceChips.Add(new("AniList", $"https://anilist.co/anime/{al}", "anilist", "A"));
        if (l.MalId is int mal && mal > 0) _sourceChips.Add(new("MyAnimeList", $"https://myanimelist.net/anime/{mal}", "mal", "M"));
        if (l.KitsuId is int ki && ki > 0) _sourceChips.Add(new("Kitsu", $"https://kitsu.io/anime/{ki}", "kitsu", "K"));
        if (!string.IsNullOrEmpty(l.ImdbId)) _sourceChips.Add(new("IMDb", $"https://www.imdb.com/title/{l.ImdbId}/", "imdb", "IMDb"));

        // Stremio web deep-link — the prefixed catalog id (kitsu:/mal:/anilist:/tt)
        // is exactly what Stremio expects, so a plain url-encode is all we need.
        // tmdb/anidb/tvdb are skipped (no public Stremio anime addon catalogs them).
        var sid = _meta?.Id;
        var supported = !string.IsNullOrEmpty(sid)
            && (sid!.StartsWith("anilist:") || sid.StartsWith("mal:")
                || sid.StartsWith("kitsu:") || sid.StartsWith("tt"));
        if (supported)
        {
            var sType = IsMovie ? "movie" : "series";
            var path = $"detail/{sType}/{Uri.EscapeDataString(sid!)}";
            _sourceChips.Add(new("Stremio", $"https://web.stremio.com/#/{path}", "stremio", "S", $"stremio:///{path}"));
        }
    }

    // Hero info line — format · eps · ~min · year · [certification] · source.
    // Certification slots in after year for video (the original inserts
    // Model.VideoCertification there); null for anime.
    private static string? BuildInfoLine(MetaDto? a, string? certification)
    {
        if (a is null) return null;
        var bits = new List<string>();
        if (!string.IsNullOrEmpty(a.Format)) bits.Add(a.Format!);
        if (a.Episodes is int eps && eps > 0) bits.Add($"{eps} ep{(eps > 1 ? "s" : "")}");
        if (a.AvgDuration is int dur && dur > 0) bits.Add($"~{dur} min");
        if (a.Year is int yr && yr > 0) bits.Add(yr.ToString());
        if (!string.IsNullOrEmpty(certification)) bits.Add(certification!);
        if (!string.IsNullOrEmpty(a.Source)) bits.Add(a.Source!);
        return bits.Count > 0 ? string.Join(" · ", bits) : null;
    }

    // Video source chips — the original's VideoDetail carries SourceLinks { ImdbId },
    // so only the IMDb + Stremio chips light up. The IMDb id is the meta id (a tt…
    // catalog id) for a Cinemeta video.
    private void BuildVideoSourceChips()
    {
        var id = _meta?.Id;
        if (string.IsNullOrEmpty(id)) return;
        if (id!.StartsWith("tt"))
            _sourceChips.Add(new("IMDb", $"https://www.imdb.com/title/{id}/", "imdb", "IMDb"));

        // Stremio web deep-link — the prefixed catalog id (tt…) is exactly what
        // Stremio expects, so a plain url-encode is all we need.
        var supported = !string.IsNullOrEmpty(id) && id.StartsWith("tt");
        if (supported)
        {
            var sType = _typeQuery == "movie" ? "movie" : "series";
            var path = $"detail/{sType}/{Uri.EscapeDataString(id!)}";
            _sourceChips.Add(new("Stremio", $"https://web.stremio.com/#/{path}", "stremio", "S", $"stremio:///{path}"));
        }
    }

    // ── User-state pill ──────────────────────────────────────────────────────
    private bool HasEntry => _state?.OnList == true && !string.IsNullOrEmpty(_state?.Status);

    private string EntryPillLabel()
    {
        if (!HasEntry) return "Add to List";
        // Video pill mirrors Detail.cshtml's vLabel: the Trakt status vocabulary, with
        // "Watching · Ep N/T" for a series only (a movie is a single unit).
        if (IsVideo) return VideoPillLabel(_state!.Status!);
        // Mirror Detail.cshtml's userBits: [PrettyStatus, "Ep N / T"] joined by " · ".
        var bits = new List<string>();
        var label = StatusLabel(_state!.Status!);
        if (!string.IsNullOrEmpty(label)) bits.Add(label);
        var prog = _state.Progress;
        if (prog > 0)
            bits.Add(_state.TotalEpisodes is int t && t > 0 ? $"Ep {prog} / {t}" : $"Ep {prog}");
        return bits.Count > 0 ? string.Join(" · ", bits) : "Add to List";
    }

    // Trakt video status → pill label. Mirrors Detail.cshtml's vLabel switch
    // (planning / completed / onhold / dropped / rewatching, else "watching" →
    // "Watching · Ep N/T" for a series with a known total, else "Watching").
    private string VideoPillLabel(string status) => status.ToLowerInvariant() switch
    {
        "planning" => "Planning",
        "completed" => "Completed",
        "onhold" => "On Hold",
        "dropped" => "Dropped",
        "rewatching" => "Rewatching",
        _ => VideoMediaType == "series" && _state?.TotalEpisodes is int vt && vt > 0
            ? $"Watching · Ep {_state.Progress}/{vt}"
            : "Watching",
    };

    private async Task OpenModal()
    {
        _modalOpen = true;
        await Task.CompletedTask;
    }

    // TV Back control — return to wherever the user came from (Discover/Library/Search), like a
    // browser/remote Back. Falls back to Discover if history isn't navigable.
    private async Task GoBack()
    {
        try { await JS.InvokeVoidAsync("history.back"); }
        catch { Nav.NavigateTo("/discover"); }
    }

    // ── Quick-add heart ────────────────────────────────────────────────────────
    // Anime: logged in, not a movie, not a multi-cour franchise umbrella (imdb tt-id
    // with >1 season). Video (movie / series): Trakt connected (the tracker), shown on
    // movies too — Trakt tracks them — but still not on a multi-cour umbrella. Visible
    // only when not-on-list or already Watching. Mirrors Detail.cshtml's heartEligible.
    private bool HeartEligible =>
        _meta is not null
        && !(_multiSeason && (_meta.Id?.StartsWith("tt") ?? false))
        && (IsVideo ? _traktConnected : (LoggedIn && !IsMovie));

    private bool ShowHeart => HeartEligible && !_heartHidden;
    private string HeartLabel => _heartFilled ? "Remove from Currently Watching" : "Add to Currently Watching";

    private async Task ToggleHeart()
    {
        if (_heartBusy) return;
        _heartBusy = true;
        // Video → the toggle routes to Trakt via the media type; anime omits it.
        var type = IsVideo ? VideoMediaType : null;
        var result = await Api.ToggleWatchingAsync(Id, type: type);
        _heartBusy = false;
        if (result is null) return;
        if (result.Hidden)
        {
            // Raced a status change elsewhere — the entry's in another list now.
            _heartHidden = true;
        }
        else if (result.Ok)
        {
            _heartFilled = result.Watching;
            // Reflect the change in the pill too (status / progress may have moved).
            _state = await Api.DetailStateAsync(Id, type: type) ?? _state;
            ApplyUserState();
        }
        StateHasChanged();
    }

    // ── Hide / Unhide ────────────────────────────────────────────────────────
    private string HideLabel => _isHidden ? "Unhide from Discover" : "Hide from Discover";

    private async Task ToggleHide()
    {
        if (_hideBusy) return;
        _hideBusy = true;
        // Cache the right media type so the Discover Hidden section renders the card
        // without a re-fetch — "movie"/"series" for video, "anime" otherwise.
        var hideType = IsVideo ? VideoMediaType : "anime";
        var result = await Api.ToggleHiddenAsync(Id, _meta?.Name, _meta?.Poster, hideType);
        _hideBusy = false;
        if (result is { Ok: true }) _isHidden = result.Hidden;
        StateHasChanged();
    }

    // ── Watch CTAs ──────────────────────────────────────────────────────────
    private bool _showWatchCta;
    private string _watchCtaHref = "";
    private string _watchCtaLabel = "";

    // Movie CTA target — anime movies: /meta/{id}/watch/1 (episode 1 = the movie
    // body); video movies: /meta/{id}/watch?type=movie (no episode segment). Mirrors
    // Detail.cshtml's movie CTA href.
    private string MovieCtaHref => IsVideo
        ? $"/meta/{Uri.EscapeDataString(Id)}/watch?type={VideoMediaType}"
        : $"/meta/{Uri.EscapeDataString(Id)}/watch/1";

    // Next-unseen-episode CTA with future-aired gating + multi-season URL. Ports
    // the showWatchCta block from Detail.cshtml (anime path). Hidden for movies
    // (their own CTA), completed shows, progress past the last episode, future
    // next-episode, and multi-cour franchise umbrellas.
    private void ComputeWatchCta()
    {
        _showWatchCta = false;
        if (_meta is null || IsMovie || _episodes.Count == 0) return;

        var progress = _state?.Progress ?? 0;
        var total = _episodes.Count;
        var norm = NormalizeStatus(_state?.Status);
        var entryTotal = _state?.TotalEpisodes;
        var completed = norm == "completed" || (entryTotal is int et && et > 0 && progress >= et);
        var nextEp = progress + 1;
        if (completed || nextEp > total) return;
        // Anime franchise umbrella (imdb tt-id grouped into one entry across cours) →
        // no single "next episode". Video series legitimately carry a tt id + multiple
        // seasons and are NOT grouped umbrellas, so the guard is anime-only.
        if (!IsVideo && _multiSeason && (_meta.Id?.StartsWith("tt") ?? false)) return;

        // Pick the target video — prefer the cour matching the tracked progress so a
        // multi-season franchise lands on the right season's episode.
        var entrySeason = _episodes
            .Where(v => v.Episode == nextEp)
            .Select(v => (int?)(v.Season > 0 ? v.Season : 1))
            .LastOrDefault();
        var target = _episodes.FirstOrDefault(v => v.Episode == nextEp
            && (entrySeason == null || (v.Season > 0 ? v.Season : 1) == entrySeason.Value));
        if (target is null) return;
        if (IsFuture(target)) return; // can't promise a future-aired episode

        var idSeg = Uri.EscapeDataString(Id);
        var q = string.IsNullOrEmpty(_typeQuery) ? "" : $"?type={_typeQuery}";
        var season = target.Season > 0 ? target.Season : 1;
        _watchCtaHref = _multiSeason
            ? $"/meta/{idSeg}/watch/{season}/{nextEp}{q}"
            : $"/meta/{idSeg}/watch/{nextEp}{q}";
        _watchCtaLabel = progress > 0 ? $"Continue · Ep {nextEp}" : $"Watch Ep {nextEp}";
        _showWatchCta = true;
    }

    // ── Episodes: future detection + season default ─────────────────────────
    // AniList airingAt (Unix) wins over the Cinemeta released string when present
    // — matches the original's OverlayAniListAiringSchedule-first gate.
    private static bool IsFuture(EpisodeInfoDto ep)
    {
        if (ep.AiringAt is long at && at > 0)
            return at > DateTimeOffset.UtcNow.ToUnixTimeSeconds();
        return !string.IsNullOrEmpty(ep.Released)
            && DateTime.TryParse(ep.Released, out var d)
            && d.ToUniversalTime().Date > DateTime.UtcNow.Date;
    }

    private static string? DisplayDate(EpisodeInfoDto ep)
    {
        if (ep.AiringAt is long at && at > 0)
            return DateTimeOffset.FromUnixTimeSeconds(at).UtcDateTime.ToString("yyyy-MM-dd");
        if (!string.IsNullOrEmpty(ep.Released) && ep.Released!.Length >= 10) return ep.Released![..10];
        return ep.Released;
    }

    // Default visible season: the one containing current progress when known,
    // otherwise the latest cour (Stremio's "land where you left off").
    private int PickDefaultSeason()
    {
        var progress = _state?.Progress ?? 0;
        if (progress > 0)
        {
            var match = _episodes.FirstOrDefault(v => v.Episode == progress);
            if (match is not null) return match.Season > 0 ? match.Season : 1;
        }
        return _seasons.LastOrDefault(1);
    }

    // Status vocabulary helpers — collapse the per-provider spelling to a canonical
    // name (mirrors Utils.NormalizeListStatus) and to the friendly label
    // (mirrors Detail.cshtml's PrettyStatus for the AniList/MAL/Kitsu union).
    private static string? NormalizeStatus(string? s) => (s ?? "").Trim().ToLowerInvariant() switch
    {
        "" => null,
        "watching" or "current" => "watching",
        "completed" => "completed",
        "planning" or "planned" or "plan_to_watch" or "plantowatch" => "planning",
        "paused" or "on_hold" or "onhold" => "paused",
        "dropped" => "dropped",
        "rewatching" or "repeating" => "rewatching",
        _ => null,
    };

    private static string StatusLabel(string s) => (s ?? "").Trim().ToLowerInvariant() switch
    {
        "current" or "watching" => "Watching",
        "completed" => "Completed",
        "planning" or "planned" or "plan_to_watch" or "plantowatch" => "Planning",
        "paused" or "on_hold" or "onhold" => "On Hold",
        "dropped" => "Dropped",
        "repeating" or "rewatching" => "Rewatching",
        _ => "In List",
    };

    // Supplementary credit chips route into Discover where we have an AniList id;
    // tags route by name (TagDetail keys on the tag name), otherwise external.
    private string SuppHref(LinkDto l)
    {
        var cat = (l.Category ?? "").ToLowerInvariant();
        if (cat.Contains("studio") && l.AnilistId is long sid) return $"/discover/studio/{sid}";
        if (cat.Contains("tag")) return $"/discover/tag/{Uri.EscapeDataString(l.Name ?? "")}";
        // Every other chip carrying an AniList id is a PERSON credit — director / writer / composer /
        // artist / producer / staff / voice actor (the server's StaffRoleToCategory maps roles to varied
        // labels like "writer" and "Artist"). Route them all to our staff page rather than enumerating
        // each role — enumerating is what sent "writer" credits out to anilist.co.
        if (l.AnilistId is long pid) return $"/discover/staff/{pid}";
        return string.IsNullOrEmpty(l.Url) ? "#" : l.Url!;
    }

    private bool SuppInternal(LinkDto l) => SuppHref(l).StartsWith('/');

    private IEnumerable<EpisodeInfoDto> _filteredEpisodes =>
        string.IsNullOrWhiteSpace(_filter)
            ? _episodes
            : _episodes.Where(e =>
                e.Episode.ToString() == _filter.Trim()
                || (e.Title?.Contains(_filter.Trim(), StringComparison.OrdinalIgnoreCase) ?? false));

    private void OnFilter(ChangeEventArgs e) => _filter = e.Value?.ToString() ?? "";

    // Refresh the hero's user-state (pill + heart) after a save/remove in the modal.
    private Task OnEntrySaved() => RefreshUserStateAsync();

    // Episode rows navigate to the watch page (the original used a delegated JS
    // click handler with role=button; here we do it through Blazor routing).
    // Future episodes are inert, matching the original's click guard.
    private void OnEpisodeActivate(EpisodeInfoDto ep, bool future)
    {
        if (future) return;
        var idSeg = Uri.EscapeDataString(Id);
        var q = string.IsNullOrEmpty(_typeQuery) ? "" : $"?type={_typeQuery}";
        var season = ep.Season > 0 ? ep.Season : 1;
        var href = _multiSeason
            ? $"/meta/{idSeg}/watch/{season}/{ep.Episode}{q}"
            : $"/meta/{idSeg}/watch/{ep.Episode}{q}";
        Nav.NavigateTo(href);
    }

    private string? QueryValue(string key)
    {
        var uri = new Uri(Nav.Uri);
        foreach (var pair in uri.Query.TrimStart('?').Split('&', StringSplitOptions.RemoveEmptyEntries))
        {
            var kv = pair.Split('=', 2);
            if (Uri.UnescapeDataString(kv[0]) == key)
                return kv.Length > 1 ? Uri.UnescapeDataString(kv[1]) : "";
        }
        return null;
    }
}
