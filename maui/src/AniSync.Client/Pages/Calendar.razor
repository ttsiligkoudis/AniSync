@page "/calendar"
@implements IDisposable
@inject IAniSyncApi Api
@inject AppState State
@inject ISecureStore Store
@inject IPrerenderSession Prerender

@* Calendar — port of Views/Calendar/Index.cshtml. A Sunday-first week strip
   (today highlighted, dots mark days with episodes) with prev/next/Today week
   navigation, then the week's recent + upcoming episodes bucketed by day. Anime
   come from the user's Watching list (AniList airing); series from Trakt
   Watching/Planning. Each card deep-links to that episode's watch page. Backed by
   /api/v1/me/calendar (the header-authed twin of the MVC view); reuses the cal-*
   classes from site.css verbatim. *@

<PageTitle>Calendar · AniSync</PageTitle>

<div class="cal-page">
    <header class="cal-header">
        <div class="cal-title-group">
            <h1 class="cal-title">Calendar</h1>
            <p class="cal-sub">Recent &amp; upcoming episodes from your anime Watching list and your Trakt series.</p>
        </div>
        <div class="cal-legend" aria-hidden="true">
            <span class="cal-legend-item"><span class="cal-dot cal-dot-anime"></span> Anime</span>
            <span class="cal-legend-item"><span class="cal-dot cal-dot-series"></span> Series</span>
        </div>
    </header>

    @* Only show "Sign in" once we've finished resolving AND have nothing to show — otherwise a
       logged-in load flashes it while the store read is in flight, and (after a prerender replay)
       the loaded calendar would be hidden because StreamConfig isn't repopulated on the circuit. *@
    @if (string.IsNullOrEmpty(State.StreamConfig) && !_loading && _model is null)
    {
        <p class="hint-text"><a href="/settings">Sign in</a> to see your week of episodes.</p>
    }
    else if (_loading && _model is null)
    {
        @* Skeleton shaped like the real calendar (week strip + day sections of cards) so the page
           holds its layout while /api/v1/me/calendar loads, instead of a bare "Loading…" line.
           Reuses the cal-* structure classes so the placeholders line up with the loaded content. *@
        <div class="cal-strip" aria-hidden="true">
            <div class="cal-strip-head">
                <span class="library-card-skeleton-line" style="width:2.2rem;height:2.2rem;margin:0;border-radius:50%"></span>
                <span class="library-card-skeleton-line" style="width:4rem;height:2rem;margin:0"></span>
                <span class="library-card-skeleton-line" style="width:2.2rem;height:2.2rem;margin:0;border-radius:50%"></span>
            </div>
            <div class="cal-strip-days">
                @for (var i = 0; i < 7; i++)
                {
                    <div class="cal-dcell">
                        <span class="library-card-skeleton-line" style="width:1.6rem;margin:0"></span>
                        <span class="library-card-skeleton-line" style="width:1.2rem;height:1.4em;margin:0.25rem 0"></span>
                        <span class="library-card-skeleton-line" style="width:1.6rem;margin:0"></span>
                    </div>
                }
            </div>
        </div>
        <div class="cal-week-data" aria-busy="true">
            <span class="sr-only">Loading your calendar…</span>
            @for (var s = 0; s < 2; s++)
            {
                <section class="cal-day-section">
                    <span class="library-card-skeleton-line" style="display:block;width:9rem;height:1.3em;margin:0 0 0.8rem"></span>
                    <div class="cal-hscroll">
                        @for (var c = 0; c < 4; c++)
                        {
                            <div class="cal-card" aria-hidden="true">
                                <div class="cal-card-thumb skeleton-shimmer"></div>
                                <div class="cal-card-info">
                                    <span class="library-card-skeleton-line"></span>
                                    <span class="library-card-skeleton-line library-card-skeleton-line-short"></span>
                                </div>
                            </div>
                        }
                    </div>
                </section>
            }
        </div>
    }
    else if (_model is null)
    {
        <p class="hint-text">Couldn't load your calendar right now.</p>
    }
    else
    {
        <div class="cal-strip">
            <div class="cal-strip-head">
                <a class="cal-strip-nav" href="/calendar?d=@_model.PrevDate" aria-label="Previous week" rel="prev">
                    <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 18l-6-6 6-6" /></svg>
                </a>
                <a class="cal-strip-today@(_model.SelectedIsToday ? " is-today" : "")" href="/calendar">Today</a>
                <a class="cal-strip-nav" href="/calendar?d=@_model.NextDate" aria-label="Next week" rel="next">
                    <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 18l6-6-6-6" /></svg>
                </a>
            </div>
            <div class="cal-strip-days">
                @foreach (var day in _model.Days)
                {
                    <div class="cal-dcell@(day.IsToday ? " today" : "")">
                        <span class="cal-dcell-mon">@MonthLabel(day.DateIso)</span>
                        <span class="cal-dcell-num">@DayNumber(day.DateIso)</span>
                        <span class="cal-dcell-dow">@DowLabel(day.DateIso)</span>
                        <span class="cal-dcell-dots" aria-hidden="true">
                            @if (day.HasAnime) { <span class="cal-dot cal-dot-anime"></span> }
                            @if (day.HasSeries) { <span class="cal-dot cal-dot-series"></span> }
                        </span>
                    </div>
                }
            </div>
        </div>

        @if (_model.TotalEpisodes == 0)
        {
            <div class="cal-empty">
                Nothing scheduled this week for the shows you're tracking. Episodes show up here once
                they're on your anime <strong>Watching</strong> list or your Trakt <strong>Watching</strong> / <strong>Planning</strong> lists.
            </div>
        }
        else
        {
            <div class="cal-week-data">
                @foreach (var day in _model.Days.Where(d => d.Episodes.Count > 0))
                {
                    <section class="cal-day-section@(day.IsToday ? " is-today" : "")" id="day-@day.DateIso">
                        <h2 class="cal-day-section-title">@day.Label</h2>
                        <div class="cal-hscroll">
                            @foreach (var ep in day.Episodes)
                            {
                                <a class="cal-card cal-card-@ep.Kind" href="@(string.IsNullOrEmpty(ep.LinkPath) ? "#" : ep.LinkPath)" title="@ep.Title">
                                    <div class="cal-card-thumb">
                                        @if (!string.IsNullOrEmpty(ep.CoverImage))
                                        {
                                            <img src="@ep.CoverImage" alt="" loading="lazy" decoding="async" />
                                        }
                                        else
                                        {
                                            <span class="cal-card-thumb-ph" aria-hidden="true"></span>
                                        }
                                        <span class="cal-card-time" data-ts="@ep.AiringAt">@AirTime(ep.AiringAt)</span>
                                    </div>
                                    <div class="cal-card-info">
                                        <div class="cal-card-title">@ep.Title</div>
                                        <div class="cal-card-meta">@EpisodeMeta(ep)</div>
                                    </div>
                                </a>
                            }
                        </div>
                    </section>
                }
            </div>
        }
    }
</div>

@code {
    [SupplyParameterFromQuery(Name = "d")] public string? D { get; set; }

    private bool _loading = true;
    private CalendarResponse? _model;

    // Re-render when the UI culture resolves (MainLayout reads navigator.language after first
    // render) so the day / month labels flip to the visitor's locale without a navigation.
    protected override void OnInitialized() => State.Changed += OnStateChanged;
    private void OnStateChanged() => InvokeAsync(StateHasChanged);
    void IDisposable.Dispose() => State.Changed -= OnStateChanged;

    protected override async Task OnParametersSetAsync()
    {
        var key = PersistKey();

        // Interactive remount after a prerender: replay the calendar the prerender stashed (keyed by
        // this exact week) instead of refetching, so a logged-in refresh doesn't flash content →
        // skeleton → content. Consumed once; a later client-side navigation (different week, or
        // nothing stashed) falls through to a normal load.
        if (RendererInfo.IsInteractive && _appliedKey != key
            && Prerender.TryReplay<PersistedCalendar?>(key, out var snap) && snap is not null)
        {
            _appliedKey = key;
            RestoreCalendar(snap);
            return;
        }

        // Already loaded this exact week — don't let a parent re-render (e.g. after the credential
        // hydrates) re-invoke OnParametersSet and refetch over the replayed model.
        if (_appliedKey == key) return;

        // Resolve the credential ourselves on the interactive pass before deciding logged-out: on a
        // cold web refresh MainLayout hasn't populated StreamConfig yet when we first run, which left
        // the page stuck on "Sign in" even when authenticated. The store derives it from the
        // anisync_uid cookie on web (secure store on native) — same self-resolve Account does.
        if (string.IsNullOrEmpty(State.StreamConfig) && RendererInfo.IsInteractive)
        {
            var saved = await Store.GetAsync(ISecureStore.ConfigKey);
            if (!string.IsNullOrEmpty(saved)) State.SetStreamConfig(saved);
        }

        if (string.IsNullOrEmpty(State.StreamConfig)) { _loading = false; return; }
        _loading = true;
        _model = await Api.CalendarAsync(D);
        _loading = false;

        _appliedKey = key;

        // Prerender (cookie-seeded credential): stash this week so the interactive remount replays it
        // instead of refetching. Web-only; no-op on native and on the interactive pass.
        if (!RendererInfo.IsInteractive)
            Prerender.Persist<PersistedCalendar>(key, RendererInfo.IsInteractive, Snapshot);
    }

    // ── Prerender → interactive replay (web only; no-op on native) ──────────────────────────────
    private string? _appliedKey;

    // Keyed by the requested week (?d=) so a stashed calendar is never replayed onto a different week.
    private string PersistKey() => $"calendar:{D}";

    private sealed record PersistedCalendar(CalendarResponse? Model);

    private PersistedCalendar Snapshot() => new(_model);

    private void RestoreCalendar(PersistedCalendar snap)
    {
        _model = snap.Model;
        _loading = false;
    }

    // Month / weekday names in the visitor's locale (State.UiCulture, from navigator.language) —
    // the web server's culture isn't theirs. Parse the ISO key invariantly (it's yyyy-MM-dd).
    private string MonthLabel(string? iso) => DateOnly.TryParse(iso, System.Globalization.CultureInfo.InvariantCulture, out var d) ? d.ToString("MMM", State.UiCulture) : "";
    private static string DayNumber(string? iso) => DateOnly.TryParse(iso, System.Globalization.CultureInfo.InvariantCulture, out var d) ? d.Day.ToString() : "";
    private string DowLabel(string? iso) => DateOnly.TryParse(iso, System.Globalization.CultureInfo.InvariantCulture, out var d) ? d.ToString("ddd", State.UiCulture) : "";
    private static string AirTime(long unix) => DateTimeOffset.FromUnixTimeSeconds(unix).UtcDateTime
        .ToString("h:mm tt", System.Globalization.CultureInfo.InvariantCulture);

    private static string EpisodeMeta(CalendarEpisodeDto ep)
    {
        if (ep.Season is int s)
        {
            var meta = $"S{s} • E{ep.Episode}";
            return string.IsNullOrEmpty(ep.EpisodeTitle) ? meta : $"{meta} - {ep.EpisodeTitle}";
        }
        return $"Episode {ep.Episode}";
    }
}
