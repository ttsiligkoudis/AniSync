@page "/configure"
@inject IAniSyncApi Api
@inject AppState State
@inject ISecureStore Store
@inject IAppEnvironment Env
@inject NavigationManager Nav
@inject IJSRuntime JS
@implements IAsyncDisposable

@* Stremio addon configuration — Blazor port of Stremio.cshtml + its shared
   partials. Account + Linked Accounts (shared component), the catalog Enable /
   Discover-Only grid, Streams toggles + stream-addon manager + one-click debrid,
   anime Preferences, and the live install-URL card. Toggle state is the three flag
   bytes (ConfigFlags mirrors the server bit layout); Save persists them and the
   server returns a fresh install segment (revision bumped) so the URL changes. *@

<PageTitle>Stremio addon · AniSync</PageTitle>

<section class="config-page">
    <header class="page-header">
        <h1 class="page-title">Stremio addon</h1>
        <p class="page-subtitle">Catalogs · streams · install URL</p>
    </header>

    @if (_loading)
    {
        <p class="hint-text">Loading configuration…</p>
    }
    else if (_config is null)
    {
        <section class="section-card">
            <p class="hint-text">
                This device is connected with an inline (no-account) config, which can't be edited
                here. <a href="/login">Sign in</a> with a tracker to manage catalogs and the install URL.
            </p>
        </section>
    }
    else
    {
        <AccountSection Config="_config" OnReload="ReloadAsync" />

        <!-- ─── CATALOGS ─── -->
        <section class="section-card">
            <span class="section-title">Catalogs</span>
            <p class="section-description">Choose which catalogs and stream sources AniSync exposes to Stremio.</p>
            <div class="catalogs-grid">
                <span class="catalog-col-spacer"></span>
                <span class="catalog-col-label">Enable</span>
                <span class="catalog-col-label">Discover Only</span>
                <hr class="option-sep" />

                <span class="option-name option-name-all">Select all</span>
                <label class="switch">
                    <input type="checkbox" checked="@_allEnable" @onchange="ToggleAllEnable" />
                    <span class="slider"></span>
                </label>
                <label class="switch">
                    <input type="checkbox" checked="@_allDiscover" @onchange="ToggleAllDiscover" />
                    <span class="slider"></span>
                </label>
                <hr class="option-sep" />

                @foreach (var row in CatalogRows.Where(r => r.Visible()))
                {
                    <span class="option-name">@row.Label</span>
                    <label class="switch">
                        <input type="checkbox" checked="@row.GetEnable()"
                               @onchange="e => SetEnable(row, (bool)e.Value!)" />
                        <span class="slider"></span>
                    </label>
                    <label class="switch @(row.GetEnable() ? "" : "switch-disabled")">
                        <input type="checkbox" checked="@row.GetDiscover()" disabled="@(!row.GetEnable())"
                               @onchange="e => SetDiscover(row, (bool)e.Value!)" />
                        <span class="slider"></span>
                    </label>
                    <hr class="option-sep" />
                }
            </div>
        </section>

        <!-- ─── STREAMS ─── -->
        <section class="section-card" id="streams">
            <span class="section-title">Streams</span>
            <p class="section-description">Choose what AniSync attaches to each episode in Stremio.</p>
            <div class="streams-grid">
                <div class="stream-option">
                    <div class="option-name-wrap">
                        <span class="option-name">Manage Entry</span>
                        <span class="option-name-sub">Quick-edit progress, score and notes from Stremio.</span>
                    </div>
                    <label class="switch">
                        <input type="checkbox" checked="@ManageEntry" @onchange="e => { ManageEntry = (bool)e.Value!; MarkDirty(); }" />
                        <span class="slider"></span>
                    </label>
                </div>
                <div class="stream-option">
                    <div class="option-name-wrap">
                        <span class="option-name">Auto-track progress</span>
                        <span class="option-name-sub">Update your list when you start an episode.</span>
                    </div>
                    <label class="switch">
                        <input type="checkbox" checked="@AutoTrack" @onchange="e => { AutoTrack = (bool)e.Value!; MarkDirty(); }" />
                        <span class="slider"></span>
                    </label>
                </div>
                <div class="stream-option">
                    <div class="option-name-wrap">
                        <span class="option-name">External services</span>
                        <span class="option-name-sub">Crunchyroll, Netflix, HiDive, …</span>
                    </div>
                    <label class="switch">
                        <input type="checkbox" checked="@_flags.ShowExternalStreams" @onchange="e => { _flags.ShowExternalStreams = (bool)e.Value!; MarkDirty(); }" />
                        <span class="slider"></span>
                    </label>
                </div>
            </div>

            <!-- Stream addons -->
            <p class="manifest-url-label" style="margin-top:1.5rem;">Stream addons</p>
            @if (_catalog.Providers.Count > 0)
            {
                <div class="debrid-setup">
                    <div class="debrid-setup-row">
                        <select class="debrid-select" @bind="_debridProvider" aria-label="Debrid provider">
                            @foreach (var p in _catalog.Providers)
                            {
                                <option value="@p.Id">@p.Name</option>
                            }
                        </select>
                        <input class="manifest-url-input" type="password" placeholder="Paste your API key"
                               autocomplete="off" spellcheck="false"
                               value="@_debridKey" @oninput="e => _debridKey = e.Value?.ToString() ?? string.Empty" />
                    </div>
                    <div class="debrid-setup-addons">
                        <span class="debrid-setup-addons-label">Add:</span>
                        @foreach (var a in _catalog.Addons)
                        {
                            <label class="debrid-addon-check">
                                <input type="checkbox" checked="@_debridAddons.Contains(a.Id!)"
                                       @onchange="e => ToggleDebridAddon(a.Id!, (bool)e.Value!)" />
                                <span>@a.Name</span>
                            </label>
                        }
                    </div>
                    <div class="debrid-setup-actions">
                        <span class="debrid-setup-links">
                            @if (SelectedProvider?.SignUpUrl is { Length: > 0 } su)
                            {
                                <a class="debrid-apikey-link" target="_blank" rel="noopener" href="@su">Sign up ↗</a>
                            }
                            @if (SelectedProvider?.ApiKeyUrl is { Length: > 0 } ak)
                            {
                                <a class="debrid-apikey-link" target="_blank" rel="noopener" href="@ak">Get your API key ↗</a>
                            }
                        </span>
                        <button class="btn-ghost btn-ghost-sm" type="button" disabled="@_debridBusy" @onclick="AddDebridAsync">
                            @(_debridBusy ? "Setting up…" : "Save")
                        </button>
                    </div>
                    @if (!string.IsNullOrEmpty(_debridStatus))
                    {
                        <p class="debrid-setup-status" role="status">@_debridStatus</p>
                    }
                </div>
            }

            <ul class="stream-addon-list">
                @for (var i = 0; i < _config.StreamAddons.Count; i++)
                {
                    var addon = _config.StreamAddons[i];
                    var idx = i;
                    <li class="stream-addon-row">
                        <div class="stream-addon-meta">
                            <span class="stream-addon-name">@addon.Name</span>
                            <span class="stream-addon-url">@addon.Url</span>
                        </div>
                        <div class="stream-addon-actions">
                            <button class="stream-addon-icon-btn" type="button" title="Move up"
                                    disabled="@(idx == 0)" @onclick="() => MoveAddonAsync(idx, -1)">▲</button>
                            <button class="stream-addon-icon-btn" type="button" title="Move down"
                                    disabled="@(idx == _config.StreamAddons.Count - 1)" @onclick="() => MoveAddonAsync(idx, 1)">▼</button>
                            <button class="stream-addon-icon-btn stream-addon-remove" type="button" title="Remove"
                                    @onclick="() => RemoveAddonAsync(addon.Url!)">✕</button>
                        </div>
                    </li>
                }
            </ul>
            <p class="manifest-url-label">Or paste a manifest URL</p>
            <div class="manifest-url-row">
                <input class="manifest-url-input" type="text" placeholder="https://….example.com/…/manifest.json"
                       autocomplete="off" value="@_addonInput" @oninput="e => _addonInput = e.Value?.ToString() ?? string.Empty" />
                <button class="btn-ghost btn-ghost-sm" type="button" style="white-space:nowrap;"
                        disabled="@_addonBusy" @onclick="AddAddonAsync">@(_addonBusy ? "Adding…" : "Add")</button>
            </div>
            <p class="option-name-sub" style="margin-top:0.5rem;">
                Already have a configured manifest URL? Paste any Stremio
                stream-addon manifest — Torrentio
                (<a href="https://torrentio.strem.fun" target="_blank" rel="noopener">torrentio.strem.fun</a>),
                MediaFusion (<a href="https://mediafusion.elfhosted.com" target="_blank" rel="noopener">mediafusion.elfhosted.com</a>),
                Comet (<a href="https://comet.feels.legal/configure" target="_blank" rel="noopener">comet.feels.legal</a>),
                Jackettio, or
                <a href="https://aiostreams.elfhosted.com" target="_blank" rel="noopener">AIOStreams</a>
                (one URL that bundles many addons). Episode lookups fan out across every entry in
                this list, with duplicates merged by torrent hash.
            </p>
            @if (!string.IsNullOrEmpty(_addonStatus))
            {
                <p class="option-name-sub">@_addonStatus</p>
            }
        </section>

        <!-- ─── PREFERENCES ─── -->
        @if (AnimeEnabled)
        {
            <section class="section-card">
                <span class="section-title">Preferences</span>
                <p class="section-description">General display preferences that apply across the site and the Stremio addon.</p>
                <div class="streams-grid">
                    <div class="stream-option">
                        <div class="option-name-wrap">
                            <span class="option-name">Hide unaired anime from Watching</span>
                            <span class="option-name-sub">When on, entries that haven't aired yet are filtered out of your Currently Watching list (site + Stremio). Off shows everything in the list as-is.</span>
                        </div>
                        <label class="switch">
                            <input type="checkbox" checked="@_flags.HideUnreleasedFromWatching" @onchange="e => { _flags.HideUnreleasedFromWatching = (bool)e.Value!; MarkDirty(); }" />
                            <span class="slider"></span>
                        </label>
                    </div>
                    <div class="stream-option">
                        <div class="option-name-wrap">
                            <span class="option-name">Group anime seasons</span>
                            <span class="option-name-sub">Collapse multi-cour franchises into a single card across the site and the Stremio addon. Off shows every cour separately.</span>
                        </div>
                        <label class="switch">
                            <input type="checkbox" checked="@_flags.EnableSeasonGrouping" @onchange="e => { _flags.EnableSeasonGrouping = (bool)e.Value!; MarkDirty(); }" />
                            <span class="slider"></span>
                        </label>
                    </div>
                    <div class="stream-option">
                        <div class="option-name-wrap">
                            <span class="option-name">Show 18+ anime content</span>
                            <span class="option-name-sub">Off (default) hides hentai / R18 entries from Discover, Library, and the Stremio addon catalogs. Direct anime URLs still work either way — this only affects what shows up in the grid.</span>
                        </div>
                        <label class="switch">
                            <input type="checkbox" checked="@_flags.ShowAdultContent" @onchange="e => { _flags.ShowAdultContent = (bool)e.Value!; MarkDirty(); }" />
                            <span class="slider"></span>
                        </label>
                    </div>
                </div>
            </section>
        }

        <!-- ─── INSTALL ─── -->
        <section class="section-card">
            <span class="section-title">Installation Options</span>
            <p class="section-description">
                Install AniSync using your preferred method. The install URL updates automatically
                when you change the toggles above — Stremio caches manifests, so a fresh install
                is needed to pick up changes.
            </p>
            <div class="install-inner-card">
                <div class="install-header">
                    <img src="_content/AniSync.Client/img/logo.png" alt="AniSync" class="install-icon-img" />
                    <div class="install-header-text">
                        <h3>Stremio</h3>
                        <p>Install to Stremio or other Stremio-compatible clients using the Manifest URL.</p>
                    </div>
                </div>
                <hr class="install-divider" />
                <a class="btn-primary-action btn-install" href="@StremioDeepLink">Install to Stremio</a>
                <a class="btn-secondary-action" target="_blank" rel="noopener" href="@StremioWebLink">Install to Stremio Web</a>

                <p class="manifest-url-label">Direct Manifest URL</p>
                <div class="manifest-url-row">
                    <input class="manifest-url-input" readonly type="text" value="@ManifestUrl" />
                    <button class="btn-icon-copy" type="button" title="Copy URL" aria-label="Copy URL" @onclick="CopyManifestAsync">
                        @if (_copied) { <span>✓</span> }
                        else
                        {
                            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                                <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
                            </svg>
                        }
                    </button>
                </div>
            </div>
        </section>

        <!-- ─── FLOATING SAVE BAR ─── -->
        <div class="floating-save-bar" aria-live="polite" role="status">
            <span class="floating-save-status">@(_dirty ? "Unsaved changes" : "All changes saved")</span>
            <button class="floating-save-btn" type="button" disabled="@_saving" @onclick="SaveAsync">
                @(_saving ? "Saving…" : "Save")
            </button>
        </div>
    }
</section>

@code {
    private bool _loading = true;
    private ConfigStateDto? _config;
    private ConfigFlags _flags = new();
    private byte _savedF1, _savedF2, _savedF3;
    private bool _dirty;
    private bool _saving;

    private StreamCatalogDto _catalog = new();
    private string _debridProvider = "";
    private string _debridKey = "";
    private readonly HashSet<string> _debridAddons = new(StringComparer.OrdinalIgnoreCase);
    private bool _debridBusy;
    private string? _debridStatus;

    private string _addonInput = "";
    private bool _addonBusy;
    private string? _addonStatus;

    private bool _copied;
    private IJSObjectReference? _js;

    private bool _allEnable;
    private bool _allDiscover;

    private bool AnimeEnabled => _config?.EnabledMediaTypes.Count is null or 0
        || _config!.EnabledMediaTypes.Contains("anime", StringComparer.OrdinalIgnoreCase);

    private bool IsAnilistOrMal =>
        string.Equals(_config?.AnimeService, "Anilist", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(_config?.AnimeService, "MyAnimeList", StringComparison.OrdinalIgnoreCase);

    // Inverted toggles: the user-facing "on" means the disable-flag is off.
    private bool ManageEntry { get => !_flags.HideManageEntry; set => _flags.HideManageEntry = !value; }
    private bool AutoTrack { get => !_flags.DisableAutoTrack; set => _flags.DisableAutoTrack = !value; }

    private string Origin => Env.ApiBaseUrl.TrimEnd('/');
    private string ManifestUrl => string.IsNullOrEmpty(_config?.InstallConfig)
        ? "" : $"{Origin}/{_config!.InstallConfig}/manifest.json";
    private string StremioDeepLink => ManifestUrl is { Length: > 0 } u && u.Contains("://")
        ? "stremio://" + u[(u.IndexOf("://", StringComparison.Ordinal) + 3)..] : "#";
    private string StremioWebLink => string.IsNullOrEmpty(ManifestUrl)
        ? "#" : $"https://web.stremio.com/#/addons?addon={Uri.EscapeDataString(ManifestUrl)}";

    private DebridProviderDto? SelectedProvider =>
        _catalog.Providers.FirstOrDefault(p => p.Id == _debridProvider) ?? _catalog.Providers.FirstOrDefault();

    private sealed record CatalogRowSpec(string Label, Func<bool> Visible,
        Func<bool> GetEnable, Action<bool> SetEnable, Func<bool> GetDiscover, Action<bool> SetDiscover);

    private List<CatalogRowSpec> CatalogRows => new()
    {
        new("Currently watching", () => true, () => _flags.ShowCurrent, v => _flags.ShowCurrent = v, () => _flags.DiscoverOnlyCurrent, v => _flags.DiscoverOnlyCurrent = v),
        new("Completed", () => true, () => _flags.ShowCompleted, v => _flags.ShowCompleted = v, () => _flags.DiscoverOnlyCompleted, v => _flags.DiscoverOnlyCompleted = v),
        new("Plan to Watch", () => true, () => _flags.ShowPlanning, v => _flags.ShowPlanning = v, () => _flags.DiscoverOnlyPlanning, v => _flags.DiscoverOnlyPlanning = v),
        new("On Hold", () => true, () => _flags.ShowPaused, v => _flags.ShowPaused = v, () => _flags.DiscoverOnlyPaused, v => _flags.DiscoverOnlyPaused = v),
        new("Dropped", () => true, () => _flags.ShowDropped, v => _flags.ShowDropped = v, () => _flags.DiscoverOnlyDropped, v => _flags.DiscoverOnlyDropped = v),
        new("Rewatching", () => IsAnilistOrMal, () => _flags.ShowRepeating, v => _flags.ShowRepeating = v, () => _flags.DiscoverOnlyRepeating, v => _flags.DiscoverOnlyRepeating = v),
        new("Trending now", () => true, () => _flags.ShowTrending, v => _flags.ShowTrending = v, () => _flags.DiscoverOnlyTrending, v => _flags.DiscoverOnlyTrending = v),
        new("Seasonal Anime", () => true, () => _flags.ShowSeasonal, v => _flags.ShowSeasonal = v, () => _flags.DiscoverOnlySeasonal, v => _flags.DiscoverOnlySeasonal = v),
        new("Airing This Week", () => true, () => _flags.ShowAiring, v => _flags.ShowAiring = v, () => _flags.DiscoverOnlyAiring, v => _flags.DiscoverOnlyAiring = v),
    };

    protected override async Task OnInitializedAsync()
    {
        // Wait for the interactive render — the credential lives in localStorage, which
        // isn't readable during prerender, so a prerender check would wrongly bounce a
        // logged-in user to /login. OnInitializedAsync runs again once interactive.
        if (!RendererInfo.IsInteractive) return;

        // Make sure the stored credential is hydrated; bounce to login if absent.
        if (string.IsNullOrEmpty(State.StreamConfig))
        {
            var saved = await Store.GetAsync(ISecureStore.ConfigKey);
            if (!string.IsNullOrEmpty(saved)) State.SetStreamConfig(saved);
        }
        if (string.IsNullOrEmpty(State.StreamConfig)) { Nav.NavigateTo("/login"); return; }

        await ReloadAsync();
        _catalog = await Api.StreamCatalogAsync();
        _debridProvider = _catalog.Providers.FirstOrDefault()?.Id ?? "";
        foreach (var a in _catalog.Addons) _debridAddons.Add(a.Id!);
        _loading = false;
    }

    private async Task ReloadAsync()
    {
        _config = await Api.GetConfigAsync();
        if (_config is not null)
        {
            _flags = ConfigFlags.Decode(_config.Flags1, _config.Flags2, _config.Flags3);
            (_savedF1, _savedF2, _savedF3) = (_config.Flags1, _config.Flags2, _config.Flags3);
            _dirty = false;
            RecomputeMasters();
        }
    }

    private void MarkDirty()
    {
        var (f1, f2, f3) = _flags.Encode();
        _dirty = f1 != _savedF1 || f2 != _savedF2 || f3 != _savedF3;
        RecomputeMasters();
    }

    private void RecomputeMasters()
    {
        var rows = CatalogRows.Where(r => r.Visible()).ToList();
        _allEnable = rows.Count > 0 && rows.All(r => r.GetEnable());
        _allDiscover = rows.Count > 0 && rows.All(r => r.GetEnable() && r.GetDiscover());
    }

    private void SetEnable(CatalogRowSpec row, bool value)
    {
        row.SetEnable(value);
        if (!value) row.SetDiscover(false); // Discover-Only is meaningless without Enable.
        MarkDirty();
    }

    private void SetDiscover(CatalogRowSpec row, bool value) { row.SetDiscover(value); MarkDirty(); }

    private void ToggleAllEnable(ChangeEventArgs e)
    {
        var on = (bool)e.Value!;
        foreach (var r in CatalogRows.Where(r => r.Visible())) { r.SetEnable(on); if (!on) r.SetDiscover(false); }
        MarkDirty();
    }

    private void ToggleAllDiscover(ChangeEventArgs e)
    {
        var on = (bool)e.Value!;
        foreach (var r in CatalogRows.Where(r => r.Visible() && r.GetEnable())) r.SetDiscover(on);
        MarkDirty();
    }

    private async Task SaveAsync()
    {
        if (_config is null) return;
        _saving = true;
        var (f1, f2, f3) = _flags.Encode();
        var result = await Api.SaveFlagsAsync(f1, f2, f3);
        if (result is not null)
        {
            (_savedF1, _savedF2, _savedF3) = (f1, f2, f3);
            _config.Revision = result.Revision;
            if (!string.IsNullOrEmpty(result.InstallConfig)) _config.InstallConfig = result.InstallConfig;
            _dirty = false;
        }
        _saving = false;
    }

    private void ToggleDebridAddon(string id, bool on)
    {
        if (on) _debridAddons.Add(id); else _debridAddons.Remove(id);
    }

    private async Task AddDebridAsync()
    {
        if (string.IsNullOrWhiteSpace(_debridKey)) { _debridStatus = "Paste your API key first."; return; }
        _debridBusy = true; _debridStatus = null;
        var result = await Api.AddDebridAddonsAsync(new DebridSetupRequest
        {
            Provider = _debridProvider,
            ApiKey = _debridKey.Trim(),
            Addons = _debridAddons.ToList(),
        });
        if (result is not null)
        {
            _debridStatus = $"Added {result.Added.Count} addon(s)" + (result.Skipped.Count > 0 ? $", {result.Skipped.Count} skipped." : ".");
            _debridKey = "";
            await ReloadAsync();
        }
        else _debridStatus = "Couldn't set up debrid addons right now.";
        _debridBusy = false;
    }

    private async Task AddAddonAsync()
    {
        var url = _addonInput.Trim();
        if (string.IsNullOrEmpty(url)) return;
        _addonBusy = true; _addonStatus = null;
        var result = await Api.AddStreamAddonAsync(url);
        if (result is { Added: true }) { _addonInput = ""; await ReloadAsync(); }
        else _addonStatus = "Couldn't add that addon — check the manifest URL.";
        _addonBusy = false;
    }

    private async Task RemoveAddonAsync(string url)
    {
        if (await Api.RemoveStreamAddonAsync(url)) await ReloadAsync();
    }

    private async Task MoveAddonAsync(int index, int delta)
    {
        if (_config is null) return;
        var urls = _config.StreamAddons.Select(a => a.Url!).ToList();
        var target = index + delta;
        if (target < 0 || target >= urls.Count) return;
        (urls[index], urls[target]) = (urls[target], urls[index]);
        if (await Api.ReorderStreamAddonsAsync(urls)) await ReloadAsync();
    }

    private async Task CopyManifestAsync()
    {
        try
        {
            _js ??= await JS.InvokeAsync<IJSObjectReference>("import", "./_content/AniSync.Client/js/configure.js");
            await _js.InvokeAsync<bool>("copyText", ManifestUrl);
            _copied = true;
            StateHasChanged();
        }
        catch { /* clipboard blocked */ }
    }

    public async ValueTask DisposeAsync()
    {
        if (_js is not null) { try { await _js.DisposeAsync(); } catch { } }
    }
}
