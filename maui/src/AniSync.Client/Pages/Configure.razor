@page "/configure"
@inject IAniSyncApi Api
@inject AppState State
@inject ISecureStore Store
@inject IAppEnvironment Env
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject IPrerenderSession Prerender
@implements IAsyncDisposable

@* Stremio addon configuration — Blazor port of Stremio.cshtml + its shared
   partials. Account + Linked Accounts (shared component), the catalog Enable /
   Discover-Only grid, the shared Streams + Preferences cards, and the live
   install-URL card. Toggle state is the three flag bytes (ConfigFlags mirrors the
   server bit layout); Save persists them and the server returns a fresh install
   segment (revision bumped) so the URL changes.

   Streams + Preferences render via the SHARED StreamsSection / PreferencesSection
   components (same ones the /account page uses) — matching the original, where
   _StreamsSection / _PreferencesSection were partials mounted by both pages. On
   the Stremio page StreamsSection runs with IsStremio=true, which shows just the
   stream toggles; the full stream-addon / debrid manager lives on /account (the
   original hid it here too). *@

<PageTitle>Stremio addon · AniSync</PageTitle>

<header class="page-header">
    <h1 class="page-title">Stremio addon</h1>
    <p class="page-subtitle">Catalogs · streams · install URL</p>
</header>

    @if (_loading)
    {
        <p class="hint-text">Loading configuration…</p>
    }
    else if (_config is null)
    {
        <section class="section-card">
            <p class="hint-text">
                This device is connected with an inline (no-account) config, which can't be edited
                here. <a href="/login">Sign in</a> with a tracker to manage catalogs and the install URL.
            </p>
        </section>
    }
    else
    {
        <AccountSection Config="_config" OnReload="ReloadAsync" />
        <LinkedAccountsSection Config="_config" OnReload="ReloadAsync" ReturnUrl="/configure" AnimeEnabled="AnimeEnabled" />

        <!-- ─── CATALOGS ─── -->
        <section class="section-card">
            <span class="section-title">Catalogs</span>
            <p class="section-description">Choose which catalogs and stream sources AniSync exposes to Stremio.</p>
            <div class="catalogs-grid">
                <span class="catalog-col-spacer"></span>
                <span class="catalog-col-label">Enable</span>
                <span class="catalog-col-label">Discover Only</span>
                <hr class="option-sep" />

                <span class="option-name option-name-all">Select all</span>
                <label class="switch">
                    <input type="checkbox" checked="@_allEnable" @onchange="ToggleAllEnable" />
                    <span class="slider"></span>
                </label>
                <label class="switch">
                    <input type="checkbox" checked="@_allDiscover" @onchange="ToggleAllDiscover" />
                    <span class="slider"></span>
                </label>
                <hr class="option-sep" />

                @foreach (var row in CatalogRows.Where(r => r.Visible()))
                {
                    <span class="option-name">@row.Label</span>
                    <label class="switch">
                        <input type="checkbox" checked="@row.GetEnable()"
                               @onchange="e => SetEnable(row, (bool)e.Value!)" />
                        <span class="slider"></span>
                    </label>
                    <label class="switch @(row.GetEnable() ? "" : "switch-disabled")">
                        <input type="checkbox" checked="@row.GetDiscover()" disabled="@(!row.GetEnable())"
                               @onchange="e => SetDiscover(row, (bool)e.Value!)" />
                        <span class="slider"></span>
                    </label>
                    <hr class="option-sep" />
                }
            </div>
        </section>

        <!-- ─── STREAMS (shared component) ─── -->
        @* IsStremio=true → just the stream toggles (Manage Entry / Auto-track /
           External services). The stream-addon + debrid manager is hidden here and
           lives on /account, exactly as the original _StreamsSection did. *@
        <StreamsSection IsStremio="true" Flags="_flags" Config="_config" OnDirty="MarkDirty" OnReload="ReloadAsync" />

        <!-- ─── PREFERENCES (shared component) ─── -->
        <PreferencesSection Flags="_flags" AnimeEnabled="AnimeEnabled" OnDirty="MarkDirty" />

        <!-- ─── INSTALL ─── -->
        <section class="section-card">
            <span class="section-title">Installation Options</span>
            <p class="section-description">
                The install URL updates automatically when you change the toggles above — Stremio caches
                manifests, so a fresh install is needed to pick up changes.
            </p>
            <div class="install-inner-card">
                <div class="install-header">
                    <img src="_content/AniSync.Client/img/logo-192.png" alt="AniSync" class="install-icon-img" width="192" height="192" decoding="async" loading="lazy" />
                    <div class="install-header-text">
                        <h3>Stremio</h3>
                        <p>Install to Stremio or other Stremio-compatible clients using the Manifest URL.</p>
                    </div>
                </div>
                <hr class="install-divider" />
                <a class="btn-primary-action btn-install" href="@StremioDeepLink">Install to Stremio</a>
                <a class="btn-secondary-action" target="_blank" rel="noopener" href="@StremioWebLink">Install to Stremio Web</a>

                <p class="manifest-url-label">Direct Manifest URL</p>
                <div class="manifest-url-row">
                    <input class="manifest-url-input" readonly type="text" value="@ManifestUrl" />
                    <button class="btn-icon-copy" type="button" title="Copy URL" aria-label="Copy URL" @onclick="CopyManifestAsync">
                        @if (_copied) { <span>✓</span> }
                        else
                        {
                            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                                <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
                            </svg>
                        }
                    </button>
                </div>
            </div>
        </section>

        <!-- Quick links to the other config surfaces -->
        <section class="section-card">
            <div class="btn-action-row">
                <a class="btn-ghost" href="/account">Account &amp; linked accounts</a>
                <a class="btn-ghost" href="/advanced">Advanced (sync · backups · danger zone)</a>
            </div>
        </section>

        <!-- ─── FLOATING SAVE BAR ─── -->
        <FloatingSaveBar Dirty="_dirty" Saving="_saving" OnSave="SaveAsync" />
    }

@code {
    private bool _loading = true;
    private ConfigStateDto? _config;
    private ConfigFlags _flags = new();
    private byte _savedF1, _savedF2, _savedF3;
    private bool _dirty;
    private bool _saving;

    private bool _copied;
    private IJSObjectReference? _js;

    private bool _allEnable;
    private bool _allDiscover;

    // Anime-only cards (the Preferences toggles + the anime sync targets in
    // LinkedAccountsSection) gate on the user's real media-type pick. That choice
    // lives client-side (AppState, hydrated from localStorage by MainLayout) — NOT in
    // the server config: the Blazor-Server self-call to /api/v1/me/config can't see the
    // browser media-type cookie and the pick is never persisted to the DB, so the
    // server defaults EnabledMediaTypes to anime. Wait for hydration so anime cards
    // aren't flashed for non-anime users.
    private bool AnimeEnabled =>
        State.MediaTypesHydrated && State.EnabledMediaTypes.Contains(MetaType.anime);

    private bool IsAnilistOrMal =>
        string.Equals(_config?.AnimeService, "Anilist", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(_config?.AnimeService, "MyAnimeList", StringComparison.OrdinalIgnoreCase);

    private string Origin => Env.ApiBaseUrl.TrimEnd('/');
    private string ManifestUrl => string.IsNullOrEmpty(_config?.InstallConfig)
        ? "" : $"{Origin}/{_config!.InstallConfig}/manifest.json";
    private string StremioDeepLink => ManifestUrl is { Length: > 0 } u && u.Contains("://")
        ? "stremio://" + u[(u.IndexOf("://", StringComparison.Ordinal) + 3)..] : "#";
    private string StremioWebLink => string.IsNullOrEmpty(ManifestUrl)
        ? "#" : $"https://web.stremio.com/#/addons?addon={Uri.EscapeDataString(ManifestUrl)}";

    private sealed record CatalogRowSpec(string Label, Func<bool> Visible,
        Func<bool> GetEnable, Action<bool> SetEnable, Func<bool> GetDiscover, Action<bool> SetDiscover);

    private List<CatalogRowSpec> CatalogRows => new()
    {
        new("Currently watching", () => true, () => _flags.ShowCurrent, v => _flags.ShowCurrent = v, () => _flags.DiscoverOnlyCurrent, v => _flags.DiscoverOnlyCurrent = v),
        new("Completed", () => true, () => _flags.ShowCompleted, v => _flags.ShowCompleted = v, () => _flags.DiscoverOnlyCompleted, v => _flags.DiscoverOnlyCompleted = v),
        new("Plan to Watch", () => true, () => _flags.ShowPlanning, v => _flags.ShowPlanning = v, () => _flags.DiscoverOnlyPlanning, v => _flags.DiscoverOnlyPlanning = v),
        new("On Hold", () => true, () => _flags.ShowPaused, v => _flags.ShowPaused = v, () => _flags.DiscoverOnlyPaused, v => _flags.DiscoverOnlyPaused = v),
        new("Dropped", () => true, () => _flags.ShowDropped, v => _flags.ShowDropped = v, () => _flags.DiscoverOnlyDropped, v => _flags.DiscoverOnlyDropped = v),
        new("Rewatching", () => IsAnilistOrMal, () => _flags.ShowRepeating, v => _flags.ShowRepeating = v, () => _flags.DiscoverOnlyRepeating, v => _flags.DiscoverOnlyRepeating = v),
        new("Trending now", () => true, () => _flags.ShowTrending, v => _flags.ShowTrending = v, () => _flags.DiscoverOnlyTrending, v => _flags.DiscoverOnlyTrending = v),
        new("Seasonal Anime", () => true, () => _flags.ShowSeasonal, v => _flags.ShowSeasonal = v, () => _flags.DiscoverOnlySeasonal, v => _flags.DiscoverOnlySeasonal = v),
        new("Airing This Week", () => true, () => _flags.ShowAiring, v => _flags.ShowAiring = v, () => _flags.DiscoverOnlyAiring, v => _flags.DiscoverOnlyAiring = v),
    };

    protected override async Task OnInitializedAsync()
    {
        if (RendererInfo.IsInteractive)
        {
            // Re-render when media types hydrate / change (the anime-only cards gate on
            // State.EnabledMediaTypes), e.g. the header chooser flips anime off.
            State.Changed += OnStateChanged;

            // Replay the config the prerender stashed (cookie-seeded credential → real cards) instead
            // of re-reading localStorage + refetching, so a logged-in refresh doesn't flash the loading
            // line. Falls through to the normal load when there's nothing to replay (anonymous, or a
            // client-side navigation).
            if (Prerender.TryReplay<PersistedConfigure?>(PersistKey, out var snap) && snap is { Config: not null })
            {
                RestoreFrom(snap);
                _loading = false;
                return;
            }
        }

        // Resolve the credential: seeded server-side during prerender (from the anisync_uid cookie),
        // else resolved from the store on the interactive pass (cookie-derived on web; secure-store on
        // native — never localStorage). With no credential during prerender
        // (anonymous / no cookie) stay on the loading skeleton and let the interactive pass resolve it —
        // don't commit the signed-out surface server-side (a localStorage-only session would flash it).
        if (string.IsNullOrEmpty(State.StreamConfig))
        {
            if (!RendererInfo.IsInteractive) return;
            var saved = await Store.GetAsync(ISecureStore.ConfigKey);
            if (!string.IsNullOrEmpty(saved)) State.SetStreamConfig(saved);
        }
        // Still no credential after resolving from the store → bounce to login (as before).
        if (string.IsNullOrEmpty(State.StreamConfig)) { Nav.NavigateTo("/login"); return; }

        await ReloadAsync();
        _loading = false;

        // Prerender (credential seeded): stash the loaded config so the interactive remount replays it.
        if (!RendererInfo.IsInteractive && _config is not null)
            Prerender.Persist<PersistedConfigure>(PersistKey, RendererInfo.IsInteractive, Snapshot);
    }

    // Carries the prerendered config across to the interactive circuit (web only; no-op on native).
    private const string PersistKey = "configure";
    private sealed record PersistedConfigure(ConfigStateDto? Config);
    private PersistedConfigure Snapshot() => new(_config);

    // Reinstate the config + re-derive the flag bytes / master toggles exactly as ReloadAsync does
    // after a fetch, so the interactive first render matches the prerendered cards.
    private void RestoreFrom(PersistedConfigure snap)
    {
        _config = snap.Config;
        if (_config is not null)
        {
            _flags = ConfigFlags.Decode(_config.Flags1, _config.Flags2, _config.Flags3);
            (_savedF1, _savedF2, _savedF3) = (_config.Flags1, _config.Flags2, _config.Flags3);
            _dirty = false;
            RecomputeMasters();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // body.config-page (original's ViewData["BodyClass"]) → main padding clears
        // the fixed save bar. OnAfterRenderAsync only runs interactively.
        if (!firstRender) return;
        try
        {
            _js ??= await JS.InvokeAsync<IJSObjectReference>("import", "./_content/AniSync.Client/js/configure.js");
            await _js.InvokeVoidAsync("setConfigPage", true);
        }
        catch { /* prerender / no JS */ }
    }

    private async Task ReloadAsync()
    {
        _config = await Api.GetConfigAsync();
        if (_config is not null)
        {
            _flags = ConfigFlags.Decode(_config.Flags1, _config.Flags2, _config.Flags3);
            (_savedF1, _savedF2, _savedF3) = (_config.Flags1, _config.Flags2, _config.Flags3);
            _dirty = false;
            RecomputeMasters();
        }
    }

    private void MarkDirty()
    {
        var (f1, f2, f3) = _flags.Encode();
        _dirty = f1 != _savedF1 || f2 != _savedF2 || f3 != _savedF3;
        RecomputeMasters();
    }

    private void RecomputeMasters()
    {
        var rows = CatalogRows.Where(r => r.Visible()).ToList();
        _allEnable = rows.Count > 0 && rows.All(r => r.GetEnable());
        _allDiscover = rows.Count > 0 && rows.All(r => r.GetEnable() && r.GetDiscover());
    }

    private void SetEnable(CatalogRowSpec row, bool value)
    {
        row.SetEnable(value);
        if (!value) row.SetDiscover(false); // Discover-Only is meaningless without Enable.
        MarkDirty();
    }

    private void SetDiscover(CatalogRowSpec row, bool value) { row.SetDiscover(value); MarkDirty(); }

    private void ToggleAllEnable(ChangeEventArgs e)
    {
        var on = (bool)e.Value!;
        foreach (var r in CatalogRows.Where(r => r.Visible())) { r.SetEnable(on); if (!on) r.SetDiscover(false); }
        MarkDirty();
    }

    private void ToggleAllDiscover(ChangeEventArgs e)
    {
        var on = (bool)e.Value!;
        foreach (var r in CatalogRows.Where(r => r.Visible() && r.GetEnable())) r.SetDiscover(on);
        MarkDirty();
    }

    private async Task SaveAsync()
    {
        if (_config is null) return;
        _saving = true;
        var (f1, f2, f3) = _flags.Encode();
        var result = await Api.SaveFlagsAsync(f1, f2, f3);
        if (result is not null)
        {
            (_savedF1, _savedF2, _savedF3) = (f1, f2, f3);
            _config.Revision = result.Revision;
            if (!string.IsNullOrEmpty(result.InstallConfig)) _config.InstallConfig = result.InstallConfig;
            _dirty = false;
        }
        _saving = false;
    }

    private async Task CopyManifestAsync()
    {
        try
        {
            _js ??= await JS.InvokeAsync<IJSObjectReference>("import", "./_content/AniSync.Client/js/configure.js");
            await _js.InvokeAsync<bool>("copyText", ManifestUrl);
            _copied = true;
            StateHasChanged();
        }
        catch { /* clipboard blocked */ }
    }

    private void OnStateChanged() => InvokeAsync(StateHasChanged);

    public async ValueTask DisposeAsync()
    {
        State.Changed -= OnStateChanged;
        if (_js is not null)
        {
            try { await _js.InvokeVoidAsync("setConfigPage", false); } catch { }
            try { await _js.DisposeAsync(); } catch { }
        }
    }
}
