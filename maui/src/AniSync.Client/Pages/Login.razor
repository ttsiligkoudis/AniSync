@page "/login"
@inject NavigationManager Nav

@* The original app has no /login route — sign-in lives on /account (the login
   partial renders inside the Account page). This route only exists so anything
   still pointing at /login (OAuth state-expired fallback, legacy links) lands on
   /account, where the provider picker + Kitsu form / OAuth dispatch render. *@

<PageTitle>Sign in · AniSync</PageTitle>

@code {
    protected override void OnInitialized()
    {
        // Preserve any query (e.g. ?expired=1) so /account can surface it if needed.
        var rel = Nav.ToBaseRelativePath(Nav.Uri);
        var query = rel.Contains('?') ? rel[rel.IndexOf('?')..] : "";
        Nav.NavigateTo("/account" + query, replace: true);
    }
}
