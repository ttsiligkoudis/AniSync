@page "/login"
@inject IAniSyncApi Api
@inject AppState State
@inject ISecureStore Store
@inject IAppEnvironment Env
@inject INativeAuth Native
@inject NavigationManager Nav

@* Sign-in surface — the Blazor port of the web app's provider picker
   (_AccountSection.cshtml) + Kitsu inline credentials / OAuth dispatch
   (_LoginSection.cshtml). Same auth logic as the web app: Kitsu uses a
   username/password grant (posts to /Auth/LoginKitsu), AniList/MAL/Trakt redirect
   into the server OAuth flow (/Auth/Login). On success the server establishes the
   session and routes back through /auth/complete, which seeds the X-AniSync-Config
   credential into this client (localStorage) before landing on /configure. The
   "paste config" block stays as the no-account / existing-install fallback. *@

<PageTitle>Sign in · AniSync</PageTitle>

<section>
    <h1 class="dashboard-section-title">Sign in</h1>

    @if (_expired)
    {
        <p class="hint-text" role="alert">Your sign-in link expired or was already used. Pick a provider and try again.</p>
    }

    <section class="section-card">
        <span class="section-title">Account</span>
        <p class="hint-text">Choose your tracker and sign in — AniSync syncs your list and powers streaming. Your account also lives on the <a href="@WebAccountUrl" target="_blank" rel="noopener">web account page</a>.</p>

        <div class="service-toggle" id="serviceToggle">
            @foreach (var p in _available)
            {
                <span class="label @(p.Key == _selected ? "active" : "")" id="@PillId(p.Key)" role="button" tabindex="0"
                      data-service="@PillIndex(p.Key)" data-service-name="@p.Key"
                      @onclick="() => _selected = p.Key"
                      @onkeydown="@(e => { if (e.Key is "Enter" or " ") _selected = p.Key; })">@p.Display</span>
            }
        </div>

        <div class="card-section" id="loginCard">
            @if (_selected == "Kitsu")
            {
                @if (Native.IsSupported)
                {
                    @* Native head: Kitsu password grant posted via the API (no browser). *@
                    <div class="cred-group">
                        <label for="username" class="required">Username</label>
                        <input type="text" id="username" autocomplete="username" required
                               value="@_username" @oninput="e => _username = e.Value?.ToString() ?? string.Empty" />
                    </div>
                    <div class="cred-group">
                        <label for="password" class="required">Password</label>
                        <input type="password" id="password" autocomplete="current-password" required
                               value="@_password" @oninput="e => _password = e.Value?.ToString() ?? string.Empty" />
                    </div>
                    <p class="option-name-sub" style="margin-top:0.5rem;">
                        AniSync uses your password only for the initial sign-in to Kitsu — it is not stored.
                    </p>
                    <button type="button" class="btn-primary-action btn-login" disabled="@_busy" @onclick="NativeKitsuAsync">
                        @(_busy ? "Signing in…" : "Login with Kitsu")
                    </button>
                }
                else
                {
                    <form id="kitsuLoginForm" method="post" action="@AuthAction("LoginKitsu")" autocomplete="on">
                        <input type="hidden" name="returnUrl" value="@PostLoginReturnUrl" />
                        <div id="kitsuCreds">
                            <div class="cred-group">
                                <label for="username" class="required">Username</label>
                                <input type="text" id="username" name="username" autocomplete="username" required />
                            </div>
                            <div class="cred-group">
                                <label for="password" class="required">Password</label>
                                <input type="password" id="password" name="password" autocomplete="current-password" required />
                            </div>
                            <p class="option-name-sub" style="margin-top:0.5rem;">
                                AniSync uses your password only for the initial sign-in to Kitsu — it is not stored
                                in the configuration. After login we keep just the OAuth tokens Kitsu issues, and
                                refresh them automatically when they expire.
                            </p>
                        </div>
                        <button type="submit" id="kitsuLoginBtn" class="btn-primary-action btn-login">Login with Kitsu</button>
                    </form>
                }
                <div id="kitsuRegister" class="kitsu-register">
                    <a href="@AuthAction("Register")?returnUrl=@Uri.EscapeDataString(PostLoginReturnUrl)" class="hint-text">Don't have a Kitsu account? <span class="kitsu-register-link">Create one</span></a>
                </div>
            }
            else
            {
                @if (Native.IsSupported)
                {
                    <button type="button" class="btn-primary-action btn-login" disabled="@_busy" @onclick="() => NativeOAuthAsync(_selected)">
                        @(_busy ? "Signing in…" : $"Login with {SelectedDisplay}")
                    </button>
                }
                else
                {
                    <a id="loginUrl" class="btn-primary-action btn-login" data-return-url="@PostLoginReturnUrl" href="@OauthUrl(_selected)">Login with <span id="loginServiceName">@SelectedDisplay</span></a>
                }
                @if (_selected == "Anilist")
                {
                    <div class="kitsu-register">
                        <a href="https://anilist.co/signup" target="_blank" rel="noopener noreferrer" class="hint-text">
                            Don't have an AniList account? <span class="kitsu-register-link">Create one ↗</span>
                        </a>
                    </div>
                }
                else if (_selected == "MyAnimeList")
                {
                    <div class="kitsu-register">
                        <a href="https://myanimelist.net/register.php" target="_blank" rel="noopener noreferrer" class="hint-text">
                            Don't have a MyAnimeList account? <span class="kitsu-register-link">Create one ↗</span>
                        </a>
                    </div>
                }
            }
            @if (!string.IsNullOrEmpty(_error))
            {
                <p class="hint-text" role="alert">@_error</p>
            }
        </div>
    </section>

    <section class="section-card">
        <span class="section-title">Advanced — paste config</span>
        <p class="hint-text">
            Already have an AniSync install URL? Paste its config segment to connect this device without signing in
            (the anonymous / existing-install path). It's stored securely on this device.
        </p>
        <form class="filter-bar" @onsubmit="SavePastedAsync" @onsubmit:preventDefault>
            <input type="text" class="filter-bar-search" placeholder="Paste config…"
                   value="@_paste" @oninput="e => _paste = e.Value?.ToString() ?? string.Empty"
                   autocomplete="off" spellcheck="false" />
            <button type="submit" class="site-header-cta site-header-cta-primary">Save</button>
        </form>
    </section>
</section>

@code {
    [SupplyParameterFromQuery(Name = "expired")] public string? ExpiredQuery { get; set; }

    private bool _expired;
    private AuthProvidersDto _providers = new();
    private List<(string Key, string Display)> _available = new();
    private string _selected = "Kitsu";
    private string _paste = "";

    // Native (MAUI) sign-in state — the web head uses anchors/forms instead.
    private string _username = "";
    private string _password = "";
    private bool _busy;
    private string? _error;

    // After signing in we land the user on the configuration page so they
    // immediately "see the configuration" (install URL, account, etc.).
    private const string PostLoginReturnUrl = "/configure";

    private string WebAccountUrl => $"{Env.ApiBaseUrl.TrimEnd('/')}/configure";

    protected override async Task OnInitializedAsync()
    {
        // Already connected → skip the login screen and show the configuration.
        if (string.IsNullOrEmpty(State.StreamConfig))
        {
            var saved = await Store.GetAsync(ISecureStore.ConfigKey);
            if (!string.IsNullOrEmpty(saved)) State.SetStreamConfig(saved);
        }
        if (!string.IsNullOrEmpty(State.StreamConfig))
        {
            Nav.NavigateTo(PostLoginReturnUrl);
            return;
        }

        _expired = ExpiredQuery == "1";
        _providers = await Api.AuthProvidersAsync();
        _available = BuildAvailable(_providers);
        _selected = _available.FirstOrDefault().Key ?? "Kitsu";
    }

    private static List<(string, string)> BuildAvailable(AuthProvidersDto p)
    {
        var list = new List<(string, string)>();
        if (p.Kitsu) list.Add(("Kitsu", "Kitsu"));
        if (p.Anilist) list.Add(("Anilist", "AniList"));
        if (p.Mal) list.Add(("MyAnimeList", "MyAnimeList"));
        if (p.Trakt) list.Add(("Trakt", "Trakt"));
        if (list.Count == 0) list.Add(("Kitsu", "Kitsu")); // Kitsu always works (no app creds)
        return list;
    }

    private string SelectedDisplay => _available.FirstOrDefault(p => p.Key == _selected).Display ?? _selected;

    // Mirror the web app's per-pill ids / indices (_AccountSection.cshtml) so the
    // rendered service-toggle DOM matches the original markup.
    private static string PillId(string key) => key switch
    {
        "Kitsu" => "labelKitsu",
        "Anilist" => "labelAnilist",
        "MyAnimeList" => "labelMal",
        "Trakt" => "labelTrakt",
        _ => $"label{key}",
    };

    private static string PillIndex(string key) => key switch
    {
        "Kitsu" => "0",
        "Anilist" => "1",
        "MyAnimeList" => "2",
        "Trakt" => "3",
        _ => "0",
    };

    // Auth endpoints live on the API host. On the Web head that's the same origin
    // (relative path is fine); an explicit base keeps it correct if ApiBaseUrl is
    // overridden to a remote backend.
    private string AuthAction(string action)
        => $"{Env.ApiBaseUrl.TrimEnd('/')}/Auth/{action}";

    private string OauthUrl(string service)
        => $"{AuthAction("Login")}?animeService={Uri.EscapeDataString(service)}&returnUrl={Uri.EscapeDataString(PostLoginReturnUrl)}";

    private async Task SavePastedAsync()
    {
        var value = _paste.Trim();
        if (string.IsNullOrEmpty(value)) return;
        await ApplyConfigAsync(value);
    }

    // ── Native (MAUI) sign-in ────────────────────────────────────────────────

    private async Task NativeOAuthAsync(string service)
    {
        _busy = true; _error = null;
        var config = await Native.StartOAuthAsync(service);
        await FinishNativeAsync(config);
    }

    private async Task NativeKitsuAsync()
    {
        if (string.IsNullOrWhiteSpace(_username) || string.IsNullOrWhiteSpace(_password))
        {
            _error = "Enter your Kitsu username and password.";
            return;
        }
        _busy = true; _error = null;
        var config = await Native.LoginKitsuAsync(_username.Trim(), _password);
        await FinishNativeAsync(config);
    }

    private async Task FinishNativeAsync(string? config)
    {
        _busy = false;
        if (string.IsNullOrEmpty(config)) { _error = "Sign-in failed or was cancelled."; return; }
        await ApplyConfigAsync(config);
    }

    private async Task ApplyConfigAsync(string config)
    {
        await Store.SetAsync(ISecureStore.ConfigKey, config);
        State.SetStreamConfig(config);
        Nav.NavigateTo(PostLoginReturnUrl);
    }
}
