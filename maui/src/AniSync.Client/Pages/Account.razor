@page "/account"
@inject IAniSyncApi Api
@inject AppState State
@inject ISecureStore Store
@inject IAppEnvironment Env
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject IPrerenderSession Prerender
@implements IAsyncDisposable

@* Account — Blazor port of Configure.cshtml (page title "Account"). Identity
   (provider picker + connected/disconnect), linked accounts, the Streams modal,
   anime Preferences, and links out to the Stremio-addon and Advanced surfaces.
   When no stored config is present the page shows the login surface (provider
   picker + Kitsu form / OAuth dispatch) instead of bouncing away. The page owns
   the three flag bytes (ConfigFlags), dirty tracking and Save (Api.SaveFlagsAsync),
   mirroring Configure.razor.

   Markup matches the original: the cards are top-level so they become direct flex
   children of the layout's <main> (gap: var(--space-5)); the page sets
   body.config-page (the original's ViewData["BodyClass"]) so the fixed save bar
   clears the last card. No extra .container wrapper — the layout already provides
   one. *@

<PageTitle>Account · AniSync</PageTitle>

@* On TV the screen is always just a QR — the phone-sign-in QR before login, the
   manage-settings QR after — so drop the page header (each QR shows its own title)
   and let it fit without scrolling. The full header returns on phone/desktop. *@
@if (!Env.IsTv)
{
    <header class="page-header">
        <h1 class="page-title">Account</h1>
        <p class="page-subtitle">Provider · linked accounts</p>
    </header>
}

@if (_loading)
{
    @* The account cards need the localStorage credential (unreadable during prerender), so a
       load is unavoidable on refresh — show card-shaped shimmer placeholders instead of a bare
       "Loading account…" line so the page holds its shape until the real cards land. *@
    <section class="section-card" aria-busy="true">
        <span class="sr-only">Loading account…</span>
        <span class="library-card-skeleton-line" style="display:block;width:35%;height:1.3em;margin-bottom:1.1rem"></span>
        <span class="library-card-skeleton-line" style="display:block;width:100%;height:2.6em;margin-bottom:0.7rem"></span>
        <span class="library-card-skeleton-line library-card-skeleton-line-short" style="height:1.1em"></span>
    </section>
    <section class="section-card" aria-busy="true">
        <span class="library-card-skeleton-line" style="display:block;width:45%;height:1.3em;margin-bottom:1.1rem"></span>
        <span class="library-card-skeleton-line" style="display:block;width:100%;height:2.1em;margin-bottom:0.6rem"></span>
        <span class="library-card-skeleton-line" style="display:block;width:80%;height:2.1em"></span>
    </section>
}
else if (Env.IsTv && _config is not null)
{
    @* TV: settings editing is a D-pad nightmare (addon URLs, debrid keys). Replace the whole
       account/settings form with a QR that opens it on the phone, already signed in. *@
    <SettingsHandoff />
}
else
{
    @* Provider picker hidden on the TV sign-in screen — the QR handles provider choice
       on the phone. It returns once signed in (account management needs it). *@
    @if (!(Env.IsTv && _config is null))
    {
        <AccountSection Config="_config" OnReload="ReloadAsync"
                        Available="_available" SelectedService="@_selectedService"
                        SelectedServiceChanged="s => _selectedService = s" />
    }

    @if (_config is not null)
    {
        <LinkedAccountsSection Config="_config" OnReload="ReloadAsync" AnimeEnabled="AnimeEnabled" />

        <StreamsModal Flags="_flags" Config="_config" OnDirty="MarkDirty" OnReload="ReloadAsync" OnReorder="OnAddonReorderPending"
                      AudioLang="_audioLang" SubLang="_subLang"
                      OnAudioLangChanged="OnAudioLangChanged" OnSubLangChanged="OnSubLangChanged" />

        @* Appearance — theme (System / Light / Dark) + dashboard customisation. The theme
           applies instantly and persists to the settings store (not the server Save bar). *@
        <section class="section-card">
            <span class="section-title">Appearance</span>
            <p class="section-description">Pick a theme, or follow your device's light/dark setting.</p>
            <div class="theme-pills" role="group" aria-label="Theme">
                <button type="button" class="theme-pill @(_theme == "system" ? "is-active" : "")" @onclick='() => SetThemeAsync("system")'>System</button>
                <button type="button" class="theme-pill @(_theme == "light" ? "is-active" : "")" @onclick='() => SetThemeAsync("light")'>Light</button>
                <button type="button" class="theme-pill @(_theme == "dark" ? "is-active" : "")" @onclick='() => SetThemeAsync("dark")'>Dark</button>
            </div>

            @* Native engine picker — only where both exist (Android phones/tablets). libVLC handles
               exotic codecs (HEVC/AC3/EAC3/DTS) with full chrome; ExoPlayer handles 4K cleanly. *@
            @if (Env.SupportsPlayerChoice)
            {
                <p class="section-description">Video player — applies to the next thing you play. TV always uses ExoPlayer.</p>
                <div class="theme-pills" role="group" aria-label="Video player">
                    <button type="button" class="theme-pill @(_player == "libvlc" ? "is-active" : "")" @onclick='() => SetPlayerAsync("libvlc")'>libVLC</button>
                    <button type="button" class="theme-pill @(_player == "exo" ? "is-active" : "")" @onclick='() => SetPlayerAsync("exo")'>ExoPlayer</button>
                </div>
            }
            <div class="btn-action-row">
                <button type="button" class="btn-ghost" @onclick="() => _dashCustomize?.Open()">Customize dashboard</button>
            </div>
        </section>

        <PreferencesSection Flags="_flags" AnimeEnabled="AnimeEnabled" OnDirty="MarkDirty" />

        <!-- Quick links to the other config surfaces (mirrors /configure's footer row) -->
        <section class="section-card">
            <div class="btn-action-row">
                <a class="btn-ghost" href="/configure">Stremio addon &amp; install URL</a>
                <a class="btn-ghost" href="/advanced">Advanced (sync · backups · danger zone)</a>
            </div>
        </section>
    }
    else
    {
        <LoginSection SelectedService="@_selectedService" ReturnUrl="@LoginReturnUrl" AllowAnonymous="false" />
    }
}

@* Dashboard layout chooser — also reachable here from Settings (not just the dashboard's
   Customize float), so the same reorder/show-hide UI is available from the account page. *@
<DashCustomizeModal @ref="_dashCustomize" />

@* No save bar on TV — the editable form isn't shown there (the handoff QR replaces it). *@
@if (!Env.IsTv && _config is not null && !string.IsNullOrEmpty(_config.ApiConfig))
{
    <FloatingSaveBar Dirty="_dirty" Saving="_saving" OnSave="SaveAsync" />
}

@code {
    // Where to land after sign-in. Defaults home, but the TV-pairing /link page sends users
    // here with ?returnUrl=/link?code=… so they bounce back and confirm once signed in. Only
    // same-app relative paths are honoured (no open-redirect to an external URL).
    [SupplyParameterFromQuery] public string? ReturnUrl { get; set; }
    private string LoginReturnUrl =>
        !string.IsNullOrEmpty(ReturnUrl) && ReturnUrl.StartsWith('/') && !ReturnUrl.StartsWith("//")
            ? ReturnUrl
            : "/";

    private bool _loading = true;
    private ConfigStateDto? _config;
    private ConfigFlags _flags = new();
    private byte _savedF1, _savedF2, _savedF3;
    private bool _dirty;
    private bool _saving;
    // Pending stream-addon order from a drag-reorder in the Streams modal. Like the original,
    // the reorder isn't persisted on drop — it marks the page dirty and the ReorderStreamAddons
    // POST is folded into Save (SaveAsync). Cleared on reload (add/remove/save invalidate it).
    private string[]? _pendingAddonOrder;

    // Playback-language dropdowns (in the Streams modal). The page owns them so they ride the same
    // Save bar as the flags: changing a dropdown marks dirty; Save persists. _saved* is the last
    // persisted value, used for the dirty diff.
    private string _audioLang = PlaybackLanguages.Default;
    private string _subLang = PlaybackLanguages.Default;
    private string _savedAudioLang = PlaybackLanguages.Default;
    private string _savedSubLang = PlaybackLanguages.Default;

    private void OnAudioLangChanged(string lang) { _audioLang = PlaybackLanguages.Normalize(lang); MarkDirty(); }
    private void OnSubLangChanged(string lang) { _subLang = PlaybackLanguages.Normalize(lang); MarkDirty(); }

    // Pre-login provider picker. Mirrors _AccountSection: with anime enabled (the
    // default until the chooser modal lands) the picker offers all three anime
    // trackers plus Trakt — the original does NOT hide providers by host config.
    private static readonly List<(string Key, string Display)> _available = new()
    {
        ("Kitsu", "Kitsu"),
        ("Anilist", "AniList"),
        ("MyAnimeList", "MyAnimeList"),
        ("Trakt", "Trakt"),
    };
    private string _selectedService = "Kitsu";

    private IJSObjectReference? _js;
    private DashCustomizeModal? _dashCustomize;

    // Theme preference for the Appearance switch: "system" (follow OS) / "light" / "dark".
    // Persisted to the settings store and applied instantly via chrome.js's anisyncApplyTheme.
    private string _theme = "system";

    private async Task SetThemeAsync(string theme)
    {
        if (_theme == theme) return;
        _theme = theme;
        await Store.SetAsync("pref:theme", theme);
        try { await JS.InvokeVoidAsync("anisyncApplyTheme", theme); } catch { /* no JS */ }
    }

    // Native video player engine: "libvlc" (default) / "exo". Read by VlcMediaPlayer at the next
    // PlayAsync — no live effect, so we just persist + repaint the pill highlight.
    private string _player = "libvlc";

    private async Task SetPlayerAsync(string player)
    {
        if (_player == player) return;
        _player = player;
        await Store.SetAsync("pref:player", player);
    }

    // Anime-only cards (Preferences toggles) gate on the user's real media-type pick.
    // That choice lives client-side (AppState, hydrated from localStorage by MainLayout) —
    // NOT in the server config: the Blazor-Server self-call to /api/v1/me/config can't see
    // the browser's media-type cookie and the pick is never persisted to the DB, so the
    // server defaults EnabledMediaTypes to anime and the toggles showed even when anime
    // was deselected. Wait for hydration so we don't flash anime cards before we know.
    private bool AnimeEnabled =>
        State.MediaTypesHydrated && State.EnabledMediaTypes.Contains(MetaType.anime);

    protected override async Task OnInitializedAsync()
    {
        if (RendererInfo.IsInteractive)
        {
            // Re-render when media types hydrate / change (the anime-only Preferences card
            // gates on State.EnabledMediaTypes), e.g. the header chooser flips anime off.
            State.Changed += OnStateChanged;

            // Current theme + native player engine for the Appearance switches' highlight
            // (theme default System = follow OS; player default libVLC).
            _theme = await Store.GetAsync("pref:theme") ?? "system";
            _player = await Store.GetAsync("pref:player") ?? "libvlc";

            // Replay the config the prerender stashed (cookie-seeded credential → real cards) instead
            // of re-reading localStorage + refetching, so a logged-in refresh doesn't flash the
            // loading skeleton. Falls through to the normal load when there's nothing to replay
            // (anonymous, or a client-side navigation).
            if (Prerender.TryReplay<PersistedAccount?>(PersistKey, out var snap) && snap is { Config: not null })
            {
                RestoreFrom(snap);
                _loading = false;
                return;
            }
        }

        // Resolve the credential: seeded server-side during prerender (from the anisync_uid cookie),
        // else resolved from the store on the interactive pass (cookie-derived on web; secure-store on
        // native — never localStorage). With no credential during prerender
        // (anonymous / no cookie) stay on the loading skeleton and let the interactive pass resolve it —
        // don't commit the login surface server-side (a localStorage-only session would flash it).
        if (string.IsNullOrEmpty(State.StreamConfig))
        {
            if (!RendererInfo.IsInteractive) return;
            var saved = await Store.GetAsync(ISecureStore.ConfigKey);
            if (!string.IsNullOrEmpty(saved)) State.SetStreamConfig(saved);
        }

        if (!string.IsNullOrEmpty(State.StreamConfig))
        {
            await ReloadAsync();
        }

        _loading = false;

        // Prerender (credential seeded): stash the loaded config so the interactive remount replays it.
        if (!RendererInfo.IsInteractive && _config is not null)
            Prerender.Persist<PersistedAccount>(PersistKey, RendererInfo.IsInteractive, Snapshot);
    }

    // Carries the prerendered config across to the interactive circuit (web only; no-op on native).
    private const string PersistKey = "account";
    private sealed record PersistedAccount(ConfigStateDto? Config);
    private PersistedAccount Snapshot() => new(_config);

    // Reinstate the config + re-derive the flag bytes exactly as ReloadAsync does after a fetch,
    // so the interactive first render matches the prerendered cards.
    private void RestoreFrom(PersistedAccount snap)
    {
        _config = snap.Config;
        _pendingAddonOrder = null;
        if (_config is not null)
        {
            _flags = ConfigFlags.Decode(_config.Flags1, _config.Flags2, _config.Flags3);
            (_savedF1, _savedF2, _savedF3) = (_config.Flags1, _config.Flags2, _config.Flags3);
            _dirty = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // body.config-page (original's ViewData["BodyClass"]) → main padding clears
        // the fixed save bar. OnAfterRenderAsync only runs interactively, so JS is live.
        if (!firstRender) return;
        try
        {
            _js ??= await JS.InvokeAsync<IJSObjectReference>("import", "./_content/AniSync.Client/js/configure.js");
            await _js.InvokeVoidAsync("setConfigPage", true);
        }
        catch { /* prerender / no JS */ }
    }

    private async Task ReloadAsync()
    {
        _config = await Api.GetConfigAsync();
        _pendingAddonOrder = null;
        if (_config is not null)
        {
            _flags = ConfigFlags.Decode(_config.Flags1, _config.Flags2, _config.Flags3);
            (_savedF1, _savedF2, _savedF3) = (_config.Flags1, _config.Flags2, _config.Flags3);
            var langs = await Api.GetPlaybackLanguagesAsync();
            _savedAudioLang = _audioLang = PlaybackLanguages.Normalize(langs?.Audio);
            _savedSubLang = _subLang = PlaybackLanguages.Normalize(langs?.Subtitle);
            _dirty = false;
        }
    }

    private void MarkDirty()
    {
        var (f1, f2, f3) = _flags.Encode();
        _dirty = f1 != _savedF1 || f2 != _savedF2 || f3 != _savedF3 || _pendingAddonOrder is { Length: > 0 }
            || _audioLang != _savedAudioLang || _subLang != _savedSubLang;
    }

    // A drag-reorder in the Streams modal — stash the new order and light up the Save bar.
    // The POST is folded into SaveAsync (the original's saveStreamAddonOrderIfChanged).
    private void OnAddonReorderPending(string[] urls)
    {
        _pendingAddonOrder = urls;
        MarkDirty();
    }

    private async Task SaveAsync()
    {
        if (_config is null) return;
        _saving = true;
        var (f1, f2, f3) = _flags.Encode();
        var result = await Api.SaveFlagsAsync(f1, f2, f3);
        if (result is not null)
        {
            (_savedF1, _savedF2, _savedF3) = (f1, f2, f3);
            _config.Revision = result.Revision;
            if (!string.IsNullOrEmpty(result.InstallConfig)) _config.InstallConfig = result.InstallConfig;

            // Playback-language dropdowns ride the same Save (only POST when they actually changed).
            if (_audioLang != _savedAudioLang || _subLang != _savedSubLang)
            {
                if (await Api.SavePlaybackLanguagesAsync(_audioLang, _subLang))
                    (_savedAudioLang, _savedSubLang) = (_audioLang, _subLang);
            }

            _dirty = false;
            // Stream-addon reorder rides on the same Save (the original folds it into
            // saveFlags() via saveStreamAddonOrderIfChanged). Persist the dragged order,
            // then reload so the rendered list matches the store. A null result means the
            // POST itself failed — keep the dragged order + the dirty bar (so the user can
            // retry) and tell them, rather than silently reloading the old order back
            // (which looked exactly like "reorder doesn't save").
            if (_pendingAddonOrder is { Length: > 0 } order)
            {
                var reordered = await Api.ReorderStreamAddonsAsync(order);
                if (reordered is null)
                {
                    _dirty = true;
                    try { await JS.InvokeVoidAsync("alert", "Couldn't save the new addon order — try again."); } catch { }
                }
                else
                {
                    await ReloadAsync();
                }
            }
        }
        else
        {
            // SaveFlags failed — keep the page dirty so the user can retry.
            _dirty = true;
        }
        _saving = false;
    }

    private void OnStateChanged() => InvokeAsync(StateHasChanged);

    public async ValueTask DisposeAsync()
    {
        State.Changed -= OnStateChanged;
        if (_js is not null)
        {
            try { await _js.InvokeVoidAsync("setConfigPage", false); } catch { }
            try { await _js.DisposeAsync(); } catch { }
        }
    }
}
