@page "/account"
@inject IAniSyncApi Api
@inject AppState State
@inject ISecureStore Store
@inject NavigationManager Nav

@* Account-focused settings — Blazor port of Configure.cshtml (/account). Identity +
   linked accounts (shared AccountSection component); catalogs, streams, preferences
   and the install URL live on /configure, advanced actions on /advanced. *@

<PageTitle>Account · AniSync</PageTitle>

<section class="config-page">
    <header class="page-header">
        <h1 class="page-title">Account</h1>
        <p class="page-subtitle">Provider · linked accounts</p>
    </header>

    @if (_loading)
    {
        <p class="hint-text">Loading account…</p>
    }
    else if (_config is null)
    {
        <section class="section-card">
            <p class="hint-text">This device is connected with an inline (no-account) config. <a href="/login">Sign in</a> with a tracker to manage your account.</p>
        </section>
    }
    else
    {
        <AccountSection Config="_config" OnReload="ReloadAsync" />

        <section class="section-card">
            <span class="section-title">Stremio addon</span>
            <p class="section-description">
                Pick which catalogs and streams the AniSync addon exposes to Stremio,
                grab the install URL — all on a dedicated page so this one stays focused
                on your account.
            </p>
            <a class="btn-primary-action btn-login" href="/configure">Configure Stremio addon →</a>
        </section>

        <section class="section-card">
            <span class="section-title">Advanced</span>
            <p class="section-description">
                Export or import a backup, configure Plex / Jellyfin / Emby scrobble,
                or reset / delete your configuration.
            </p>
            <a class="btn-primary-action btn-login" href="/advanced">Open advanced settings →</a>
        </section>
    }
</section>

@code {
    private bool _loading = true;
    private ConfigStateDto? _config;

    protected override async Task OnInitializedAsync()
    {
        // localStorage (the credential) is unreadable during prerender — wait for
        // interactive so a logged-in user isn't bounced to /login. Re-runs interactively.
        if (!RendererInfo.IsInteractive) return;

        if (string.IsNullOrEmpty(State.StreamConfig))
        {
            var saved = await Store.GetAsync(ISecureStore.ConfigKey);
            if (!string.IsNullOrEmpty(saved)) State.SetStreamConfig(saved);
        }
        if (string.IsNullOrEmpty(State.StreamConfig)) { Nav.NavigateTo("/login"); return; }

        await ReloadAsync();
        _loading = false;
    }

    private async Task ReloadAsync() => _config = await Api.GetConfigAsync();
}
