@page "/discover/staff/{StaffId:int}"
@inject IAniSyncApi Api
@inject IPrerenderSession Prerender

@* A staff member's anime credits — 1:1 port of Views/Discover/StaffDetail.cshtml.
   A single, non-paginated poster grid: the original view renders one _PosterGrid
   from one GetStaffMediaAsync call (there is no /discover/staff/{id}/page route,
   no sentinel, no pagination JS). Shape mirrors the sibling ActorDetail.razor. *@

<PageTitle>@Title · AniSync</PageTitle>

<section>
    <header class="page-header">
        <p class="page-subtitle">Anime by</p>
        <h1 class="page-title">@Title</h1>
    </header>

    @if (_loading)
    {
        <div class="library-grid">
            @for (var i = 0; i < 12; i++)
            {
                <div class="library-card library-card-skeleton">
                    <div class="library-card-poster-wrap"><div class="library-card-poster skeleton-shimmer"></div></div>
                    <span class="library-card-skeleton-line"></span>
                </div>
            }
        </div>
    }
    else
    {
        <PosterGrid Items="_items" EmptyMessage="@EmptyMessage" />
    }
</section>

@code {
    [Parameter] public int StaffId { get; set; }

    private IReadOnlyList<MetaDto> _items = Array.Empty<MetaDto>();
    private string? _name;
    private bool _loading = true;

    private string Title => string.IsNullOrEmpty(_name) ? $"Staff #{StaffId}" : _name!;
    private string EmptyMessage => $"No anime found for {Title}.";

    protected override async Task OnParametersSetAsync()
    {
        var key = PersistKey();

        // Interactive remount after a prerender: replay the stashed list instead of resetting to the
        // skeleton + refetching, so a refresh doesn't flash content → skeleton → content. Native and
        // client-side navigations (no stash) fall through to a normal load.
        if (RendererInfo.IsInteractive && _appliedKey != key
            && Prerender.TryReplay<PersistedStaff?>(key, out var snap) && snap is not null)
        {
            _appliedKey = key;
            RestoreStaff(snap);
            return;
        }
        if (_appliedKey == key) return;   // already loaded/replayed this exact view; ignore redundant re-renders

        _loading = true;
        _name = null;
        _items = Array.Empty<MetaDto>();
        StaffMediaResponse resp;
        try { resp = await Api.StaffMediaAsync(StaffId); }
        catch { resp = new(); }
        _name = resp.Name;
        _items = resp.Items;
        _loading = false;

        _appliedKey = key;
        // Prerender: stash a snapshot so the interactive remount replays it. Web-only; no-op otherwise.
        if (!RendererInfo.IsInteractive)
            Prerender.Persist<PersistedStaff>(key, RendererInfo.IsInteractive, Snapshot);
    }

    private string? _appliedKey;
    private string PersistKey() => $"staff:{StaffId}";

    private sealed record PersistedStaff(List<MetaDto> Items, string? Name);

    private PersistedStaff Snapshot() => new(_items.ToList(), _name);

    private void RestoreStaff(PersistedStaff snap)
    {
        _items = snap.Items;
        _name = snap.Name;
        _loading = false;
    }
}
