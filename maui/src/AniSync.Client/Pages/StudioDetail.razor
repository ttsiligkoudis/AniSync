@page "/discover/studio/{StudioId:int}"
@inject IAniSyncApi Api

@* A studio's filmography — port of Views/Discover/StudioDetail.cshtml. Poster
   grid with skip-offset "Load more" (server reports HasNextPage). *@

<PageTitle>@Title · AniSync</PageTitle>

<section>
    <header class="page-header">
        <p class="page-subtitle">From</p>
        <h1 class="page-title">@Title</h1>
    </header>

    @if (_loading && _items.Count == 0)
    {
        <div class="library-grid">
            @for (var i = 0; i < 12; i++)
            {
                <div class="library-card library-card-skeleton">
                    <div class="library-card-poster-wrap"><div class="library-card-poster skeleton-shimmer"></div></div>
                    <span class="library-card-skeleton-line"></span>
                </div>
            }
        </div>
    }
    else if (HasItems)
    {
        <div class="studio-detail-paginator" data-studio-id="@StudioId" data-page="1">
            <PosterGrid Items="_items" EmptyMessage="@EmptyMessage" />
            <div class="paginator-loader" hidden="@(!_loading)" aria-hidden="true">
                <div class="paginator-loader-spinner"></div>
            </div>
            <div class="studio-detail-sentinel" aria-hidden="true"></div>
        </div>
    }
    else
    {
        <PosterGrid Items="_items" EmptyMessage="@EmptyMessage" />
    }

    @if (_canLoadMore)
    {
        <div class="discover-pagination">
            <button type="button" class="discover-paginator" disabled="@_loading" @onclick="LoadMore">
                @(_loading ? "Loading…" : "Load more")
            </button>
        </div>
    }
</section>

@code {
    [Parameter] public int StudioId { get; set; }

    private readonly List<MetaDto> _items = new();
    private string? _name;
    private bool _loading;
    private bool _canLoadMore;

    private string Title => string.IsNullOrEmpty(_name) ? $"Studio #{StudioId}" : _name!;
    private bool HasItems => _items.Count > 0;
    private string EmptyMessage => $"No anime found for {Title}.";

    protected override async Task OnParametersSetAsync()
    {
        _items.Clear();
        _name = null;
        _canLoadMore = false;
        await Load();
    }

    private Task LoadMore() => Load();

    private async Task Load()
    {
        _loading = true;
        StateHasChanged();
        var skip = _items.Count > 0 ? _items.Count.ToString() : null;
        var resp = await Api.StudioMediaAsync(StudioId, skip);
        _name ??= resp.Name;
        _items.AddRange(resp.Items);
        _canLoadMore = resp.HasNextPage;
        _loading = false;
        StateHasChanged();
    }
}
