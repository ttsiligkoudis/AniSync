@page "/notifications"
@inject IAniSyncApi Api
@inject IAppEnvironment Env
@inject NavigationManager Nav
@inject IJSRuntime JS

@* Notifications — full episode-release history. Port of the /notifications page
   over /api/v1/notifications: list, mark-read-on-open, per-row delete, mark-all,
   and (web head) a Web Push opt-in toggle backed by /api/v1/push. Reuses the
   notif-page-* classes from site.css. *@

<PageTitle>Notifications · AniSync</PageTitle>

<section>
    <div class="page-header-row">
        <div class="page-header-titles">
            <h1 class="page-title">Notifications</h1>
            <p class="page-subtitle" data-notif-page-subtitle>
                @_items.Count notification@(_items.Count == 1 ? "" : "s")
            </p>
        </div>
        <div class="notif-page-toolbar" data-notif-page-toolbar>
            @if (_items.Count > 0)
            {
                <button type="button" class="notif-page-action notif-page-action-quiet"
                        data-notif-mark-all-read @onclick="MarkAllRead">Mark all read</button>
            }
        </div>
    </div>
    @if (_pushEnabled)
    {
        <div class="notif-push-toggle" data-push-toggle>
            <span class="notif-push-toggle-label" data-push-toggle-label>Get notified when episodes drop</span>
            <button type="button" class="notif-push-toggle-btn" data-push-toggle-btn
                    disabled="@_pushBusy" @onclick="TogglePush">
                @(_pushBusy ? "…" : _pushSubscribed ? "Disable browser notifications" : "Enable browser notifications")
            </button>
        </div>
    }
</section>

@if (_loading)
{
    <div class="notif-page-loader">Loading…</div>
}
else if (_items.Count == 0)
{
    <p class="library-empty">No notifications yet. New episode releases will land here.</p>
}
else
{
    <div class="notif-page-list">
        @foreach (var n in _items)
        {
            <a class="notif-page-item @(IsRead(n) ? "" : "notif-page-item-unread")"
               href="@(string.IsNullOrEmpty(n.LinkPath) ? "#" : n.LinkPath)"
               data-notif-id="@n.Id"
               @onclick="() => OpenAsync(n)" @onclick:preventDefault>
                <span class="notif-page-checkbox" data-notif-page-checkbox>
                    <input type="checkbox"
                           class="notif-page-checkbox-input"
                           aria-label="Select notification: @n.AnimeTitle @EpLabel(n)" />
                </span>
                @if (!string.IsNullOrEmpty(n.ThumbnailUrl))
                {
                    <img class="notif-page-thumb" src="@n.ThumbnailUrl" alt="" loading="lazy" decoding="async" />
                }
                else
                {
                    <div class="notif-page-thumb notif-page-thumb-placeholder" aria-hidden="true"></div>
                }
                <div class="notif-page-body">
                    <div class="notif-page-title">@n.AnimeTitle</div>
                    <div class="notif-page-meta">@EpLabel(n) &middot; @RelativeTime(n.CreatedAt)</div>
                </div>
                <button type="button"
                        class="notif-page-delete"
                        data-notif-page-delete
                        aria-label="Delete notification: @n.AnimeTitle @EpLabel(n)"
                        @onclick="() => DeleteAsync(n)" @onclick:stopPropagation @onclick:preventDefault>
                    <svg viewBox="0 0 24 24" width="16" height="16" fill="none"
                         stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <polyline points="3 6 5 6 21 6"></polyline>
                        <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"></path>
                        <path d="M10 11v6"></path>
                        <path d="M14 11v6"></path>
                    </svg>
                </button>
            </a>
        }
    </div>
}

@code {
    private bool _loading = true;
    private List<NotificationDto> _items = new();
    private readonly HashSet<long> _readIds = new();

    private bool _pushEnabled;
    private bool _pushSubscribed;
    private bool _pushBusy;

    protected override async Task OnInitializedAsync()
    {
        _items = (await Api.NotificationsAsync(limit: 50)).ToList();
        _loading = false;

        // Web Push opt-in is web-head only; hidden when the deployment has no
        // VAPID keys configured (status.Enabled == false) or the browser lacks
        // the Push API.
        if (!Env.IsNative)
        {
            var status = await Api.PushStatusAsync();
            if (status is { Enabled: true })
            {
                var supported = await JS.InvokeAsync<bool>("anisyncPush.supported");
                _pushEnabled = supported;
                _pushSubscribed = status.Subscribed;
                StateHasChanged();
            }
        }
    }

    private bool IsRead(NotificationDto n) => n.IsRead || _readIds.Contains(n.Id);

    private async Task OpenAsync(NotificationDto n)
    {
        if (!IsRead(n))
        {
            _readIds.Add(n.Id);
            await Api.MarkNotificationReadAsync(n.Id);
        }
        if (!string.IsNullOrEmpty(n.LinkPath)) Nav.NavigateTo(n.LinkPath);
    }

    private async Task DeleteAsync(NotificationDto n)
    {
        await Api.DeleteNotificationAsync(n.Id);
        _items.RemoveAll(x => x.Id == n.Id);
    }

    private async Task MarkAllRead()
    {
        await Api.MarkAllNotificationsReadAsync();
        foreach (var n in _items) _readIds.Add(n.Id);
    }

    private async Task TogglePush()
    {
        _pushBusy = true;
        try
        {
            if (_pushSubscribed)
            {
                var endpoint = await JS.InvokeAsync<string?>("anisyncPush.unsubscribe");
                if (!string.IsNullOrEmpty(endpoint)) await Api.PushUnsubscribeAsync(endpoint);
                _pushSubscribed = false;
            }
            else
            {
                var key = await Api.PushVapidKeyAsync();
                if (key is { Enabled: true, PublicKey: { Length: > 0 } pk })
                {
                    var sub = await JS.InvokeAsync<PushSubscribeRequestDto?>("anisyncPush.subscribe", pk);
                    if (sub is not null && await Api.PushSubscribeAsync(sub))
                        _pushSubscribed = true;
                }
            }
        }
        finally { _pushBusy = false; }
    }

    // Series notifications carry a season (S1E5); single-cour anime don't (Episode 5).
    private static string EpLabel(NotificationDto n)
        => n.Season.HasValue ? $"S{n.Season}E{n.EpisodeNumber}" : $"Episode {n.EpisodeNumber}";

    // Mirrors _NotificationRows' Relative(): just now / Nm / Nh / Nd ago.
    private static string RelativeTime(long unixSeconds)
    {
        var diff = DateTimeOffset.UtcNow.ToUnixTimeSeconds() - unixSeconds;
        if (diff < 60) return "just now";
        if (diff < 3600) return $"{diff / 60}m ago";
        if (diff < 86400) return $"{diff / 3600}h ago";
        return $"{diff / 86400}d ago";
    }
}
