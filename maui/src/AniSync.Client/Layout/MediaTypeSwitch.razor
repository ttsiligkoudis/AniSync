@inject AppState State
@inject NavigationManager Nav
@inject IJSRuntime JS
@implements IAsyncDisposable

@* Fixed media-type switch below the header — port of _MediaTypeSwitch.cshtml.
   Shown only on the dashboard / Library / Discover surfaces and only when more
   than one mode is enabled. The dashboard variant prepends an "All" pill and
   filters sections client-side (via AppState); the others switch the active
   mode. Active state is driven in C# (the web used media-type-switch.js +
   localStorage). *@
@if (State.MediaTypesHydrated && State.EnabledMediaTypes.Count > 1 && _show)
{
    <div class="mt-switch-bar" data-mt-switch="@(_dashboard ? "dashboard" : "navigate")">
        <div class="container mt-switch-inner">
            <div class="mt-switch" role="tablist" aria-label="Media type">
                @if (_dashboard)
                {
                    <button type="button" class="mt-switch-btn @(_selected == "all" ? "active" : "")"
                            data-mt-value="all" role="tab" aria-selected="@(_selected == "all" ? "true" : "false")"
                            @onclick="@(() => SelectAsync("all"))">
                        <span class="mt-switch-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="3" y="3" width="7" height="7" rx="1.5" />
                                <rect x="14" y="3" width="7" height="7" rx="1.5" />
                                <rect x="3" y="14" width="7" height="7" rx="1.5" />
                                <rect x="14" y="14" width="7" height="7" rx="1.5" />
                            </svg>
                        </span>
                        <span class="mt-switch-label">All</span>
                    </button>
                }
                @foreach (var mt in State.EnabledMediaTypes)
                {
                    var isActive = _selected == mt.ToString();
                    <button type="button" class="mt-switch-btn @(isActive ? "active" : "")"
                            data-mt-value="@mt" role="tab" aria-selected="@(isActive ? "true" : "false")"
                            @onclick="@(() => SelectAsync(mt.ToString()))">
                        <span class="mt-switch-icon" aria-hidden="true">
                            @if (mt == MetaType.anime)
                            {
                                <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M12 3l1.9 5.6L19.5 10l-5.6 1.9L12 17.5l-1.9-5.6L4.5 10l5.6-1.4z" />
                                    <path d="M19 4l.6 1.8L21.5 6.5l-1.9.6L19 9l-.6-1.9L16.5 6.5l1.9-.7z" />
                                </svg>
                            }
                            else if (mt == MetaType.movie)
                            {
                                <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                    <rect x="3" y="4" width="18" height="16" rx="2" />
                                    <line x1="7" y1="4" x2="7" y2="20" />
                                    <line x1="17" y1="4" x2="17" y2="20" />
                                    <line x1="3" y1="12" x2="21" y2="12" />
                                </svg>
                            }
                            else
                            {
                                <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                    <rect x="2" y="7" width="20" height="13" rx="2" />
                                    <polyline points="8 3 12 7 16 3" />
                                </svg>
                            }
                        </span>
                        <span class="mt-switch-label">@Label(mt)</span>
                    </button>
                }
            </div>
        </div>
    </div>
}

@code {
    private bool _show;
    private bool _dashboard;
    private string _selected = "all";
    private IJSObjectReference? _js;

    protected override void OnInitialized()
    {
        Recompute();
        // Chrome components don't re-render when the parent layout does, so subscribe
        // to the shared state directly: AppState for the enabled-mode pill list, and
        // LocationChanged for the route-driven show/hide + active highlight.
        State.Changed += OnStateChanged;
        Nav.LocationChanged += OnLocationChanged;
    }

    protected override void OnParametersSet() => Recompute();

    private void Recompute()
    {
        var nav = NavActive.From(Nav.ToBaseRelativePath(Nav.Uri));
        _show = nav is "home" or "library" or "discover";
        _dashboard = nav == "home";
        // Dashboard defaults to "All"; the other surfaces start on the active mode.
        _selected = _dashboard ? "all" : State.MediaType.ToString();
    }

    // AppState changed (chooser modal / hydration / a media-type switch): re-render so the
    // pill list (foreach State.EnabledMediaTypes) refreshes. On the navigate (non-dashboard)
    // surfaces also resync the highlighted pill to the active mode — otherwise after hydration
    // the switch can show Anime while Discover already shows Movies. On the dashboard, _selected
    // mirrors the client-side filter the user picked, so leave it.
    private void OnStateChanged()
    {
        if (!_dashboard) _selected = State.MediaType.ToString();
        StateHasChanged();
    }

    // Navigation drives _show / _dashboard / _selected → recompute on every move.
    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        Recompute();
        StateHasChanged();
    }

    private async Task SelectAsync(string value)
    {
        _selected = value;
        if (_dashboard)
        {
            // Dashboard filters its sections client-side without touching the
            // persisted global mode (so the "all" filter does NOT persist active).
            State.SetDashboardFilter(value);
        }
        else if (Enum.TryParse<MetaType>(value, out var mt))
        {
            // Library / Discover switch the active mode and reload their content.
            State.SetMediaType(mt);
            // Persist the active mode so a switched mode survives a reload (the
            // ACTIVE mode is owned by this toggle as well as the chooser modal).
            try
            {
                _js ??= await JS.InvokeAsync<IJSObjectReference>("import", "./_content/AniSync.Client/js/media-type.js");
                await _js.InvokeVoidAsync("setActiveOnly", mt.ToString());
            }
            catch { /* prerender / no JS */ }
        }
    }

    public async ValueTask DisposeAsync()
    {
        State.Changed -= OnStateChanged;
        Nav.LocationChanged -= OnLocationChanged;
        if (_js is not null) { try { await _js.DisposeAsync(); } catch { } }
    }

    private static string Label(MetaType mt) => mt switch
    {
        MetaType.movie => "Movies",
        MetaType.series => "Series",
        _ => "Anime",
    };
}
