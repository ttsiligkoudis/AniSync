@inject NavigationManager Nav
@inject AppState State
@implements IDisposable

@* Site header — exact port of _Layout.cshtml's .site-header. Back button, logo,
   inline desktop nav (collapses to the hamburger under 992px via site.css), the
   global SearchBox typeahead, notification bell, media-type button, the
   desktop auth CTA and the hamburger. Behaviour (back, more) is wired by
   the ported chrome.js loaded in each head. (Theme now lives on the Account page.) *@
<header class="site-header">
    <div class="container site-header-inner">
        <button type="button" class="site-back-btn" aria-label="Go back" data-site-back>
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M15 18l-6-6 6-6"/>
            </svg>
        </button>
        <a class="site-logo" href="/" aria-label="AniSync home">
            <img src="_content/AniSync.Client/img/logo-96.png" alt="AniSync" width="96" height="96" decoding="async" />
        </a>
        <nav class="site-header-nav" aria-label="Primary">
            <a href="/" class="@Cls("home")">
                <svg class="nav-icon" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M3 12L12 3l9 9"></path>
                    <path d="M5 10v10a1 1 0 0 0 1 1h4v-6h4v6h4a1 1 0 0 0 1-1V10"></path>
                </svg>
                <span class="nav-label">Home</span>
            </a>
            @if (State.LoggedIn)
            {
                <a href="/library" class="@Cls("library")">
                    <svg class="nav-icon" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"></path>
                    </svg>
                    <span class="nav-label">Library</span>
                </a>
            }
            <a href="/discover" class="@Cls("discover")">
                <svg class="nav-icon" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <circle cx="11" cy="11" r="8"></circle>
                    <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                </svg>
                <span class="nav-label">Discover</span>
            </a>
            @if (State.LoggedIn)
            {
                <a href="/calendar" class="@Cls("calendar")">
                    <svg class="nav-icon" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <rect x="3" y="4" width="18" height="18" rx="2"></rect>
                        <line x1="16" y1="2" x2="16" y2="6"></line>
                        <line x1="8" y1="2" x2="8" y2="6"></line>
                        <line x1="3" y1="10" x2="21" y2="10"></line>
                    </svg>
                    <span class="nav-label">Calendar</span>
                </a>
            }
            @if (State.LoggedIn)
            {
                <a href="/account" class="@(_active is "configure" ? "active" : "")">
                    <svg class="nav-icon" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <circle cx="12" cy="12" r="3"></circle>
                        <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 1 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 1 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 1 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 1 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
                    </svg>
                    <span class="nav-label">Settings</span>
                </a>
            }
        </nav>

        <SearchBox />

        @if (State.LoggedIn)
        {
            <NotifBell />
        }

        <button type="button" class="media-type-btn" data-media-type-open
                @onclick="() => State.RequestMediaTypeModal()"
                aria-label="Change mode (currently @_mtBtnLabel)" title="Change mode">
            <span class="media-type-btn-icon" aria-hidden="true">
                @if (_mtMultiple)
                {
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="3" width="7" height="7" rx="1.5" />
                        <rect x="14" y="3" width="7" height="7" rx="1.5" />
                        <rect x="3" y="14" width="7" height="7" rx="1.5" />
                        <rect x="14" y="14" width="7" height="7" rx="1.5" />
                    </svg>
                }
                else if (State.MediaType == MetaType.movie)
                {
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="4" width="18" height="16" rx="2" />
                        <line x1="7" y1="4" x2="7" y2="20" /><line x1="17" y1="4" x2="17" y2="20" />
                        <line x1="3" y1="12" x2="21" y2="12" />
                    </svg>
                }
                else if (State.MediaType == MetaType.series)
                {
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="2" y="7" width="20" height="13" rx="2" />
                        <polyline points="8 3 12 7 16 3" />
                    </svg>
                }
                else
                {
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 3l1.9 5.6L19.5 10l-5.6 1.9L12 17.5l-1.9-5.6L4.5 10l5.6-1.4z" />
                    </svg>
                }
            </span>
            <span class="media-type-btn-label">@_mtBtnLabel</span>
        </button>

        @* The theme switch moved to the Account page (Appearance section) and now persists
           via the settings store rather than a header toggle / localStorage key. *@

        @* Gate the auth CTA on SessionHydrated so a signed-in user never sees "Sign in" flash
           before the stored config is read (it resolves to Disconnect a beat later). Until then
           render nothing here rather than committing the wrong state. *@
        @if (State.SessionHydrated)
        {
            @if (State.HasSession)
            {
                <a class="site-header-cta site-header-cta-secondary" href="/logout" data-disconnect>Disconnect</a>
            }
            else
            {
                <a class="site-header-cta site-header-cta-primary" href="/account">Sign in</a>
            }
        }

        <button class="hamburger-btn" aria-label="Open menu"
                onclick="document.body.classList.toggle('drawer-open')">
            <span></span><span></span><span></span>
        </button>
    </div>
</header>

@code {
    private string _active = "";
    private bool _mtMultiple;
    private string _mtBtnLabel = "All";

    protected override void OnInitialized()
    {
        Recompute();
        // Re-render on auth/state changes (Sign in → Disconnect + the logged-in nav
        // links) and on navigation (active-nav highlight). The parent layout's
        // re-render does NOT cascade to this parameterless child, so subscribe here.
        State.Changed += OnChanged;
        Nav.LocationChanged += OnLocationChanged;
    }

    protected override void OnParametersSet() => Recompute();

    private void Recompute()
    {
        _active = NavActive.From(Nav.ToBaseRelativePath(Nav.Uri));
        _mtMultiple = State.EnabledMediaTypes.Count > 1;
        _mtBtnLabel = _mtMultiple ? "All" : State.MediaTypeLabel;
    }

    private void OnChanged() { Recompute(); StateHasChanged(); }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        Recompute();
        StateHasChanged();
    }

    public void Dispose()
    {
        State.Changed -= OnChanged;
        Nav.LocationChanged -= OnLocationChanged;
    }

    private string Cls(string section) => _active == section ? "active" : "";
}
