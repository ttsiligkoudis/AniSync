@inject NavigationManager Nav
@inject AppState State
@implements IDisposable

@* Mobile bottom nav + floating "More" sheet — exact port of _Layout.cshtml.
   site.css hides it on wide viewports. The More toggle / sheet behaviour is
   wired by chrome.js (delegated, so it works whenever the component mounts). *@
<nav class="bottom-nav" aria-label="Primary">
    <a href="/" class="bottom-nav-item @Cls("home")" aria-label="Home">
        <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 12L12 3l9 9"></path>
            <path d="M5 10v10a1 1 0 0 0 1 1h4v-6h4v6h4a1 1 0 0 0 1-1V10"></path>
        </svg>
        <span class="bottom-nav-label">Home</span>
    </a>
    @if (State.LoggedIn)
    {
        <a href="/library" class="bottom-nav-item @Cls("library")" aria-label="Library">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"></path>
            </svg>
            <span class="bottom-nav-label">Library</span>
        </a>
    }
    <a href="/discover" class="bottom-nav-item @Cls("discover")" aria-label="Discover">
        <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
        <span class="bottom-nav-label">Discover</span>
    </a>
    <button type="button" class="bottom-nav-item bottom-nav-more" aria-label="More"
            aria-expanded="false" aria-controls="bottom-nav-more-dome" data-bottom-nav-more-toggle>
        <span class="bottom-nav-more-icon" data-more-icon aria-hidden="true">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="4" y1="7" x2="20" y2="7"></line>
                <line x1="4" y1="12" x2="20" y2="12"></line>
                <line x1="4" y1="17" x2="20" y2="17"></line>
            </svg>
        </span>
        <span class="bottom-nav-more-icon bottom-nav-more-icon-close" data-close-icon aria-hidden="true">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="18" y1="6" x2="6" y2="18"></line>
                <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
        </span>
        <span class="bottom-nav-label" data-more-label>More</span>
    </button>
</nav>
<div class="bottom-nav-more-sheet" id="bottom-nav-more-dome" role="menu" hidden>
    @if (State.LoggedIn)
    {
        <a href="/account" class="bottom-nav-more-row @(_active is "configure" ? "active" : "")" role="menuitem">
            <svg class="bottom-nav-more-row-icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="3"></circle>
                <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 1 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 1 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 1 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 1 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
            </svg>
            <span class="bottom-nav-more-row-label">Settings</span>
        </a>
        <a href="/notifications" class="bottom-nav-more-row @(_active is "notifications" ? "active" : "")" role="menuitem">
            <svg class="bottom-nav-more-row-icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9"></path>
                <path d="M13.73 21a2 2 0 0 1-3.46 0"></path>
            </svg>
            <span class="bottom-nav-more-row-label">Notifications</span>
        </a>
        <a href="/calendar" class="bottom-nav-more-row @(_active is "calendar" ? "active" : "")" role="menuitem">
            <svg class="bottom-nav-more-row-icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="3" y="4" width="18" height="18" rx="2"></rect>
                <line x1="16" y1="2" x2="16" y2="6"></line>
                <line x1="8" y1="2" x2="8" y2="6"></line>
                <line x1="3" y1="10" x2="21" y2="10"></line>
            </svg>
            <span class="bottom-nav-more-row-label">Calendar</span>
        </a>
    }
    <button type="button" class="bottom-nav-more-row" data-pwa-install role="menuitem" aria-label="Install app" hidden>
        <svg class="bottom-nav-more-row-icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 3v12"></path>
            <path d="M7 10l5 5 5-5"></path>
            <path d="M5 21h14"></path>
        </svg>
        <span class="bottom-nav-more-row-label">Install app</span>
    </button>
    <span class="bottom-nav-more-divider" aria-hidden="true"></span>
    @if (State.SessionHydrated)
    {
    @if (State.HasSession)
    {
        <a href="/logout" class="bottom-nav-more-row bottom-nav-more-row-danger" role="menuitem" data-disconnect>
            <svg class="bottom-nav-more-row-icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                <polyline points="16 17 21 12 16 7"></polyline>
                <line x1="21" y1="12" x2="9" y2="12"></line>
            </svg>
            <span class="bottom-nav-more-row-label">Disconnect</span>
        </a>
    }
    else
    {
        <a href="/account" class="bottom-nav-more-row" role="menuitem">
            <svg class="bottom-nav-more-row-icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"></path>
                <polyline points="10 17 15 12 10 7"></polyline>
                <line x1="15" y1="12" x2="3" y2="12"></line>
            </svg>
            <span class="bottom-nav-more-row-label">Sign in</span>
        </a>
    }
    }
</div>

@code {
    private string _active = "";

    protected override void OnInitialized()
    {
        _active = NavActive.From(Nav.ToBaseRelativePath(Nav.Uri));
        State.Changed += OnChanged;
        Nav.LocationChanged += OnLocationChanged;
    }

    protected override void OnParametersSet()
        => _active = NavActive.From(Nav.ToBaseRelativePath(Nav.Uri));

    private void OnChanged() => StateHasChanged();

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        _active = NavActive.From(Nav.ToBaseRelativePath(Nav.Uri));
        StateHasChanged();
    }

    public void Dispose()
    {
        State.Changed -= OnChanged;
        Nav.LocationChanged -= OnLocationChanged;
    }

    private string Cls(string section) => _active == section ? "active" : "";
}
