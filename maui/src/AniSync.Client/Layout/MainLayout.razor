@inherits LayoutComponentBase
@implements IAsyncDisposable
@inject NavigationManager Nav
@inject AppState State
@inject ISecureStore Store
@inject IAniSyncApi Api
@inject IJSRuntime JS
@inject IPrerenderSession PrerenderSession
@inject IPlatformChrome PlatformChrome
@inject IAppEnvironment Env

@* Shared chrome for every page — composed to match _Layout.cshtml's body
   order exactly: drawer (+ backdrop), site header, fixed media-type switch,
   centered .container > main, then the mobile bottom nav (+ more sheet). The
   layout persists across navigation, so we re-render it on LocationChanged and
   AppState.Changed to keep the active-nav highlight and the switch in sync. *@
@if (Env.IsTv)
{
    @* TV (10-foot) shell: collapsible left rail + tile-first content. Gated entirely on the native
       DeviceIdiom==TV verdict, so phones/tablets and the web app render the identical chrome below. *@
    <TvLayout>@Body</TvLayout>
}
else
{
    <NavDrawer />

    <AppHeader />

    <MediaTypeModal />

    <MediaTypeSwitch />

    <div class="container">
        <main role="main" style="min-height: 100vh;">
            @Body
        </main>
    </div>

    <BottomNav />
}

@code {
    protected override void OnInitialized()
    {
        Nav.LocationChanged += OnLocationChanged;
        State.Changed += OnStateChanged;
        // ?tv=1 opts a browser into the full TV-shell preview (?tv=0 exits). Read it synchronously so the
        // first render already picks the TV branch. Native heads ignore ForceTv (DeviceIdiom decides).
        ApplyTvQuery();
        // Cookie-backed prerender: when the server can see the anisync_uid session cookie, render the
        // signed-in chrome from the first paint (and bridge that verdict to the interactive circuit via
        // PersistentComponentState) so a signed-in user never sees the signed-out chrome flash. No-op on
        // native and when no cookie is present (then the store-backed hydration below decides — the
        // credential is cookie-derived on web, secure-store on native).
        PrerenderSession.Bootstrap(State, RendererInfo.IsInteractive);
    }

    protected override async Task OnInitializedAsync()
    {
        // Prerender has no JS, so media-type prefs (localStorage) and the connected-services label
        // can't be read there. Leave them un-hydrated so the chrome renders neutral rather than
        // committing a wrong state and flashing it. (The signed-in verdict + credential ARE known on
        // prerender via Bootstrap's cookie read above; this deferral is about the JS-backed bits.)
        // They hydrate on the interactive pass below.
        if (!RendererInfo.IsInteractive) return;

        // Restore the TV-preview override across reloads — tv-navigation.js persists ?tv=1 to
        // localStorage. Web-only in effect (native decides TV by device idiom). Brief web→TV reflow
        // on a bare reload is acceptable for a preview/dev toggle.
        try
        {
            if (await JS.InvokeAsync<string?>("localStorage.getItem", "anisync-tv") == "1")
                State.SetForceTv(true);
        }
        catch { /* prerender / storage blocked */ }

        try
        {
            // Hydrate the config credential once at startup so the dashboard, Library and Watch pages
            // authenticate without a trip through Settings. The store abstracts the source: on the web
            // head it's derived server-side from the authenticated anisync_uid cookie (no localStorage, so
            // no credential skeleton and nothing XSS-readable); on native it's the secure-stored credential.
            if (string.IsNullOrEmpty(State.StreamConfig))
            {
                var saved = await Store.GetAsync(ISecureStore.ConfigKey);
                if (!string.IsNullOrEmpty(saved)) State.SetStreamConfig(saved);
            }

            await HydrateMediaTypesAsync();

            // Signed-in verdict from the resolved credential — a synchronous flip (no network) so the
            // chrome and the dashboard's logged-in layout resolve immediately. The "Connected to X · Y"
            // label is a /me/linked round-trip kept OFF this critical path (below), so the shelves never
            // wait on it (that wait was a visible chunk of the cold-load skeleton).
            State.HydrateSession(!string.IsNullOrEmpty(State.StreamConfig), "");
        }
        finally
        {
            // Signal the credential is resolved (found or not) so the dashboard can render its
            // data-bearing shelves WITH the X-AniSync-Config header. Always runs — even if a
            // hydration step throws — so the dashboard never hangs on the skeleton.
            State.MarkConfigHydrated();
        }

        // Fill in the connected-services label after the dashboard is already unblocked — ConfigHydrated
        // fired above, so this /me/linked round-trip updates only the chrome and never gates the shelves.
        if (!string.IsNullOrEmpty(State.StreamConfig))
            await RefreshLinkedLabelAsync();
    }

    // Seed the switch / dashboard from the stored media-type preference so they
    // reflect the chosen modes on load. The chooser modal owns first-visit /
    // autodefault; this only mirrors an existing pick into AppState (interactive
    // only — prerender has no JS / localStorage).
    private async Task HydrateMediaTypesAsync()
    {
        if (!RendererInfo.IsInteractive) return;
        try
        {
            var js = await JS.InvokeAsync<IJSObjectReference>("import", "./_content/AniSync.Client/js/media-type.js");
            var stored = await js.InvokeAsync<string[]>("getEnabled");
            if (stored is { Length: > 0 })
            {
                var set = stored
                    .Select(s => Enum.TryParse<MetaType>(s, out var mt) ? (MetaType?)mt : null)
                    .Where(mt => mt.HasValue)
                    .Select(mt => mt!.Value)
                    .ToList();
                if (set.Count > 0)
                {
                    var activeStr = await js.InvokeAsync<string>("getActive");
                    var active = Enum.TryParse<MetaType>(activeStr, out var a) && set.Contains(a) ? a : set[0];
                    State.SetEnabledMediaTypes(set, active);
                }
            }

            // Restore the dashboard's own toggle ("all" or a mode) so it survives a reload like the
            // active mode does. Accept "all" or any enabled mode; ignore a stale/disabled value.
            var dash = await js.InvokeAsync<string>("getDashFilter");
            if (dash == "all" || (Enum.TryParse<MetaType>(dash, out var dm) && State.EnabledMediaTypes.Contains(dm)))
                State.SetDashboardFilter(dash);

            await js.DisposeAsync();
        }
        catch { /* prerender / no JS */ }
        // Mark hydrated even when nothing was stored (the default set stands) so the
        // dashboard + switch render now rather than waiting on a set that never comes.
        State.MarkMediaTypesHydrated();
    }

    // Resolve login + the "Connected to X · Y" chrome label. Logged-in == a config
    // credential is stored; the connected-services label comes from /me/linked
    // (empty when the config can't be resolved upstream, matching the web app's
    // "only show when known" behaviour).
    // Fetch the "Connected to X · Y" services label and update the chrome. Runs off the dashboard's
    // critical path (ConfigHydrated has already fired), so the /me/linked round-trip never delays the
    // shelves. Best-effort: on failure the chrome stays signed-in with no services line.
    private async Task RefreshLinkedLabelAsync()
    {
        try
        {
            var linked = await Api.LinkedAsync();
            if (linked is null || string.IsNullOrEmpty(linked.Primary)) return;

            var services = new List<string> { PrettyService(linked.Primary) };
            services.AddRange(linked.Linked
                .Where(l => !string.IsNullOrEmpty(l.Service))
                .Select(l => PrettyService(l.Service!)));
            State.HydrateSession(true, string.Join(" · ", services.Distinct(StringComparer.OrdinalIgnoreCase)));
        }
        catch { /* label stays blank — chrome still shows signed-in */ }
    }

    private static string PrettyService(string service) => service switch
    {
        "Anilist" => "AniList",
        "MyAnimeList" => "MAL",
        _ => service,
    };

    // Bridge the web app's resolved theme to the native host so it can re-tint the OS system bars when the
    // user toggles light/dark (or the system theme changes). Web + non-Android heads get a no-op
    // IPlatformChrome, so this is native-only in effect. Wired after first interactive render (needs JS).
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || !RendererInfo.IsInteractive) return;
        try
        {
            // Resolve the date-formatting locale straight from the browser/WebView (navigator.language).
            // The web server's CurrentCulture isn't the visitor's, and the Accept-Language prerender seed
            // can disagree with what the browser actually uses — this is the authoritative client read.
            // Pages subscribed to State.Changed re-render with the new culture. Native gets the device
            // locale here too (matches its default CurrentCulture).
            var locale = await JS.InvokeAsync<string>("anisyncBrowserLocale");
            if (!string.IsNullOrWhiteSpace(locale))
            {
                try { State.SetUiCulture(System.Globalization.CultureInfo.GetCultureInfo(locale)); }
                catch (System.Globalization.CultureNotFoundException) { /* unknown tag — keep default */ }
            }
        }
        catch { /* no JS — keep the default / Accept-Language culture */ }
        try
        {
            // Apply the saved theme (System / Light / Dark) from the settings store — the
            // preference lives here now, not a header toggle / localStorage key. On web the
            // pre-paint stamp already applied it (this is an idempotent re-apply); on native
            // this is the authoritative apply once the secure store is readable. Done before
            // registering the bridge so its first push reflects the resolved data-theme.
            var theme = await Store.GetAsync("pref:theme");
            await JS.InvokeVoidAsync("anisyncApplyTheme", theme ?? "system");
        }
        catch { /* no JS / nothing stored — CSS prefers-color-scheme decides */ }
        try
        {
            _themeBridge = await JS.InvokeAsync<IJSObjectReference>(
                "import", "./_content/AniSync.Client/js/theme-bridge.js");
            _themeRef = DotNetObjectReference.Create(this);
            await _themeBridge.InvokeVoidAsync("register", _themeRef);
        }
        catch { /* no JS (prerender) — native bars fall back to the system theme set in MainActivity */ }
    }

    [JSInvokable]
    public void OnThemeChanged(bool dark) => PlatformChrome.SetTheme(dark);

    private IJSObjectReference? _themeBridge;
    private DotNetObjectReference<MainLayout>? _themeRef;

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        ApplyTvQuery();
        StateHasChanged();
    }

    // Opt a browser into / out of the full TV-shell preview via ?tv=1 / ?tv=0. tv-navigation.js handles
    // the matching .tv-mode CSS + localStorage persistence; this drives the C# side (Env.IsTv → TvLayout
    // + every Env.IsTv-gated bit). No-op on native, where DeviceIdiom is authoritative.
    private void ApplyTvQuery()
    {
        try
        {
            var query = new Uri(Nav.Uri).Query;
            if (string.IsNullOrEmpty(query)) return;
            foreach (var part in query.TrimStart('?').Split('&'))
            {
                if (part == "tv=1") { State.SetForceTv(true); return; }
                if (part == "tv=0") { State.SetForceTv(false); return; }
            }
        }
        catch { /* malformed URI — ignore */ }
    }

    private void OnStateChanged() => StateHasChanged();

    public async ValueTask DisposeAsync()
    {
        Nav.LocationChanged -= OnLocationChanged;
        State.Changed -= OnStateChanged;
        if (_themeBridge is not null)
        {
            try { await _themeBridge.InvokeVoidAsync("unregister"); } catch { }
            try { await _themeBridge.DisposeAsync(); } catch { }
        }
        _themeRef?.Dispose();
    }
}
