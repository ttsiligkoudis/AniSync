@inject NavigationManager Nav
@inject AppState State
@inject IJSRuntime JS
@implements IDisposable

@* TV (10-foot) navigation rail — only rendered by TvLayout on Android TV / Google TV.
   A narrow vertical icon rail that expands to show labels on focus/hover (CSS width
   transition, .tv-mode .tv-rail). D-pad friendly: every item is a plain <a>/<button>
   already in tv-navigation.js's focusable set, so up/down walks the rail and
   right moves into the content. Mirrors AppHeader's destinations + logged-in gating
   and reuses its nav-icon SVGs, but drops the search/theme/auth-CTA clutter for a
   Stremio-style minimal rail. *@
<nav class="tv-rail" aria-label="Primary">
    <a class="tv-rail-logo" href="/" aria-label="AniSync home">
        <img src="_content/AniSync.Client/img/logo-96.png" alt="AniSync" width="44" height="44" decoding="async" />
    </a>

    <div class="tv-rail-items">
        <a href="/" class="tv-rail-item @Cls("home")">
            <svg class="tv-rail-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M3 12L12 3l9 9"></path>
                <path d="M5 10v10a1 1 0 0 0 1 1h4v-6h4v6h4a1 1 0 0 0 1-1V10"></path>
            </svg>
            <span class="tv-rail-label">Home</span>
        </a>
        <a href="/discover" class="tv-rail-item @Cls("discover")">
            <svg class="tv-rail-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="11" cy="11" r="8"></circle>
                <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            </svg>
            <span class="tv-rail-label">Discover</span>
        </a>
        @if (State.LoggedIn)
        {
            <a href="/library" class="tv-rail-item @Cls("library")">
                <svg class="tv-rail-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"></path>
                </svg>
                <span class="tv-rail-label">Library</span>
            </a>
            <a href="/calendar" class="tv-rail-item @Cls("calendar")">
                <svg class="tv-rail-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <rect x="3" y="4" width="18" height="18" rx="2"></rect>
                    <line x1="16" y1="2" x2="16" y2="6"></line>
                    <line x1="8" y1="2" x2="8" y2="6"></line>
                    <line x1="3" y1="10" x2="21" y2="10"></line>
                </svg>
                <span class="tv-rail-label">Calendar</span>
            </a>
        }
        @if (State.EnabledMediaTypes.Count > 1)
        {
            <button type="button" class="tv-rail-item" @onclick="() => State.RequestMediaTypeModal()"
                    aria-label="Change mode (currently @_mtLabel)">
                <svg class="tv-rail-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <rect x="3" y="3" width="7" height="7" rx="1.5" />
                    <rect x="14" y="3" width="7" height="7" rx="1.5" />
                    <rect x="3" y="14" width="7" height="7" rx="1.5" />
                    <rect x="14" y="14" width="7" height="7" rx="1.5" />
                </svg>
                <span class="tv-rail-label">@_mtLabel</span>
            </button>
        }
    </div>

    <div class="tv-rail-footer">
        @if (State.SessionHydrated)
        {
            <a href="/account" class="tv-rail-item @(_active == "configure" ? "active" : "")">
                @if (State.HasSession)
                {
                    <svg class="tv-rail-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <circle cx="12" cy="12" r="3"></circle>
                        <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 1 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 1 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 1 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 1 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
                    </svg>
                    <span class="tv-rail-label">Settings</span>
                }
                else
                {
                    <svg class="tv-rail-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                        <circle cx="12" cy="7" r="4"></circle>
                    </svg>
                    <span class="tv-rail-label">Sign in</span>
                }
            </a>
        }
    </div>
</nav>

@code {
    private string _active = "";
    private string _mtLabel = "All";

    protected override void OnInitialized()
    {
        Recompute();
        // Chrome children don't re-render when the layout does, so subscribe directly:
        // AppState for logged-in gating + the mode label, LocationChanged for the active highlight.
        State.Changed += OnChanged;
        Nav.LocationChanged += OnLocationChanged;
    }

    protected override void OnParametersSet() => Recompute();

    private void Recompute()
    {
        _active = NavActive.From(Nav.ToBaseRelativePath(Nav.Uri));
        _mtLabel = State.EnabledMediaTypes.Count > 1 ? "All" : State.MediaTypeLabel;
    }

    private void OnChanged() { Recompute(); StateHasChanged(); }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        Recompute();
        StateHasChanged();
        // Activating a rail link leaves focus on the rail, so it stays expanded (it opens on
        // :focus-within) over the page. Push focus into the content after the route renders so the
        // rail collapses and the D-pad lands in the page. TV-only (this rail only renders there).
        _ = MoveFocusToContentAsync();
    }

    private async Task MoveFocusToContentAsync()
    {
        await Task.Delay(80); // let the destination content render before we look for something to focus
        try { await JS.InvokeVoidAsync("anisyncTv.focusContent"); } catch { /* JS not ready / prerender */ }
    }

    public void Dispose()
    {
        State.Changed -= OnChanged;
        Nav.LocationChanged -= OnLocationChanged;
    }

    private string Cls(string section) => _active == section ? "active" : "";
}
