@inject IAniSyncApi Api
@inject NavigationManager Nav
@inject AppState State
@inject IPrerenderSession Prerender
@implements IDisposable

@* Episode-release notification bell — interactive C# port of the header bell
   (the web version was driven by notifications.js). Shows the unread badge from
   /api/v1/notifications/count and, on open, the most recent rows; "Mark all
   read" clears them. Reuses the notif-* classes from site.css. *@
<div class="notif-bell @(_open ? "notif-bell-open" : "")" data-notif-bell>
    <button class="notif-bell-btn" type="button" aria-label="Notifications"
            aria-expanded="@_open" @onclick="Toggle">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9"></path>
            <path d="M13.73 21a2 2 0 0 1-3.46 0"></path>
        </svg>
        @if (_count > 0)
        {
            <span class="notif-bell-badge">@(_count > 99 ? "99+" : _count.ToString())</span>
        }
    </button>
    @if (_open)
    {
        <div class="notif-panel" role="dialog" aria-label="Notifications">
            <header class="notif-panel-header">
                <span class="notif-panel-title">Notifications</span>
                <button type="button" class="notif-read-all" @onclick="MarkAllRead">Mark all read</button>
            </header>
            <div class="notif-panel-body">
                @if (_loading)
                {
                    <div class="notif-empty">Loading…</div>
                }
                else if (_items.Count == 0)
                {
                    <div class="notif-empty">You're all caught up.</div>
                }
                else
                {
                    @foreach (var n in _items)
                    {
                        <a class="notif-item @(n.IsRead ? "" : "notif-item-unread")"
                           href="@(string.IsNullOrEmpty(n.LinkPath) ? "#" : n.LinkPath)"
                           data-notif-id="@n.Id">
                            @if (!string.IsNullOrEmpty(n.ThumbnailUrl))
                            {
                                <img class="notif-thumb" src="@n.ThumbnailUrl" alt="" loading="lazy" onerror="this.remove()" />
                            }
                            else
                            {
                                <span class="notif-thumb notif-thumb-placeholder" aria-hidden="true"></span>
                            }
                            <div class="notif-body">
                                <div class="notif-title">@n.AnimeTitle</div>
                                <div class="notif-meta">@EpLabel(n) &middot; @RelativeTime(n.CreatedAt)</div>
                            </div>
                        </a>
                    }
                }
            </div>
            <a class="notif-panel-footer" href="/notifications">View all</a>
        </div>
    }
</div>

@code {
    private bool _open;
    private bool _loading;
    private int _count;
    private IReadOnlyList<NotificationDto> _items = Array.Empty<NotificationDto>();
    private System.Threading.Timer? _poll;
    private bool _liveStarted;

    protected override async Task OnInitializedAsync()
    {
        // Replay the prerendered unread count so the badge doesn't blink off on the interactive
        // remount before the credential hydrates (web only; no-op on native).
        if (RendererInfo.IsInteractive && Prerender.TryReplay<int>(CountKey, out var saved))
            _count = saved;

        // Fetch only when we actually have a credential. On the interactive pass StreamConfig is
        // empty until MainLayout reads it from localStorage, and a credential-less count call comes
        // back 0 — which would blank the badge that the prerender (where the credential is seeded)
        // correctly showed. We refresh for real once it hydrates (OnStateChanged).
        if (!string.IsNullOrEmpty(State.StreamConfig))
        {
            _credentialFetchDone = true;
            await RefreshCountAsync();
        }

        // Live-refresh the unread badge once interactive (the credential lives in
        // localStorage, unreadable during prerender; and OnInitializedAsync runs twice,
        // so the flag stops a second timer/subscription on the interactive pass).
        if (RendererInfo.IsInteractive && !_liveStarted)
        {
            _liveStarted = true;
            State.Changed += OnStateChanged;
            Nav.LocationChanged += OnLocationChanged;
            // Poll every 60s so freshly-aired episode notifications surface without a reload.
            _poll = new System.Threading.Timer(
                _ => _ = InvokeAsync(RefreshCountAsync), null,
                TimeSpan.FromSeconds(60), TimeSpan.FromSeconds(60));
        }

        // Prerender (credential seeded): stash the count so the interactive remount replays it.
        if (!RendererInfo.IsInteractive)
            Prerender.Persist<int>(CountKey, RendererInfo.IsInteractive, () => _count);
    }

    private const string CountKey = "notif.count";
    private bool _credentialFetchDone;

    // Fire the catch-up fetch exactly once — when the credential first hydrates on the interactive
    // circuit. After that the 60s poll + per-navigation refresh keep the badge live; we don't want to
    // refetch on every unrelated State.Changed (media-type toggle, theme, etc.).
    private void OnStateChanged()
    {
        if (!_credentialFetchDone && !string.IsNullOrEmpty(State.StreamConfig))
        {
            _credentialFetchDone = true;
            _ = InvokeAsync(RefreshCountAsync);
        }
    }

    private async Task RefreshCountAsync()
    {
        var count = (await Api.NotificationCountAsync()).Count;
        if (count != _count)
        {
            _count = count;
            StateHasChanged();
        }
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
        => _ = InvokeAsync(RefreshCountAsync);

    private async Task Toggle()
    {
        _open = !_open;
        if (_open)
        {
            _loading = true;
            _items = await Api.NotificationsAsync(limit: 20);
            _loading = false;
            // Opening the panel is a good moment to re-sync the badge too.
            await RefreshCountAsync();
        }
    }

    private async Task MarkAllRead()
    {
        await Api.MarkAllNotificationsReadAsync();
        _count = 0;
        _items = await Api.NotificationsAsync(limit: 20);
    }

    // Series notifications carry a season (S1E5); single-cour anime don't (Episode 5).
    private static string EpLabel(NotificationDto n)
        => n.Season.HasValue ? $"S{n.Season}E{n.EpisodeNumber}" : $"Episode {n.EpisodeNumber}";

    // Mirrors notifications.js relativeTime(): just now / Nm / Nh / Nd ago.
    private static string RelativeTime(long unixSeconds)
    {
        var diff = DateTimeOffset.UtcNow.ToUnixTimeSeconds() - unixSeconds;
        if (diff < 60) return "just now";
        if (diff < 3600) return $"{diff / 60}m ago";
        if (diff < 86400) return $"{diff / 3600}h ago";
        return $"{diff / 86400}d ago";
    }

    public void Dispose()
    {
        if (_liveStarted)
        {
            Nav.LocationChanged -= OnLocationChanged;
            State.Changed -= OnStateChanged;
        }
        _poll?.Dispose();
    }
}
