@inject IAniSyncApi Api
@inject NavigationManager Nav
@inject AppState State
@inject IPrerenderSession Prerender
@inject IJSRuntime JS
@implements IAsyncDisposable

@* Episode-release notification bell — interactive C# port of the header bell
   (the web version was driven by notifications.js). Shows the unread badge from
   /api/v1/notifications/count and, on open, the most recent rows; "Mark all
   read" clears them. Reuses the notif-* classes from site.css. *@
<div class="notif-bell @(_open ? "notif-bell-open" : "")" data-notif-bell @ref="_root">
    <button class="notif-bell-btn" type="button" aria-label="Notifications"
            aria-expanded="@_open" @onclick="Toggle">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9"></path>
            <path d="M13.73 21a2 2 0 0 1-3.46 0"></path>
        </svg>
        @if (_count > 0)
        {
            <span class="notif-bell-badge">@(_count > 99 ? "99+" : _count.ToString())</span>
        }
    </button>
    @if (_open)
    {
        <div class="notif-panel" role="dialog" aria-label="Notifications">
            <header class="notif-panel-header">
                <span class="notif-panel-title">Notifications</span>
                <button type="button" class="notif-read-all" @onclick="MarkAllRead">Mark all read</button>
            </header>
            <div class="notif-panel-body">
                @if (_loading)
                {
                    @* Skeleton rows shaped like .notif-item so the panel keeps its height while the
                       first fetch is in flight (instead of a centred "Loading…" that jumps the layout). *@
                    @for (var i = 0; i < 4; i++)
                    {
                        <div class="notif-item notif-item-skeleton" aria-hidden="true">
                            <span class="notif-thumb skeleton-shimmer"></span>
                            <div class="notif-body">
                                <div class="notif-skeleton-line skeleton-shimmer"></div>
                                <div class="notif-skeleton-line notif-skeleton-line-short skeleton-shimmer"></div>
                            </div>
                        </div>
                    }
                }
                else if (_items.Count == 0)
                {
                    <div class="notif-empty">You're all caught up.</div>
                }
                else
                {
                    @foreach (var n in _items)
                    {
                        <a class="notif-item @(n.IsRead ? "" : "notif-item-unread")"
                           href="@(string.IsNullOrEmpty(n.LinkPath) ? "#" : n.LinkPath)"
                           data-notif-id="@n.Id"
                           @onclick="() => OnNotifClick(n)" @onclick:preventDefault="true">
                            @if (!string.IsNullOrEmpty(n.ThumbnailUrl))
                            {
                                <img class="notif-thumb" src="@n.ThumbnailUrl" alt="" loading="lazy" onerror="this.remove()" />
                            }
                            else
                            {
                                <span class="notif-thumb notif-thumb-placeholder" aria-hidden="true"></span>
                            }
                            <div class="notif-body">
                                <div class="notif-title">@n.AnimeTitle</div>
                                <div class="notif-meta">@EpLabel(n) &middot; @RelativeTime(n.CreatedAt)</div>
                            </div>
                        </a>
                    }
                }
            </div>
            <a class="notif-panel-footer" href="/notifications">View all</a>
        </div>
    }
</div>

@code {
    private bool _open;
    private bool _loading;
    private int _count;
    private IReadOnlyList<NotificationDto> _items = Array.Empty<NotificationDto>();
    // Cache the fetched rows across opens so re-opening the panel renders instantly instead of
    // showing the loading state and refetching every time. _loaded flips true after the first fetch;
    // _itemsCountAtFetch snapshots the unread count those cached rows correspond to, so a later open
    // can tell whether the cache is still current (count unchanged) or needs a silent background refresh.
    private bool _loaded;
    private int _itemsCountAtFetch;
    private System.Threading.Timer? _poll;
    private bool _liveStarted;
    private ElementReference _root;
    private IJSObjectReference? _dismiss;
    private DotNetObjectReference<NotifBell>? _selfRef;
    private int _dismissId;

    protected override async Task OnInitializedAsync()
    {
        // Replay the prerendered unread count so the badge doesn't blink off on the interactive
        // remount before the credential hydrates (web only; no-op on native).
        if (RendererInfo.IsInteractive && Prerender.TryReplay<int>(CountKey, out var saved))
            _count = saved;

        // Fetch only when we actually have a credential. On the interactive pass StreamConfig is
        // empty until MainLayout reads it from localStorage, and a credential-less count call comes
        // back 0 — which would blank the badge that the prerender (where the credential is seeded)
        // correctly showed. We refresh for real once it hydrates (OnStateChanged).
        if (!string.IsNullOrEmpty(State.StreamConfig))
        {
            _credentialFetchDone = true;
            await RefreshCountAsync();
        }

        // Live-refresh the unread badge once interactive (the credential lives in
        // localStorage, unreadable during prerender; and OnInitializedAsync runs twice,
        // so the flag stops a second timer/subscription on the interactive pass).
        if (RendererInfo.IsInteractive && !_liveStarted)
        {
            _liveStarted = true;
            State.Changed += OnStateChanged;
            Nav.LocationChanged += OnLocationChanged;
            // Poll every 60s so freshly-aired episode notifications surface without a reload.
            _poll = new System.Threading.Timer(
                _ => _ = InvokeAsync(RefreshCountAsync), null,
                TimeSpan.FromSeconds(60), TimeSpan.FromSeconds(60));
        }

        // Prerender (credential seeded): stash the count so the interactive remount replays it.
        if (!RendererInfo.IsInteractive)
            Prerender.Persist<int>(CountKey, RendererInfo.IsInteractive, () => _count);
    }

    private const string CountKey = "notif.count";
    private bool _credentialFetchDone;

    // Fire the catch-up fetch exactly once — when the credential first hydrates on the interactive
    // circuit. After that the 60s poll + per-navigation refresh keep the badge live; we don't want to
    // refetch on every unrelated State.Changed (media-type toggle, theme, etc.).
    private void OnStateChanged()
    {
        if (!_credentialFetchDone && !string.IsNullOrEmpty(State.StreamConfig))
        {
            _credentialFetchDone = true;
            _ = InvokeAsync(RefreshCountAsync);
        }
    }

    private async Task RefreshCountAsync()
    {
        var count = (await Api.NotificationCountAsync()).Count;
        if (count != _count)
        {
            _count = count;
            StateHasChanged();
        }
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
        => _ = InvokeAsync(async () =>
        {
            // Navigating away (a notification link, "View all", or anywhere else) should dismiss the
            // open panel — it isn't relevant to the page the user just landed on.
            await CloseAsync();
            await RefreshCountAsync();
        });

    private async Task Toggle()
    {
        if (_open) { await CloseAsync(); return; }

        _open = true;
        // Arm outside-press dismissal only while the panel is open.
        await RegisterDismissAsync();

        if (!_loaded)
        {
            // First open: nothing cached — show the skeleton rows while the initial fetch runs.
            _loading = true;
            StateHasChanged();
            await LoadItemsAsync();
            _loading = false;
            StateHasChanged();
        }
        else
        {
            // Re-open: render the cached rows immediately (no loading flash, no refetch). Re-sync the
            // badge, and only refresh the rows — silently, no skeleton — if the unread count has moved
            // since we cached (a new episode aired, or something was read elsewhere).
            StateHasChanged();
            await RefreshCountAsync();
            if (_count != _itemsCountAtFetch)
                await LoadItemsAsync();
        }
    }

    // Fetch the recent rows and snapshot the unread count they correspond to, so a later open can
    // tell whether the cache is still current. Refreshes the count first so the snapshot is accurate.
    private async Task LoadItemsAsync()
    {
        _items = await Api.NotificationsAsync(limit: 20);
        await RefreshCountAsync();
        _itemsCountAtFetch = _count;
        _loaded = true;
        StateHasChanged();
    }

    // Single close path — clears the open flag and tears down the outside-press listener.
    // Used by the toggle, a row click, navigation, and an outside press so the listener is
    // never left dangling.
    private async Task CloseAsync()
    {
        if (!_open) return;
        _open = false;
        await UnregisterDismissAsync();
        StateHasChanged();
    }

    private async Task RegisterDismissAsync()
    {
        if (_dismissId != 0) return; // already armed — don't stack document listeners
        try
        {
            _dismiss ??= await JS.InvokeAsync<IJSObjectReference>(
                "import", "./_content/AniSync.Client/js/outside-click.js");
            _selfRef ??= DotNetObjectReference.Create(this);
            _dismissId = await _dismiss.InvokeAsync<int>("register", _root, _selfRef);
        }
        catch { /* interop unavailable (prerender) — panel still closes on toggle/nav/row-click */ }
    }

    private async Task UnregisterDismissAsync()
    {
        if (_dismiss is not null && _dismissId != 0)
        {
            try { await _dismiss.InvokeVoidAsync("unregister", _dismissId); } catch { }
            _dismissId = 0;
        }
    }

    [JSInvokable]
    public Task OnOutsideClick() => CloseAsync();

    // Clicking a row marks just that notification read (the panel never did this — only "Mark all read"
    // touched the store), closes the panel, then follows the deep link. We handle the nav in code
    // (@onclick:preventDefault on the anchor) so the read is recorded before we leave, and so a link back
    // to the page the user is already on still closes the panel (LocationChanged wouldn't fire there).
    private async Task OnNotifClick(NotificationDto n)
    {
        await CloseAsync();
        if (!n.IsRead)
        {
            // Optimistic: clear the unread style + drop the badge now; the per-navigation RefreshCountAsync
            // re-syncs from the server regardless, so a failed POST self-heals.
            n.ReadAt = DateTimeOffset.UtcNow.ToUnixTimeSeconds();
            if (_count > 0) _count--;
            // Keep the cache baseline in step with the optimistic count drop — the cached row's read
            // state was just updated too, so the cache is still current and shouldn't refetch on reopen.
            if (_itemsCountAtFetch > 0) _itemsCountAtFetch--;
            try { await Api.MarkNotificationReadAsync(n.Id); }
            catch { /* best-effort — badge re-syncs on the next poll / navigation */ }
        }

        if (!string.IsNullOrEmpty(n.LinkPath))
            Nav.NavigateTo(n.LinkPath);
    }

    private async Task MarkAllRead()
    {
        await Api.MarkAllNotificationsReadAsync();
        _count = 0;
        // Refetch the rows (now all read) and re-snapshot the baseline so the refreshed cache is reused
        // on the next open rather than refetched.
        await LoadItemsAsync();
    }

    // Series notifications carry a season (S1E5); single-cour anime don't (Episode 5).
    private static string EpLabel(NotificationDto n)
        => n.Season.HasValue ? $"S{n.Season}E{n.EpisodeNumber}" : $"Episode {n.EpisodeNumber}";

    // Mirrors notifications.js relativeTime(): just now / Nm / Nh / Nd ago.
    private static string RelativeTime(long unixSeconds)
    {
        var diff = DateTimeOffset.UtcNow.ToUnixTimeSeconds() - unixSeconds;
        if (diff < 60) return "just now";
        if (diff < 3600) return $"{diff / 60}m ago";
        if (diff < 86400) return $"{diff / 3600}h ago";
        return $"{diff / 86400}d ago";
    }

    public async ValueTask DisposeAsync()
    {
        if (_liveStarted)
        {
            Nav.LocationChanged -= OnLocationChanged;
            State.Changed -= OnStateChanged;
        }
        _poll?.Dispose();
        await UnregisterDismissAsync();
        _selfRef?.Dispose();
        if (_dismiss is not null) { try { await _dismiss.DisposeAsync(); } catch { } }
    }
}
