@inject IAniSyncApi Api
@inject NavigationManager Nav
@inject AppState State
@inject IJSRuntime JS
@implements IAsyncDisposable

@*
    Global search typeahead — Blazor port of wwwroot/js/site-search.js. Same
    .site-search-* markup/classes as the web app (so the enlarged posters and
    broken-image placeholder styling carry over), but the debounce, fetch and
    render are C# instead of vanilla JS.
*@
<div class="site-search" role="combobox" aria-expanded="@(_open ? "true" : "false")" @ref="_root">
    <div class="site-search-input-wrap">
        <input class="site-search-input"
               type="search"
               placeholder="Search…"
               autocomplete="off"
               value="@_query"
               @oninput="OnInput" />
    </div>

    @if (_open)
    {
        <div class="site-search-results" role="listbox">
            @if (_loading)
            {
                <div class="site-search-status">Searching…</div>
            }
            else if (_results.Count == 0)
            {
                <div class="site-search-status">No matches</div>
            }
            else
            {
                @foreach (var m in _results)
                {
                    <a class="site-search-result" role="option" href="@HrefFor(m)">
                        @if (!string.IsNullOrEmpty(m.Poster) && !_broken.Contains(m.Id))
                        {
                            <img class="site-search-result-poster"
                                 src="@m.Poster" alt="" loading="lazy"
                                 @onerror="@(() => MarkBroken(m.Id))" />
                        }
                        else
                        {
                            <div class="site-search-result-poster site-search-result-poster-placeholder" aria-hidden="true"></div>
                        }
                        <span class="site-search-result-name">@m.Name</span>
                        @if (string.Equals(m.Type, "movie", StringComparison.OrdinalIgnoreCase))
                        {
                            <span class="site-search-result-type site-search-result-type-movie">Movie</span>
                        }
                        else
                        {
                            <span class="site-search-result-type site-search-result-type-tv">TV</span>
                        }
                    </a>
                }
            }
        </div>
    }
</div>

@code {
    private const int MinChars = 3;
    private const int DebounceMs = 250;
    private const int Limit = 8;

    private string _query = "";
    private bool _open;
    private bool _loading;
    private List<SuggestMatch> _results = new();
    private readonly HashSet<string> _broken = new(StringComparer.OrdinalIgnoreCase);
    private CancellationTokenSource? _cts;
    private ElementReference _root;
    private IJSObjectReference? _dismiss;
    private DotNetObjectReference<SearchBox>? _selfRef;
    private int _dismissId;
    private bool _navHooked;

    protected override void OnInitialized()
    {
        // Close the results on navigation (e.g. clicking a result) — only on the interactive pass so we
        // don't double-subscribe across the prerender + interactive OnInitialized runs.
        if (RendererInfo.IsInteractive && !_navHooked)
        {
            _navHooked = true;
            Nav.LocationChanged += OnLocationChanged;
        }
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
        => _ = InvokeAsync(CloseResultsAsync);

    private async Task OnInput(ChangeEventArgs e)
    {
        _query = e.Value?.ToString() ?? "";
        // Cancel the in-flight request/debounce so a slower response can't
        // overwrite a fresher query (mirrors site-search.js's AbortController).
        _cts?.Cancel();
        if (_query.Trim().Length < MinChars)
        {
            await CloseResultsAsync();
            _results = new();
            return;
        }

        _cts = new CancellationTokenSource();
        var token = _cts.Token;
        _open = true;
        // Arm outside-press dismissal while the dropdown is open.
        await RegisterDismissAsync();
        _loading = true;
        try
        {
            await Task.Delay(DebounceMs, token);
            // Span the user's enabled media types (anime/movies/series), matching the header selection —
            // the server defaults to anime-only without this.
            var types = string.Join(",", State.EnabledMediaTypes);
            var matches = await Api.SuggestAsync(_query.Trim(), Limit, types, token);
            if (token.IsCancellationRequested) return;
            _results = matches.ToList();
            _broken.Clear();
        }
        catch (OperationCanceledException) { return; }
        finally
        {
            if (!token.IsCancellationRequested)
            {
                _loading = false;
                StateHasChanged();
            }
        }
    }

    private void MarkBroken(string id)
    {
        _broken.Add(id);
        StateHasChanged();
    }

    // Anime results carry a service prefix (anilist:/mal:/kitsu:) and link to the
    // anime detail route; video results are IMDb ids and append ?type=.
    private static string HrefFor(SuggestMatch m)
    {
        var isVideo = string.Equals(m.Type, "movie", StringComparison.OrdinalIgnoreCase)
                   || string.Equals(m.Type, "series", StringComparison.OrdinalIgnoreCase);
        return isVideo
            ? $"/meta/{Uri.EscapeDataString(m.Id)}?type={m.Type}"
            : $"/meta/{Uri.EscapeDataString(m.Id)}";
    }

    // Hide the results dropdown and tear down the outside-press listener. Used on navigation, when the
    // query drops below the minimum, and on an outside press.
    private async Task CloseResultsAsync()
    {
        await UnregisterDismissAsync();
        if (_open)
        {
            _open = false;
            StateHasChanged();
        }
    }

    private async Task RegisterDismissAsync()
    {
        if (_dismissId != 0) return; // already armed — don't stack document listeners
        try
        {
            _dismiss ??= await JS.InvokeAsync<IJSObjectReference>(
                "import", "./_content/AniSync.Client/js/outside-click.js");
            _selfRef ??= DotNetObjectReference.Create(this);
            _dismissId = await _dismiss.InvokeAsync<int>("register", _root, _selfRef);
        }
        catch { /* interop unavailable (prerender) — results still close on nav / query change */ }
    }

    private async Task UnregisterDismissAsync()
    {
        if (_dismiss is not null && _dismissId != 0)
        {
            try { await _dismiss.InvokeVoidAsync("unregister", _dismissId); } catch { }
            _dismissId = 0;
        }
    }

    [JSInvokable]
    public Task OnOutsideClick() => CloseResultsAsync();

    public async ValueTask DisposeAsync()
    {
        _cts?.Cancel();
        if (_navHooked) Nav.LocationChanged -= OnLocationChanged;
        await UnregisterDismissAsync();
        _selfRef?.Dispose();
        if (_dismiss is not null) { try { await _dismiss.DisposeAsync(); } catch { } }
    }
}
